#!/usr/bin/env python3
"""macos-shortcuts — save/restore native macOS keyboard shortcuts.

macOS stores its system keyboard shortcuts (System Settings -> Keyboard ->
Keyboard Shortcuts) in the `com.apple.symbolichotkeys` defaults domain, keyed by
opaque numeric IDs. This tool round-trips that dictionary through a readable TOML
file so it can live in version control.

    macos-shortcuts list             # bound (enabled) shortcuts as TOML -> stdout
    macos-shortcuts list --all       # every known shortcut, bound or not
    macos-shortcuts export FILE      # write `list` output to FILE (--all allowed)
    macos-shortcuts import FILE      # apply a saved TOML file, then reload settings
    macos-shortcuts import --dry-run FILE

TOML format — a single [keys] table mapping a name (or raw numeric id) to an
inline table:

    [keys]
    next_window_in_app = { key = "`", mods = ["cmd"] }
    select_previous_input_source = { key = "f7", mods = ["ctrl", "shift"] }
    56 = { key = "f20", mods = ["cmd"] }

`key` + `mods` are the friendly form; modifiers may be cmd/command, opt/option/alt,
ctrl/control, shift. Listing an entry implies `enabled = true` — add
`enabled = false` to disable. Function keys (f1-f20) and arrows get the macOS fn
modifier automatically. For exotic bindings the tool falls back to a raw
`params = [char, key_code, mask]` triple, which is always authoritative.
"""

from __future__ import annotations

import argparse
import os
import plistlib
import subprocess
import sys

DOMAIN = "com.apple.symbolichotkeys"
ROOT_KEY = "AppleSymbolicHotKeys"
ACTIVATE = (
    "/System/Library/PrivateFrameworks/SystemAdministration.framework"
    "/Resources/activateSettings"
)
DEFAULT_PATH = os.path.expanduser(
    os.path.join(
        os.environ.get("XDG_CONFIG_HOME", "~/.config"),
        "macos-shortcuts",
        "shortcuts.toml",
    )
)

NO_CHAR = 65535     # 0xFFFF — "no ASCII character" (arrows, F-keys, ...)
FN_BIT = 0x800000   # NSEventModifierFlagFunction — set for function/arrow keys

# modifier bitmask <-> names
MODS = {"control": 0x40000, "option": 0x80000, "shift": 0x20000, "command": 0x100000}
MOD_ORDER = ["control", "option", "shift", "command"]
MOD_SHORT = {"control": "ctrl", "option": "opt", "shift": "shift", "command": "cmd"}
MOD_ALIASES = {
    "ctrl": "control", "ctl": "control", "^": "control",
    "alt": "option", "opt": "option",
    "cmd": "command", "super": "command", "win": "command",
    "shft": "shift",
}

# printable single char -> virtual key code (US ANSI)
CHAR_KEYCODE = {
    "a": 0, "s": 1, "d": 2, "f": 3, "h": 4, "g": 5, "z": 6, "x": 7, "c": 8,
    "v": 9, "b": 11, "q": 12, "w": 13, "e": 14, "r": 15, "y": 16, "t": 17,
    "1": 18, "2": 19, "3": 20, "4": 21, "6": 22, "5": 23, "=": 24, "9": 25,
    "7": 26, "-": 27, "8": 28, "0": 29, "]": 30, "o": 31, "u": 32, "[": 33,
    "i": 34, "p": 35, "l": 37, "j": 38, "'": 39, "k": 40, ";": 41, "\\": 42,
    ",": 43, "/": 44, "n": 45, "m": 46, ".": 47, "`": 50,
}
# named non-printable key -> (char, key_code)
NAMED_KEY = {
    "space": (32, 49), "tab": (NO_CHAR, 48), "return": (NO_CHAR, 36),
    "enter": (NO_CHAR, 76), "escape": (NO_CHAR, 53), "esc": (NO_CHAR, 53),
    "delete": (NO_CHAR, 51), "backspace": (NO_CHAR, 51),
    "forward_delete": (NO_CHAR, 117),
    "left": (NO_CHAR, 123), "right": (NO_CHAR, 124),
    "down": (NO_CHAR, 125), "up": (NO_CHAR, 126),
    "f1": (NO_CHAR, 122), "f2": (NO_CHAR, 120), "f3": (NO_CHAR, 99),
    "f4": (NO_CHAR, 118), "f5": (NO_CHAR, 96), "f6": (NO_CHAR, 97),
    "f7": (NO_CHAR, 98), "f8": (NO_CHAR, 100), "f9": (NO_CHAR, 101),
    "f10": (NO_CHAR, 109), "f11": (NO_CHAR, 103), "f12": (NO_CHAR, 111),
    "f13": (NO_CHAR, 105), "f14": (NO_CHAR, 107), "f15": (NO_CHAR, 113),
    "f16": (NO_CHAR, 106), "f17": (NO_CHAR, 64), "f18": (NO_CHAR, 79),
    "f19": (NO_CHAR, 80), "f20": (NO_CHAR, 90),
}
# keys that imply the fn modifier bit
FN_KEYS = {f"f{n}" for n in range(1, 21)} | {
    "left", "right", "up", "down", "forward_delete",
}
KEYCODE_NAME = {kc: name for name, (_c, kc) in NAMED_KEY.items()}
KEYCODE_CHAR = {kc: ch for ch, kc in CHAR_KEYCODE.items()}

# friendly labels for well-known shortcut IDs (cosmetic; source of truth is `list`)
KNOWN_IDS = {
    27: "next_window_in_app",
    28: "screenshot_to_file",
    29: "screenshot_to_clipboard",
    30: "screenshot_area_to_file",
    31: "screenshot_area_to_clipboard",
    32: "mission_control",
    33: "application_windows",
    35: "spotlight_applications",
    52: "toggle_dock",
    60: "select_previous_input_source",
    61: "select_next_input_source",
    64: "spotlight",
    65: "finder_search",
    79: "move_left_a_space",
    81: "move_right_a_space",
}
NAME_TO_ID = {v: k for k, v in KNOWN_IDS.items()}


def die(msg: str):
    print(f"macos-shortcuts: {msg}", file=sys.stderr)
    raise SystemExit(1)


# --------------------------------------------------------------------------- #
# live defaults domain
# --------------------------------------------------------------------------- #
def read_domain() -> dict:
    out = subprocess.run(["defaults", "export", DOMAIN, "-"], capture_output=True).stdout
    if not out:
        return {}
    try:
        return plistlib.loads(out).get(ROOT_KEY, {})
    except Exception:
        return {}


def write_domain(hotkeys: dict) -> None:
    blob = plistlib.dumps({ROOT_KEY: hotkeys})
    subprocess.run(["defaults", "import", DOMAIN, "-"], input=blob, check=True)


def activate_settings() -> None:
    subprocess.run([ACTIVATE, "-u"], check=False)


# --------------------------------------------------------------------------- #
# encode / decode key bindings
# --------------------------------------------------------------------------- #
def is_fn_key(key: str) -> bool:
    return key.lower() in FN_KEYS


def encode_key(key: str) -> tuple[int, int]:
    k = key.lower()
    if k in NAMED_KEY:
        return NAMED_KEY[k]
    if len(key) == 1 and k in CHAR_KEYCODE:
        return (ord(k), CHAR_KEYCODE[k])
    die(f"don't know key {key!r} (add it to NAMED_KEY/CHAR_KEYCODE)")


def encode_params(key: str, mods: list[str]) -> list[int]:
    char, key_code = encode_key(key)
    mask = 0
    for m in mods:
        name = MOD_ALIASES.get(m.lower(), m.lower())
        if name not in MODS:
            die(f"unknown modifier: {m!r}")
        mask |= MODS[name]
    if is_fn_key(key):
        mask |= FN_BIT
    return [char, key_code, mask]


def decode_key(char: int, key_code: int):
    if key_code in KEYCODE_NAME:
        return KEYCODE_NAME[key_code]
    if char != NO_CHAR and 32 <= char <= 126:
        return chr(char)
    return KEYCODE_CHAR.get(key_code)


def decode_params(char: int, key_code: int, mask: int):
    """Return (key, mods) only if re-encoding reproduces the exact triple.

    Self-verifying: this is what guarantees a list -> import round-trip is
    lossless. Anything that doesn't reproduce exactly (char-less bindings on a
    printable keycode, exotic modifier bits, ...) falls back to raw `params`.
    """
    key = decode_key(char, key_code)
    if key is None:
        return None
    mods = [MOD_SHORT[m] for m in MOD_ORDER if mask & MODS[m]]
    if encode_params(key, mods) != [char, key_code, mask]:
        return None
    return key, mods


# --------------------------------------------------------------------------- #
# TOML: minimal parser (used when tomllib is unavailable) + writer
# --------------------------------------------------------------------------- #
def load_toml(path: str) -> dict:
    with open(path, "rb") as fh:
        data = fh.read()
    try:
        import tomllib  # py3.11+
        return tomllib.loads(data.decode("utf-8"))
    except ModuleNotFoundError:
        return _MiniToml(data.decode("utf-8")).parse()


class _MiniToml:
    """Tiny TOML subset: [tables] + key = value, where value is a string, int,
    bool, array, or single-level inline table. Not general TOML."""

    def __init__(self, text: str):
        self.text = text

    def parse(self) -> dict:
        root: dict = {}
        cur = root
        for raw in self.text.splitlines():
            line = self._strip_comment(raw).strip()
            if not line:
                continue
            if line[0] == "[" and line[-1] == "]":
                cur = root.setdefault(self._unquote(line[1:-1].strip()), {})
                continue
            key, val = self._split_kv(line)
            cur[self._unquote(key.strip())] = self._value(val.strip(), 0)[0]
        return root

    @staticmethod
    def _unquote(s: str) -> str:
        if len(s) >= 2 and s[0] in "\"'" and s[-1] == s[0]:
            return s[1:-1]
        return s

    @staticmethod
    def _strip_comment(line: str) -> str:
        q = None
        for i, c in enumerate(line):
            if q:
                if c == q:
                    q = None
            elif c in "\"'":
                q = c
            elif c == "#":
                return line[:i]
        return line

    @staticmethod
    def _split_kv(line: str) -> tuple[str, str]:
        q = None
        for i, c in enumerate(line):
            if q:
                if c == q:
                    q = None
            elif c in "\"'":
                q = c
            elif c == "=":
                return line[:i], line[i + 1:]
        die(f"malformed line (no '='): {line!r}")

    def _value(self, s: str, i: int):
        i = self._ws(s, i)
        c = s[i]
        if c in "\"'":
            return self._string(s, i)
        if c == "[":
            return self._array(s, i)
        if c == "{":
            return self._inline(s, i)
        j = i
        while j < len(s) and s[j] not in ",]}":
            j += 1
        return self._scalar(s[i:j].strip()), j

    @staticmethod
    def _ws(s: str, i: int) -> int:
        while i < len(s) and s[i] in " \t":
            i += 1
        return i

    @staticmethod
    def _string(s: str, i: int):
        q = s[i]
        i += 1
        buf = []
        esc = {"n": "\n", "t": "\t", "\\": "\\", '"': '"', "'": "'"}
        while i < len(s):
            c = s[i]
            if c == "\\" and q == '"' and i + 1 < len(s):
                buf.append(esc.get(s[i + 1], s[i + 1]))
                i += 2
                continue
            if c == q:
                return "".join(buf), i + 1
            buf.append(c)
            i += 1
        die("unterminated string")

    def _array(self, s: str, i: int):
        i += 1
        arr = []
        while True:
            i = self._ws(s, i)
            if s[i] == "]":
                return arr, i + 1
            val, i = self._value(s, i)
            arr.append(val)
            i = self._ws(s, i)
            if s[i] == ",":
                i += 1
            elif s[i] == "]":
                return arr, i + 1

    def _inline(self, s: str, i: int):
        i += 1
        tbl = {}
        while True:
            i = self._ws(s, i)
            if s[i] == "}":
                return tbl, i + 1
            if s[i] in "\"'":
                k, i = self._string(s, i)
            else:
                j = i
                while s[j] not in "=" and s[j] not in " \t":
                    j += 1
                k, i = s[i:j], j
            i = self._ws(s, i)
            if s[i] != "=":
                die("expected '=' in inline table")
            val, i = self._value(s, i + 1)
            tbl[k] = val
            i = self._ws(s, i)
            if s[i] == ",":
                i += 1
            elif s[i] == "}":
                return tbl, i + 1

    @staticmethod
    def _scalar(tok: str):
        if tok in ("true", "false"):
            return tok == "true"
        try:
            return int(tok)
        except ValueError:
            return tok


def _toml_str(s: str) -> str:
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def _bare_key(name: str) -> str:
    ok = name and all(c.isalnum() or c in "_-" for c in name)
    return name if ok else _toml_str(name)


def format_entry(sid: str, entry: dict) -> str:
    enabled = bool(entry.get("enabled", False))
    value = entry.get("value") or {}
    params = value.get("parameters")
    fields: list[str] = []
    if isinstance(params, (list, tuple)) and len(params) >= 2:
        ints = [int(x) for x in params]
        decoded = decode_params(*ints) if len(ints) == 3 else None
        if decoded is not None:
            key, mods = decoded
            fields.append(f"key = {_toml_str(key)}")
            fields.append("mods = [" + ", ".join(_toml_str(m) for m in mods) + "]")
        else:
            fields.append("params = [" + ", ".join(str(x) for x in ints) + "]")
            vtype = value.get("type", "standard")
            if vtype != "standard":
                fields.append(f"type = {_toml_str(vtype)}")
    if not enabled:
        fields.append("enabled = false")
    name = _bare_key(KNOWN_IDS.get(int(sid), str(sid)))
    inline = "{ " + ", ".join(fields) + " }" if fields else "{}"
    return f"{name} = {inline}"


def dump_toml(hotkeys: dict, include_all: bool) -> str:
    lines = [
        "# macOS native keyboard shortcuts (com.apple.symbolichotkeys).",
        "# Generated by `macos-shortcuts list`. Re-apply with `macos-shortcuts import`.",
        "",
        "[keys]",
    ]
    for sid in sorted(hotkeys, key=lambda x: int(x)):
        entry = hotkeys[sid]
        if not isinstance(entry, dict):
            continue
        if not include_all and not entry.get("enabled", False):
            continue
        lines.append(format_entry(sid, entry))
    return "\n".join(lines).rstrip() + "\n"


# --------------------------------------------------------------------------- #
# import
# --------------------------------------------------------------------------- #
def resolve_id(name: str) -> str:
    s = str(name)
    if s.isdigit():
        return str(int(s))
    if s in NAME_TO_ID:
        return str(NAME_TO_ID[s])
    die(f"unknown shortcut name {name!r}; use a numeric id "
        f"(see `macos-shortcuts list --all`)")


def build_entry(name: str, spec: dict, live: dict) -> tuple[str, dict]:
    sid = resolve_id(name)
    enabled = bool(spec.get("enabled", True))
    if "params" in spec:
        params = [int(x) for x in spec["params"]]
        if len(params) < 2:
            die(f"[{name}] params needs at least 2 elements")
        vtype = str(spec.get("type", "standard"))
    elif "key" in spec:
        params = encode_params(str(spec["key"]), list(spec.get("mods", [])))
        vtype = "standard"
    else:
        # toggle-only: preserve whatever binding the live entry has
        old = live.get(sid)
        out = {"enabled": enabled}
        if isinstance(old, dict) and "value" in old:
            out["value"] = old["value"]
        return sid, out
    return sid, {"enabled": enabled, "value": {"parameters": params, "type": vtype}}


# --------------------------------------------------------------------------- #
# subcommands
# --------------------------------------------------------------------------- #
def cmd_list(args) -> int:
    text = dump_toml(read_domain(), include_all=args.all)
    if getattr(args, "file", None):
        os.makedirs(os.path.dirname(os.path.abspath(args.file)), exist_ok=True)
        with open(args.file, "w") as fh:
            fh.write(text)
        print(f"wrote {args.file}", file=sys.stderr)
    else:
        sys.stdout.write(text)
    return 0


def cmd_import(args) -> int:
    path = args.file or DEFAULT_PATH
    if not os.path.exists(path):
        die(f"file not found: {path}")
    config = load_toml(path)
    keys = config.get("keys", config)  # accept bare tables too
    if not isinstance(keys, dict):
        die("no [keys] table found")

    live = read_domain()
    desired = dict(live)
    changes = []
    for name, spec in keys.items():
        if not isinstance(spec, dict):
            continue
        sid, new_entry = build_entry(name, spec, live)
        if live.get(sid) != new_entry:
            changes.append((name, sid, live.get(sid), new_entry))
        desired[sid] = new_entry

    if not changes:
        print("no changes — system already matches file")
        return 0
    for name, sid, old, new in changes:
        old_en = old.get("enabled") if isinstance(old, dict) else None
        params = (new.get("value") or {}).get("parameters", "-")
        print(f"  [{name}] id={sid}: enabled {old_en} -> {new['enabled']} params={params}")
    if args.dry_run:
        print(f"\n--dry-run: {len(changes)} change(s) not applied")
        return 0
    write_domain(desired)
    activate_settings()
    print(f"\napplied {len(changes)} change(s) and reloaded settings")
    return 0


def main(argv=None) -> int:
    p = argparse.ArgumentParser(
        prog="macos-shortcuts",
        description="Save/restore native macOS keyboard shortcuts via TOML.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    pl = sub.add_parser("list", help="print bound shortcuts as TOML (--all for every one)")
    pl.add_argument("--all", action="store_true", help="include disabled/unbound shortcuts")
    pl.set_defaults(func=cmd_list, file=None)

    pe = sub.add_parser("export", help="write `list` output to a file")
    pe.add_argument("file", help="destination TOML file")
    pe.add_argument("--all", action="store_true", help="include disabled/unbound shortcuts")
    pe.set_defaults(func=cmd_list)

    pi = sub.add_parser("import", help="apply a saved TOML file and reload settings")
    pi.add_argument("file", nargs="?", help=f"TOML file (default: {DEFAULT_PATH})")
    pi.add_argument("--dry-run", action="store_true", help="show changes, apply nothing")
    pi.set_defaults(func=cmd_import)

    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
