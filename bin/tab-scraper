#!/usr/bin/env bash
set -euo pipefail

repo="${TAB_SCRAPER_REPO:-${UG_CHORDPRO_REPO:-$HOME/src/tab-scraper}}"
venv="${TAB_SCRAPER_VENV:-${UG_CHORDPRO_VENV:-$repo/.venv}}"
python="${PYTHON:-python3}"
deps_stamp="$venv/.tab-scraper-deps-installed"

if [[ ! -d "$repo" ]]; then
  echo "tab-scraper: repo not found: $repo" >&2
  echo "Set TAB_SCRAPER_REPO=/path/to/tab-scraper if it lives elsewhere." >&2
  exit 1
fi

if [[ ! -x "$venv/bin/python" ]]; then
  "$python" -m venv "$venv"
fi

case "${1:-}" in
  ""|-h|--help|help)
    ;;
  *)
    if [[ ! -f "$deps_stamp" || "$repo/requirements.txt" -nt "$deps_stamp" || "$repo/pyproject.toml" -nt "$deps_stamp" ]]; then
      "$venv/bin/python" -m pip install --upgrade pip --quiet >/dev/null
      "$venv/bin/python" -m pip install --quiet -r "$repo/requirements.txt"
      mkdir -p "$(dirname "$deps_stamp")"
      touch "$deps_stamp"
    fi
    ;;
esac

PYTHONPATH="$repo${PYTHONPATH:+:$PYTHONPATH}" exec "$venv/bin/python" -m ug_chordpro.cli "$@"
