#!/bin/bash
#
# bulk-rename — edit a list of filenames in $EDITOR, then apply renames safely.
#
# A drop-in replacement for yazi's built-in `bulk_rename` that gives us control
# over the confirmation screen (a proper modal dialog) while being *safer* than
# both yazi's built-in and the old ls|awk one-liner:
#
#   - line-count validation: if the editor changes the number of lines, we abort
#     rather than guess which old name maps to which new name (prevents the
#     classic "reordered a line → renamed the wrong file" data loss).
#   - never clobbers: a rename whose target already exists (and isn't itself
#     being moved out of the way) is SKIPPED, never overwritten.
#   - collision-safe: two files mapped to the same name are skipped, not raced.
#   - swap/chain-safe: renames run in two phases through unique staging names,
#     so a↔b swaps and a→b→c chains work without stepping on each other.
#
# Usage:
#   bulk-rename [FILE...]   rename the given files (yazi passes selected via %s)
#   bulk-rename DIR         rename the contents of DIR
#   bulk-rename             rename the contents of the current directory

set -u

# ---------------------------------------------------------------------------
# styling
# ---------------------------------------------------------------------------
if [[ -t 1 ]]; then
	C_RESET=$'\e[0m'; C_BOLD=$'\e[1m'; C_DIM=$'\e[2m'
	C_RED=$'\e[31m'; C_GREEN=$'\e[32m'; C_YELLOW=$'\e[33m'
	C_BLUE=$'\e[34m'; C_CYAN=$'\e[36m'; C_GREY=$'\e[90m'

	# truecolor diff palette (GitHub-style: light row background, darker on the
	# changed span, dark text on top). Buttons are solid flat blocks.
	FG_INK=$'\e[38;2;28;28;30m'                 # near-black text for colored rows
	BG_OLD=$'\e[48;2;250;207;207m'              # light red row
	BG_OLD_GUT=$'\e[48;2;236;176;176m'          # darker index gutter on old row
	BG_OLD_HI=$'\e[48;2;244;155;155m'           # changed span on the old row
	BG_NEW=$'\e[48;2;198;240;204m'              # light green row
	BG_NEW_GUT=$'\e[48;2;172;216;180m'          # darker index gutter on new row
	BG_NEW_HI=$'\e[48;2;134;220;150m'           # changed span on the new row
	C_EOL=$'\e[K'                               # paint to the real line end with active bg
	FG_ON_BTN=$'\e[38;2;255;255;255m'
	BG_APPLY=$'\e[48;2;46;160;86m'              # green apply button
	BG_CANCEL=$'\e[48;2;92;98;115m'             # slate cancel button
else
	C_RESET=; C_BOLD=; C_DIM=; C_RED=; C_GREEN=; C_YELLOW=; C_BLUE=; C_CYAN=; C_GREY=
	FG_INK=; BG_OLD=; BG_OLD_GUT=; BG_OLD_HI=; BG_NEW=; BG_NEW_GUT=; BG_NEW_HI=; C_EOL=
	FG_ON_BTN=; BG_APPLY=; BG_CANCEL=
fi

# Nerd Font glyphs (swap these if your terminal font lacks them).
ICON_TITLE=$''   #
ICON_OK=$''      #
ICON_WARN=$''    #
ICON_SKIP=$''    #
ICON_ARROW=$'→'   # →

die() { printf '%s%s bulk-rename:%s %s\n' "$C_RED" "$ICON_WARN" "$C_RESET" "$*" >&2; exit 1; }

# ---------------------------------------------------------------------------
# collect sources
# ---------------------------------------------------------------------------
declare -a src_path=() src_base=()
DIR=""

add_source() {
	local p=$1 d b
	d=$(cd -- "$(dirname -- "$p")" >/dev/null 2>&1 && pwd -P) || die "cannot resolve directory of: $p"
	b=$(basename -- "$p")
	if [[ -z $DIR ]]; then
		DIR=$d
	elif [[ $d != "$DIR" ]]; then
		die "all files must be in the same directory (got $d and $DIR)"
	fi
	src_path+=("$DIR/$b")
	src_base+=("$b")
}

if [[ $# -eq 0 ]]; then
	DIR=$(pwd -P)
	while IFS= read -r -d '' entry; do
		add_source "$entry"
	done < <(cd -- "$DIR" && find . -mindepth 1 -maxdepth 1 -print0 | sort -z)
elif [[ $# -eq 1 && -d $1 ]]; then
	DIR=$(cd -- "$1" >/dev/null 2>&1 && pwd -P) || die "no such directory: $1"
	while IFS= read -r -d '' entry; do
		add_source "$DIR/$(basename -- "$entry")"
	done < <(cd -- "$DIR" && find . -mindepth 1 -maxdepth 1 -print0 | sort -z)
else
	for f in "$@"; do
		[[ -e $f || -L $f ]] || die "no such file: $f"
		add_source "$f"
	done
fi

n=${#src_base[@]}
[[ $n -gt 0 ]] || die "nothing to rename"

# ---------------------------------------------------------------------------
# edit in $EDITOR
# ---------------------------------------------------------------------------
tmp=$(mktemp "${TMPDIR:-/tmp}/bulk-rename.XXXXXX") || die "cannot create temp file"
cleanup() { rm -f -- "$tmp"; }
trap cleanup EXIT

printf '%s\n' "${src_base[@]}" > "$tmp"

# Prefer the controlling terminal (yazi runs us with `--block`, so it exists).
# Fall back to inherited stdio when there's no tty (e.g. non-interactive runs).
tty=""
if { : >/dev/tty; } 2>/dev/null; then
	tty=/dev/tty
fi

if [[ -n $tty ]]; then
	"${EDITOR:-hx}" "$tmp" <"$tty" >"$tty" 2>&1 || die "editor exited with an error; no files changed"
else
	"${EDITOR:-hx}" "$tmp" || die "editor exited with an error; no files changed"
fi

# read new names back (do NOT strip: filenames may legitimately have spaces)
declare -a new_base=()
while IFS= read -r line || [[ -n $line ]]; do
	new_base+=("$line")
done < "$tmp"

# ---------------------------------------------------------------------------
# safety: line-count validation
# ---------------------------------------------------------------------------
if [[ ${#new_base[@]} -ne $n ]]; then
	die "line count changed ($n → ${#new_base[@]}). To keep names aligned, don't add or remove lines. No files changed."
fi

# ---------------------------------------------------------------------------
# build the rename plan  (bash 3.2 compatible — no associative arrays)
# status codes: same | blank | subpath | collision | exists | rename
# ---------------------------------------------------------------------------
declare -a status=()

# pass 1: classify obvious cases
for ((i = 0; i < n; i++)); do
	local_new=${new_base[i]}
	if [[ -z $local_new ]]; then
		status[i]="blank"
	elif [[ $local_new == */* ]]; then
		status[i]="subpath"
	elif [[ $local_new == "${src_base[i]}" ]]; then
		status[i]="same"
	else
		status[i]="rename"
	fi
done

# how many rename candidates aim at this exact name (for collision detection)?
count_targeting() {
	local name=$1 j c=0
	for ((j = 0; j < n; j++)); do
		[[ ${status[j]} == "rename" && ${new_base[j]} == "$name" ]] && ((c++))
	done
	printf '%s' "$c"
}

# pass 2: demote collisions (two+ sources → one name).
# Decide first, mutate after — otherwise demoting the first of a pair changes
# the count seen by the second and lets it slip through.
declare -a is_collision=()
for ((i = 0; i < n; i++)); do
	is_collision[i]=0
	[[ ${status[i]} == "rename" ]] || continue
	[[ $(count_targeting "${new_base[i]}") -gt 1 ]] && is_collision[i]=1
done
for ((i = 0; i < n; i++)); do
	[[ ${is_collision[i]} == 1 ]] && status[i]="collision"
done

# Would a file named $1 survive the operation and thus block a rename into it?
# It survives if something exists at that path AND that something is not one of
# the sources we're moving away. The `-ef` (same inode) check is what makes
# case-only renames work on case-insensitive filesystems (macOS APFS): there,
# "$DIR/My Song.mp3" -e matches the source "my song.mp3", but they share an
# inode, so we recognise it as the vacating source rather than a clobber target.
survives() {
	local name=$1 target=$DIR/$1 j
	[[ -e $target || -L $target ]] || return 1        # nothing there → free
	for ((j = 0; j < n; j++)); do
		[[ ${status[j]} == "rename" ]] || continue
		[[ ${src_path[j]} -ef $target ]] && return 1  # it's a source we vacate → free
	done
	return 0                                           # a distinct file lives there
}

# pass 3: demote renames whose target would clobber a surviving file
for ((i = 0; i < n; i++)); do
	[[ ${status[i]} == "rename" ]] || continue
	survives "${new_base[i]}" && status[i]="exists"
done

# ---------------------------------------------------------------------------
# render  (GitHub-style diff: full-width coloured rows, one file-pair per block)
# ---------------------------------------------------------------------------

# longest common prefix length (in characters) of $1 and $2
common_prefix() {
	local a=$1 b=$2 i=0 m=${#1}
	(( ${#2} < m )) && m=${#2}
	while (( i < m )) && [[ ${a:i:1} == "${b:i:1}" ]]; do ((i++)); done
	printf '%s' "$i"
}

# longest common suffix length not overlapping the prefix region ($3 = prefix len)
common_suffix() {
	local a=$1 b=$2 p=$3 i=0 la=${#1} lb=${#2} m
	m=$(( la - p )); (( lb - p < m )) && m=$(( lb - p ))
	while (( i < m )) && [[ ${a:la-1-i:1} == "${b:lb-1-i:1}" ]]; do ((i++)); done
	printf '%s' "$i"
}

idxw=${#n}   # gutter width = digits in the largest index

# Build a coloured two-row diff for one rename. The whole old row is light red,
# the whole new row light green; the index gutter is a shade darker (header
# vibe) and the span that actually changed is darker still so the eye lands on
# it. Each row ends with C_EOL (\e[K), which fills to the true right edge with
# the active background — so rows always span the whole line, wrap or not, with
# no dependence on a possibly-wrong column count. Sets RP_OLD / RP_NEW.
RP_OLD=""; RP_NEW=""
render_pair() {
	local num=$1 old=$2 new=$3 p s pre om nm suf og np
	p=$(common_prefix "$old" "$new")
	s=$(common_suffix "$old" "$new" "$p")
	pre=${old:0:p}
	om=${old:p:${#old}-p-s}
	nm=${new:p:${#new}-p-s}
	suf=${old:${#old}-s}

	og=$(printf '%*s  ' "$idxw" "$num")   # "12  " — index gutter
	np=$(printf '%*s  ' "$idxw" "")        # blank gutter, same width

	RP_OLD="${BG_OLD_GUT}${FG_INK}${og}${BG_OLD}${pre}${BG_OLD_HI}${om}${BG_OLD}${suf}${C_EOL}${C_RESET}"
	RP_NEW="${BG_NEW_GUT}${FG_INK}${np}${BG_NEW}${pre}${BG_NEW_HI}${nm}${BG_NEW}${suf}${C_EOL}${C_RESET}"
}

declare -a body=()          # rendered rows, printed verbatim (already full-width)
n_rename=0; n_skip=0; n_same=0
have_exists=0; have_collision=0; have_blank=0; have_subpath=0

for ((i = 0; i < n; i++)); do
	old=${src_base[i]}; new=${new_base[i]}
	case ${status[i]} in
	rename)
		((n_rename++))
		render_pair "$((i + 1))" "$old" "$new"
		body+=("$RP_OLD" "$RP_NEW" "")
		;;
	same) ((n_same++));;
	blank)
		((n_skip++)); have_blank=1
		body+=("${C_YELLOW}!${C_RESET} $((i + 1)). ${C_DIM}${old}${C_RESET} ${C_YELLOW}(left as-is: blank)${C_RESET}" "")
		;;
	subpath)
		((n_skip++)); have_subpath=1
		body+=("${C_YELLOW}!${C_RESET} $((i + 1)). ${C_DIM}${old}${C_RESET} ${C_YELLOW}(skipped: contains '/')${C_RESET}" "")
		;;
	collision)
		((n_skip++)); have_collision=1
		body+=("${C_RED}!${C_RESET} $((i + 1)). ${C_DIM}${old}${C_RESET} ${C_GREY}${ICON_ARROW}${C_RESET} ${C_RED}${new}${C_RESET} ${C_RED}(collision)${C_RESET}" "")
		;;
	exists)
		((n_skip++)); have_exists=1
		body+=("${C_RED}!${C_RESET} $((i + 1)). ${C_DIM}${old}${C_RESET} ${C_GREY}${ICON_ARROW}${C_RESET} ${C_RED}${new}${C_RESET} ${C_RED}(target exists)${C_RESET}" "")
		;;
	esac
done

# warning / explanation lines
declare -a warn=()
if (( have_exists )); then
	warn+=("${C_RED}${ICON_WARN} Some targets already exist — those renames are skipped so nothing is overwritten.${C_RESET}")
fi
if (( have_collision )); then
	warn+=("${C_RED}${ICON_WARN} Two or more files map to the same name — skipped to avoid loss.${C_RESET}")
fi
if (( have_blank || have_subpath )); then
	warn+=("${C_YELLOW}${ICON_SKIP} Blank names and names with '/' are left untouched.${C_RESET}")
fi

dir_disp=${DIR/#$HOME/\~}
header="${C_CYAN}${C_BOLD}${ICON_TITLE} Bulk rename${C_RESET}${C_DIM} — ${dir_disp}${C_RESET}"
summary="${C_BOLD}${n_rename}${C_RESET} to rename"
(( n_skip )) && summary+="${C_DIM} · ${C_RESET}${C_RED}${n_skip} skipped${C_RESET}"
(( n_same )) && summary+="${C_DIM} · ${n_same} unchanged${C_RESET}"

# a pair of big flat buttons, three rows tall, side by side.
# ⏎ = Enter key, ⎋ = Esc key (swap these if your font lacks the glyphs).
render_buttons() {
	local a="  ⏎  APPLY  " c="  ⎋  CANCEL  " sa sc
	sa=$(printf '%*s' "${#a}" ""); sc=$(printf '%*s' "${#c}" "")
	if [[ -n $BG_APPLY ]]; then
		printf '%s%s%s   %s%s%s\n' "$BG_APPLY" "$sa" "$C_RESET" "$BG_CANCEL" "$sc" "$C_RESET"
		printf '%s%s%s%s%s   %s%s%s%s%s\n' \
			"$BG_APPLY" "$FG_ON_BTN" "$C_BOLD" "$a" "$C_RESET" \
			"$BG_CANCEL" "$FG_ON_BTN" "$C_BOLD" "$c" "$C_RESET"
		printf '%s%s%s   %s%s%s\n' "$BG_APPLY" "$sa" "$C_RESET" "$BG_CANCEL" "$sc" "$C_RESET"
	else
		printf '[ ⏎ APPLY ]   [ ⎋ CANCEL ]\n'
	fi
}

print_screen() {
	printf '\n%s\n%s\n\n' "$header" "$summary"
	local l
	for l in ${body[@]+"${body[@]}"}; do printf '%s\n' "$l"; done
	if (( ${#warn[@]} )); then
		for l in "${warn[@]}"; do printf '%s\n' "$l"; done
		printf '\n'
	fi
}

print_screen

# nothing to apply → show the result, never block on input
if (( n_rename == 0 )); then
	printf '\n'
	exit 0
fi

# ---------------------------------------------------------------------------
# read the decision
#   Enter / y  → apply (default OK)     Esc / n / q → cancel
#   BULK_RENAME_YES=1 applies without prompting (for scripting/tests).
# ---------------------------------------------------------------------------
decision=""
if [[ ${BULK_RENAME_YES:-} == 1 ]]; then
	decision="apply"
elif [[ -z $tty ]]; then
	# no terminal to confirm at → refuse rather than guess
	printf '%s%s no terminal to confirm — cancelled (set BULK_RENAME_YES=1 to apply).%s\n' \
		"$C_YELLOW" "$ICON_SKIP" "$C_RESET" >&2
	exit 0
else
	render_buttons
	printf '%s' $'\e[?25l'   # hide cursor
	restore_cursor() { printf '%s' $'\e[?25h'; }
	trap 'restore_cursor; cleanup' EXIT

	while [[ -z $decision ]]; do
		IFS= read -rsn1 key <"$tty"
		case $key in
			"" | $'\n' | $'\r' | y | Y) decision="apply" ;;
			$'\e')
				read -rsn8 -t 1 _ <"$tty"   # drain any arrow-key tail (instant if present)
				decision="cancel" ;;
			n | N | q | Q) decision="cancel" ;;
			*) : ;;
		esac
	done
fi

if [[ $decision == "cancel" ]]; then
	printf '%s%s cancelled — no files changed.%s\n' "$C_YELLOW" "$ICON_SKIP" "$C_RESET"
	exit 0
fi

# ---------------------------------------------------------------------------
# apply: two-phase staging so swaps/chains never clobber
# ---------------------------------------------------------------------------
declare -a stage_from=() stage_to=() stage_final=()
stage_prefix="$DIR/.bulk-rename.$$"

rollback() {  # move any staged files back to their originals
	local k
	for ((k = ${#stage_to[@]} - 1; k >= 0; k--)); do
		[[ -e ${stage_to[k]} ]] && mv -- "${stage_to[k]}" "${stage_from[k]}" 2>/dev/null
	done
}

# phase A: originals → unique staging names
idx=0
for ((i = 0; i < n; i++)); do
	[[ ${status[i]} == "rename" ]] || continue
	from="${src_path[i]}"
	to="${stage_prefix}.${idx}"
	if ! mv -- "$from" "$to" 2>/dev/null; then
		printf '%s%s failed to stage %s — rolling back.%s\n' "$C_RED" "$ICON_WARN" "${src_base[i]}" "$C_RESET" >&2
		rollback
		exit 1
	fi
	stage_from+=("$from"); stage_to+=("$to"); stage_final+=("$DIR/${new_base[i]}")
	((idx++))
done

# phase B: staging names → final targets
done_count=0
for ((k = 0; k < ${#stage_to[@]}; k++)); do
	if [[ -e ${stage_final[k]} || -L ${stage_final[k]} ]]; then
		# should not happen (we filtered these), but never clobber: put it back
		mv -- "${stage_to[k]}" "${stage_from[k]}" 2>/dev/null
		printf '%s%s %s already exists — skipped.%s\n' "$C_RED" "$ICON_WARN" "${stage_final[k]##*/}" "$C_RESET" >&2
		continue
	fi
	if mv -- "${stage_to[k]}" "${stage_final[k]}" 2>/dev/null; then
		((done_count++))
	else
		mv -- "${stage_to[k]}" "${stage_from[k]}" 2>/dev/null
		printf '%s%s failed to rename to %s — left unchanged.%s\n' "$C_RED" "$ICON_WARN" "${stage_final[k]##*/}" "$C_RESET" >&2
	fi
done

printf '%s%s renamed %d file(s).%s\n' "$C_GREEN" "$ICON_OK" "$done_count" "$C_RESET"
