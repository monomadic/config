{
  "title": "Pieoneer launcher shortcuts",
  "rules": [
    {
      "description": "Pieoneer: tap Command to press Escape",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^studio\\.appahead\\.AA2$"]
            }
          ],
          "from": {
            "key_code": "left_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_command"
            }
          ],
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^studio\\.appahead\\.AA2$"]
            }
          ],
          "from": {
            "key_code": "right_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_command"
            }
          ],
          "to_if_alone": [
            {
              "key_code": "escape"
            }
          ]
        }
      ]
    },
    {
      "description": "Mouse button 4 opens Pieoneer launcher",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button4",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "spacebar",
              "modifiers": ["left_control", "left_option"]
            }
          ]
        }
      ]
    },
    {
      "description": "Double-tap Command opens Pieoneer launcher",
      "manipulators": [
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": ["^studio\\.appahead\\.AA2$"]
            },
            {
              "type": "variable_if",
              "name": "left_command_tapped_once",
              "value": 1
            }
          ],
          "from": {
            "key_code": "left_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_command"
            }
          ],
          "to_if_alone": [
            {
              "set_variable": {
                "name": "left_command_tapped_once",
                "value": 0
              }
            },
            {
              "key_code": "spacebar",
              "modifiers": ["left_control", "left_option"]
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": ["^studio\\.appahead\\.AA2$"]
            }
          ],
          "from": {
            "key_code": "left_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_command"
            }
          ],
          "to_if_alone": [
            {
              "set_variable": {
                "name": "left_command_tapped_once",
                "value": 1
              }
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "left_command_tapped_once",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "left_command_tapped_once",
                  "value": 0
                }
              }
            ]
          },
          "parameters": {
            "basic.to_delayed_action_delay_milliseconds": 300
          }
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": ["^studio\\.appahead\\.AA2$"]
            },
            {
              "type": "variable_if",
              "name": "right_command_tapped_once",
              "value": 1
            }
          ],
          "from": {
            "key_code": "right_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_command"
            }
          ],
          "to_if_alone": [
            {
              "set_variable": {
                "name": "right_command_tapped_once",
                "value": 0
              }
            },
            {
              "key_code": "spacebar",
              "modifiers": ["left_control", "left_option"]
            }
          ]
        },
        {
          "type": "basic",
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": ["^studio\\.appahead\\.AA2$"]
            }
          ],
          "from": {
            "key_code": "right_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "right_command"
            }
          ],
          "to_if_alone": [
            {
              "set_variable": {
                "name": "right_command_tapped_once",
                "value": 1
              }
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "right_command_tapped_once",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "right_command_tapped_once",
                  "value": 0
                }
              }
            ]
          },
          "parameters": {
            "basic.to_delayed_action_delay_milliseconds": 300
          }
        }
      ]
    }
  ]
}
