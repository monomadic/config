{
  "title": "Restore Command+Grave app-window cycling",
  "rules": [
    {
      "description": "Cycle front app windows with Cmd+grave",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "grave_accent_and_tilde",
            "modifiers": {
              "mandatory": ["command"]
            }
          },
          "to": [
            {
              "shell_command": "/bin/zsh -lc 'exec /Users/nom/.zsh/bin/cycle-app-windows >/dev/null 2>&1'"
            }
          ]
        }
      ]
    }
  ]
}
