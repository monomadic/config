#!/bin/zsh
emulate -L zsh

# rename-media
# Analyze common video metadata and rename files into a normalized format.
# Dependencies: ffprobe (ffmpeg), awk, sed, cut, head, mv

DRY_RUN=false
USE_COLOR=false
USE_ICONS=false

# Default plain Unicode symbols
ICON_VIDEO="▶ "
ICON_OK="✓ "
ICON_WARN="⚠ "
ICON_SKIP="• "

# Color handling (disabled by default)
RESET=""
GREEN=""
YELLOW=""
CYAN=""

enable_color() {
  RESET=$'\e[0m'
  GREEN=$'\e[32m'
  YELLOW=$'\e[33m'
  CYAN=$'\e[36m'
  USE_COLOR=true
}

enable_icons() {
  ICON_VIDEO="󰎈 "
  ICON_OK=" "
  ICON_WARN=" "
  ICON_SKIP="󰄱 "
  USE_ICONS=true
}

usage() {
  print -r -- "Usage: ${0:t} [OPTIONS] video_file..."
  print -r -- ""
  print -r -- "Analyze video files with ffprobe and rename them to include:"
  print -r -- "resolution, frame rate, duration, bitrate, orientation, and optional star rating."
  print -r -- ""
  print -r -- "Options:"
  print -r -- "  --dry-run    Show what would be renamed without changing files"
  print -r -- "  --color      Enable ANSI colors in output"
  print -r -- "  --icons      Use Nerd Font icons instead of plain Unicode symbols"
  print -r -- "  -h, --help   Show this message"
}

while (( $# > 0 )); do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --color)
      enable_color
      shift
      ;;
    --icons)
      enable_icons
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      print -u2 -r -- "${YELLOW}${ICON_WARN}Unknown option: $1${RESET}"
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if ! command -v ffprobe >/dev/null 2>&1; then
  print -u2 -r -- "${YELLOW}${ICON_WARN}ffprobe is required but not installed.${RESET}"
  exit 1
fi

clean_name() {
  local name="$1"
  local tags=(1080p 1080 720p 4k 60fps 30fps 25fps)

  # remove every non-nested {...} block
  name="$(printf '%s' "$name" | sed -E 's/\{[^}]*\}//g')"

  # remove a few known technical tags if present as hashtags
  local t
  for t in $tags; do
    name="${name//\#$t/}"
  done

  # remove trailing " s01"
  name="$(printf '%s' "$name" | sed -E 's/[[:space:]]s01$//I')"

  # collapse repeated spaces and trim
  name="${name//  / }"
  name="${name//  / }"
  name="${name## }"
  name="${name%% }"

  print -r -- "$name"
}

extract_rating() {
  local s="$1"
  local rating=""

  if [[ "$s" =~ '([★☆]{5})' ]]; then
    rating="${match[1]}"
  fi

  # remove all 5-char star blocks from the main title
  s="${s//[★☆][★☆][★☆][★☆][★☆]/}"

  # collapse repeated spaces and trim
  s="${s//  / }"
  s="${s//  / }"
  s="${s## }"
  s="${s%% }"

  # always emit two lines:
  # 1. title without rating
  # 2. rating or empty string
  print -r -- "$s"
  print -r -- "$rating"
}

get_resolution_label() {
  local d=${1:-0}

  if   (( d <= 480 )); then
    print -r -- "480p"
  elif (( d <= 720 )); then
    print -r -- "720p"
  elif (( d <= 1080 )); then
    print -r -- "1080p"
  elif (( d <= 1440 )); then
    print -r -- "1440p"
  elif (( d <= 2160 )); then
    print -r -- "2160p"
  else
    print -r -- "${d}p"
  fi
}

format_duration() {
  local secs=${1:-0}
  local hours=$(( secs / 3600 ))
  local mins=$(( secs / 60 ))

  if (( hours > 0 )); then
    print -r -- "${hours}hr"
  elif (( mins > 0 )); then
    print -r -- "${mins}min"
  else
    print -r -- "${secs}sec"
  fi
}

get_rotation() {
  local file="$1"
  local rotation=""

  rotation="$(
    ffprobe -v error -select_streams v:0 \
      -show_entries stream_side_data=rotation \
      -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
  )"

  if [[ -z "$rotation" ]]; then
    rotation="$(
      ffprobe -v error -select_streams v:0 \
        -show_entries stream_tags=rotate \
        -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
    )"
  fi

  if [[ -z "$rotation" ]]; then
    rotation="$(
      ffprobe -v error \
        -show_entries format_tags=rotate \
        -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
    )"
  fi

  [[ -z "$rotation" ]] && rotation="0"
  print -r -- "$rotation"
}

process_video() {
  local file="$1"
  local filename="${file:t}"
  local dirname="${file:h}"
  local extension="${filename:e}"
  local name_without_ext="${filename:r}"

  [[ "${extension:l}" == "m4v" ]] && extension="mp4"

  local extracted_name rating
  local -a parts

  parts=("${(@f)$(extract_rating "$name_without_ext")}")
  extracted_name="${parts[1]-$name_without_ext}"
  rating="${parts[2]-}"

  name_without_ext="$(clean_name "$extracted_name")"

  local video_info
  if ! video_info="$(
    ffprobe -v error -select_streams v:0 \
      -show_entries stream=width,height,r_frame_rate,bit_rate \
      -of csv=p=0:s=, -- "$file" 2>/dev/null
  )"; then
    print -r -- "${YELLOW}${ICON_WARN}Could not read video info: $file${RESET}"
    return 0
  fi

  local rotation
  rotation="$(get_rotation "$file")"

  local duration_secs
  if ! duration_secs="$(
    ffprobe -v error -show_entries format=duration \
      -of csv=p=0 -- "$file" 2>/dev/null
  )"; then
    duration_secs="0"
  fi
  duration_secs="$(awk -v d="$duration_secs" 'BEGIN{printf("%d", d+0.5)}')"

  local width height frame_rate bit_rate
  width="$(print -r -- "$video_info" | cut -d, -f1)"
  height="$(print -r -- "$video_info" | cut -d, -f2)"
  frame_rate="$(print -r -- "$video_info" | cut -d, -f3)"
  bit_rate="$(print -r -- "$video_info" | cut -d, -f4)"

  if [[ "$frame_rate" == */* ]]; then
    local num=${frame_rate%%/*}
    local denom=${frame_rate##*/}
    if (( denom > 0 )); then
      frame_rate=$(( (num + denom / 2) / denom ))
    else
      frame_rate=0
    fi
  fi

  local display_width=$width
  local display_height=$height
  local abs_rotation=${rotation#-}

  if [[ "$abs_rotation" == "90" || "$abs_rotation" == "270" ]]; then
    display_width=$height
    display_height=$width
  fi

  local smaller_dim=$(( display_width < display_height ? display_width : display_height ))
  local resolution
  resolution="$(get_resolution_label "$smaller_dim")"

  local orientation
  if (( display_width > display_height )); then
    orientation="landscape"
  elif (( display_height > display_width )); then
    orientation="portrait"
  else
    orientation="square"
  fi

  local mbps="unknown"
  if [[ -n "$bit_rate" && "$bit_rate" != "N/A" ]]; then
    mbps="$(awk -v b="$bit_rate" 'BEGIN{printf("%dmbps", (b+500000)/1000000)}')"
  fi

  local duration
  duration="$(format_duration "$duration_secs")"

  local rating_suffix=""
  if [[ -n "$rating" ]]; then
    rating_suffix=" ${rating}"
  fi

  local new_filename="${name_without_ext} {${resolution} ${frame_rate}fps ${duration} ${mbps} ${orientation}}${rating_suffix}.${extension}"
  local new_path="${dirname}/${new_filename}"

  if [[ "$filename" == "$new_filename" ]]; then
    print -r -- "${YELLOW}${ICON_SKIP}${filename}${RESET}"
  elif [[ -e "$new_path" ]]; then
    print -r -- "${YELLOW}${ICON_WARN}Exists: $new_filename${RESET}"
  else
    if $DRY_RUN; then
      print -r -- "${CYAN}${ICON_VIDEO}${new_filename}${RESET}"
    else
      mv -- "$file" "$new_path"
      print -r -- "${GREEN}${ICON_OK}${new_filename}${RESET}"
    fi
  fi
}

normalize_input_path() {
  local s="$1"

  if [[ -e "$s" ]]; then
    print -r -- "$s"
    return 0
  fi

  local unescaped="${(Q)s}"
  if [[ -e "$unescaped" ]]; then
    print -r -- "$unescaped"
    return 0
  fi

  print -r -- "$s"
}

for raw_file in "$@"; do
  local file
  file="$(normalize_input_path "$raw_file")"

  if [[ -f "$file" ]]; then
    case "${file:l}" in
      *.mp4|*.mov|*.avi|*.mkv|*.wmv|*.flv|*.webm|*.m4v)
        process_video "$file"
        ;;
      *)
        print -r -- "${YELLOW}${ICON_SKIP}${file:t}${RESET}"
        ;;
    esac
  else
    print -r -- "${YELLOW}${ICON_SKIP}${file:t}${RESET}"
  fi
done
