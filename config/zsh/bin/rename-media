#!/bin/zsh
emulate -L zsh

# rename-media
# Analyze common video metadata and rename files to the canonical media-library
# filename syntax.
#
# Defaults:
#   - Rename only; no container repair or metadata repair is performed here.
#   - Use media-check-files for media-library health checks and fixes.
#
# Options:
#   --print-target      Print the canonical target path only
#   --dry-run           Show what would be renamed/rebuilt
#   --verbose           Print debug information
#   --color             Enable ANSI colors
#   --icons             Use Nerd Font icons
#
# Dependencies:
#   ffprobe, awk, head, grep, mv

DRY_RUN=false
VERBOSE=false
USE_COLOR=false
USE_ICONS=false
PRINT_TARGET=false
SCRIPT_NAME="${0:t}"

ICON_VIDEO="▶ "
ICON_OK="✓ "
ICON_WARN="⚠ "
ICON_SKIP="• "

RESET=""
GREEN=""
YELLOW=""
CYAN=""

enable_color() {
  RESET=$'\e[0m'
  GREEN=$'\e[32m'
  YELLOW=$'\e[33m'
  CYAN=$'\e[36m'
  USE_COLOR=true
}

enable_icons() {
  ICON_VIDEO="󰎈 "
  ICON_OK=" "
  ICON_WARN=" "
  ICON_SKIP="󰄱 "
  USE_ICONS=true
}

usage() {
  print -r -- "Usage: ${SCRIPT_NAME} [OPTIONS] video_file..."
  print -r -- ""
  print -r -- "Analyze video files with ffprobe and rename them to canonical syntax:"
  print -r -- "resolution, frame rate, duration, bitrate, orientation, and optional star rating."
  print -r -- ""
  print -r -- "Options:"
  print -r -- "  --print-target     Print only the canonical target path"
  print -r -- "  --dry-run          Show what would be renamed without changing files"
  print -r -- "  --verbose          Print debug information about probe and rename decisions"
  print -r -- "  --color            Enable ANSI colors in output"
  print -r -- "  --icons            Use Nerd Font icons instead of plain Unicode symbols"
  print -r -- "  -h, --help         Show this message"
}

trim_whitespace() {
  local s="$1"

  s="${s//$'\t'/ }"
  s="${s//$'\n'/ }"
  s="${s//$'\r'/ }"

  while [[ "$s" == *"  "* ]]; do
    s="${s//  / }"
  done

  while [[ "$s" == [[:space:]]* ]]; do
    s="${s[2,-1]}"
  done

  while [[ "$s" == *[[:space:]] ]]; do
    s="${s[1,-2]}"
  done

  print -r -- "$s"
}

log_verbose() {
  $VERBOSE || return 0
  print -u2 -r -- "${CYAN}${ICON_SKIP}$*${RESET}"
}

touch_modified_now() {
  local file="$1"

  touch "$file" 2>/dev/null || true
}

clean_name() {
  local name="$1"
  local tags=(1080p 1080 720p 4k 60fps 30fps 25fps)
  local t source_label before after

  name="${name//.trimmed/}"

  # Convert source prefixes like "[xHamster - ..." to "(xHamster) ...".
  while [[ "$name" =~ '\[([^][]+) - ' ]]; do
    source_label="${match[1]}"
    before="${name[1,$(( MBEGIN - 1 ))]}"
    after="${name[$(( MEND + 1 )),-1]}"
    name="${before}(${source_label}) ${after}"
  done

  # remove every non-nested {...} block since the script rebuilds it
  while [[ "$name" == *\{*\}* ]]; do
    name="${name%%\{*}${name#*\}}"
  done

  for t in $tags; do
    name="${name//\#$t/}"
  done

  if [[ "${name:l}" == *" s01" ]]; then
    name="${name[1,-5]}"
  fi

  trim_whitespace "$name"
}

extract_rating() {
  local s="$1"
  local rating=""

  if [[ "$s" =~ '([★☆]{5})' ]]; then
    rating="${match[1]}"
  fi

  s="${s//[★☆][★☆][★☆][★☆][★☆]/}"
  s="$(trim_whitespace "$s")"

  print -r -- "$s"
  print -r -- "$rating"
}

get_resolution_label() {
  local d=${1:-0}

  if (( d <= 480 )); then
    print -r -- "480p"
  elif (( d <= 720 )); then
    print -r -- "720p"
  elif (( d <= 1080 )); then
    print -r -- "1080p"
  elif (( d <= 1440 )); then
    print -r -- "1440p"
  elif (( d <= 2160 )); then
    print -r -- "2160p"
  else
    print -r -- "${d}p"
  fi
}

format_duration() {
  local secs=${1:-0}
  local hours=$(( secs / 3600 ))
  local mins=$(( secs / 60 ))

  if (( hours > 0 )); then
    print -r -- "${hours}hr"
  elif (( mins > 0 )); then
    print -r -- "${mins}min"
  else
    print -r -- "${secs}sec"
  fi
}

get_rotation() {
  local file="$1"
  local rotation=""

  rotation="$(
    ffprobe -v error -select_streams v:0 \
      -show_entries stream_side_data=rotation \
      -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
  )"

  if [[ -z "$rotation" ]]; then
    rotation="$(
      ffprobe -v error -select_streams v:0 \
        -show_entries stream_tags=rotate \
        -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
    )"
  fi

  if [[ -z "$rotation" ]]; then
    rotation="$(
      ffprobe -v error \
        -show_entries format_tags=rotate \
        -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
    )"
  fi

  [[ -z "$rotation" ]] && rotation="0"
  print -r -- "$rotation"
}

process_video() {
  local file="$1"

  log_verbose "processing file: $file"

  local filename="${file:t}"
  local dirname="${file:h}"
  local extension="${filename:e}"
  local name_without_ext="${filename:r}"

  local extracted_name rating
  local -a parts

  parts=("${(@f)$(extract_rating "$name_without_ext")}")
  extracted_name="${parts[1]-$name_without_ext}"
  rating="${parts[2]-}"

  name_without_ext="$(clean_name "$extracted_name")"

  log_verbose "title parse: extracted='${extracted_name}' cleaned='${name_without_ext}' rating='${rating}'"

  local video_info
  if ! video_info="$(
    ffprobe -v error -select_streams v:0 \
      -show_entries stream=codec_name,width,height,r_frame_rate,bit_rate,color_transfer,color_primaries,pix_fmt \
      -of default=noprint_wrappers=1:nokey=0 -- "$file" 2>/dev/null
  )"; then
    print -r -- "${YELLOW}${ICON_WARN}Could not read video info: $file${RESET}"
    return 0
  fi

  log_verbose "ffprobe stream info for ${filename}: ${(qqq)video_info}"

  local rotation
  rotation="$(get_rotation "$file")"

  local duration_secs
  if ! duration_secs="$(
    ffprobe -v error -show_entries format=duration \
      -of csv=p=0 -- "$file" 2>/dev/null
  )"; then
    duration_secs="0"
  fi

  duration_secs="$(awk -v d="$duration_secs" 'BEGIN{printf("%d", d+0.5)}')"

  log_verbose "duration seconds for ${filename}: ${duration_secs}"

  local has_chapters=false
  if ffprobe -v error -show_chapters -of csv=p=0 -- "$file" 2>/dev/null | grep -q .; then
    has_chapters=true
  fi

  local title_tag=""
  title_tag="$(
    ffprobe -v error -show_entries format_tags=title \
      -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
  )"
  title_tag="$(trim_whitespace "$title_tag")"

  log_verbose "title tag for ${filename}: ${title_tag:-<empty>}"

  local width="" height="" frame_rate="" bit_rate="" codec_name=""
  local color_transfer="" color_primaries="" pix_fmt=""
  local line key value

  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"

    case "$key" in
      codec_name) codec_name="$value" ;;
      width) width="$value" ;;
      height) height="$value" ;;
      r_frame_rate) frame_rate="$value" ;;
      bit_rate) bit_rate="$value" ;;
      color_transfer) color_transfer="$value" ;;
      color_primaries) color_primaries="$value" ;;
      pix_fmt) pix_fmt="$value" ;;
    esac
  done <<< "$video_info"

  log_verbose "parsed video fields for ${filename}: codec=${codec_name:-?} width=${width:-?} height=${height:-?} fps=${frame_rate:-?} bitrate=${bit_rate:-?} transfer=${color_transfer:-?} primaries=${color_primaries:-?} pix_fmt=${pix_fmt:-?}"

  if [[ "$frame_rate" == */* ]]; then
    local num=${frame_rate%%/*}
    local denom=${frame_rate##*/}

    if (( denom > 0 )); then
      frame_rate=$(( (num + denom / 2) / denom ))
    else
      frame_rate=0
    fi
  fi

  log_verbose "normalized frame rate for ${filename}: ${frame_rate}"

  local display_width=$width
  local display_height=$height
  local abs_rotation=${rotation#-}

  if [[ "$abs_rotation" == "90" || "$abs_rotation" == "270" ]]; then
    display_width=$height
    display_height=$width
  fi

  log_verbose "display geometry for ${filename}: width=${display_width} height=${display_height} rotation=${rotation}"

  local smaller_dim=$(( display_width < display_height ? display_width : display_height ))

  local resolution
  resolution="$(get_resolution_label "$smaller_dim")"

  local orientation_flag
  if (( display_width > display_height )); then
    orientation_flag="􁻯"
  elif (( display_height > display_width )); then
    orientation_flag="􁻮"
  else
    orientation_flag="􀂒"
  fi

  local mbps="unknown"
  if [[ -n "$bit_rate" && "$bit_rate" != "N/A" ]]; then
    mbps="$(awk -v b="$bit_rate" 'BEGIN{printf("%dmbps", (b+500000)/1000000)}')"
  fi

  local duration
  duration="$(format_duration "$duration_secs")"

  local codec_flag=""
  case "${codec_name:l}" in
    hevc|h265)
      codec_flag="HEVC"
      ;;
    h264|avc1)
      codec_flag="AVC1"
      ;;
    prores)
      codec_flag="PRO"
      ;;
    vp9)
      codec_flag="VP9"
      ;;
    av1)
      codec_flag="AV1"
      ;;
  esac

  local hdr_flag=false
  case "${color_transfer:l}" in
    smpte2084|arib-std-b67)
      hdr_flag=true
      ;;
  esac

  if ! $hdr_flag; then
    if [[ "${color_primaries:l}" == "bt2020" && ( "${pix_fmt:l}" == *10* || "${pix_fmt:l}" == *12* || "${pix_fmt:l}" == *16* ) ]]; then
      hdr_flag=true
    fi
  fi

  log_verbose "derived flags for ${filename}: codec_flag=${codec_flag:-<none>} orientation=${orientation_flag} chapters=${has_chapters} meta=$([[ -n "$title_tag" ]] && print yes || print no) hdr=${hdr_flag}"

  extension="${filename:e}"

  local -a meta_flags

  [[ -n "$codec_flag" ]] && meta_flags+=("$codec_flag")
  meta_flags+=("$orientation_flag")
  $has_chapters && meta_flags+=("CH")
  [[ -n "$title_tag" ]] && meta_flags+=("META")
  $hdr_flag && meta_flags+=("HDR")

  local details_block="${resolution}@${frame_rate}fps ${duration}@${mbps}"

  if (( ${#meta_flags[@]} > 0 )); then
    details_block+=" ${meta_flags[*]}"
  fi

  local rating_suffix=""
  [[ -n "$rating" ]] && rating_suffix=" ${rating}"

  local new_filename="${name_without_ext} {${details_block}}${rating_suffix}.${extension}"
  local new_path="${dirname}/${new_filename}"

  log_verbose "rename target for ${filename}: ${new_filename}"

  if $PRINT_TARGET; then
    print -r -- "$new_path"
    return 0
  fi

  if [[ "$filename" == "$new_filename" ]]; then
    print -r -- "${YELLOW}${ICON_SKIP}${filename}${RESET}"
  elif [[ -e "$new_path" ]]; then
    print -r -- "${YELLOW}${ICON_WARN}Exists: $new_filename${RESET}"
  else
    if $DRY_RUN; then
      print -r -- "${CYAN}${ICON_VIDEO}${new_filename}${RESET}"
    else
      if mv -- "$file" "$new_path"; then
        touch_modified_now "$new_path"
        print -r -- "${GREEN}${ICON_OK}${new_filename}${RESET}"
      else
        print -r -- "${YELLOW}${ICON_WARN}Could not rename: ${filename} -> ${new_filename}${RESET}"
        return 1
      fi
    fi
  fi
}

normalize_input_path() {
  local s="$1"

  if [[ -e "$s" ]]; then
    print -r -- "$s"
    return 0
  fi

  local unescaped="${(Q)s}"

  if [[ -e "$unescaped" ]]; then
    print -r -- "$unescaped"
    return 0
  fi

  print -r -- "$s"
}

main() {
  while (( $# > 0 )); do
    case "$1" in
      --dry-run)
        DRY_RUN=true
        shift
        ;;
      --verbose)
        VERBOSE=true
        shift
        ;;
      --color)
        enable_color
        shift
        ;;
      --icons)
        enable_icons
        shift
        ;;
      --print-target|--target-path)
        PRINT_TARGET=true
        shift
        ;;
      --)
        shift
        break
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      -*)
        print -u2 -r -- "${YELLOW}${ICON_WARN}Unknown option: $1${RESET}"
        exit 1
        ;;
      *)
        break
        ;;
    esac
  done

  if ! command -v ffprobe >/dev/null 2>&1; then
    print -u2 -r -- "${YELLOW}${ICON_WARN}ffprobe is required but not installed.${RESET}"
    exit 1
  fi

  local raw_file file

  for raw_file in "$@"; do
    file="$(normalize_input_path "$raw_file")"

    if [[ -f "$file" ]]; then
      case "${file:l}" in
        *.mp4|*.mov|*.avi|*.mkv|*.wmv|*.flv|*.webm|*.m4v)
          process_video "$file"
          ;;
        *)
          print -r -- "${YELLOW}${ICON_SKIP}${file:t}${RESET}"
          ;;
      esac
    else
      print -r -- "${YELLOW}${ICON_SKIP}${file:t}${RESET}"
    fi
  done
}

main "$@"
