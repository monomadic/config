#!/bin/zsh
# Fuzzy-pick an open kitty tab and focus it.

local socket="${KITTY_LISTEN_ON:-unix:/tmp/kitty-$USER}"
local selected tab_id

selected="$(
kitten @ --to "$socket" ls 2>/dev/null \
  | jq -r '
      .[] as $os
      | $os.tabs[]
      | [
          (.id | tostring),
          ("os:" + ($os.id|tostring)),
          (.title // "untitled"),
          (
            .windows
            | map(.title // .cmdline[0] // "window")
            | join("  │  ")
          )
        ]
      | @tsv
    ' \
  | fzf --ansi --delimiter=$'\t' --with-nth=2,3,4 --nth=3,4 \
        --prompt='kitty tab> ' \
        --preview-window='down:3:wrap' \
        --preview='printf "tab id: %s\n%s\n\n%s\n" {1} {3} {4}'
)" || return

tab_id="${selected%%$'\t'*}"
[[ -n "$tab_id" ]] || return

kitten @ --to "$socket" focus-tab --match "id:$tab_id"

