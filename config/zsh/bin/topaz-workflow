#!/usr/bin/env zsh
emulate -L zsh
set -euo pipefail

script_name="${0:t}"

usage() {
  cat <<EOF
usage:
  $script_name [--trash-originals] file1 [file2 ...]
  $script_name --help

Two-step Topaz flow:
  1. Pick a transform preset.
  2. Pick an output profile.

In the transform picker, preview shortcuts are:
  alt-1  1f Static
  alt-4  4f Static
  alt-0  10f Motion
  alt-3  30f Motion
EOF
}

trash_originals=false
files=()

while (( $# > 0 )); do
  case "$1" in
    -h|--help|help)
      usage
      exit 0
      ;;
    --trash-originals|--trash-original)
      trash_originals=true
      shift
      ;;
    --)
      shift
      files+=("$@")
      break
      ;;
    -*)
      print -u2 -- "unknown option: $1"
      usage >&2
      exit 1
      ;;
    *)
      files+=("$1")
      shift
      ;;
  esac
done

(( ${#files[@]} > 0 )) || {
  usage >&2
  exit 1
}

for input in "${files[@]}"; do
  [[ -f "$input" ]] || {
    print -u2 -- "not a file: $input"
    exit 1
  }
done

command -v fzf >/dev/null 2>&1 || {
  print -u2 -- "fzf not found"
  exit 1
}

format_frame_rate() {
  emulate -L zsh
  local rate="${1:-}"

  [[ -n "$rate" && "$rate" != "0/0" ]] || {
    print -r -- "unknown fps"
    return
  }

  awk -v rate="$rate" '
    BEGIN {
      split(rate, parts, "/")
      if (parts[2] == "" || parts[2] == 0) {
        value = parts[1]
      } else {
        value = parts[1] / parts[2]
      }

      if (value == int(value)) {
        printf "%dfps\n", value
      } else {
        printf "%.2ffps\n", value
      }
    }
  '
}

format_duration() {
  emulate -L zsh
  local seconds="${1:-}"

  [[ "$seconds" == <-> || "$seconds" == <->.<-> ]] || {
    print -r -- "unknown"
    return
  }

  awk -v seconds="$seconds" '
    BEGIN {
      total = int(seconds + 0.5)
      hours = int(total / 3600)
      minutes = int((total % 3600) / 60)
      secs = total % 60

      if (hours > 0) {
        printf "%dh %dm\n", hours, minutes
      } else if (minutes > 0) {
        printf "%d min\n", minutes
      } else {
        printf "%d sec\n", secs
      }
    }
  '
}

media_preview_summary() {
  emulate -L zsh
  local input_file="$1"
  local ffprobe="${FFPROBE:-}"
  local width="" height="" codec="" avg_frame_rate="" r_frame_rate="" duration=""
  local key value line resolution framerate runtime

  if [[ -z "$ffprobe" ]] && command -v ffprobe >/dev/null 2>&1; then
    ffprobe="$(command -v ffprobe)"
  fi

  if [[ -z "$ffprobe" || ! -x "$ffprobe" ]]; then
    print -r -- "${input_file:t}"$'\n'"media info unavailable"
    return
  fi

  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      width) width="$value" ;;
      height) height="$value" ;;
      codec_name) codec="$value" ;;
      avg_frame_rate) avg_frame_rate="$value" ;;
      r_frame_rate) r_frame_rate="$value" ;;
      duration) duration="$value" ;;
    esac
  done < <(
    "$ffprobe" \
      -v error \
      -select_streams v:0 \
      -show_entries stream=width,height,codec_name,avg_frame_rate,r_frame_rate:format=duration \
      -of default=noprint_wrappers=1 \
      -- "$input_file" 2>/dev/null
  )

  if [[ "$width" == <-> && "$height" == <-> ]]; then
    resolution="${height}p"
  else
    resolution="unknown"
  fi

  framerate="$(format_frame_rate "${avg_frame_rate:-$r_frame_rate}")"
  runtime="$(format_duration "$duration")"

  print -r -- "${input_file:t}"
  print -r -- "${resolution}, ${framerate}, ${codec:-unknown}, ${runtime}"
}

script_dir="${0:A:h}"
TOPAZ_RUN="$script_dir/topaz-run"
if command -v topaz-run >/dev/null 2>&1; then
  TOPAZ_RUN="$(command -v topaz-run)"
elif [[ ! -x "$TOPAZ_RUN" ]]; then
  print -u2 -- "topaz-run not found in PATH or next to $script_name: $TOPAZ_RUN"
  exit 1
fi

PRESET_CATALOG="$script_dir/topaz-preset-catalog.zsh"
TOPAZ_PREVIEW_AB_KITTY="$script_dir/topaz-preview-ab-kitty"

[[ -r "$PRESET_CATALOG" ]] || {
  print -u2 -- "Topaz preset catalog not found: $PRESET_CATALOG"
  exit 1
}

source "$PRESET_CATALOG"

workflow_tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/topaz-workflow.XXXXXXXX")"
trap 'rm -rf "$workflow_tmp_dir"' EXIT

media_summary_file="$workflow_tmp_dir/media-summary.txt"
media_preview_summary "$files[1]" > "$media_summary_file"

transform_preview_script="$workflow_tmp_dir/transform-preview.zsh"
cat > "$transform_preview_script" <<'EOF'
#!/usr/bin/env zsh
emulate -L zsh

summary_file="$1"
filter_complex="$2"
metadata="${3:-}"

cyan=$'\033[1;36m'
dim=$'\033[2m'
yellow=$'\033[1;33m'
reset=$'\033[0m'

filename="unknown file"
details="media info unavailable"

if [[ -r "$summary_file" ]]; then
  {
    IFS= read -r filename || true
    IFS= read -r details || true
  } < "$summary_file"
fi

printf "%s%s%s\n" "$cyan" "$filename" "$reset"
printf "%s%s%s\n\n" "$dim" "$details" "$reset"
if [[ -n "$metadata" ]]; then
  printf "%ssummary%s\n" "$yellow" "$reset"
  printf "%s\n\n" "${metadata#videoai=}"
fi
printf "%sfilter%s\n" "$yellow" "$reset"
printf "%s\n" "$filter_complex"
EOF
chmod +x "$transform_preview_script"

preview_bind_1=""
preview_bind_4=""
preview_bind_10=""
preview_bind_30=""
if [[ -x "$TOPAZ_PREVIEW_AB_KITTY" ]]; then
  preview_base="${(q)TOPAZ_PREVIEW_AB_KITTY} --input ${(q)files[1]} --preset-name {3} --filter {4}"
  preview_bind_1="alt-1:execute-silent(${preview_base} --mode static --frames 1)"
  preview_bind_4="alt-4:execute-silent(${preview_base} --mode static --frames 4)"
  preview_bind_10="alt-0:execute-silent(${preview_base} --mode motion --frames 10)"
  preview_bind_30="alt-3:execute-silent(${preview_base} --mode motion --frames 30)"
fi

fzf_select_mode=(
  --no-input
  --bind='j:down,k:up,h:page-up,l:page-down,g:first,G:last'
)

transform_selection="$(
  topaz_transform_preset_rows |
    fzf \
      "${fzf_select_mode[@]}" \
      --delimiter=$'\t' \
      --height=70% \
      --reverse \
      --border \
      --header='j/k: move | h/l: page | g/G: first/last | enter: choose transform | alt-1: 1f Static | alt-4: 4f Static | alt-0: 10f Motion | alt-3: 30f Motion' \
      --header-first \
      --with-nth=1 \
      --preview="zsh ${(q)transform_preview_script} ${(q)media_summary_file} {4} {5}" \
      --preview-window='down:10:wrap' \
      ${preview_bind_1:+--bind="$preview_bind_1"} \
      ${preview_bind_4:+--bind="$preview_bind_4"} \
      ${preview_bind_10:+--bind="$preview_bind_10"} \
      ${preview_bind_30:+--bind="$preview_bind_30"}
)"

[[ -n "$transform_selection" ]] || {
  print -u2 -- "no transform selected"
  exit 1
}

IFS=$'\t' read -r transform_display transform_categories transform_slug transform_filter transform_metadata <<< "$transform_selection"

output_selection="$(
  topaz_output_profile_rows |
    fzf \
      "${fzf_select_mode[@]}" \
      --delimiter=$'\t' \
      --with-nth=1 \
      --height=40% \
      --reverse \
      --border \
      --header="j/k: move | h/l: page | g/G: first/last | enter: choose | transform: $transform_display" \
      --header-first \
      --preview='printf "slug:   %s\next:    .%s\nvideo:\n%s\n" {2} {3} {4}' \
      --preview-window='down:6:wrap'
)"

[[ -n "$output_selection" ]] || {
  print -u2 -- "no output selected"
  exit 1
}

IFS=$'\t' read -r output_display output_slug output_ext output_video_args <<< "$output_selection"

preset_label="${transform_display} - ${output_display}"
metadata="$transform_metadata"
[[ -n "$metadata" ]] || metadata="videoai=$transform_display"

cmd=(
  "$TOPAZ_RUN"
  --preset_name "$preset_label"
  --filter_complex "$transform_filter"
  --output_ext "$output_ext"
  --video_args "$output_video_args"
  --metadata "$metadata"
)

[[ "$trash_originals" == true ]] && cmd+=(--trash-originals)
cmd+=(-- "${files[@]}")

print -P -- "%F{cyan}Topaz workflow%f"
print -P -- "  %F{white}transform:%f $transform_display"
print -P -- "  %F{white}categories:%f $transform_categories"
print -P -- "  %F{white}output:%f    $output_display"
print -P -- "  %F{white}cmd:%f       ${(q+)cmd}"
print

"${cmd[@]}"
