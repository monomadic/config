#!/usr/bin/env zsh
set -euo pipefail

show_absolute=false
print_color=false

for arg in "$@"; do
  case "$arg" in
    --absolute-paths) show_absolute=true ;;
    --color)          print_color=true ;;
  esac
done

if [[ ! -p /dev/stdin ]]; then
  print -u2 "Error: expected piped input"
  exit 1
fi

for bin in fzf mktemp; do
  command -v "$bin" >/dev/null 2>&1 || {
    print -u2 "Error: missing dependency: $bin"
    exit 1
  }
done

tmp_raw=$(mktemp -t fzf-select.raw.XXXXXX)
tmp_lines=$(mktemp -t fzf-select.lines.XXXXXX)

cleanup() {
  rm -f -- "$tmp_raw" "$tmp_lines"
}
trap cleanup EXIT INT TERM

cat > "$tmp_raw"

esc=$'\033'
grey="${esc}[90m"
reset="${esc}[0m"

while IFS= read -r raw; do
  [[ -z "$raw" ]] && continue

  if $show_absolute; then
    disp=$raw
  else
    base=${raw:t}
    dir=${raw:h}

    if $print_color; then
      disp="${base} ${grey}${dir}${reset}"
    else
      disp="$base $dir"
    fi
  fi

  printf '%s\t%s\n' "$raw" "$disp" >> "$tmp_lines"
done < "$tmp_raw"

fzf_args=(
  --multi
  --exact
  --cycle
  --delimiter=$'\t'
  --with-nth=2
  --accept-nth=1
  --bind 'enter:select-all+accept'
  --bind 'alt-r:execute-silent(open --reveal {1})'
  --bind 'ctrl-r:execute-silent(open --reveal {1})'
)

$print_color && fzf_args+=(--ansi)

set +e
selected=$(
  fzf "${fzf_args[@]}" < "$tmp_lines"
)
fzf_status=$?
set -e

case "$fzf_status" in
  0) ;;
  1) exit 0 ;;
  130) exit 130 ;;
  *) exit "$fzf_status" ;;
esac

[[ -n "$selected" ]] && printf '%s\n' "$selected"
