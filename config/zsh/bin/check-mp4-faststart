#!/usr/bin/env zsh
#  mp4-check-faststart
# Check whether MP4/MOV files are "fast start" by verifying that the moov atom
# appears before the mdat atom.
#
# Usage:
#   mp4-faststart-check file.mp4
#   mp4-faststart-check *.mp4
#   fd -e mp4 -0 | xargs -0 mp4-faststart-check
#
# Exit codes:
#   0 = all checked files are fast start
#   1 = one or more files are not fast start or could not be checked

set -uo pipefail

if (( $# == 0 )); then
  print -u2 "Usage: mp4-faststart-check <file.mp4> [more files...]"
  exit 1
fi

if ! command -v AtomicParsley >/dev/null 2>&1; then
  print -u2 "Error: AtomicParsley is required."
  print -u2 "Install with: brew install atomicparsley"
  exit 1
fi

failed=0

for media_file in "$@"; do
  if [[ ! -f "$media_file" ]]; then
    print -P "%F{red}✗ Missing:%f $media_file"
    failed=1
    continue
  fi

  atom_tree="$(AtomicParsley "$media_file" -T 2>/dev/null)"

  moov_offset="$(
    print -r -- "$atom_tree" |
      awk '/Atom moov @/ { print $4; exit }'
  )"

  mdat_offset="$(
    print -r -- "$atom_tree" |
      awk '/Atom mdat @/ { print $4; exit }'
  )"

  if [[ -z "$moov_offset" || -z "$mdat_offset" ]]; then
    print -P "%F{yellow}? Unknown:%f $media_file"
    print -P "  Could not find both %F{cyan}moov%f and %F{cyan}mdat%f atoms"
    failed=1
    continue
  fi

  if (( moov_offset < mdat_offset )); then
    print -P "%F{green}✓ Fast start:%f $media_file"
    print -P "  moov=$moov_offset  mdat=$mdat_offset"
  else
    print -P "%F{red}✗ Not fast start:%f $media_file"
    print -P "  moov=$moov_offset  mdat=$mdat_offset"
    failed=1
  fi
done

exit "$failed"
