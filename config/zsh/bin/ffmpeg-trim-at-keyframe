#!/usr/bin/env zsh
# ffmpeg-trim-at-keyframe
#
# Losslessly trims the first N frames by seeking to the nearest *previous* keyframe
# (fast seek, stream-copy). This avoids broken GOP decode at the start, but the cut
# point will be <= the requested time (i.e., you may keep a little extra at the front).
#
# Usage:
#   ffmpeg-trim-at-keyframe <frames> <input> [output]
#
# Examples:
#   ffmpeg-trim-at-keyframe 120 in.mp4
#   ffmpeg-trim-at-keyframe 60  "in.mov" "out.mov"
#
# Notes:
# - Truly lossless: uses `-c copy` (no re-encode).
# - Keyframe-aligned: `-ss` is placed *before* `-i` for keyframe seek.
# - Accurate-to-frame trimming *without* re-encode is not generally possible unless
#   the cut lands on a keyframe.

set -euo pipefail

usage() {
  cat <<'EOF'
ffmpeg-trim-at-keyframe — losslessly trim the first N frames (keyframe-aligned)

USAGE
  ffmpeg-trim-at-keyframe <frames> <input> [output]

ARGS
  <frames>   Number of initial frames to trim (integer > 0)
  <input>    Input video path
  [output]   Optional output path
             Default: <input_basename>.trim<frames>f.<ext>

BEHAVIOR
  - Computes seconds = frames / avg_frame_rate (from ffprobe)
  - Seeks to nearest previous keyframe at/just before that timestamp (fast seek)
  - Stream-copies all streams (-map 0 -c copy), no quality loss

EXAMPLES
  ffmpeg-trim-at-keyframe 120 in.mp4
  ffmpeg-trim-at-keyframe 60  "in.mov" "out.mov"

EOF
}

(( $# < 2 )) && { usage >&2; exit 2; }
[[ "${1}" == "-h" || "${1}" == "--help" ]] && { usage; exit 0; }

frames="$1"
in="$2"
out="${3:-${in:r}.trim${frames}f.${in:e}}"

[[ "$frames" =~ '^[0-9]+$' ]] || { print -u2 "frames must be an integer"; exit 2; }
(( frames > 0 )) || { print -u2 "frames must be > 0"; exit 2; }
[[ -f "$in" ]] || { print -u2 "input not found: $in"; exit 2; }

# avg_frame_rate looks like "30000/1001"
fps=$(ffprobe -v error -select_streams v:0 -show_entries stream=avg_frame_rate \
  -of default=nk=1:nw=1 -- "$in" | head -n1)

[[ -n "$fps" && "$fps" != "0/0" ]] || { print -u2 "couldn't determine fps for: $in"; exit 2; }

sec=$(python3 - <<'PY' "$frames" "$fps"
from fractions import Fraction
import sys
frames = int(sys.argv[1])
fps = Fraction(sys.argv[2])
t = Fraction(frames, 1) / fps
# Print with enough precision for ffmpeg -ss
print(f"{float(t):.9f}")
PY
)

# Keyframe-aligned trim: -ss BEFORE -i, then stream copy.
ffmpeg -hide_banner -loglevel error \
  -ss "$sec" -i "$in" \
  -map 0 -c copy -movflags +faststart \
  -- "$out"

print -r -- "Wrote: $out"
print -r -- "Requested trim: ${frames} frames (~${sec}s @ ${fps} fps)"
print -r -- "Actual trim: keyframe-aligned (may be slightly less than requested)"
