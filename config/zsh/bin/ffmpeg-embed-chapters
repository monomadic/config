#!/usr/bin/env zsh
# Review detected scenes, then embed them as chapters in a copied file.

emulate -L zsh
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ffmpeg-embed-chapters [options] <input-video>

Options:
  -n, --dry-run            Print planned chapters and ffmpeg command without writing files
  -t, --threshold <value>  Scene sensitivity threshold passed to ffmpeg-detect-scenes
                           Lower values detect more cuts; higher values detect fewer.
  -k, --snap-to-keyframe   Build chapter boundaries from keyframe-safe cut times instead
                           of the exact detected scene times
  -f, --force              Overwrite the output file if it already exists
  -w, --width <px>         Thumbnail preview width in fzf (default: 480)
  -p, --title-prefix <s>   Chapter title prefix (default: Scene)
  --keep-previews          Keep generated preview thumbnails instead of deleting them
  -h, --help               Show this help

Behavior:
  - Shows an fzf review of detected scenes before writing anything
  - Saves a copy beside the source as <name>.chapters.<ext>
  - Muxes chapter metadata without re-encoding the media streams

Examples:
  ffmpeg-embed-chapters movie.mp4
  ffmpeg-embed-chapters --dry-run movie.mp4
  ffmpeg-embed-chapters --snap-to-keyframe --title-prefix Cut movie.mkv
EOF
}

die() {
  print -u2 -- "error: $*"
  exit 1
}

warn() {
  print -u2 -- "warning: $*"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

format_ts() {
  python3 - "$1" <<'PY'
import sys
s = float(sys.argv[1])
h = int(s // 3600)
m = int((s % 3600) // 60)
sec = s % 60
print(f"{h:02d}:{m:02d}:{sec:09.6f}")
PY
}

quote_cmd() {
  printf '%q ' "$@"
  printf '\n'
}

review_scenes() {
  local input_file="$1"
  local detections_file="$2"
  local width="$3"
  local keep_previews="$4"

  local tmp_dir
  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/ffmpeg-embed-chapters-review.XXXXXXXX")"

  review_cleanup() {
    if [[ "$keep_previews" == true ]]; then
      print -u2 -- "kept previews in: $tmp_dir"
    else
      rm -rf -- "$tmp_dir"
    fi
  }

  local list_file="$tmp_dir/list.tsv"
  : > "$list_file"

  local idx raw_frame raw_time cut_frame cut_time score pretty_ts img_file
  local -a ffmpeg_pids=()
  while IFS=$'\t' read -r idx raw_frame raw_time cut_frame cut_time score; do
    [[ -n "$idx" ]] || continue
    pretty_ts="$(format_ts "$raw_time")"
    img_file="$tmp_dir/scene-${idx}.jpg"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$idx" "$raw_time" "$pretty_ts" "$score" "$cut_time" "$raw_frame" "$img_file" >> "$list_file"
    (
      ffmpeg -v error -y \
        -ss "$raw_time" -i "$input_file" \
        -frames:v 1 \
        -vf "scale=${width}:-2:flags=lanczos" \
        -q:v 3 \
        -- "$img_file"
    ) &
    ffmpeg_pids+=("$!")
  done < <(grep -v '^#' "$detections_file")

  if [[ ! -s "$list_file" ]]; then
    review_cleanup
    return 0
  fi

  local pid
  for pid in "${ffmpeg_pids[@]}"; do
    wait "$pid" || {
      review_cleanup
      return 1
    }
  done

  local preview_script="$tmp_dir/preview.zsh"
  cat > "$preview_script" <<'EOF'
#!/usr/bin/env zsh
emulate -L zsh
set -euo pipefail

idx="$1"
raw_ts="$2"
pretty_ts="$3"
score="$4"
cut_ts="$5"
raw_frame="$6"
img="$7"

preview_cols="${FZF_PREVIEW_COLUMNS:-80}"
preview_lines="${FZF_PREVIEW_LINES:-24}"
image_lines=$(( preview_lines > 5 ? preview_lines - 5 : preview_lines ))

print -- "Scene break #$idx"
print -- "Detected frame: $raw_frame"
print -- "Detected time:  $pretty_ts ($raw_ts)"
print -- "Scene score:    $score"
print -- "Cut-safe time:  $cut_ts"
print -- ""

if [[ -n "${KITTY_WINDOW_ID:-}" ]] && command -v kitty >/dev/null 2>&1; then
  kitty +kitten icat \
    --clear \
    --transfer-mode=stream \
    --stdin=no \
    --place="${preview_cols}x${image_lines}@0x5" \
    -- "$img"
elif [[ -n "${WEZTERM_PANE:-}" ]] && command -v wezterm >/dev/null 2>&1; then
  wezterm imgcat --width "${preview_cols}" -- "$img"
elif command -v imgcat >/dev/null 2>&1; then
  imgcat "$img"
elif command -v chafa >/dev/null 2>&1; then
  chafa --animate=off --size="${preview_cols}x${image_lines}" -- "$img"
else
  print -- "$img"
fi
EOF
  chmod +x "$preview_script"

  fzf \
    --delimiter=$'\t' \
    --with-nth=1,3,4 \
    --no-sort \
    --layout=reverse \
    --height=100% \
    --border \
    --prompt='scene> ' \
    --header="Review detected scenes for ${input_file:t} - Enter to continue, Esc to cancel" \
    --preview-window='right,70%,border-left' \
    --preview "zsh '$preview_script' {1} {2} {3} {4} {5} {6} {7}" \
    < "$list_file" >/dev/null || {
      rc=$?
      review_cleanup
      return "$rc"
    }

  review_cleanup
}

escape_ffmeta() {
  python3 - "$1" <<'PY'
import sys
s = sys.argv[1]
s = s.replace("\\", "\\\\")
s = s.replace("=", "\\=")
s = s.replace(";", "\\;")
s = s.replace("#", "\\#")
s = s.replace("\n", " ")
print(s)
PY
}

dry_run=false
threshold="0.30"
snap_to_keyframe=false
force=false
width=480
title_prefix="Scene"
keep_previews=false
typeset -a positionals=()

while (( $# > 0 )); do
  case "$1" in
    -n|--dry-run)
      dry_run=true
      shift
      ;;
    -t|--threshold)
      (( $# >= 2 )) || die "missing value for $1"
      threshold="$2"
      shift 2
      ;;
    -k|--snap-to-keyframe)
      snap_to_keyframe=true
      shift
      ;;
    -f|--force)
      force=true
      shift
      ;;
    -w|--width)
      (( $# >= 2 )) || die "missing value for $1"
      width="$2"
      shift 2
      ;;
    -p|--title-prefix)
      (( $# >= 2 )) || die "missing value for $1"
      title_prefix="$2"
      shift 2
      ;;
    --keep-previews)
      keep_previews=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while (( $# > 0 )); do
        positionals+=("$1")
        shift
      done
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      positionals+=("$1")
      shift
      ;;
  esac
done

(( ${#positionals[@]} == 1 )) || {
  usage >&2
  exit 2
}

input_file="${positionals[1]}"
[[ -f "$input_file" ]] || die "input not found: $input_file"
[[ "$threshold" == <-> || "$threshold" == <->.<-> || "$threshold" == .<-> ]] || die "threshold must be numeric"
[[ "$width" == <-> ]] || die "width must be an integer"

have ffmpeg || die "ffmpeg not found"
have ffprobe || die "ffprobe not found"
have python3 || die "python3 not found"
have fzf || die "fzf not found"
have ffmpeg-detect-scenes || die "ffmpeg-detect-scenes not found"

base_name="${input_file:t}"
dir_name="${input_file:h}"
if [[ "$base_name" == *.* ]]; then
  stem="${base_name:r}"
  ext="${base_name:e}"
else
  stem="$base_name"
  ext="mkv"
fi
output_file="${dir_name}/${stem}.chapters.${ext}"

tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/ffmpeg-embed-chapters.XXXXXXXX")"
cleanup() {
  rm -rf -- "$tmp_dir"
}
trap cleanup EXIT INT TERM

detections_file="$tmp_dir/detections.tsv"
duration_file="$tmp_dir/duration.txt"
meta_file="$tmp_dir/chapters.ffmeta"

if [[ "$snap_to_keyframe" == true ]]; then
  ffmpeg-detect-scenes --snap-to-keyframe --threshold "$threshold" -- "$input_file" > "$detections_file"
else
  ffmpeg-detect-scenes --threshold "$threshold" -- "$input_file" > "$detections_file"
fi

ffprobe -v error \
  -show_entries format=duration \
  -of default=nw=1:nk=1 \
  -- "$input_file" > "$duration_file"

if grep -qv '^#' "$detections_file"; then
  print -- "Reviewing detected scenes..."
  review_scenes "$input_file" "$detections_file" "$width" "$keep_previews" || exit $?
else
  warn "no scene changes detected; output will contain a single chapter covering the whole file"
fi

python3 - "$detections_file" "$duration_file" "$meta_file" "$snap_to_keyframe" "$title_prefix" <<'PY'
import math
import sys

detections_path = sys.argv[1]
duration_path = sys.argv[2]
meta_path = sys.argv[3]
snap = sys.argv[4].lower() == "true"
title_prefix = sys.argv[5]

duration = float(open(duration_path, "r", encoding="utf-8").read().strip())
if not math.isfinite(duration) or duration <= 0:
    raise SystemExit("invalid duration")

boundaries = [0.0]
with open(detections_path, "r", encoding="utf-8") as fh:
    for line in fh:
        if not line.strip() or line.startswith("#"):
            continue
        idx, raw_frame, raw_time, cut_frame, cut_time, score = line.rstrip("\n").split("\t")
        boundaries.append(float(cut_time if snap else raw_time))
boundaries.append(duration)

deduped = [boundaries[0]]
for ts in boundaries[1:]:
    if ts - deduped[-1] > 1e-6:
        deduped.append(ts)

with open(meta_path, "w", encoding="utf-8") as fh:
    fh.write(";FFMETADATA1\n")
    for index, (start, end) in enumerate(zip(deduped, deduped[1:]), start=1):
        start_ms = int(round(start * 1000))
        end_ms = int(round(end * 1000))
        fh.write("[CHAPTER]\n")
        fh.write("TIMEBASE=1/1000\n")
        fh.write(f"START={start_ms}\n")
        fh.write(f"END={end_ms}\n")
        fh.write(f"title={title_prefix} {index:03d}\n")
PY

[[ -e "$output_file" && "$force" == false && "$dry_run" == false ]] && die "output exists: $output_file (use --force to overwrite)"

print -- "Planned chapters:"
python3 - "$meta_file" <<'PY'
import sys

current = {}
for line in open(sys.argv[1], "r", encoding="utf-8"):
    line = line.strip()
    if line == "[CHAPTER]":
        current = {}
        continue
    if "=" not in line:
        continue
    key, value = line.split("=", 1)
    current[key] = value
    if key == "title":
        start = int(current["START"]) / 1000.0
        end = int(current["END"]) / 1000.0
        print(f"{value}: {start:.3f}s -> {end:.3f}s")
PY

cmd=(
  ffmpeg
  -hide_banner
  -loglevel error
)
if [[ "$force" == true ]]; then
  cmd+=(-y)
else
  cmd+=(-n)
fi
cmd+=(
  -i "$input_file"
  -f ffmetadata
  -i "$meta_file"
  -map 0
  -c copy
  -map_metadata 0
  -map_chapters 1
  "$output_file"
)

if [[ "$dry_run" == true ]]; then
  print -- ""
  print -- "ffmetadata:"
  sed -n '1,200p' "$meta_file"
  print -- ""
  print -- "command:"
  print -n -- "  "
  quote_cmd "${cmd[@]}"
  print -- "Dry run only. No files were written."
else
  "${cmd[@]}"
  print -- "Wrote chaptered file: $output_file"
fi
