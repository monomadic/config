#!/usr/bin/env zsh
set -euo pipefail

typeset -r SELF="${0:A}"

show_absolute=false
print_color=false
read0=false
print0=false
stream=false
passthrough_args=()
records_loaded=0

esc=$'\033'
cyan="${esc}[36m"
yellow="${esc}[33m"
red="${esc}[31m"
grey="${esc}[90m"
reset="${esc}[0m"

usage() {
  cat <<'USAGE'
Usage: fzf-select-preview [options] [fzf args ...]

Read file paths from stdin, browse them in fzf with cached thumbnail previews,
press enter to play the hovered file in mpv, or press ctrl-s to print selected
paths to stdout.

Options:
  --absolute-paths   Show each path as received instead of "basename dirname".
  --color            Color the dirname portion of compact display rows.
  -0, --read0        Read NUL-delimited input.
  --print0           Print selected paths as NUL-delimited output.
  --stream           Stream input into fzf instead of preloading it.
  -h, --help         Show this help.

Environment:
  FZF_SELECT_PREVIEW_CACHE_DIR      Thumbnail cache directory.
  FZF_SELECT_PREVIEW_IMAGE_HANDLER  auto, kitty, sixel, symbols, or none.
  FZF_PREVIEW_IMAGE_HANDLER         Fallback image handler.
USAGE
}

status_message() {
  [[ -t 2 ]] || return 0
  print -u2 -- "fzf-select-preview: $*"
}

sanitize_utf8() {
  if command -v iconv >/dev/null 2>&1; then
    iconv -f UTF-8 -t UTF-8 -c 2>/dev/null
  else
    cat
  fi
}

cache_dir() {
  print -r -- "${FZF_SELECT_PREVIEW_CACHE_DIR:-${XDG_CACHE_HOME:-$HOME/.cache}/fzf-select-preview}"
}

thumb_cache_dir() {
  print -r -- "$(cache_dir)/thumbs"
}

file_mime() {
  local file="$1"
  local mime=""

  mime="$(file -b --mime-type "$file" 2>/dev/null || true)"
  if [[ -z "$mime" ]]; then
    mime="$(file -b -I "$file" 2>/dev/null | sed 's/;.*//' || true)"
  fi

  [[ -n "$mime" ]] && print -r -- "$mime" || print -r -- "unknown"
}

file_size_bytes() {
  local file="$1"
  local size=""

  size="$(stat -f %z "$file" 2>/dev/null || true)"
  [[ -n "$size" ]] || size="$(stat -c %s "$file" 2>/dev/null || true)"
  [[ -n "$size" ]] && print -r -- "$size" || print -r -- "0"
}

file_mtime_epoch() {
  local file="$1"
  local mtime=""

  mtime="$(stat -f %m "$file" 2>/dev/null || true)"
  [[ -n "$mtime" ]] || mtime="$(stat -c %Y "$file" 2>/dev/null || true)"
  [[ -n "$mtime" ]] && print -r -- "$mtime" || print -r -- "0"
}

human_bytes() {
  local bytes="${1:-0}"

  awk -v bytes="$bytes" '
    BEGIN {
      split("B KiB MiB GiB TiB PiB", unit, " ")
      value = bytes + 0
      i = 1
      while (value >= 1024 && i < 6) {
        value = value / 1024
        i++
      }
      if (i == 1) printf "%d %s", value, unit[i]
      else printf "%.1f %s", value, unit[i]
    }
  '
}

human_mtime() {
  local mtime="${1:-0}"

  date -r "$mtime" '+%Y-%m-%d %H:%M:%S %z' 2>/dev/null ||
    date -d "@$mtime" '+%Y-%m-%d %H:%M:%S %z' 2>/dev/null ||
    print -r -- "$mtime"
}

file_kind() {
  local file="$1"
  local mime="$2"
  local ext="${file:e}"
  ext="${(L)ext}"

  case "$mime" in
    image/*) print -r -- "image"; return 0 ;;
    video/*) print -r -- "video"; return 0 ;;
    audio/*) print -r -- "audio"; return 0 ;;
    application/pdf) print -r -- "pdf"; return 0 ;;
    text/*) print -r -- "text"; return 0 ;;
    inode/directory) print -r -- "directory"; return 0 ;;
  esac

  case "$ext" in
    jpg|jpeg|png|webp|gif|bmp|tif|tiff|heic|heif|avif) print -r -- "image" ;;
    mp4|m4v|mov|mkv|webm|avi|wmv|flv|mpg|mpeg|3gp|ts) print -r -- "video" ;;
    mp3|m4a|flac|wav|aiff|aif|ogg|opus|aac|wma|mka) print -r -- "audio" ;;
    pdf) print -r -- "pdf" ;;
    txt|md|markdown|json|yaml|yml|toml|csv|tsv|log|zsh|sh|bash|py|js|ts|lua|go|rs) print -r -- "text" ;;
    *) print -r -- "file" ;;
  esac
}

file_cache_key() {
  local file="$1"
  local size mtime

  size="$(file_size_bytes "$file")"
  mtime="$(file_mtime_epoch "$file")"

  printf 'fzf-select-preview-v1\n%s\n%s\n%s' "$file" "$size" "$mtime" |
    shasum -a 256 |
    awk '{print $1}'
}

thumbnail_is_valid() {
  local file="$1"
  local mime

  [[ -s "$file" ]] || return 1
  mime="$(file_mime "$file")"
  [[ "$mime" == image/* ]]
}

cached_thumbnail() {
  local file="$1"
  local kind="$2"
  local key base out tmp prefix ext candidate

  [[ -r "$file" ]] || return 1

  if [[ "$kind" == "image" ]]; then
    print -r -- "$file"
    return 0
  fi

  case "$kind" in
    video|audio|pdf) ;;
    *) return 1 ;;
  esac

  key="$(file_cache_key "$file")"
  base="$(thumb_cache_dir)/$key"
  mkdir -p "${base:h}"

  for ext in jpg jpeg png webp; do
    candidate="${base}.${ext}"
    if thumbnail_is_valid "$candidate"; then
      print -r -- "$candidate"
      return 0
    fi
  done

  out="${base}.jpg"
  tmp="${base}.tmp.$$"

  case "$kind" in
    video)
      command -v ffmpegthumbnailer >/dev/null 2>&1 || return 1
      if ffmpegthumbnailer -i "$file" -o "$tmp" -s 1200 >/dev/null 2>&1 &&
        thumbnail_is_valid "$tmp"; then
        mv -f -- "$tmp" "$out"
        print -r -- "$out"
        return 0
      fi
      ;;
    audio)
      command -v ffmpeg >/dev/null 2>&1 || return 1
      if ffmpeg -v error -y -i "$file" -map 0:v:0 -frames:v 1 "$tmp" >/dev/null 2>&1 &&
        thumbnail_is_valid "$tmp"; then
        mv -f -- "$tmp" "$out"
        print -r -- "$out"
        return 0
      fi
      ;;
    pdf)
      command -v pdftoppm >/dev/null 2>&1 || return 1
      prefix="${base}.tmp.$$"
      if pdftoppm -jpeg -f 1 -singlefile "$file" "$prefix" >/dev/null 2>&1 &&
        thumbnail_is_valid "${prefix}.jpg"; then
        mv -f -- "${prefix}.jpg" "$out"
        print -r -- "$out"
        return 0
      fi
      rm -f -- "${prefix}.jpg"
      ;;
  esac

  rm -f -- "$tmp"
  return 1
}

preview_image_handler() {
  local handler="${FZF_SELECT_PREVIEW_IMAGE_HANDLER:-${FZF_PREVIEW_IMAGE_HANDLER:-auto}}"

  if [[ "$handler" != "auto" ]]; then
    print -r -- "$handler"
    return 0
  fi

  if [[ -n "${KITTY_WINDOW_ID:-}" || "${TERM_PROGRAM:-}" == "kitty" || "${TERM:-}" == xterm-kitty* ]]; then
    print -r -- "kitty"
  elif command -v chafa >/dev/null 2>&1; then
    print -r -- "symbols"
  else
    print -r -- "none"
  fi
}

render_kitty_image() {
  local image="$1"
  local columns="$2"
  local image_lines="$3"
  local -a icat_cmd
  local i

  if command -v kitty >/dev/null 2>&1; then
    icat_cmd=(kitty +kitten icat)
  elif command -v kitten >/dev/null 2>&1; then
    icat_cmd=(kitten icat)
  else
    return 1
  fi

  "${icat_cmd[@]}" \
    --clear \
    --transfer-mode=file \
    --stdin=no \
    --align=left \
    --place="${columns}x${image_lines}@0x0" \
    "$image" 2>/dev/null || return 1

  for (( i = 0; i < image_lines; i++ )); do
    print ""
  done
}

render_preview_image() {
  local image="$1"
  local columns="${FZF_PREVIEW_COLUMNS:-80}"
  local lines="${FZF_PREVIEW_LINES:-40}"
  local image_lines=$(( lines - 14 ))
  local handler

  (( image_lines > 24 )) && image_lines=24
  (( image_lines < 7 )) && image_lines=7

  handler="$(preview_image_handler)"

  case "$handler" in
    kitty)
      if render_kitty_image "$image" "$columns" "$image_lines"; then
        return 0
      fi
      ;;
    sixel)
      if command -v chafa >/dev/null 2>&1; then
        chafa -f sixel -s "${columns}x${image_lines}" "$image" --animate false
        return 0
      fi
      ;;
    symbols)
      if command -v chafa >/dev/null 2>&1; then
        chafa -f symbols -s "${columns}x${image_lines}" "$image" --animate false
        return 0
      fi
      ;;
    none)
      print "${cyan}Thumbnail:${reset} $image"
      return 0
      ;;
  esac

  print "${cyan}Thumbnail:${reset} $image"
}

print_basic_metadata() {
  local file="$1"
  local mime="$2"
  local kind="$3"
  local size mtime

  size="$(file_size_bytes "$file")"
  mtime="$(file_mtime_epoch "$file")"

  print "${cyan}File:${reset} ${file:t}"
  print "${cyan}Folder:${reset} ${file:h}"
  print "${cyan}Kind:${reset} $kind"
  print "${cyan}MIME:${reset} $mime"
  print "${cyan}Size:${reset} $(human_bytes "$size")"
  print "${cyan}Modified:${reset} $(human_mtime "$mtime")"
}

print_ffprobe_metadata() {
  local file="$1"

  command -v ffprobe >/dev/null 2>&1 || return 0
  command -v jq >/dev/null 2>&1 || return 0

  ffprobe -v error -print_format json -show_format -show_streams -- "$file" 2>/dev/null |
    jq -r '
      def emit(k; v):
        if v == null or v == "" or v == "N/A" then empty
        else "\u001b[36m" + k + ":\u001b[0m " + (v | tostring)
        end;
      def clean:
        tostring
        | gsub("[\r\n\t]+"; " ")
        | gsub("  +"; " ");
      def human_duration:
        if .format.duration == null then null
        else
          (.format.duration | tonumber | floor) as $total
          | (($total / 3600) | floor) as $hours
          | ((($total % 3600) / 60) | floor) as $minutes
          | ($total % 60) as $seconds
          | if $hours > 0
            then "\($hours)h \($minutes)m \($seconds)s"
            else "\($minutes)m \($seconds)s"
            end
        end;
      def kbps($bits):
        if $bits == null or $bits == "N/A" then null
        else (((($bits | tonumber) / 1000) | round | tostring) + " kb/s")
        end;
      def fps($rate):
        if $rate == null or $rate == "" or $rate == "0/0" then null
        else ($rate | split("/")) as $p
          | if (($p | length) == 2 and ($p[1] | tonumber) != 0)
            then (((($p[0] | tonumber) / ($p[1] | tonumber) * 100) | round / 100 | tostring) + " fps")
            else null
            end
        end;
      def stream($type):
        (.streams // [] | map(select(.codec_type == $type)) | .[0]);

      stream("video") as $v
      | stream("audio") as $a
      | (.format.tags // {}) as $tags
      | emit("Duration"; human_duration),
        emit("Bitrate"; kbps(.format.bit_rate)),
        emit("Video";
          if $v == null then null
          else [
            ($v.codec_name // null),
            (if $v.width != null and $v.height != null then "\($v.width)x\($v.height)" else null end),
            (fps($v.avg_frame_rate) // fps($v.r_frame_rate))
          ] | map(select(. != null and . != "")) | join(" ")
          end),
        emit("Audio";
          if $a == null then null
          else [
            ($a.codec_name // null),
            (if $a.channels != null then "\($a.channels)ch" else null end),
            (if $a.sample_rate != null then ((($a.sample_rate | tonumber) / 1000 | tostring) + " kHz") else null end)
          ] | map(select(. != null and . != "")) | join(" ")
          end),
        emit("Title"; ($tags.title // $tags.TITLE)),
        emit("Artist"; ($tags.artist // $tags.ARTIST // $tags.album_artist // $tags.ALBUMARTIST)),
        emit("Album"; ($tags.album // $tags.ALBUM)),
        emit("Date"; ($tags.date // $tags.DATE // $tags.creation_time)),
        (($tags.description // $tags.DESCRIPTION // $tags.comment // $tags.COMMENT) as $description
          | if $description == null or $description == "" then empty
            else "\n" + ($description | clean | .[0:800])
            end)
    ' 2>/dev/null || true
}

print_text_preview() {
  local file="$1"

  [[ -r "$file" ]] || return 0
  print ""
  if command -v bat >/dev/null 2>&1; then
    bat -p --color=always --line-range :80 -- "$file" 2>/dev/null || true
  else
    sed -n '1,80p' "$file" 2>/dev/null || true
  fi
}

path_for_index() {
  local idx="$1"
  local map_file="$2"

  [[ "$idx" == <-> && -r "$map_file" ]] || return 1
  sed -n "${idx}p" "$map_file"
}

cmd_preview() {
  local idx="${1:-}"
  local map_file="${2:-}"
  local raw file mime kind thumbnail

  raw="$(path_for_index "$idx" "$map_file" 2>/dev/null)" || return 0
  [[ -n "$raw" ]] || return 0

  file="${raw:A}"

  if [[ ! -e "$file" ]]; then
    print "${red}Missing:${reset} $raw"
    return 0
  fi

  mime="$(file_mime "$file")"
  kind="$(file_kind "$file" "$mime")"
  thumbnail="$(cached_thumbnail "$file" "$kind" 2>/dev/null)" || thumbnail=""

  if [[ -n "$thumbnail" ]]; then
    render_preview_image "$thumbnail"
    print ""
  else
    print "${yellow}No cached thumbnail available.${reset}"
    print ""
  fi

  print_basic_metadata "$file" "$mime" "$kind"

  case "$kind" in
    video|audio|image)
      print_ffprobe_metadata "$file"
      ;;
    text)
      print_text_preview "$file"
      ;;
  esac
}

cmd_play() {
  local idx="${1:-}"
  local map_file="${2:-}"
  local raw file

  raw="$(path_for_index "$idx" "$map_file" 2>/dev/null)" || return 0
  [[ -n "$raw" ]] || return 0

  file="${raw:A}"
  [[ -e "$file" ]] || return 0

  (mpv-send play -- "$file" </dev/null >/dev/null 2>&1) &!
}

case "${1:-}" in
  __preview)
    shift
    cmd_preview "$@"
    exit $?
    ;;
  __play)
    shift
    cmd_play "$@"
    exit $?
    ;;
esac

for arg in "$@"; do
  case "$arg" in
    --absolute-paths) show_absolute=true ;;
    --color)          print_color=true ;;
    -0|--read0)       read0=true ;;
    --print0)         print0=true ;;
    --stream)         stream=true ;;
    -h|--help)        usage; exit 0 ;;
    *)                passthrough_args+=("$arg") ;;
  esac
done

if [[ -t 0 ]]; then
  print -u2 "Error: expected piped input"
  exit 1
fi

for bin in fzf mktemp awk shasum mpv-send; do
  command -v "$bin" >/dev/null 2>&1 || {
    print -u2 "Error: missing dependency: $bin"
    exit 1
  }
done

tmp_map=$(mktemp -t fzf-select-preview.map.XXXXXX)
tmp_lines=$(mktemp -t fzf-select-preview.lines.XXXXXX)
tmp_selected=$(mktemp -t fzf-select-preview.selected.XXXXXX)
tmp_selected_lines=$(mktemp -t fzf-select-preview.selected-lines.XXXXXX)
tmp_fzf_status=$(mktemp -t fzf-select-preview.status.XXXXXX)

cleanup() {
  rm -f -- "$tmp_map" "$tmp_lines" "$tmp_selected" "$tmp_selected_lines" "$tmp_fzf_status"
  (stty sane < /dev/tty >/dev/null 2>&1) 2>/dev/null || true
}
trap cleanup EXIT INT TERM

format_display() {
  local raw="$1"
  local base dir disp

  if $show_absolute; then
    disp=$raw
  else
    base=${raw:t}
    dir=${raw:h}

    if $print_color; then
      disp="${base} ${grey}${dir}${reset}"
    else
      disp="$base $dir"
    fi
  fi
  printf '%s' "$disp"
}

emit_record() {
  local raw="$1"
  local idx="$2"
  local disp

  [[ -z "$raw" ]] && return 0

  printf '%s\n' "$raw" >> "$tmp_map"
  disp="$(format_display "$raw")"

  if $read0; then
    printf '%s\t%s\0' "$idx" "$disp"
  else
    printf '%s\t%s\n' "$idx" "$disp"
  fi
}

append_record() {
  local raw="$1"
  local idx="$2"

  [[ -z "$raw" ]] && return 0

  emit_record "$raw" "$idx" | sanitize_utf8 >> "$tmp_lines"
  (( ++records_loaded ))
}

emit_fzf_input() {
  local raw
  local idx=1

  if $read0; then
    while IFS= read -r -d $'\0' raw || [[ -n "$raw" ]]; do
      emit_record "$raw" "$idx"
      (( ++idx ))
      raw=""
    done
  else
    while IFS= read -r raw || [[ -n "$raw" ]]; do
      emit_record "$raw" "$idx"
      (( ++idx ))
      raw=""
    done
  fi
}

build_fzf_input() {
  local raw
  local idx=1

  if $read0; then
    while IFS= read -r -d $'\0' raw || [[ -n "$raw" ]]; do
      append_record "$raw" "$idx"
      (( ++idx ))
      raw=""
    done
  else
    while IFS= read -r raw || [[ -n "$raw" ]]; do
      append_record "$raw" "$idx"
      (( ++idx ))
      raw=""
    done
  fi
}

map_selection() {
  if $print0; then
    tr '\0' '\n' < "$tmp_selected" > "$tmp_selected_lines"
    LC_ALL=C awk '
      NR == FNR { paths[NR] = $0; next }
      $1 in paths { printf "%s%c", paths[$1], 0 }
    ' "$tmp_map" "$tmp_selected_lines"
  else
    LC_ALL=C awk '
      NR == FNR { paths[NR] = $0; next }
      $1 in paths { print paths[$1] }
    ' "$tmp_map" "$tmp_selected"
  fi
}

preview_cmd="${(q)SELF} __preview {1} ${(q)tmp_map}"
play_cmd="${(q)SELF} __play {1} ${(q)tmp_map}"
reveal_bind="execute-silent(zsh -c 'path=\$(sed -n \"\${1}p\" \"\$2\"); [[ -n \"\$path\" ]] && open --reveal \"\$path\"' _ {1} ${(q)tmp_map})"

(stty -ixon < /dev/tty >/dev/null 2>&1) 2>/dev/null || true

fzf_args=(
  --multi
  --exact
  --cycle
  --delimiter=$'\t'
  --with-nth=2
  --accept-nth=1
  --prompt='preview> '
  --header='enter: play hovered in mpv | tab: mark | ctrl-s: stdout selected/current | alt-a/d: all/none | alt-r: reveal | ctrl-/: preview'
  --bind "enter:execute-silent($play_cmd)"
  --bind 'ctrl-s:accept'
  --bind 'alt-a:select-all'
  --bind 'alt-d:deselect-all'
  --bind 'ctrl-/:toggle-preview'
  --bind 'alt-p:toggle-preview'
  --bind "alt-r:$reveal_bind"
  --bind "ctrl-r:$reveal_bind"
  --preview="$preview_cmd"
  --preview-window='right,40%,wrap,border-left'
)

$print_color && fzf_args+=(--ansi)
$read0 && fzf_args+=(--read0)
$print0 && fzf_args+=(--print0)
fzf_args+=("${passthrough_args[@]}")

set +e
if $stream; then
  emit_fzf_input | sanitize_utf8 | {
    fzf "${fzf_args[@]}" > "$tmp_selected"
    print -r -- "$?" > "$tmp_fzf_status"
  }
  fzf_status="$(< "$tmp_fzf_status")"
  [[ -n "$fzf_status" ]] || fzf_status=1
else
  status_message "reading stdin before launching fzf (safe mode; use --stream for experimental live input)"
  build_fzf_input
  status_message "loaded $records_loaded item(s); launching fzf"
  fzf "${fzf_args[@]}" < "$tmp_lines" > "$tmp_selected"
  fzf_status=$?
fi
set -e

case "$fzf_status" in
  0) ;;
  1) exit 0 ;;
  130) exit 130 ;;
  *) exit "$fzf_status" ;;
esac

if [[ -s "$tmp_selected" ]]; then
  map_selection
fi
