#!/usr/bin/env zsh
emulate -L zsh
set -euo pipefail

script_name="${0:t}"

usage() {
  cat <<EOF
usage:
  $script_name [--preview [seconds]] [--trash-originals] file1 [file2 ...]
  $script_name --help

Pick a simple Topaz preset, then call:
  topaz-run [--preview [seconds]] [--trash-originals] --preset_name name --filter_complex filter [--output_ext ext] [--video_args args] [--metadata key=value] -- file1 [file2 ...]
EOF
}

(( $# == 0 )) && {
  usage >&2
  exit 1
}

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
esac

is_number() {
  [[ "${1:-}" == <-> || "${1:-}" == <->.<-> ]]
}

number_gt_zero() {
  awk -v v="$1" 'BEGIN { exit !(v > 0) }'
}

trash_originals=false
preview_mode=false
preview_seconds="1"
files=()

while (( $# > 0 )); do
  case "$1" in
    --preview=*)
      preview_mode=true
      preview_seconds="${1#--preview=}"
      shift
      ;;
    --preview)
      preview_mode=true
      if (( $# >= 2 )) && [[ "${2:-}" != -* ]] && is_number "$2"; then
        preview_seconds="$2"
        shift 2
      else
        shift
      fi
      ;;
    --trash-originals|--trash-original)
      trash_originals=true
      shift
      ;;
    --)
      shift
      files+=("$@")
      break
      ;;
    -*)
      print -u2 "unknown option: $1"
      usage >&2
      exit 1
      ;;
    *)
      files+=("$1")
      shift
      ;;
  esac
done

is_number "$preview_seconds" || {
  print -u2 -- "--preview length must be numeric seconds"
  exit 1
}
number_gt_zero "$preview_seconds" || {
  print -u2 -- "--preview length must be greater than 0"
  exit 1
}

(( ${#files[@]} > 0 )) || {
  usage >&2
  exit 1
}

for input in "${files[@]}"; do
  [[ -f "$input" ]] || {
    print -u2 "not a file: $input"
    exit 1
  }
done

command -v fzf >/dev/null 2>&1 || {
  print -u2 "fzf not found"
  exit 1
}

TOPAZ_RUN="${0:A:h}/topaz-run"
if command -v topaz-run >/dev/null 2>&1; then
  TOPAZ_RUN="$(command -v topaz-run)"
elif [[ ! -x "$TOPAZ_RUN" ]]; then
  print -u2 "topaz-run not found in PATH or next to $script_name: $TOPAZ_RUN"
  exit 1
fi

PRESET_CATALOG="${0:A:h}/topaz-preset-catalog.zsh"

[[ -r "$PRESET_CATALOG" ]] || {
  print -u2 "Topaz preset catalog not found: $PRESET_CATALOG"
  exit 1
}

source "$PRESET_CATALOG"

selection="$(
  topaz_preset_picker_rows simple |
    fzf \
      --prompt='󰎆 Topaz preset > ' \
      --delimiter=$'\t' \
      --with-nth=1 \
      --height=40% \
      --reverse \
      --border
)"

[[ -n "$selection" ]] || {
  print -u2 "no preset selected"
  exit 1
}

preset_name=""
preset_flag=""
filter_complex=""
output_ext=""
video_args=""
metadata=""

topaz_parse_preset_row "$selection"
preset_label="$TOPAZ_PRESET_DISPLAY"
preset_name="$TOPAZ_PRESET_NAME"
preset_flag="$TOPAZ_PRESET_FLAG"
filter_complex="$TOPAZ_PRESET_FILTER"
output_ext="$TOPAZ_PRESET_OUTPUT_EXT"
video_args="$TOPAZ_PRESET_VIDEO_ARGS"
metadata="$TOPAZ_PRESET_METADATA"

cmd_preview=(
  "$TOPAZ_RUN"
  --preset_name "$preset_name"
  "$preset_flag" "$filter_complex"
)

if [[ "$preview_mode" == true ]]; then
  cmd_preview+=(--preview "$preview_seconds")
fi
[[ "$trash_originals" == true ]] && cmd_preview+=(--trash-originals)
[[ -n "$output_ext" ]] && cmd_preview+=(--output_ext "$output_ext")
[[ -n "$video_args" ]] && cmd_preview+=(--video_args "$video_args")
[[ -n "$metadata" ]] && cmd_preview+=(--metadata "$metadata")

cmd_preview+=(-- "${files[@]}")

print -P -- "%F{cyan}󰏬%f preset: $preset_label"
print -P -- "%F{white}slug:%f   $preset_name"
print -P -- "%F{white}cmd:%f    ${(q+)cmd_preview}"
print

"${cmd_preview[@]}"
