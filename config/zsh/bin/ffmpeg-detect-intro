#!/usr/bin/env zsh
# ffmpeg-detect-intro
# Estimate black intro duration by sampling the first few seconds and
# checking whether most corner crops are dark.
#
# Heuristic:
# - sample frames from t=0 forward
# - crop four corners
# - compute average luma (YAVG) for each crop
# - mark frame as "black" if at least N corners are below threshold
# - intro length = last consecutive passing sample from start
# - fast-path: if nothing black is seen in the first early_window seconds,
#   assume there is no black intro and stop early
#
# Dependencies:
# - ffmpeg
# - ffprobe
# - awk
# - rg

emulate -L zsh
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ffmpeg-detect-intro <video-file> [scan_seconds] [step_seconds]

Examples:
  ffmpeg-detect-intro clip.mp4
  ffmpeg-detect-intro clip.mp4 5 0.1

Defaults:
  scan_seconds = 5
  step_seconds = 0.1
EOF
  exit 1
}

(( $# < 1 || $# > 3 )) && usage

video_file=$1
scan_seconds=${2:-5}
step_seconds=${3:-0.1}

[[ -f $video_file ]] || {
  print -u2 "error: file not found: $video_file"
  exit 1
}

for cmd in ffmpeg ffprobe awk rg; do
  command -v "$cmd" >/dev/null 2>&1 || {
    print -u2 "error: missing command: $cmd"
    exit 1
  }
done

video_info=$(
  ffprobe -v error \
    -select_streams v:0 \
    -show_entries stream=width,height \
    -of csv=p=0:s=x \
    -- "$video_file"
)

width=${video_info%x*}
height=${video_info#*x}

[[ -n ${width:-} && -n ${height:-} ]] || {
  print -u2 "error: could not read video dimensions"
  exit 1
}

crop_w=$(( width / 8 ))
crop_h=$(( height / 8 ))
(( crop_w < 16 )) && crop_w=16
(( crop_h < 16 )) && crop_h=16

# Average luma threshold.
# Y plane is typically 16..235 in limited range video.
y_threshold=24

# Require at least this many corners to be dark.
required_black_corners=3

# Early-exit window:
# if no black frame is found at all in this opening span,
# assume there is no black intro.
early_window=1.0

get_yavg() {
  local ts=$1
  local crop_expr=$2
  local out yavg

  out=$(
    ffmpeg -hide_banner -loglevel info \
      -ss "$ts" -i "$video_file" \
      -frames:v 1 -an \
      -vf "${crop_expr},signalstats,metadata=print" \
      -f null - 2>&1 || true
  )

  yavg=$(
    print -r -- "$out" |
      awk -F= '/lavfi.signalstats.YAVG=/ { print $2; exit }'
  )

  [[ -n $yavg ]] || return 1
  print -- "$yavg"
}

is_dark() {
  local value=$1
  awk -v v="$value" -v t="$y_threshold" 'BEGIN { exit !(v <= t) }'
}

sample_is_black() {
  local ts=$1
  local dark_count=0
  local y

  local corners=(
    "crop=${crop_w}:${crop_h}:0:0"
    "crop=${crop_w}:${crop_h}:iw-${crop_w}:0"
    "crop=${crop_w}:${crop_h}:0:ih-${crop_h}"
    "crop=${crop_w}:${crop_h}:iw-${crop_w}:ih-${crop_h}"
  )

  local crop_expr
  for crop_expr in "${corners[@]}"; do
    y=$(get_yavg "$ts" "$crop_expr") || continue
    if is_dark "$y"; then
      (( dark_count += 1 ))
    fi
  done

  (( dark_count >= required_black_corners ))
}

float_le() {
  awk -v a="$1" -v b="$2" 'BEGIN { exit !(a <= b + 1e-9) }'
}

float_add() {
  awk -v a="$1" -v b="$2" 'BEGIN { printf "%.3f\n", a + b }'
}

intro_end=0
started_black=false
seen_any_early_black=false
ts=0

print -- "file=$video_file"
print -- "scan_seconds=$scan_seconds"
print -- "step_seconds=$step_seconds"
print -- "corner_crop=${crop_w}x${crop_h}"
print -- "y_threshold=$y_threshold"
print -- "required_black_corners=$required_black_corners"
print -- "early_window=$early_window"

while float_le "$ts" "$scan_seconds"; do
  if sample_is_black "$ts"; then
    print -- "sample t=${ts} black=yes"

    if float_le "$ts" "$early_window"; then
      seen_any_early_black=true
    fi

    started_black=true
    intro_end=$ts
  else
    print -- "sample t=${ts} black=no"

    if [[ $started_black == true ]]; then
      break
    fi
  fi

  # Fast-path:
  # once we have finished checking the early window, if we have not seen
  # any black frame at all, stop immediately.
  if float_le "$early_window" "$ts" && [[ $seen_any_early_black == false ]]; then
    print -- "early_exit=no_black_detected_in_first_${early_window}s"
    print -- "intro_detected=no"
    print -- "intro_seconds=0"
    exit 1
  fi

  ts=$(float_add "$ts" "$step_seconds")
done

if [[ $started_black == true ]]; then
  print -- "intro_detected=yes"
  print -- "intro_seconds=$intro_end"
  exit 0
else
  print -- "intro_detected=no"
  print -- "intro_seconds=0"
  exit 1
fi
