#!/usr/bin/env zsh
# ============================================================================
# vdjstems-create — lossless VirtualDJ stem file from the CWD (pack wrapper)
# ============================================================================
#
# Convenience one-shot: packs the Demucs-style stem WAVs in the current
# directory (vocals/drums/bass/other, plus kick/hihat/mixed if present)
# into a lossless ALAC STANDALONE 6-track M4A (a self-contained library
# track). For a VDJ-native sidecar for an existing track, use
# vdjstems-pack --sidecar ORIGINAL instead.
#
# Everything is delegated to vdjstems-pack --lossless, which handles
# filename aliases, the drums → kick+hihat −6 dB fallback, the s32p master,
# parallel encoding, BPM measurement, and tagging. This wrapper only
# supplies the "current directory, lossless" defaults.
#
# Dependencies: vdjstems-pack (and its deps: ffmpeg, ffprobe, MP4Box)
# See also: vdjstems-split (make the input WAVs), vdjstems-pack (all
#           options incl. AAC, --bpm/--key, --standalone/--sidecar)
# ============================================================================
set -euo pipefail
SELF="${0:t}"

usage() {
  cat <<EOF
Usage: $SELF [OUTPUT.m4a]
Packs vocals/drums/bass/other WAVs from the CWD into a lossless
STANDALONE 6-track M4A (default: "<cwd name>-stems.m4a").
For a VDJ-native sidecar: vdjstems-pack --sidecar ORIGINAL <stemdir>
All other options: see vdjstems-pack --help
EOF
  exit 2
}
[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && usage

command -v vdjstems-pack >/dev/null 2>&1 || { print -u2 "ERROR: vdjstems-pack not found"; exit 1; }

if (( $# )); then
  exec vdjstems-pack --lossless --out "$1" "$PWD"
else
  exec vdjstems-pack --lossless "$PWD"
fi
