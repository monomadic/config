#!/bin/zsh
# ==============================================================================
# sort-vdj-pad-pages.zsh
#
# Sort VirtualDJ's padsPagesOrder setting alphabetically in settings.xml.
#
# Usage:
#   sort-vdj-pad-pages.zsh
#   sort-vdj-pad-pages.zsh --dry-run
#   sort-vdj-pad-pages.zsh --force
#   sort-vdj-pad-pages.zsh --settings "$HOME/Library/Application Support/VirtualDJ/settings.xml"
#
# Notes:
#   - Quit VirtualDJ first. Use --force only if you know what you're doing.
#   - A timestamped .bak copy is created before writing.
# ==============================================================================

emulate -L zsh
set -euo pipefail

dry_run=0
force=0
settings_file=""

while (( $# )); do
  case "$1" in
    --dry-run)
      dry_run=1
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    --settings)
      settings_file="${2:-}"
      shift 2
      ;;
    -h|--help)
      sed -n '1,32p' "$0"
      exit 0
      ;;
    *)
      print -u2 "Unknown argument: $1"
      exit 2
      ;;
  esac
done

# ── Locate settings.xml ────────────────────────────────────────────────────────

candidate_files=(
  "$HOME/Library/Application Support/VirtualDJ/settings.xml"
  "$HOME/Documents/VirtualDJ/settings.xml"
)

if [[ -z "$settings_file" ]]; then
  for candidate_file in "${candidate_files[@]}"; do
    if [[ -f "$candidate_file" ]]; then
      settings_file="$candidate_file"
      break
    fi
  done
fi

if [[ -z "$settings_file" || ! -f "$settings_file" ]]; then
  print -u2 "✘ Could not find VirtualDJ settings.xml"
  print -u2 "  Tried:"
  for candidate_file in "${candidate_files[@]}"; do
    print -u2 "  - $candidate_file"
  done
  print -u2 ""
  print -u2 "Pass it manually with:"
  print -u2 "  $0 --settings /path/to/settings.xml"
  exit 1
fi

# ── Refuse to edit while VirtualDJ is running ──────────────────────────────────

if (( ! force )); then
  if pgrep -x "VirtualDJ" >/dev/null 2>&1 || pgrep -f "VirtualDJ.app" >/dev/null 2>&1; then
    print -u2 "✘ VirtualDJ appears to be running."
    print -u2 "  Quit VirtualDJ first, or rerun with --force."
    exit 1
  fi
fi

# ── Work in Ruby because it ships on macOS and handles XML escaping cleanly ─────

ruby_script='
require "rexml/document"
require "rexml/xpath"
require "time"

settings_path = ARGV.fetch(0)
dry_run = ARGV.fetch(1) == "1"

xml = File.read(settings_path, mode: "rb")
doc = REXML::Document.new(xml)

# VirtualDJ settings.xml has appeared in a few shapes over the years.
# Support the common variants defensively:
#
#   <settings padsPagesOrder="A,B,C" .../>
#   <setting name="padsPagesOrder" value="A,B,C"/>
#   <padsPagesOrder>A,B,C</padsPagesOrder>
#
targets = []

doc.elements.each("//*") do |el|
  if el.attributes.key?("padsPagesOrder")
    targets << [:attribute_direct, el, "padsPagesOrder", el.attributes["padsPagesOrder"]]
  end

  if el.name == "setting" && el.attributes["name"] == "padsPagesOrder" && el.attributes.key?("value")
    targets << [:setting_value, el, "value", el.attributes["value"]]
  end

  if el.name == "padsPagesOrder"
    targets << [:element_text, el, nil, el.text.to_s]
  end
end

if targets.empty?
  warn "✘ Could not find padsPagesOrder in #{settings_path}"
  exit 1
end

kind, node, attr_name, old_value = targets.first

items =
  old_value
    .split(",")
    .map { |s| s.strip }
    .reject(&:empty?)

if items.empty?
  warn "✘ padsPagesOrder exists, but it appears to be empty."
  exit 1
end

sorted = items.sort_by { |s| s.downcase }

if sorted == items
  puts "✓ padsPagesOrder is already sorted."
  puts
  puts old_value
  exit 0
end

new_value = sorted.join(",")

puts "File: #{settings_path}"
puts
puts "Before:"
puts old_value
puts
puts "After:"
puts new_value
puts

if dry_run
  puts "Dry run only; no changes written."
  exit 0
end

backup_path = "#{settings_path}.bak.#{Time.now.strftime("%Y%m%d-%H%M%S")}"
File.write(backup_path, xml, mode: "wb")

case kind
when :attribute_direct, :setting_value
  node.attributes[attr_name] = new_value
when :element_text
  node.text = new_value
end

formatter = REXML::Formatters::Default.new
out = +""
formatter.write(doc, out)

File.write(settings_path, out, mode: "wb")

puts "✓ Backup written:"
puts backup_path
puts
puts "✓ Updated padsPagesOrder."
'

ruby -e "$ruby_script" "$settings_file" "$dry_run"
