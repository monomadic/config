#!/bin/zsh
# Open Helix with a temporary Kitty tab title/color when available.

target="hx"
if (( $# > 0 )); then
  target="${argv[-1]}"
fi

if [[ "$target" == -* || "$target" == +* ]]; then
  base="hx"
else
  base="${target:A:t}"
fi

if [[ -z ${KITTY_WINDOW_ID:-} && -z ${KITTY_LISTEN_ON:-} ]]; then
  exec hx "$@"
fi

exec kitty-exec " $base" "#04F273" hx "$@"
