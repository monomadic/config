#!/bin/zsh
# Open Helix with a temporary Kitty tab title/color when available.

target="hx"
skip_next=0
for arg in "$@"; do
  if (( skip_next )); then
    skip_next=0
    continue
  fi

  case "$arg" in
    -c|--config|--log|-w|--working-dir)
      skip_next=1
      ;;
    --config=*|--log=*|--working-dir=*|--health*|-g|--grammar|--tutor|--vsplit|--hsplit|-h|--help|-V|--version|-v|+*)
      ;;
    -*)
      ;;
    *)
      target="$arg"
      break
      ;;
  esac
done

if [[ "$target" == -* || "$target" == +* ]]; then
  base="hx"
else
  base="${target:A:t}"
  base="${base%%:[0-9]*}"
fi

if [[ -z ${KITTY_WINDOW_ID:-} && -z ${KITTY_LISTEN_ON:-} ]]; then
  exec hx "$@"
fi

exec kitty-exec " $base" "#04F273" hx "$@"
