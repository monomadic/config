#!/usr/bin/env zsh
#
#   media-index — manage the media index: a newline-delimited list of file
#   paths stored at $MEDIA_INDEX (default: $TMPDIR/media-index.cache).
#
#   This tool is ONLY concerned with the index. Building it and consuming it
#   live elsewhere, e.g.:
#       fd-media --sort created --progress | media-index write
#       media-index read | fzf-metaselect --persistent
#
#   Commands:
#     write          Replace the index with the paths read on stdin
#     read           Print the index to stdout
#     insert PATH... Append path(s) to the index
#     prune          Drop entries whose file no longer exists

set -u

script_name="${0:t}"
index_file="${MEDIA_INDEX:-${TMPDIR:-/tmp}/media-index.cache}"

die() {
  print -u2 -- "$script_name: $*"
  exit 1
}

usage() {
  print -u2 -- "Usage: $script_name <write|read|insert|prune> [args]"
  print -u2 -- ""
  print -u2 -- "Manage the media index ($index_file)."
  print -u2 -- ""
  print -u2 -- "Commands:"
  print -u2 -- "  write          Replace the index with the paths read on stdin"
  print -u2 -- "  read           Print the index to stdout"
  print -u2 -- "  insert PATH... Append path(s) to the index"
  print -u2 -- "  prune          Drop entries whose file no longer exists"
  print -u2 -- ""
  print -u2 -- "Examples:"
  print -u2 -- "  fd-media --sort created --progress | $script_name write"
  print -u2 -- "  $script_name read | fzf-metaselect --persistent"
  print -u2 -- "  $script_name insert /Movies/clip.mp4"
  print -u2 -- "  $script_name prune"
}

cmd_write() {
  local tmp
  tmp="$(mktemp -t media-index.XXXXXX)" || die "could not create temp file"
  cat > "$tmp"
  if [[ ! -s "$tmp" ]]; then
    rm -f -- "$tmp"
    die "refusing to write an empty index (nothing on stdin)"
  fi
  mv -f -- "$tmp" "$index_file"
}

cmd_read() {
  [[ -f "$index_file" ]] || return 0
  cat -- "$index_file"
}

cmd_insert() {
  (( $# > 0 )) || die "insert: need at least one path"
  print -rl -- "$@" >> "$index_file"
}

cmd_prune() {
  [[ -f "$index_file" ]] || return 0
  local tmp line kept=0 removed=0
  tmp="$(mktemp -t media-index.XXXXXX)" || die "could not create temp file"
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" ]] && continue
    if [[ -e "$line" ]]; then
      print -r -- "$line"
      (( ++kept ))
    else
      (( ++removed ))
    fi
  done < "$index_file" > "$tmp"
  mv -f -- "$tmp" "$index_file"
  print -u2 -- "pruned $removed missing, kept $kept"
}

(( $# > 0 )) || { usage; exit 1; }
cmd="$1"; shift

case "$cmd" in
  write) cmd_write "$@" ;;
  read)  cmd_read  "$@" ;;
  insert) cmd_insert "$@" ;;
  prune) cmd_prune "$@" ;;
  -h|--help|help) usage ;;
  *) die "unknown command: $cmd (try: write, read, insert, prune)" ;;
esac
