#!/usr/bin/env zsh
# gc
#
# AI-powered git commits using Codex + Gum.
#
# Usage:
#   gc
#   gc --multi
#   gc --staged-only
#   gc --multi --staged-only

emulate -L zsh
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  gc [options]

Options:
  --multi    Generate a multiline conventional commit message
  --staged-only
             Commit only already-staged changes
  -h, --help Show this help

Examples:
  gc
  gc --multi
  gc --staged-only
  gc --multi --staged-only
EOF
}

die() {
  gum style --foreground 196 --bold "✘ $*"
  exit 1
}

info() {
  gum style --foreground 81 --bold "◆ $*"
}

ok() {
  gum style --foreground 82 --bold "✓ $*"
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "Missing dependency: $1"
}

build_prompt() {
  local diff_file=$1
  local previous_message=${2:-}

  if [[ -n "$previous_message" ]]; then
    cat <<EOF
Generate a better conventional commit message for this git diff.

The previous message was not satisfactory:

$previous_message

Improve it. Be more accurate, specific, and useful.

$(prompt_rules)

Git diff:

$(cat "$diff_file")
EOF
  else
    cat <<EOF
Generate a conventional commit message for this git diff.

$(prompt_rules)

Git diff:

$(cat "$diff_file")
EOF
  fi
}

prompt_rules() {
  if [[ "${GC_MULTI:-false}" == "true" ]]; then
    cat <<'EOF'
Format:

<type>[optional scope]: <short summary>

<body>

Rules:
- Return only the commit message.
- No markdown.
- No code fences.
- No explanation outside the commit message.
- First line must be conventional commit format.
- First line should be under 80 characters.
- Body should be 1-4 bullet points.
- Body should explain meaningful changes, not restate filenames.
- Use present tense.
- Use types like feat, fix, refactor, chore, docs, test, build, ci, perf.
- Add BREAKING CHANGE footer only if the diff clearly introduces one.
EOF
  else
    cat <<'EOF'
Rules:
- Return only the commit message.
- No markdown.
- No code fences.
- No explanation.
- One line only.
- Use format: <type>[optional scope]: <summary>
- Keep under 80 characters if possible.
- Use types like feat, fix, refactor, chore, docs, test, build, ci, perf.
EOF
  fi
}

generate_message() {
  local diff_file=$1
  local output_file=$2
  local previous_message=${3:-}

  local prompt_file="${output_file}.prompt"

  build_prompt "$diff_file" "$previous_message" > "$prompt_file"

  : > "$output_file"

  if ! gum spin \
    --spinner dot \
    --title "Thinking..." \
    -- \
    codex exec \
      --output-last-message "$output_file" \
      - < "$prompt_file"
  then
    die "Codex failed"
  fi

  [[ -s "$output_file" ]] || die "Codex returned an empty message"
}

show_message() {
  local msg_file=$1

  gum style \
    --border rounded \
    --border-foreground 63 \
    --padding "0 1" \
    --width 100 \
    "$(<"$msg_file")"
}

edit_message() {
  local msg_file=$1
  local editor_cmd=${EDITOR:-vim}

  "$editor_cmd" "$msg_file"

  [[ -s "$msg_file" ]] || die "Commit cancelled: empty message"
}

commit_now() {
  local msg_file=$1
  local should_push=$2

  print
  git diff --cached --stat
  print

  git commit -F "$msg_file"

  ok "Committed"

  if [[ "$should_push" == "true" ]]; then
    info "Pushing"
    git push
    ok "Pushed"
  fi
}

main() {
  need git
  need gum
  need codex

  local staged_only=false
  export GC_MULTI=false

  while (( $# )); do
    case "$1" in
      --multi)
        export GC_MULTI=true
        ;;
      --staged-only)
        staged_only=true
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
    shift
  done

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || die "Not inside a git repository"

  cd "$repo_root"

  local flags=()
  [[ "$GC_MULTI" == "true" ]] && flags+=(multi) || flags+=(single)
  $staged_only && flags+=(staged-only) || flags+=(stage)

  gum style \
    --border rounded \
    --padding "0 1" \
    --border-foreground 63 \
    --bold \
    "󰊢 git commit · ${repo_root:t} · ${(j: :)flags}"

  if ! $staged_only; then
    info "Staging all changes"
    git add -A
  fi

  git diff --cached --quiet && die "No staged changes"

  local work_dir
  work_dir=$(mktemp -d)

  {
    local diff_file="$work_dir/diff.patch"
    local msg_file="$work_dir/message.txt"

    git diff --cached > "$diff_file"

    info "Generating commit message"
    generate_message "$diff_file" "$msg_file"

    while true; do
      show_message "$msg_file"

      local action
      action=$(
        gum choose \
          --cursor "› " \
          --selected-prefix "● " \
          --unselected-prefix "○ " \
          "edit" \
          "regenerate" \
          "commit" \
          "commit + push"
      )

      case "$action" in
        edit)
          edit_message "$msg_file"
          ;;
        regenerate)
          local previous_message
          previous_message=$(<"$msg_file")

          info "Regenerating commit message"
          generate_message "$diff_file" "$msg_file" "$previous_message"
          ;;
        commit)
          commit_now "$msg_file" false
          break
          ;;
        "commit + push")
          commit_now "$msg_file" true
          break
          ;;
        *)
          die "Commit cancelled"
          ;;
      esac
    done

  } always {
    rm -rf "$work_dir"
  }
}

main "$@"
