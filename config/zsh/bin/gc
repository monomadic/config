#!/usr/bin/env zsh
# gc
#
# AI-powered git commits using Codex or Claude + Gum.
#
# Usage:
#   gc
#   gc --multi
#   gc --staged-only
#   gc --claude
#   gc --codex
#   gc --multi --staged-only --claude

emulate -L zsh
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  gc [options]

Options:
  --multi    Generate a multiline conventional commit message
  --staged-only
             Commit only already-staged changes
  --codex    Use Codex to generate the message (default)
  --claude   Use Claude to generate the message
  -h, --help Show this help

Environment variables:
  GC_BACKEND              codex|claude (default: codex)
  GC_REASONING            Codex reasoning effort (default: low)
  GC_CLAUDE_MODEL         Claude model to use (default: claude-haiku-4-5-20251001)

Examples:
  gc
  gc --multi
  gc --staged-only
  gc --claude
  gc --multi --staged-only
  GC_CLAUDE_MODEL=claude-opus-4-8 gc --claude
EOF
}

die() {
  gum style --foreground 196 --bold "✘ $*"
  exit 1
}

info() {
  gum style --foreground 81 --bold "◆ $*"
}

ok() {
  gum style --foreground 82 --bold "✓ $*"
}

warn() {
  gum style --foreground 214 --bold "▲ $*"
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "Missing dependency: $1"
}

build_prompt() {
  local diff_file=$1
  local previous_message=${2:-}

  if [[ -n "$previous_message" ]]; then
    cat <<EOF
Generate a better conventional commit message for this git diff.

The previous message was not satisfactory:

$previous_message

Improve it. Be more accurate, specific, and useful.

$(prompt_rules)

Git diff:

$(cat "$diff_file")
EOF
  else
    cat <<EOF
Generate a conventional commit message for this git diff.

$(prompt_rules)

Git diff:

$(cat "$diff_file")
EOF
  fi
}

prompt_rules() {
  if [[ "${GC_MULTI:-false}" == "true" ]]; then
    cat <<'EOF'
Format:

<type>[optional scope]: <short summary>

<body>

Rules:
- Return only the commit message.
- No markdown.
- No code fences.
- No explanation outside the commit message.
- First line must be conventional commit format.
- First line should be under 80 characters.
- Body should be 1-4 bullet points.
- Body should explain meaningful changes, not restate filenames.
- Use present tense.
- Use types like feat, fix, refactor, chore, docs, test, build, ci, perf.
- Add BREAKING CHANGE footer only if the diff clearly introduces one.
EOF
  else
    cat <<'EOF'
Rules:
- Return only the commit message.
- No markdown.
- No code fences.
- No explanation.
- One line only.
- Use format: <type>[optional scope]: <summary>
- Keep under 80 characters if possible.
- Use types like feat, fix, refactor, chore, docs, test, build, ci, perf.
EOF
  fi
}

generate_message() {
  local diff_file=$1
  local output_file=$2
  local previous_message=${3:-}

  local prompt_file="${output_file}.prompt"

  build_prompt "$diff_file" "$previous_message" > "$prompt_file"

  : > "$output_file"

  case "${GC_BACKEND:-codex}" in
    claude)
      local err_file="${output_file}.err"
      # When gc is invoked from inside a Claude Code session, the parent
      # injects session env (nested-session guard, staging OAuth, proxy
      # base URL) that makes a plain `claude` refuse to run or hit a 401.
      # Strip that env so claude authenticates as a normal standalone CLI.
      local claude_env=(
        CLAUDECODE
        CLAUDE_CODE_ENTRYPOINT
        CLAUDE_CODE_SESSION_ID
        CLAUDE_CODE_CHILD_SESSION
        CLAUDE_CODE_EXECPATH
        CLAUDE_AGENT_SDK_VERSION
        CLAUDE_CODE_OAUTH_SCOPES
        CLAUDE_CODE_SDK_HAS_OAUTH_REFRESH
        CLAUDE_CODE_SDK_HAS_HOST_AUTH_REFRESH
        ANTHROPIC_BASE_URL
        USE_STAGING_OAUTH
        USE_LOCAL_OAUTH
      )
      if ! gum spin \
        --spinner dot \
        --title "Thinking..." \
        -- \
        zsh -c "env ${(j: :)${(@)claude_env/#/-u }} claude --print --model ${GC_CLAUDE_MODEL:-claude-haiku-4-5-20251001} < ${(q)prompt_file} > ${(q)output_file} 2> ${(q)err_file}"
      then
        die "Claude failed: $(<"$err_file")$(<"$output_file")"
      fi
      [[ -s "$output_file" ]] || die "Claude returned an empty message"
      ;;
    codex)
      # Writing a one-line commit message needs no deep reasoning. The user's
      # global ~/.codex/config.toml may set a high reasoning effort, which makes
      # every message slow to generate; override it low here just for gc.
      # ("minimal" is rejected when web_search/image_gen tools are enabled.)
      if ! gum spin \
        --spinner dot \
        --title "Thinking..." \
        -- \
        codex exec \
          -c model_reasoning_effort="${GC_REASONING:-low}" \
          --output-last-message "$output_file" \
          - < "$prompt_file"
      then
        die "Codex failed"
      fi
      [[ -s "$output_file" ]] || die "Codex returned an empty message"
      ;;
    *)
      die "Unknown backend: ${GC_BACKEND}"
      ;;
  esac
}

show_message() {
  local msg_file=$1

  gum style \
    --border rounded \
    --border-foreground 63 \
    --padding "0 1" \
    --width 100 \
    "$(<"$msg_file")"
}

edit_message() {
  local msg_file=$1
  local editor_cmd=${EDITOR:-vim}

  "$editor_cmd" "$msg_file"

  [[ -s "$msg_file" ]] || die "Commit cancelled: empty message"
}

commit_now() {
  local msg_file=$1

  print
  git diff --cached --stat
  print

  git commit -F "$msg_file"

  ok "Committed"
}

rebase_in_progress() {
  local git_dir
  git_dir=$(git rev-parse --git-dir)
  [[ -d "$git_dir/rebase-merge" || -d "$git_dir/rebase-apply" ]]
}

has_conflicts() {
  [[ -n "$(git diff --name-only --diff-filter=U)" ]]
}

push_now() {
  info "Pushing"
  git push
  ok "Pushed"
}

# Ask the configured backend to edit the currently-conflicted files in place.
# Its only job is to remove the conflict markers — staging and continuing the
# rebase is handled by resolve_rebase_with_ai, not the model.
ai_resolve_conflicts() {
  local files
  files=$(git diff --name-only --diff-filter=U)

  local prompt
  prompt=$(cat <<EOF
Resolve the git merge conflicts in this repository.

These files contain conflict markers (<<<<<<<, |||||||, =======, >>>>>>>):
$files

Edit each file in place to produce a correct merge that preserves the intent of
both sides, removing every conflict marker. Do not run git commands, do not
stage, do not commit — only edit the files.
EOF
)

  local rc=0
  case "$GC_BACKEND" in
    claude)
      # Same session-env strip as generate_message so claude authenticates as a
      # standalone CLI. acceptEdits lets it write files without prompting.
      local -a unset_args
      local v
      for v in \
        CLAUDECODE CLAUDE_CODE_ENTRYPOINT CLAUDE_CODE_SESSION_ID \
        CLAUDE_CODE_CHILD_SESSION CLAUDE_CODE_EXECPATH CLAUDE_AGENT_SDK_VERSION \
        CLAUDE_CODE_OAUTH_SCOPES CLAUDE_CODE_SDK_HAS_OAUTH_REFRESH \
        CLAUDE_CODE_SDK_HAS_HOST_AUTH_REFRESH ANTHROPIC_BASE_URL \
        USE_STAGING_OAUTH USE_LOCAL_OAUTH
      do
        unset_args+=(-u "$v")
      done
      gum spin --spinner dot --title "Resolving conflicts..." -- \
        env "${unset_args[@]}" \
          claude --print --permission-mode acceptEdits "$prompt" \
        || rc=$?
      ;;
    codex)
      gum spin --spinner dot --title "Resolving conflicts..." -- \
        codex exec -s workspace-write -c approval_policy="never" "$prompt" \
        || rc=$?
      ;;
  esac

  return $rc
}

# Drive a conflicted rebase to completion with the AI: resolve markers, stage,
# continue, and repeat for each commit the rebase replays.
resolve_rebase_with_ai() {
  while rebase_in_progress; do
    if has_conflicts; then
      local files
      files=$(git diff --name-only --diff-filter=U)
      info "Resolving conflicts: ${files//$'\n'/, }"

      ai_resolve_conflicts || return 1

      if has_conflicts; then
        return 1   # backend left markers behind — bail to manual
      fi

      git add -A
      GIT_EDITOR=true git rebase --continue >/dev/null 2>&1 || true
    else
      # Mid-rebase with nothing to merge: the replayed commit became empty
      # (its change is already upstream), so drop it and carry on.
      GIT_EDITOR=true git rebase --skip >/dev/null 2>&1 || return 1
    fi
  done

  return 0
}

# Commit, rebase onto the remote, then push. On conflict, offer AI or manual.
sync_repo() {
  info "Syncing with remote (pull --rebase)"

  if git pull --rebase --autostash; then
    push_now
    return
  fi

  # pull --rebase exited non-zero. Only a genuine rebase conflict is something
  # we can offer to resolve; anything else (no upstream, network) is the user's.
  if ! rebase_in_progress || ! has_conflicts; then
    die "Sync failed — resolve manually, then push (see 'git status')"
  fi

  warn "Merge conflicts while rebasing onto the remote:"
  git diff --name-only --diff-filter=U | sed 's/^/  • /'

  local choice
  choice=$(
    gum choose \
      --cursor "› " \
      --selected-prefix "● " \
      --unselected-prefix "○ " \
      --header "Resolve conflicts:" \
      "automatically (AI)" \
      "manually (exit)"
  )

  if [[ "$choice" != "automatically (AI)" ]]; then
    info "Stopping so you can resolve manually."
    info "When done:  git rebase --continue  &&  git push"
    exit 0
  fi

  resolve_rebase_with_ai \
    || die "AI could not finish the rebase — resolve manually (see 'git status')"

  ok "Conflicts resolved, rebase complete"
  push_now
}

commit_and_sync() {
  local msg_file=$1

  commit_now "$msg_file"
  sync_repo
}

main() {
  need git
  need gum

  local staged_only=false
  export GC_MULTI=false
  export GC_BACKEND=${GC_BACKEND:-codex}

  while (( $# )); do
    case "$1" in
      --multi)
        export GC_MULTI=true
        ;;
      --staged-only)
        staged_only=true
        ;;
      --codex)
        export GC_BACKEND=codex
        ;;
      --claude)
        export GC_BACKEND=claude
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
    shift
  done

  case "$GC_BACKEND" in
    codex)  need codex ;;
    claude) need claude ;;
    *)      die "Unknown backend: $GC_BACKEND" ;;
  esac

  local repo_root
  repo_root=$(git rev-parse --show-toplevel 2>/dev/null) \
    || die "Not inside a git repository"

  cd "$repo_root"

  local flags=("$GC_BACKEND")
  [[ "$GC_MULTI" == "true" ]] && flags+=(multi) || flags+=(single)
  $staged_only && flags+=(staged-only) || flags+=(stage)

  gum style \
    --border rounded \
    --padding "0 1" \
    --border-foreground 63 \
    --bold \
    "󰊢 git commit · ${repo_root:t} · ${(j: :)flags}"

  if ! $staged_only; then
    info "Staging all changes"
    git add -A
  fi

  git diff --cached --quiet && die "No staged changes"

  local work_dir
  work_dir=$(mktemp -d)

  {
    local diff_file="$work_dir/diff.patch"
    local msg_file="$work_dir/message.txt"

    git diff --cached > "$diff_file"

    info "Generating commit message"
    generate_message "$diff_file" "$msg_file"

    while true; do
      show_message "$msg_file"

      local action
      action=$(
        gum choose \
          --cursor "› " \
          --selected-prefix "● " \
          --unselected-prefix "○ " \
          "commit and sync" \
          "edit commit message" \
          "commit only" \
          "regenerate commit message"
      )

      case "$action" in
        "commit and sync")
          commit_and_sync "$msg_file"
          break
          ;;
        "edit commit message")
          edit_message "$msg_file"
          ;;
        "commit only")
          commit_now "$msg_file"
          break
          ;;
        "regenerate commit message")
          local previous_message
          previous_message=$(<"$msg_file")

          info "Regenerating commit message"
          generate_message "$diff_file" "$msg_file" "$previous_message"
          ;;
        *)
          die "Commit cancelled"
          ;;
      esac
    done

  } always {
    rm -rf "$work_dir"
  }
}

main "$@"
