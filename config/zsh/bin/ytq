#!/usr/bin/env zsh
# -----------------------------------------------------------------------------
# ytq - yt-dlp queue manager
#
# Environment:
#   export YT_DLP_BATCH_FILE=~/.local/share/yt-dlp/queue.txt
#   export YT_DLP_ARCHIVE_FILE=~/.local/share/yt-dlp/archive.txt
#   export YT_DLP_JSON_DIR=~/.local/share/yt-dlp/json
#
# Examples:
#   ytq add https://youtu.be/foo
#   ytq next https://youtu.be/bar
#   ytq addclip
#   ytq queue
#   ytq list
#   ytq run
# -----------------------------------------------------------------------------

setopt pipefail

typeset -r YTQ_SELF="${0:A}"

require_batch_file() {
  if [[ -z "${YT_DLP_BATCH_FILE:-}" ]]; then
    print -u2 "❌ YT_DLP_BATCH_FILE is not set"
    exit 1
  fi

  mkdir -p "${YT_DLP_BATCH_FILE:h}"
  touch "$YT_DLP_BATCH_FILE"
}

require_command() {
  local cmd="$1"

  command -v "$cmd" >/dev/null 2>&1 || {
    print -u2 "❌ Missing dependency: $cmd"
    exit 1
  }
}

is_url() {
  [[ "$1" =~ '^https?://[^[:space:]]+$' ]]
}

youtube_id_from_url() {
  local url="$1"

  if [[ "$url" =~ 'youtu\.be/([A-Za-z0-9_-]{11})' ]]; then
    print -r -- "$match[1]"
    return 0
  fi

  if [[ "$url" =~ 'youtube(-nocookie)?\.com/(shorts|embed|live|v)/([A-Za-z0-9_-]{11})' ]]; then
    print -r -- "$match[3]"
    return 0
  fi

  if [[ "$url" =~ '[?&]v=([A-Za-z0-9_-]{11})' ]]; then
    print -r -- "$match[1]"
    return 0
  fi

  return 1
}

archive_key_for_url() {
  local url="$1"
  local video_id

  if video_id="$(youtube_id_from_url "$url" 2>/dev/null)"; then
    print -r -- "youtube $video_id"
    return 0
  fi

  if video_id="$(faphouse_id_from_url "$url" 2>/dev/null)"; then
    print -r -- "faphouse $video_id"
    return 0
  fi

  return 1
}

faphouse_id_from_url() {
  local url="$1"

  if [[ "$url" =~ 'faphouse\.com/([a-z]{2}(-[a-z]{2})?/)?(videos?|watch)/([^/?#&]+)' ]]; then
    print -r -- "$match[4]"
    return 0
  fi

  return 1
}

load_archive() {
  typeset -gA ARCHIVED
  ARCHIVED=()

  [[ -n "${YT_DLP_ARCHIVE_FILE:-}" && -r "$YT_DLP_ARCHIVE_FILE" ]] || return 0

  local line
  while IFS= read -r line; do
    [[ -n "$line" ]] && ARCHIVED[$line]=1
  done < "$YT_DLP_ARCHIVE_FILE"
}

is_archived_url() {
  local url="$1"
  local archive_key

  [[ -n "${YT_DLP_ARCHIVE_FILE:-}" && -r "$YT_DLP_ARCHIVE_FILE" ]] || return 1

  archive_key="$(archive_key_for_url "$url" 2>/dev/null)" || archive_key=""

  if [[ -n "$archive_key" && -n "${ARCHIVED[$archive_key]:-}" ]]; then
    return 0
  fi

  [[ -n "${ARCHIVED[$url]:-}" ]]
}

load_queue() {
  typeset -gA QUEUED

  local line
  while IFS= read -r line; do
    [[ -n "$line" ]] && QUEUED[$line]=1
  done < "$YT_DLP_BATCH_FILE"
}

cmd_add() {
  require_batch_file
  load_queue

  (( $# > 0 )) || {
    print -u2 "Usage: ytq add <url> [url ...]"
    exit 1
  }

  local added=0
  local skipped=0
  local url

  for url in "$@"; do
    if ! is_url "$url"; then
      print -u2 "❌ Invalid URL: $url"
      ((skipped++))
      continue
    fi

    if [[ -n ${QUEUED[$url]} ]]; then
      print "⚠️  Already queued: $url"
      ((skipped++))
      continue
    fi

    print -r -- "$url" >> "$YT_DLP_BATCH_FILE"
    QUEUED[$url]=1

    print "➕ Added: $url"
    ((added++))
  done

  print ""
  print "Added:   $added"
  print "Skipped: $skipped"
}

cmd_next() {
  require_batch_file

  (( $# > 0 )) || {
    print -u2 "Usage: ytq next <url> [url ...]"
    exit 1
  }

  local tmp_file
  tmp_file="$(mktemp)" || exit 1

  local url
  local added=0
  local skipped=0

  {
    for url in "$@"; do
      if ! is_url "$url"; then
        print -u2 "❌ Invalid URL: $url"
        ((skipped++))
        continue
      fi

      print -r -- "$url"
      [[ -w /dev/tty ]] && print "⬆️  Prioritized: $url" > /dev/tty
      ((added++))
    done

    while IFS= read -r line; do
      local keep=1

      for url in "$@"; do
        [[ "$line" == "$url" ]] && keep=0 && break
      done

      (( keep )) && print -r -- "$line"
    done < "$YT_DLP_BATCH_FILE"

  } > "$tmp_file"

  mv "$tmp_file" "$YT_DLP_BATCH_FILE"

  print ""
  print "Prioritized: $added"
  print "Skipped:     $skipped"
}

cmd_addclip() {
  local clip
  clip="$(pbpaste)"

  [[ -n "$clip" ]] || {
    print -u2 "❌ Clipboard is empty"
    exit 1
  }

  cmd_add ${(f)clip}
}

cmd_queue() {
  require_batch_file

  if [[ ! -s "$YT_DLP_BATCH_FILE" ]]; then
    print "📭 Queue is empty"
    return
  fi

  nl -ba "$YT_DLP_BATCH_FILE"
}

queue_list_item() {
  local url="$1"

  if is_archived_url "$url"; then
    printf '%s\t\033[32m✓\033[0m \033[2m%s\033[0m\n' "$url" "$url"
  else
    printf '%s\t\033[34m▶\033[0m %s\n' "$url" "$url"
  fi
}

ytq_cache_dir() {
  print -r -- "${XDG_CACHE_HOME:-$HOME/.cache}/ytq"
}

url_cache_key() {
  printf 'ytq-preview-v4\n%s' "$1" | shasum -a 256 | awk '{print $1}'
}

ytq_json_dir() {
  [[ -n "${YT_DLP_JSON_DIR:-}" ]] || return 1
  print -r -- "${~YT_DLP_JSON_DIR}"
}

metadata_json_candidates() {
  local url="$1"
  local dir="$2"
  local video_id

  if video_id="$(youtube_id_from_url "$url" 2>/dev/null)"; then
    print -r -- "$dir/youtube_${video_id}.info.json"
  fi

  if video_id="$(faphouse_id_from_url "$url" 2>/dev/null)"; then
    print -r -- "$dir/faphouse_${video_id}.info.json"
  fi
}

metadata_json_matches_url() {
  local json="$1"
  local url="$2"
  local url_no_fragment="${url%%#*}"
  local youtube_id faphouse_id

  command -v jq >/dev/null 2>&1 || return 1

  youtube_id="$(youtube_id_from_url "$url" 2>/dev/null)" || youtube_id=""
  faphouse_id="$(faphouse_id_from_url "$url" 2>/dev/null)" || faphouse_id=""

  jq -e \
    --arg url "$url" \
    --arg url_no_fragment "$url_no_fragment" \
    --arg youtube_id "$youtube_id" \
    --arg faphouse_id "$faphouse_id" '
      def extractor:
        ((.extractor_key // .extractor // "") | tostring | ascii_downcase);

      (.webpage_url? == $url)
      or (.original_url? == $url)
      or (.webpage_url? == $url_no_fragment)
      or (.original_url? == $url_no_fragment)
      or ($youtube_id != "" and (.id? == $youtube_id) and extractor == "youtube")
      or ($faphouse_id != "" and (.id? == $faphouse_id) and extractor == "faphouse")
    ' "$json" >/dev/null 2>&1
}

find_cached_metadata_json() {
  local url="$1"
  local dir candidate file
  local -a candidates

  dir="$(ytq_json_dir 2>/dev/null)" || return 1
  [[ -d "$dir" ]] || return 1

  candidates=("${(@f)$(metadata_json_candidates "$url" "$dir")}")
  for candidate in "${candidates[@]}"; do
    [[ -s "$candidate" ]] && {
      print -r -- "$candidate"
      return 0
    }
  done

  command -v jq >/dev/null 2>&1 || return 1

  for file in "$dir"/*.info.json(N.); do
    if metadata_json_matches_url "$file" "$url"; then
      print -r -- "$file"
      return 0
    fi
  done

  return 1
}

metadata_json_has_thumbnail() {
  local json="$1"

  [[ -s "$json" ]] || return 1
  command -v jq >/dev/null 2>&1 || return 1

  jq -e '
    ((.thumbnail // "") | tostring | length > 0)
    or ((.thumbnails // []) | length > 0)
  ' "$json" >/dev/null 2>&1
}

find_preview_thumbnail() {
  local base="$1"
  local ext candidate

  for ext in jpg jpeg png webp avif; do
    candidate="${base}.${ext}"
    [[ -s "$candidate" ]] && {
      print -r -- "$candidate"
      return 0
    }
  done

  return 1
}

preview_error_cache_fresh() {
  local error_file="$1"
  local max_age="${YTQ_PREVIEW_ERROR_CACHE_SECONDS:-300}"
  local now mtime

  [[ -s "$error_file" ]] || return 1
  if grep -qiE 'already been recorded in the archive|has already been recorded in the archive' "$error_file" 2>/dev/null; then
    return 1
  fi

  [[ "$max_age" == <-> ]] || max_age=300
  (( max_age > 0 )) || return 1

  now="$(date +%s)" || return 1
  mtime="$(stat -f %m "$error_file" 2>/dev/null || stat -c %Y "$error_file" 2>/dev/null)" || return 1

  (( now - mtime < max_age ))
}

fetch_preview_cache() {
  local url="$1"
  local base="$2"
  local json="${base}.info.json"
  local error_file="${base}.error"
  local cache_dir="${base:h}"
  local cache_template="${base:t}.%(ext)s"
  local metadata_json json_dir fetch_status tmp_log
  local -a metadata_args

  metadata_json="$(find_cached_metadata_json "$url" 2>/dev/null)" || metadata_json=""
  if [[ -s "$metadata_json" ]]; then
    find_preview_thumbnail "$base" >/dev/null 2>&1 && return 0
    fetch_preview_thumbnail_from_json "$metadata_json" "$base"
    find_preview_thumbnail "$base" >/dev/null 2>&1 && return 0
    metadata_json_has_thumbnail "$metadata_json" && return 0
  fi

  [[ -s "$json" ]] && return 0
  preview_error_cache_fresh "$error_file" && return 0
  rm -f "$error_file"

  if ! command -v yt-dlp >/dev/null 2>&1; then
    print -r -- "yt-dlp not found" > "$error_file"
    return 0
  fi

  tmp_log="${error_file}.tmp.$$"
  rm -f "$tmp_log"

  if json_dir="$(ytq_json_dir 2>/dev/null)"; then
    mkdir -p "$json_dir" 2>/dev/null
    metadata_args=(
      --paths "infojson:$json_dir"
      --output 'infojson:%(extractor)s_%(id)s'
    )
  else
    metadata_args=(
      --paths "infojson:$cache_dir"
      --output "infojson:$cache_template"
    )
  fi

  yt-dlp \
    --skip-download \
    --write-thumbnail \
    --write-info-json \
    --no-download-archive \
    --no-playlist \
    --no-warnings \
    --no-progress \
    "${metadata_args[@]}" \
    --paths "home:$cache_dir" \
    --paths "temp:$cache_dir" \
    --paths "thumbnail:$cache_dir" \
    --output "$cache_template" \
    --output "thumbnail:$cache_template" \
    "$url" > "$tmp_log" 2>&1
  fetch_status=$?

  metadata_json="$(find_cached_metadata_json "$url" 2>/dev/null)" || metadata_json=""

  if (( fetch_status != 0 )) || [[ ! -s "$metadata_json" && ! -s "$json" ]]; then
    if [[ -s "$tmp_log" ]]; then
      cat "$tmp_log" > "$error_file"
    else
      print -r -- "yt-dlp preview fetch failed with status $fetch_status" > "$error_file"
    fi
    rm -f "$tmp_log"
  else
    rm -f "$tmp_log"
    rm -f "$error_file"
  fi
}

fetch_preview_thumbnail_from_json() {
  local json="$1"
  local base="$2"
  local cache_dir="${base:h}"
  local cache_template="${base:t}.%(ext)s"

  [[ -s "$json" ]] || return 1
  command -v yt-dlp >/dev/null 2>&1 || return 1

  yt-dlp \
    --load-info-json "$json" \
    --skip-download \
    --write-thumbnail \
    --no-write-info-json \
    --no-download-archive \
    --no-warnings \
    --no-progress \
    --paths "home:$cache_dir" \
    --paths "temp:$cache_dir" \
    --paths "thumbnail:$cache_dir" \
    --output "$cache_template" \
    --output "thumbnail:$cache_template" \
    >/dev/null 2>&1
}

preview_image_handler() {
  local handler="${YTQ_PREVIEW_IMAGE_HANDLER:-auto}"

  if [[ "$handler" != "auto" ]]; then
    print -r -- "$handler"
    return 0
  fi

  if [[ -n "${KITTY_WINDOW_ID:-}" || "${TERM_PROGRAM:-}" == "kitty" || "${TERM:-}" == xterm-kitty* ]]; then
    print -r -- "kitty"
  elif command -v chafa >/dev/null 2>&1; then
    print -r -- "symbols"
  else
    print -r -- "none"
  fi
}

render_kitty_image() {
  local image="$1"
  local columns="$2"
  local image_lines="$3"
  local -a icat_cmd
  local i

  if command -v kitty >/dev/null 2>&1; then
    icat_cmd=(kitty +kitten icat)
  elif command -v kitten >/dev/null 2>&1; then
    icat_cmd=(kitten icat)
  else
    return 1
  fi

  "${icat_cmd[@]}" \
    --clear \
    --transfer-mode=file \
    --stdin=no \
    --align=left \
    --place="${columns}x${image_lines}@0x0" \
    "$image" 2>/dev/null || return 1

  for (( i = 0; i < image_lines; i++ )); do
    print ""
  done
}

render_preview_image() {
  local image="$1"
  local columns="${FZF_PREVIEW_COLUMNS:-80}"
  local lines="${FZF_PREVIEW_LINES:-40}"
  local image_lines=$(( lines - 13 ))
  local handler

  (( image_lines > 22 )) && image_lines=22
  (( image_lines < 8 )) && image_lines=8

  handler="$(preview_image_handler)"

  case "$handler" in
    kitty)
      if render_kitty_image "$image" "$columns" "$image_lines"; then
        return 0
      fi
      ;;
    none)
      print "\033[36mThumbnail:\033[0m $image"
      return 0
      ;;
    symbols)
      if command -v chafa >/dev/null 2>&1; then
        chafa -f symbols -s "${columns}x${image_lines}" "$image" --animate false
        return 0
      fi
      ;;
  esac

  if command -v chafa >/dev/null 2>&1; then
    chafa -f symbols -s "${columns}x${image_lines}" "$image" --animate false
  else
    print "\033[36mThumbnail:\033[0m $image"
  fi
}

print_preview_archive_status() {
  local url="$1"

  load_archive

  if [[ -z "${YT_DLP_ARCHIVE_FILE:-}" ]]; then
    print "\033[33mArchive:\033[0m YT_DLP_ARCHIVE_FILE is not set"
  elif [[ ! -r "$YT_DLP_ARCHIVE_FILE" ]]; then
    print "\033[33mArchive:\033[0m $YT_DLP_ARCHIVE_FILE is not readable"
  elif is_archived_url "$url"; then
    print "\033[32mArchive:\033[0m already downloaded"
  else
    print "\033[36mArchive:\033[0m not found"
  fi
}

print_preview_metadata() {
  local json="$1"

  if command -v jq >/dev/null 2>&1; then
    jq -r '
      def emit(k; v):
        if v == null or v == "" then empty
        else "\u001b[36m" + k + ":\u001b[0m " + (v | tostring)
        end;
      def compact_text:
        tostring
        | gsub("[\r\n\t]+"; " ")
        | gsub("  +"; " ");
      def human_duration:
        if .duration == null then null
        else
          (.duration | floor) as $total
          | (($total / 3600) | floor) as $hours
          | ((($total % 3600) / 60) | floor) as $minutes
          | ($total % 60) as $seconds
          | if $hours > 0
            then "\($hours)h \($minutes)m \($seconds)s"
            else "\($minutes)m \($seconds)s"
            end
        end;
      def upload_day:
        (.upload_date // .release_date) as $day
        | if $day == null then null
          else ($day | tostring) as $text
          | if ($text | test("^[0-9]{8}$"))
            then $text[0:4] + "-" + $text[4:6] + "-" + $text[6:8]
            else $text
            end
          end;

      emit("Title"; .title),
      emit("Uploader"; (.uploader // .channel // .creator)),
      emit("ID"; (((.extractor_key // .extractor // "yt-dlp") | tostring) + " " + ((.id // "") | tostring))),
      emit("Duration"; human_duration),
      emit("Uploaded"; upload_day),
      emit("Views"; .view_count),
      emit("URL"; (.webpage_url // .original_url)),
      emit("Thumbnail"; .thumbnail),
      if .description == null or .description == "" then empty
      else "\n" + (.description | compact_text | .[0:800])
      end
    ' "$json" 2>/dev/null
  else
    print "\033[33mjq not found; showing raw metadata path:\033[0m $json"
  fi
}

cmd_preview() {
  local url="$1"

  [[ -n "$url" ]] || return 0

  local cache_dir
  cache_dir="$(ytq_cache_dir)"
  mkdir -p "$cache_dir"

  local key base json error_file thumbnail
  key="$(url_cache_key "$url")"
  base="${cache_dir}/${key}"
  json="$(find_cached_metadata_json "$url" 2>/dev/null)" || json=""
  [[ -n "$json" ]] || json="${base}.info.json"
  error_file="${base}.error"

  print_preview_archive_status "$url"
  print "\033[36mQueue URL:\033[0m $url"
  print ""

  fetch_preview_cache "$url" "$base"
  json="$(find_cached_metadata_json "$url" 2>/dev/null)" || json=""
  [[ -n "$json" ]] || json="${base}.info.json"

  if [[ -s "$error_file" && ! -s "$json" ]]; then
    print "\033[31mPreview load failed:\033[0m"
    sed -n '1,24p' "$error_file"
    return 0
  fi

  thumbnail="$(find_preview_thumbnail "$base" 2>/dev/null)" || thumbnail=""
  if [[ -n "$thumbnail" ]]; then
    render_preview_image "$thumbnail"
    print ""
  fi

  if [[ -s "$json" ]]; then
    print_preview_metadata "$json"
  else
    print "\033[33mNo metadata cached yet.\033[0m"
  fi
}

cmd_list() {
  require_batch_file
  require_command fzf

  if [[ ! -s "$YT_DLP_BATCH_FILE" ]]; then
    print "📭 Queue is empty"
    return
  fi

  load_archive

  local archive_note="archive: ${YT_DLP_ARCHIVE_FILE:-unset}"
  local selected fzf_status

  [[ -n "${YT_DLP_ARCHIVE_FILE:-}" && -r "$YT_DLP_ARCHIVE_FILE" ]] || archive_note="archive: unavailable"

  selected="$(
    while IFS= read -r line; do
      [[ -n "$line" ]] && queue_list_item "$line"
    done < "$YT_DLP_BATCH_FILE" |
      fzf \
        --ansi \
        --no-sort \
        --tiebreak=index \
        --delimiter=$'\t' \
        --with-nth=2 \
        --accept-nth=1 \
        --prompt='ytq list> ' \
        --header="enter: move to top | esc: cancel | ✓: already in archive | $archive_note" \
        --preview="${(q)YTQ_SELF} __preview {1}" \
        --preview-window='right,60%,wrap,border-left'
  )"
  fzf_status=$?

  case "$fzf_status" in
    0) ;;
    1) return 0 ;;
    130) return 130 ;;
    *) return "$fzf_status" ;;
  esac

  [[ -n "$selected" ]] || return 0
  cmd_next "$selected"
  cmd_get 1 "$@"
}

cmd_run() {
  require_batch_file

  if [[ ! -s "$YT_DLP_BATCH_FILE" ]]; then
    print "📭 Queue is empty"
    return
  fi

  yt-dlp "$@" --batch-file "$YT_DLP_BATCH_FILE"
}

cmd_get() {
  require_batch_file

  local index="$1"

  [[ -n "$index" ]] || {
    print -u2 "Usage: ytq get <number> [yt-dlp args ...]"
    exit 1
  }

  [[ "$index" == <-> && "$index" -gt 0 ]] || {
    print -u2 "❌ Invalid queue number: $index"
    exit 1
  }

  shift

  local url
  url="$(sed -n "${index}p" "$YT_DLP_BATCH_FILE")"

  [[ -n "$url" ]] || {
    print -u2 "❌ No queue item at position $index"
    exit 1
  }

  if ! is_url "$url"; then
    print -u2 "❌ Queue item $index is not a URL: $url"
    exit 1
  fi

  yt-dlp "$@" "$url"
}

cmd_runclear() {
  require_batch_file

  yt-dlp "$@" --batch-file "$YT_DLP_BATCH_FILE" || exit $?

  : > "$YT_DLP_BATCH_FILE"

  print "🗑️  Queue cleared"
}

cmd_clear() {
  require_batch_file

  : > "$YT_DLP_BATCH_FILE"

  print "🗑️  Queue cleared"
}

cmd_rm() {
  require_batch_file

  local url="$1"

  [[ -n "$url" ]] || {
    print -u2 "Usage: ytq rm <url>"
    exit 1
  }

  local tmp_file
  tmp_file="$(mktemp)" || exit 1

  grep -Fvx -- "$url" "$YT_DLP_BATCH_FILE" > "$tmp_file"
  mv "$tmp_file" "$YT_DLP_BATCH_FILE"

  print "➖ Removed: $url"
}

cmd_dedupe() {
  require_batch_file

  local tmp_file
  tmp_file="$(mktemp)" || exit 1

  awk 'NF && !seen[$0]++' "$YT_DLP_BATCH_FILE" > "$tmp_file"
  mv "$tmp_file" "$YT_DLP_BATCH_FILE"

  print "🧹 Queue deduped"
}

cmd_edit() {
  require_batch_file
  "${EDITOR:-nvim}" "$YT_DLP_BATCH_FILE"
}

cmd_path() {
  require_batch_file
  print "$YT_DLP_BATCH_FILE"
}

usage() {
  cat <<EOF
Usage:
  ytq add <url> [url ...]     Add URL(s) to end of queue
  ytq next <url> [url ...]    Move URL(s) to front of queue
  ytq addclip                 Add URL(s) from clipboard
  ytq queue                   Show queue
  ytq list [yt-dlp args ...]  Pick a queue item, move it to top, then get it
  ytq run [yt-dlp args ...]   Run yt-dlp
  ytq get <n> [yt-dlp args]   Download only queue item n
  ytq runclear [args ...]     Run then clear queue
  ytq clear                   Clear queue
  ytq rm <url>                Remove URL
  ytq dedupe                  Remove duplicate entries
  ytq edit                    Edit queue file
  ytq path                    Show queue file path
EOF
}

case "$1" in
  add)
    shift
    cmd_add "$@"
    ;;
  next)
    shift
    cmd_next "$@"
    ;;
  addclip)
    shift
    cmd_addclip "$@"
    ;;
  queue|ls)
    cmd_queue
    ;;
  list)
    shift
    cmd_list "$@"
    ;;
  run)
    shift
    cmd_run "$@"
    ;;
  get)
    shift
    cmd_get "$@"
    ;;
  runclear)
    shift
    cmd_runclear "$@"
    ;;
  clear)
    cmd_clear
    ;;
  rm)
    shift
    cmd_rm "$@"
    ;;
  dedupe)
    cmd_dedupe
    ;;
  edit)
    cmd_edit
    ;;
  path)
    cmd_path
    ;;
  __preview)
    shift
    cmd_preview "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
