#!/usr/bin/env zsh
set -u

usage() {
  print -u2 -- "Usage: ${0:t} [--path PATH]... [--match-string STRING]... [--match-regex REGEX]... [--sort KEY] [--reverse] [--print0] [--verbose]"
  print -u2 -- ""
  print -u2 -- "Options:"
  print -u2 -- "  --path PATH | --path=PATH"
  print -u2 -- "  --match-string STRING | --match-string=STRING"
  print -u2 -- "  --match-regex REGEX | --match-regex=REGEX"
  print -u2 -- "  --sort KEY | --sort=KEY           KEY: modified | created"
  print -u2 -- "  --reverse"
  print -u2 -- "  --print0"
  print -u2 -- "  --verbose"
  print -u2 -- "  --help"
}

typeset -a match_strings=()
typeset -a match_regexes=()
typeset -a explicit_paths=()
typeset -a directories=()
typeset -a results=()
typeset -a sorted=()

typeset verbose=false
typeset print0=false
typeset reverse=false
typeset sort_key=""

log_verbose() {
  $verbose && print -u2 -- "[DEBUG] $*"
}

die() {
  print -u2 -- "$*"
  exit 1
}

append_arg() {
  local arr_name="$1"
  local value="$2"
  eval "${arr_name}+=(\"\$value\")"
}

parse_value_opt() {
  # args:
  #   $1 = option name for error messages
  #   $2 = current token
  #   $3 = next token (may be empty)
  #
  # stdout:
  #   parsed value
  #
  # return:
  #   0 on success, 1 on missing value
  local opt_name="$1"
  local token="$2"
  local next="${3-}"

  if [[ "$token" == *=* ]]; then
    print -r -- "${token#*=}"
    return 0
  fi

  [[ -n "$next" ]] || {
    print -u2 -- "Missing value for $opt_name"
    return 1
  }

  print -r -- "$next"
  return 0
}

while (( $# > 0 )); do
  case "$1" in
    --path|--path=*)
      value="$(parse_value_opt --path "$1" "${2-}")" || { usage; exit 1; }
      append_arg explicit_paths "$value"
      [[ "$1" == *=* ]] && shift || shift 2
      ;;
    --match-string|--match-string=*)
      value="$(parse_value_opt --match-string "$1" "${2-}")" || { usage; exit 1; }
      append_arg match_strings "$value"
      [[ "$1" == *=* ]] && shift || shift 2
      ;;
    --match-regex|--match-regex=*)
      value="$(parse_value_opt --match-regex "$1" "${2-}")" || { usage; exit 1; }
      append_arg match_regexes "$value"
      [[ "$1" == *=* ]] && shift || shift 2
      ;;
    --sort|--sort=*)
      value="$(parse_value_opt --sort "$1" "${2-}")" || { usage; exit 1; }
      sort_key="$value"
      [[ "$1" == *=* ]] && shift || shift 2
      ;;
    --reverse)
      reverse=true
      shift
      ;;
    --print0)
      print0=true
      shift
      ;;
    --verbose)
      verbose=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage
      die "Unknown argument: $1"
      ;;
  esac
done

case "$sort_key" in
  ""|modified|created) ;;
  *)
    die "Invalid --sort value: $sort_key (expected: modified or created)"
    ;;
esac

if (( ${#explicit_paths[@]} > 0 )); then
  directories=("${explicit_paths[@]}")
  log_verbose "Using explicit paths: ${directories[*]}"
else
  directories=("${(@f)$(ls-media-paths)}")
  log_verbose "Using paths from ls-media-paths: ${directories[*]}"
fi

(( ${#directories[@]} > 0 )) || die "No directories found"

matches_filters() {
  local file="$1"
  local str regex

  for str in "${match_strings[@]}"; do
    [[ "${file:l}" == *"${str:l}"* ]] || return 1
  done

  for regex in "${match_regexes[@]}"; do
    [[ "$file" =~ $regex ]] || return 1
  done

  return 0
}

get_timestamp() {
  local file="$1"

  case "$sort_key" in
    modified)
      stat -f '%m' -- "$file" 2>/dev/null
      ;;
    created)
      stat -f '%B' -- "$file" 2>/dev/null
      ;;
    *)
      return 1
      ;;
  esac
}

process_files() {
  local dir="$1"
  local file ts
  local -a fd_cmd

  [[ -d "$dir" && -r "$dir" ]] || {
    log_verbose "Skipping unreadable directory: $dir"
    return 0
  }

  # Assumes fd-video behaves like fd and accepts a search pattern plus a path.
  fd_cmd=(fd-video -t f --full-path --ignore-case -0 . "$dir")
  log_verbose "Executing: ${fd_cmd[*]}"

  while IFS= read -r -d $'\0' file; do
    matches_filters "$file" || continue

    if [[ -n "$sort_key" ]]; then
      ts="$(get_timestamp "$file")" || continue
      printf '%020d\t%s\0' "$ts" "$file"
    else
      printf '%s\0' "$file"
    fi
  done < <("${fd_cmd[@]}")
}

emit_path() {
  local rec="$1"

  [[ -n "$sort_key" ]] && rec="${rec#*$'\t'}"

  if $print0; then
    printf '%s\0' "$rec"
  else
    print -r -- "$rec"
  fi
}

if [[ -z "$sort_key" ]]; then
  for dir in "${directories[@]}"; do
    if $print0; then
      process_files "$dir"
    else
      while IFS= read -r -d $'\0' line; do
        print -r -- "$line"
      done < <(process_files "$dir")
    fi
  done
else
  for dir in "${directories[@]}"; do
    while IFS= read -r -d $'\0' line; do
      results+=("$line")
    done < <(process_files "$dir")
  done

  if $reverse; then
    sorted=("${(on)results[@]}")
  else
    sorted=("${(On)results[@]}")
  fi

  for rec in "${sorted[@]}"; do
    emit_path "$rec"
  done
fi

log_verbose "Execution complete."
