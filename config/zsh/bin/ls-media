#!/usr/bin/env zsh
# 
#   Search media files via fd-video, optionally sort by file timestamps, and emit
#   matching paths as newline- or NUL-delimited output.

set -u

usage() {
  print -u2 -- "Usage: ${0:t} [--sort KEY] [--reverse] [--print0] [--verbose] [pattern] [path]..."
  print -u2 -- ""
  print -u2 -- "Search media files using fd-video with an fd-like interface."
  print -u2 -- "The optional [pattern] and [path]... are passed through to fd-video."
  print -u2 -- "If no paths are provided, paths from ls-media-paths are used."
  print -u2 -- ""
  print -u2 -- "Options:"
  print -u2 -- "  --sort KEY | --sort=KEY           KEY: modified | created"
  print -u2 -- "  --reverse                         Reverse sort order (only applies with --sort)"
  print -u2 -- "  --print0                          Output NUL-delimited paths"
  print -u2 -- "  --verbose                         Print debug logs to stderr"
  print -u2 -- "  --help, -h"
  print -u2 -- ""
  print -u2 -- "Examples:"
  print -u2 -- "  ${0:t}"
  print -u2 -- "  ${0:t} catwalk"
  print -u2 -- "  ${0:t} '#bg-black' ~/Movies /Volumes/Media"
  print -u2 -- "  ${0:t} --sort modified --reverse concert ~/Movies/Visuals"
}

typeset -a directories=()
typeset -a results=()
typeset -a sorted=()
typeset -a fd_paths=()

typeset verbose=false
typeset print0=false
typeset reverse=false
typeset sort_key=""
typeset pattern="."

log_verbose() {
  $verbose && print -u2 -- "[DEBUG] $*"
}

die() {
  print -u2 -- "$*"
  exit 1
}

parse_value_opt() {
  local opt_name="$1"
  local token="$2"
  local next="${3-}"

  if [[ "$token" == *=* ]]; then
    print -r -- "${token#*=}"
    return 0
  fi

  [[ -n "$next" ]] || {
    print -u2 -- "Missing value for $opt_name"
    return 1
  }

  print -r -- "$next"
  return 0
}

while (( $# > 0 )); do
  case "$1" in
    --sort|--sort=*)
      value="$(parse_value_opt --sort "$1" "${2-}")" || { usage; exit 1; }
      sort_key="$value"
      [[ "$1" == *=* ]] && shift || shift 2
      ;;
    --reverse)
      reverse=true
      shift
      ;;
    --print0)
      print0=true
      shift
      ;;
    --verbose)
      verbose=true
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      usage
      die "Unknown argument: $1"
      ;;
    *)
      break
      ;;
  esac
done

case "$sort_key" in
  ""|modified|created) ;;
  *)
    die "Invalid --sort value: $sort_key (expected: modified or created)"
    ;;
esac

if (( $# > 0 )); then
  pattern="$1"
  shift
fi

if (( $# > 0 )); then
  fd_paths=("$@")
  directories=("${fd_paths[@]}")
  log_verbose "Using explicit paths: ${directories[*]}"
else
  directories=("${(@f)$(ls-media-paths)}")
  log_verbose "Using paths from ls-media-paths: ${directories[*]}"
fi

(( ${#directories[@]} > 0 )) || die "No directories found"

get_timestamp() {
  local file="$1"

  case "$sort_key" in
    modified)
      stat -f '%m' -- "$file" 2>/dev/null
      ;;
    created)
      stat -f '%B' -- "$file" 2>/dev/null
      ;;
    *)
      return 1
      ;;
  esac
}

process_files() {
  local file ts
  local -a fd_cmd
  local -a valid_dirs=()

  for dir in "${directories[@]}"; do
    if [[ -d "$dir" && -r "$dir" ]]; then
      valid_dirs+=("$dir")
    else
      log_verbose "Skipping unreadable directory: $dir"
    fi
  done

  (( ${#valid_dirs[@]} > 0 )) || return 0

  # Assumes fd-video behaves like fd and accepts: pattern [path...]
  fd_cmd=(fd-video -t f --full-path --ignore-case -0 "$pattern" "${valid_dirs[@]}")
  log_verbose "Executing: ${fd_cmd[*]}"

  while IFS= read -r -d $'\0' file; do
    if [[ -n "$sort_key" ]]; then
      ts="$(get_timestamp "$file")" || continue
      printf '%020d\t%s\0' "$ts" "$file"
    else
      printf '%s\0' "$file"
    fi
  done < <("${fd_cmd[@]}")
}

emit_path() {
  local rec="$1"

  [[ -n "$sort_key" ]] && rec="${rec#*$'\t'}"

  if $print0; then
    printf '%s\0' "$rec"
  else
    print -r -- "$rec"
  fi
}

if [[ -z "$sort_key" ]]; then
  if $print0; then
    process_files
  else
    while IFS= read -r -d $'\0' line; do
      print -r -- "$line"
    done < <(process_files)
  fi
else
  while IFS= read -r -d $'\0' line; do
    results+=("$line")
  done < <(process_files)

  if $reverse; then
    sorted=("${(on)results[@]}")
  else
    sorted=("${(On)results[@]}")
  fi

  for rec in "${sorted[@]}"; do
    emit_path "$rec"
  done
fi

log_verbose "Execution complete."
