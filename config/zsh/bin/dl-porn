#!/usr/bin/env zsh
set -euo pipefail

(( $# == 0 )) && {
  print -u2 "usage: ${0:t} [yt-dlp args...] <url>"
  exit 1
}

argv=( "$@" )
url="${argv[-1]}"
passthru=( "${argv[@]:1:$#-1}" )

echo "URL: $url"

yt-dlp --porn \
  --replace-in-metadata "tags" "[ _]+" "-" \
  --parse-metadata "%(webpage_url)s:(?P<meta_comment>.+)" \
  --parse-metadata "%(webpage_url)s:(?P<meta_purl>.+)" \
  "${passthru[@]}" \
  "$url"
