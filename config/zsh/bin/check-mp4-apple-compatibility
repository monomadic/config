#!/usr/bin/env zsh
#  check-mp4-apple-compatibility
# Inspect an MP4 for common Apple ecosystem compatibility issues.

set -euo pipefail

file="${1:-}"

if [[ -z "$file" || ! -f "$file" ]]; then
  print -u2 "Usage: mp4-apple-check.zsh <file.mp4>"
  exit 1
fi

print -P "%F{cyan}== ffprobe streams ==%f"
ffprobe -hide_banner -v error \
  -show_entries stream=index,codec_type,codec_name,codec_tag_string,pix_fmt,width,height,avg_frame_rate,time_base \
  -of compact=p=0:nk=0 \
  "$file"

print
print -P "%F{cyan}== chapters ==%f"
ffprobe -hide_banner -v error \
  -show_chapters \
  -of compact=p=0:nk=1 \
  "$file" || true

print
print -P "%F{cyan}== format ==%f"
ffprobe -hide_banner -v error \
  -show_entries format=format_name,duration,bit_rate,tags \
  -of default=nw=1 \
  "$file"

if command -v AtomicParsley >/dev/null; then
  print
  print -P "%F{cyan}== atom order ==%f"
  AtomicParsley "$file" -T | rg 'moov|mdat|trak|chap|udta|meta' || true
fi
