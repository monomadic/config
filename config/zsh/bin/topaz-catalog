#!/usr/bin/env zsh
emulate -L zsh
set -euo pipefail

script_name="${0:t}"

usage() {
  cat <<EOF
usage:
  $script_name [--picker encode|simple|all] [--fzf] [query ...]
  $script_name --help

Print readable summaries of presets from topaz-preset-catalog.zsh.
Queries match the picker, display label, preset name, filter, output settings,
or metadata.
EOF
}

picker="all"
use_fzf=false
queries=()

while (( $# > 0 )); do
  case "$1" in
    -h|--help|help)
      usage
      exit 0
      ;;
    --picker=*)
      picker="${1#--picker=}"
      shift
      ;;
    --picker)
      (( $# >= 2 )) || {
        print -u2 -- "--picker requires encode, simple, or all"
        exit 1
      }
      picker="$2"
      shift 2
      ;;
    --fzf)
      use_fzf=true
      shift
      ;;
    --)
      shift
      queries+=("$@")
      break
      ;;
    -*)
      print -u2 -- "unknown option: $1"
      usage >&2
      exit 1
      ;;
    *)
      queries+=("$1")
      shift
      ;;
  esac
done

case "$picker" in
  encode|simple|all) ;;
  *)
    print -u2 -- "--picker must be encode, simple, or all"
    exit 1
    ;;
esac

PRESET_CATALOG="${0:A:h}/lib/topaz-preset-catalog.zsh"
[[ -r "$PRESET_CATALOG" ]] || {
  print -u2 -- "Topaz preset catalog not found: $PRESET_CATALOG"
  exit 1
}

source "$PRESET_CATALOG"

topaz_preview_rows() {
  emulate -L zsh
  local row_picker display preset_name preset_flag filter_complex output_ext video_args metadata

  topaz_preset_catalog_rows | while IFS=$'\t' read -r row_picker display preset_name preset_flag filter_complex output_ext video_args metadata; do
    [[ "$picker" == all || "$row_picker" == "$picker" ]] || continue
    print -r -- "${row_picker}"$'\t'"${display}"$'\t'"${preset_name}"$'\t'"${preset_flag}"$'\t'"${filter_complex}"$'\t'"${output_ext}"$'\t'"${video_args}"$'\t'"${metadata}"
  done
}

row_matches_queries() {
  emulate -L zsh
  local haystack="${1:l}"
  local query

  for query in "${queries[@]}"; do
    [[ "$haystack" == *"${query:l}"* ]] || return 1
  done

  return 0
}

format_filter_part() {
  emulate -L zsh
  local part="$1"
  local name="${part%%[:=]*}"
  local body="$part"
  local key value param
  local -a params

  if [[ "$part" == *=* ]]; then
    name="${part%%=*}"
    body="${part#*=}"
  elif [[ "$part" == *:* ]]; then
    name="${part%%:*}"
    body="${part#*:}"
  fi

  print -r -- "  - $name"

  params=("${(@s/:/)body}")
  for param in "${params[@]}"; do
    [[ "$param" == *=* ]] || continue
    key="${param%%=*}"
    value="${param#*=}"
    print -r -- "      ${key}: ${value}"
  done
}

print_preset_summary() {
  emulate -L zsh
  local row="$1"
  local row_picker display preset_name preset_flag filter_complex output_ext video_args metadata
  local part
  local -a parts

  IFS=$'\t' read -r row_picker display preset_name preset_flag filter_complex output_ext video_args metadata <<< "$row"

  print -r -- "$display"
  print -r -- "  picker: $row_picker"
  print -r -- "  name:   $preset_name"
  print -r -- "  flag:   $preset_flag"

  if [[ -n "$output_ext" ]]; then
    print -r -- "  output: .$output_ext"
  else
    print -r -- "  output: topaz-encode default"
  fi

  if [[ -n "$video_args" ]]; then
    print -r -- "  video:  $video_args"
  fi

  if [[ -n "$metadata" ]]; then
    print -r -- "  meta:   $metadata"
  fi

  print -r -- "  filter:"
  parts=("${(@s:,:)filter_complex}")
  for part in "${parts[@]}"; do
    format_filter_part "$part"
  done
}

filtered_rows() {
  emulate -L zsh
  local row

  topaz_preview_rows | while IFS= read -r row; do
    if (( ${#queries[@]} == 0 )) || row_matches_queries "$row"; then
      print -r -- "$row"
    fi
  done
}

if [[ "$use_fzf" == true ]]; then
  command -v fzf >/dev/null 2>&1 || {
    print -u2 -- "fzf not found"
    exit 1
  }

  selection="$(
    filtered_rows |
      fzf \
        --prompt='Topaz preset preview > ' \
        --delimiter=$'\t' \
        --with-nth=1,2,3 \
        --height=70% \
        --reverse \
        --border \
        --preview='printf "picker: %s\nname:   %s\nflag:   %s\noutput: %s\nvideo:  %s\nmeta:   %s\n\nfilter:\n%s\n" {1} {3} {4} {6} {7} {8} {5}' \
        --preview-window='down:12:wrap'
  )"

  [[ -n "$selection" ]] || {
    print -u2 -- "no preset selected"
    exit 1
  }

  print_preset_summary "$selection"
  exit 0
fi

matched=false
while IFS= read -r row; do
  if [[ "$matched" == true ]]; then
    print
  fi
  print_preset_summary "$row"
  matched=true
done < <(filtered_rows)

[[ "$matched" == true ]] || {
  print -u2 -- "no presets matched"
  exit 1
}
