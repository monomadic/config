#!/usr/bin/env zsh
# kitty-launch
# Launch a command in Kitty from an external environment.
#
# Behavior:
#   - If Kitty IPC is reachable, open a new Kitty window/tab via `kitten @ launch`.
#   - If not reachable, start a new Kitty instance listening on the chosen socket.
#   - If no command is provided, open an interactive login shell.
#   - Activates Kitty.app on macOS by default after launching.
#
# Socket priority:
#   1. KITTY_LAUNCH_SOCKET
#   2. KITTY_LISTEN_ON, when launched from inside Kitty
#   3. unix:/tmp/kitty-$USER
#   4. reachable /tmp/kitty-* socket discovery

emulate -L zsh
set -euo pipefail

script_name="${0:t}"

user_name="${USER:-${LOGNAME:-$(id -un)}}"
default_shell="${SHELL:-/bin/zsh}"

configured_socket_addr="${KITTY_LAUNCH_SOCKET:-${KITTY_LISTEN_ON:-unix:/tmp/kitty-${user_name}}}"
socket_addr="$configured_socket_addr"

launch_type="tab"
cwd=""
title=""
keep_focus=false
activate=true
detach=true
debug=false

usage() {
  cat <<EOF
$script_name

Launch a command in Kitty, using IPC if Kitty is already running.

If no command is provided, opens an interactive login shell.

Usage:
  $script_name [options] [-- command [args...]]

Options:
  --tab              Open in a new Kitty tab (default)
  --window           Open in a new Kitty window inside current OS window
  --os-window        Open in a new top-level OS window
  --cwd DIR          Working directory for launched command
  --title TITLE      Window/tab title
  --keep-focus       Do not focus the newly launched Kitty window/tab internally
  --activate         Activate Kitty.app after launch (default)
  --no-activate      Do not activate Kitty.app after launch
  --socket ADDR      Kitty IPC address
  --no-detach        Do not detach when starting Kitty fallback
  --debug            Print chosen socket and command
  -h, --help         Show help

Environment:
  KITTY_LAUNCH_SOCKET  Override socket address.
  KITTY_LISTEN_ON      Used automatically when running inside Kitty.
  SHELL                Shell used when no command is provided.

Current defaults:
  socket: $configured_socket_addr
  shell:  $default_shell

Examples:
  $script_name
  $script_name --cwd ~/Downloads
  $script_name --tab -- zsh -lc 'cd ~/src && hx .'
  $script_name --window -- yazi ~/Downloads
  $script_name --os-window -- zsh -l
EOF
}

normalize_cwd() {
  local input="${1:-}"
  local resolved=""

  # ForkLift may pass newline-separated selected paths.
  # zsh: split scalar into lines.
  local -a selected_paths
  selected_paths=( "${(@f)input}" )

  resolved="${selected_paths[1]:-}"

  # Empty input: use HOME.
  if [[ -z "$resolved" ]]; then
    print -r -- "$HOME"
    return 0
  fi

  # Trim trailing slash except root.
  if [[ "$resolved" != "/" ]]; then
    resolved="${resolved%/}"
  fi

  # If selected item is a file, use its containing directory.
  if [[ -f "$resolved" ]]; then
    resolved="${resolved:h}"
  fi

  print -r -- "$resolved"
}

while (( $# )); do
  case "$1" in
    --tab)
      launch_type="tab"
      shift
      ;;
    --window)
      launch_type="window"
      shift
      ;;
    --os-window|--os_window)
      launch_type="os-window"
      shift
      ;;
    --cwd)
      (( $# >= 2 )) || {
        print -u2 -- "missing argument for --cwd"
        exit 2
      }
      cwd="$(normalize_cwd "$2")"
      shift 2
      ;;
    --title)
      (( $# >= 2 )) || {
        print -u2 -- "missing argument for --title"
        exit 2
      }
      title="$2"
      shift 2
      ;;
    --keep-focus)
      keep_focus=true
      shift
      ;;
    --activate)
      activate=true
      shift
      ;;
    --no-activate)
      activate=false
      shift
      ;;
    --socket)
      (( $# >= 2 )) || {
        print -u2 -- "missing argument for --socket"
        exit 2
      }
      configured_socket_addr="$2"
      socket_addr="$2"
      shift 2
      ;;
    --no-detach)
      detach=false
      shift
      ;;
    --debug)
      debug=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      print -u2 -- "unknown option: $1"
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

if (( $# )); then
  command_argv=( "$@" )
else
  command_argv=( "$default_shell" -l )
fi

have() {
  command -v "$1" >/dev/null 2>&1
}

activate_kitty() {
  osascript -e 'tell application id "net.kovidgoyal.kitty" to activate' >/dev/null 2>&1 || \
  osascript -e 'tell application "kitty" to activate' >/dev/null 2>&1 || \
  true
}

have kitty || {
  print -u2 -- "kitty not found in PATH"
  exit 127
}

if have kitten; then
  kitten_cmd=( kitten )
else
  kitten_cmd=( kitty +kitten )
fi

reachable_socket() {
  local candidate="$1"
  "${kitten_cmd[@]}" @ --to "$candidate" ls >/dev/null 2>&1
}

discover_socket() {
  local candidate

  # 1. Explicit/configured socket first.
  if reachable_socket "$configured_socket_addr"; then
    print -r -- "$configured_socket_addr"
    return 0
  fi

  # 2. Common fixed socket.
  candidate="unix:/tmp/kitty-${user_name}"
  if [[ "$candidate" != "$configured_socket_addr" ]] && reachable_socket "$candidate"; then
    print -r -- "$candidate"
    return 0
  fi

  # 3. Scan Kitty socket-looking files in /tmp.
  local socket_file
  for socket_file in /tmp/kitty-* /tmp/kitty.*(N); do
    [[ -S "$socket_file" ]] || continue

    candidate="unix:$socket_file"
    if reachable_socket "$candidate"; then
      print -r -- "$candidate"
      return 0
    fi
  done

  return 1
}

if discovered_socket="$(discover_socket)"; then
  socket_addr="$discovered_socket"

  $debug && {
    print -u2 -- "mode:            ipc"
    print -u2 -- "socket:          $socket_addr"
    print -u2 -- "launch_type:     $launch_type"
    print -u2 -- "cwd:             ${cwd:-}"
    print -u2 -- "title:           ${title:-}"
    print -u2 -- "keep_focus:      $keep_focus"
    print -u2 -- "activate:        $activate"
    print -u2 -- "command:         ${(q)command_argv[@]}"
  }

  launch_args=(
    @
    --to "$socket_addr"
    launch
    --type "$launch_type"
  )

  [[ -n "$cwd" ]] && launch_args+=( --cwd "$cwd" )
  [[ -n "$title" ]] && launch_args+=( --title "$title" )
  $keep_focus && launch_args+=( --keep-focus )

  "${kitten_cmd[@]}" "${launch_args[@]}" -- "${command_argv[@]}"

  $activate && activate_kitty

  exit 0
fi

$debug && {
  print -u2 -- "mode:            fallback-new-kitty"
  print -u2 -- "socket:          $socket_addr"
  print -u2 -- "launch_type:     $launch_type"
  print -u2 -- "cwd:             ${cwd:-}"
  print -u2 -- "title:           ${title:-}"
  print -u2 -- "activate:        $activate"
  print -u2 -- "detach:          $detach"
  print -u2 -- "command:         ${(q)command_argv[@]}"
}

kitty_args=(
  --listen-on "$socket_addr"
  -o allow_remote_control=socket-only
)

[[ -n "$cwd" ]] && kitty_args+=( --directory "$cwd" )
[[ -n "$title" ]] && kitty_args+=( --title "$title" )

case "$launch_type" in
  os-window)
    # Starting a fresh Kitty app already creates an OS window.
    ;;
  tab|window)
    # Fallback cannot create a tab/window inside a non-existent Kitty instance;
    # this starts a fresh OS window instead.
    ;;
esac

if $detach; then
  nohup kitty "${kitty_args[@]}" -- "${command_argv[@]}" >/dev/null 2>&1 &
  disown

  $activate && activate_kitty

  exit 0
else
  $activate && activate_kitty
  exec kitty "${kitty_args[@]}" -- "${command_argv[@]}"
fi
