#!/usr/bin/env zsh
# ============================================================================
# vdjstems — umbrella command for the VirtualDJ stem toolchain
# ============================================================================
#
# One entry point for the whole family. `make` is the full pipeline —
# audio file in, .vdjstems out; every other subcommand delegates to its
# standalone vdjstems-<cmd> tool (which remains directly invocable).
#
#   vdjstems make song.flac        separate + pack a VDJ-native sidecar
#   vdjstems split song.flac       → 5 stem WAVs (vdjstems-split)
#   vdjstems pack DIR              → pack stem WAVs (vdjstems-pack)
#   vdjstems create [OUT]          → pack CWD, lossless (vdjstems-create)
#   vdjstems info FILE             → inspect a stem container
#   vdjstems extract FILE          → pull streams out of a stem container
#   vdjstems from-nistem FILE      → convert NI .stem.mp4
#
# make: by default produces the VDJ-native SIDECAR "song.flac.vdjstems"
#       (Matroska, 5 stems) next to the input — load the original in VDJ.
#       --standalone instead builds a self-contained 6-track M4A.
#       --sw / --fast go to vdjstems-split; -l/-b/-k to vdjstems-pack
#       (standalone only). Stem WAVs are kept in <input name>.stems/.
#
# Dependencies: the vdjstems-* tools and their deps (see each tool's header)
# ============================================================================
set -euo pipefail
SELF="${0:t}"

die() { print -r -- "ERROR: $*" >&2; exit 1; }

usage() {
  cat <<EOF
Usage: $SELF <command> [args]

Commands:
  make [--sw|--fast] [--standalone] [-l] [-b BPM] [-k KEY] INPUT
               separate INPUT and pack. Default: VDJ-native sidecar
               <input>.vdjstems (Matroska); --standalone: 6-track M4A
  split        separate an audio file into 5 stem WAVs
  pack         pack a directory of stem WAVs into a .vdjstems
  create       pack the CWD losslessly (vdjstems-create)
  info         inspect a stem container's metadata
  extract      extract individual streams from a stem container
  from-nistem  convert a Native Instruments .stem.mp4

Run '$SELF <command> --help' for command-specific options.
EOF
  exit 2
}

(( $# )) || usage
cmd="$1"; shift

case "$cmd" in
  -h|--help) usage ;;

  split|pack|create|info|extract|from-nistem)
    exec "vdjstems-$cmd" "$@"
    ;;

  make)
    split_flags=()
    pack_flags=()
    standalone=false
    input=""
    while (( $# )); do
      case "${1:-}" in
        -h|--help) usage ;;
        --sw|--fast) split_flags+=("$1"); shift ;;
        --standalone) standalone=true; shift ;;
        -l|--lossless) pack_flags+=("$1"); shift ;;
        -b|--bpm|-k|--key)
          [[ -n "${2:-}" ]] || die "$1 requires a value"
          pack_flags+=("$1" "$2"); shift 2 ;;
        -*) die "Unknown make option: $1" ;;
        *)
          [[ -z "$input" ]] || die "make takes exactly one input file"
          input="$1"; shift ;;
      esac
    done
    [[ -n "$input" ]] || usage
    [[ -f "$input" ]] || die "No such file: $input"
    input="${input:A}"

    stems_dir="${input:r}.stems"

    vdjstems-split "${split_flags[@]}" -o "$stems_dir" "$input"
    print ""
    if [[ "$standalone" == "true" ]]; then
      out="${input:r}-stems.m4a"
      vdjstems-pack --standalone "${pack_flags[@]}" --out "$out" "$stems_dir"
    else
      out="${input}.vdjstems"
      vdjstems-pack --sidecar "$input" "${pack_flags[@]}" "$stems_dir"
    fi
    print "\n🎧 ${out}"
    ;;

  *)
    die "Unknown command: $cmd (see $SELF --help)"
    ;;
esac
