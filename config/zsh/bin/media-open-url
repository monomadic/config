#!/usr/bin/env zsh

emulate -L zsh
set -euo pipefail

local video_file="${1:?usage: media-open-url <video.mp4>}"

notify() {
	# macOS toast; silent no-op elsewhere (Linux configs are dormant)
	command -v osascript >/dev/null 2>&1 &&
		osascript -e "display notification \"$1\" with title \"media-open-url\"" >/dev/null 2>&1
}

local url
url="$(
	ffprobe -v error \
		-show_entries format_tags=source_url,purl,comment,description \
		-of default=nw=1:nk=1 \
		"$video_file" |
		rg -m1 -o "https?://[^[:space:]]+"
)" || true

if [[ -z "$url" ]]; then
	notify "No URL found in metadata"
	exit 0
fi

# Fire-and-forget the browser launch (`&!` backgrounds + disowns) so Yazi's
# opener task completes the instant extraction is done and never blocks quit.
open "$url" &!
