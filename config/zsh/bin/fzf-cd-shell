#!/usr/bin/env zsh
# Kitty entrypoint (karabiner Cmd+F4): pick a directory with fzf-open,
# then drop into a login shell there.

emulate -L zsh

selected_dir="$(fzf-open)"
if [[ $? -eq 0 && -n "$selected_dir" && -d "$selected_dir" ]]; then
  builtin cd -- "$selected_dir" || true
fi

exec "${SHELL:-/bin/zsh}" -l
