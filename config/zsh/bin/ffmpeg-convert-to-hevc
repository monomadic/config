#!/usr/bin/env zsh
set -euo pipefail

usage() {
  cat >&2 <<EOF
Usage: ${0:t} [--keep-audio] input1 [input2 ...]
  Converts video files to HEVC in MP4 using Apple VideoToolbox hardware encoding.

Options:
  --keep-audio   Keep audio and convert it to AAC.
                 Default is to strip audio (video-only output).
EOF
  exit 1
}

keep_audio=false

while (( $# )); do
  case "$1" in
    --keep-audio) keep_audio=true; shift ;;
    -h|--help) usage ;;
    --*) print -u2 "Unknown option: $1"; usage ;;
    *) break ;;
  esac
done

(( $# >= 1 )) || usage

if $keep_audio; then
  audio_args=(-c:a aac -b:a 192k)
else
  audio_args=(-an)
fi

for infile in "$@"; do
  [[ -f "$infile" ]] || { print -u2 "Skip (not a file): $infile"; continue; }

  ext="${${infile##*.}:l}"
  case "$ext" in
    webm|mp4|mov|mkv|m4v) ;;
    *) print -u2 "Skip (unsupported extension .$ext): $infile"; continue ;;
  esac

  dir="${infile:h}"
  base="${infile:t:r}"
  outfile="${dir}/${base}.hevc.mp4"

  ffmpeg -y -i "$infile" \
    "${audio_args[@]}" \
    -c:v hevc_videotoolbox \
    -b:v 40M \
    -maxrate 40M \
    -bufsize 80M \
    -tag:v hvc1 \
    -movflags +faststart \
    "$outfile"
done
