#!/usr/bin/env zsh
# ============================================================
# video-rotate-lossless
# Losslessly rotate QuickTime-based videos (.mov/.mp4/.m4v) by
# rewriting the container's display-rotation flag — no re-encode.
#
# Pixels are copied verbatim (ffmpeg stream copy); only the display
# matrix changes, so players that honor it (QuickTime, Finder/Quick
# Look, mpv, VLC, ffmpeg autorotate) show the video rotated. ffmpeg
# re-muxes the file, so unlike an in-place metadata edit this also
# works on fragmented MP4 (e.g. processed iPhone clips), which is
# why a plain exiftool/metadata rewrite is not used here.
#
# Rotation is relative to each file's current rotation:
#   --right  rotate 90° clockwise          (default)
#   --left   rotate 90° counter-clockwise
#
# Output:
# - replaces each file in place (atomic mv from a temp beside it)
# - preserves the filesystem modified time, and creation date on macOS
#
# Requirements:
# - zsh
# - ffmpeg / ffprobe
#
# Optional:
# - SetFile   (restores macOS creation date)
# ============================================================

emulate -L zsh
set -euo pipefail

script_name="${0:t}"

usage() {
  cat <<EOF
Usage:
  $script_name [--left | --right] <video1> [video2 ...]

Losslessly rotate .mov/.mp4/.m4v videos by rewriting the container
display-rotation flag (ffmpeg stream copy, no re-encode). Rotation is
relative to each file's current rotation.

Options:
  -r, --right   Rotate 90° clockwise (default)
  -l, --left    Rotate 90° counter-clockwise
  -h, --help    Show this help
EOF
}

die()  { print -r -u2 -- "error: $*"; exit 1; }
warn() { print -r -u2 -- "warning: $*"; }
info() { print -r -- "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }

supported_ext() {
  case "${1:l}" in
    mov|mp4|m4v) return 0 ;;
    *)           return 1 ;;
  esac
}

muxer_for() {
  case "${1:l}" in
    mov) print -- mov ;;
    *)   print -- mp4 ;;
  esac
}

# Current display rotation in clockwise degrees (0/90/180/270), 0 if none.
# ffprobe reports the display-matrix rotation counter-clockwise, so the
# clockwise value is its negation.
current_rotation_cw() {
  local file="$1" raw intval
  raw="$(ffprobe -v error -select_streams v:0 \
        -show_entries stream_side_data=rotation \
        -of default=nw=1:nk=1 -- "$file" 2>/dev/null)" || raw=""
  [[ -n "$raw" ]] || { print -- 0; return; }
  intval="${raw%%.*}"                       # drop any fractional part
  [[ "$intval" == -<-> || "$intval" == <-> ]] || { print -- 0; return; }
  print -- $(( ( -intval % 360 + 360 ) % 360 ))
}

restore_creation_date() {
  local src_epoch="$1" dst="$2" created
  have SetFile || return 0
  [[ "$src_epoch" == <-> ]] || return 0
  (( src_epoch > 0 )) || return 0
  created="$(date -r "$src_epoch" '+%m/%d/%Y %H:%M:%S')" || return 0
  SetFile -d "$created" "$dst" 2>/dev/null \
    || warn "could not restore creation date: ${dst:t}"
}

rotate_one() {
  local file="$1" delta="$2" direction="$3"
  local dir="${file:h}" base="${file:t}" ext="${file:e}"
  local cur new dr fmt tmp btime

  cur="$(current_rotation_cw "$file")"
  new=$(( (cur + delta) % 360 ))
  dr=$(( (360 - new) % 360 ))     # ffmpeg display_rotation (CCW) for target CW angle
  fmt="$(muxer_for "$ext")"

  btime="$(stat -f '%B' -- "$file" 2>/dev/null)" || btime=""
  tmp="${dir}/.${base:r}.rotate.$$.${ext}"

  if ! ffmpeg -hide_banner -loglevel error -y \
        -display_rotation:v:0 "$dr" \
        -i "$file" \
        -map 0 -map_metadata 0 -movflags use_metadata_tags \
        -c copy \
        -f "$fmt" \
        -- "$tmp"; then
    rm -f -- "$tmp"
    warn "ffmpeg failed to rotate: $base"
    return 1
  fi

  touch -r "$file" "$tmp" 2>/dev/null || true
  if ! mv -f -- "$tmp" "$file"; then
    rm -f -- "$tmp"
    warn "failed to replace: $base"
    return 1
  fi
  restore_creation_date "$btime" "$file"

  info "Rotated ${direction}: $base  (${cur}° → ${new}°)"
}

delta=90            # clockwise
direction="right"
typeset -a files=()

while (( $# > 0 )); do
  case "$1" in
    -r|--right) delta=90;  direction="right"; shift ;;
    -l|--left)  delta=270; direction="left";  shift ;;
    -h|--help)  usage; exit 0 ;;
    --)         shift; files+=("$@"); break ;;
    -*)         die "unknown option: $1" ;;
    *)          files+=("$1"); shift ;;
  esac
done

(( ${#files[@]} > 0 )) || { usage; exit 1; }
have ffmpeg  || die "ffmpeg not found"
have ffprobe || die "ffprobe not found"

integer ok_count=0 skip_count=0 fail_count=0

for file in "${files[@]}"; do
  if [[ ! -f "$file" ]]; then
    warn "not a file, skipping: $file"
    (( ++skip_count ))
    continue
  fi

  if ! supported_ext "${file:e}"; then
    warn "unsupported format (need .mov/.mp4/.m4v), skipping: ${file:t}"
    (( ++skip_count ))
    continue
  fi

  if rotate_one "$file" "$delta" "$direction"; then
    (( ++ok_count ))
  else
    (( ++fail_count ))
  fi
done

info "Summary: ok=$ok_count skipped=$skip_count failed=$fail_count"
(( fail_count == 0 ))
