#!/usr/bin/env zsh
#
# copy-kitty-next-pane — copy (or move) files into the next Kitty pane's cwd.
#
# Run it from a shell in one Kitty split. It finds the next window in the
# current tab whose cwd differs from yours (same-directory panes are skipped),
# asks Kitty for that window's working directory, and rsyncs your files there
# with a live progress bar and transfer speed.
#
# Usage:
#   copy-kitty-next-pane [--move] [--check] [--] <path>...
#   <producer> | copy-kitty-next-pane [--move] [--check]   # one path per line on stdin
#
# Options:
#   --move    remove each source once it has copied successfully
#   --check   verify the copy afterwards (checksum pass; nothing should differ)
#   -h|--help show this help
#
# Requires: Kitty with allow_remote_control + listen_on, jq, rsync.

emulate -L zsh
set -euo pipefail

script_name=${0:t}
user_name=${USER:-${LOGNAME:-$(id -un)}}

# --- colors (tasteful; disabled when piped or NO_COLOR is set) --------------
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  c_reset=$'\e[0m'; c_bold=$'\e[1m'; c_dim=$'\e[2m'
  c_label=$'\e[36m'; c_path=$'\e[1;34m'; c_ok=$'\e[32m'
  c_barfill=$'\e[32m'      # progress-bar filled blocks (green)
  c_bardim=$'\e[90m'       # progress-bar empty track (grey)
else
  c_reset= c_bold= c_dim= c_label= c_path= c_ok= c_barfill= c_bardim=
fi
if [[ -t 2 && -z "${NO_COLOR:-}" ]]; then c_err=$'\e[31m'; else c_err=; fi

die()  { print -u2 -- "${c_err}${script_name}:${c_reset} $*"; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

usage() {
  cat <<EOF
$script_name — copy/move files into the next Kitty pane's cwd

Usage:
  $script_name [--move] [--check] [--] <path>...
  <producer> | $script_name [--move] [--check]

Options:
  --move    remove each source once it has copied successfully
  --check   verify the copy afterwards (checksum pass; nothing should differ)
  -h|--help show this help
EOF
  exit "${1:-0}"
}

# --- parse arguments -------------------------------------------------------

move=0
check=0
sources=()

while (( $# )); do
  case "$1" in
    --move)     move=1 ;;
    --check)    check=1 ;;
    -h|--help)  usage 0 ;;
    --)         shift; sources+=("$@"); break ;;
    -*)         die "unknown option: $1 (try --help)" ;;
    *)          sources+=("$1") ;;
  esac
  shift
done

# Fall back to newline-delimited paths on stdin when none were passed.
if (( ${#sources[@]} == 0 )); then
  [[ -t 0 ]] && usage 1
  while IFS= read -r line; do
    [[ -n "$line" ]] && sources+=("$line")
  done
fi

(( ${#sources[@]} )) || die "no source paths given"

have jq || die "jq not found in PATH"

for src in "${sources[@]}"; do
  [[ -e "$src" ]] || die "source does not exist: $src"
done

# --- find the next pane and its cwd ----------------------------------------

self=${KITTY_WINDOW_ID:-}
[[ -n "$self" ]] || die "KITTY_WINDOW_ID unset — run this inside a Kitty window"

kitty_ls() {
  # Prefer the controlling terminal, then known listen sockets.
  kitty @ ls 2>/dev/null && return 0
  local sock
  for sock in "${KITTY_LISTEN_ON:-}" unix:/tmp/kitty "unix:/tmp/kitty-$user_name"; do
    [[ -n "$sock" ]] || continue
    kitty @ --to "$sock" ls 2>/dev/null && return 0
  done
  return 1
}

decode_url() {
  local u=$1
  [[ "$u" == file://* ]] || { print -r -- "$u"; return; }
  if have python3; then
    python3 - "$u" <<'PY'
import sys, urllib.parse as p
print(p.unquote(p.urlparse(sys.argv[1]).path))
PY
  else
    print -r -- "${u#file://}"
  fi
}

# List every OTHER window in the active tab, in layout order, as
#   <window id>  <fg cwd>  <fg command>  <pid,pid,…>
# The last column is EVERY pid in the window's process tree. Kitty's per-window
# cwd tracks whichever process is in front; when a Yazi pane is running fzf (or
# any blocking child) that's the child, not Yazi — so the reported cwd can lag.
# We keep the whole pid list to correlate the pane with a Yazi over DDS below,
# which finds the Yazi even when it isn't the foreground process.
windows=$(
  kitty_ls | jq -r --arg self "$self" '
    def cwdof: (.foreground_processes[-1].cwd // .cwd // "");
    def fgof:  (.foreground_processes[-1].cmdline // [] | (.[0] // ""));
    def pids:  ([.foreground_processes[].pid | tostring] | join(","));
    ( [ .[] | select(.is_active) | .tabs[] | select(.is_active) ] | first ) as $tab
    | ($tab.windows // [])[]
    | select((.id | tostring) != $self)
    | [ (.id | tostring), cwdof, fgof, pids ] | @tsv
  '
) || die "cannot reach Kitty remote control (allow_remote_control + listen_on?)"

# Ask Yazi directly instead of trusting kitty's cwd for Yazi panes.
#
# Every Yazi subscribes to "cwd-req" on Yazi's DDS bus (see config/yazi/init.lua)
# and answers with its live cwd tagged with its own pid. We broadcast one
# request, collect the replies into pid -> cwd, and later match a pane by any
# pid in its process tree. This is authoritative regardless of what the pane's
# foreground process is, and it takes kitty out of the cwd business entirely.
typeset -A yazi_cwd
if have ya; then
  replies=$(mktemp) || die "mktemp failed"
  ya sub cwd-rep >"$replies" 2>/dev/null &
  sub_pid=$!
  sleep 0.15                          # let the subscriber attach before we ask
  ya pub-to 0 cwd-req --str q 2>/dev/null || true
  sleep 0.35                          # brief window for every instance to answer
  kill "$sub_pid" 2>/dev/null || true
  wait "$sub_pid" 2>/dev/null || true

  # Each line is: cwd-rep,<receiver>,<sender>,<json-body>. Strip the three
  # leading comma fields (# is a shortest-match, so it stops at the 3rd comma
  # and leaves the JSON — which contains its own commas — intact).
  while IFS= read -r line; do
    body=${line#*,*,*,}
    [[ "$body" == \{* ]] || continue
    rpid=$(jq -r '.pid // empty' <<<"$body" 2>/dev/null) || continue
    rcwd=$(jq -r '.cwd // empty' <<<"$body" 2>/dev/null) || continue
    [[ -n "$rpid" && -n "$rcwd" ]] && yazi_cwd[$rpid]=$rcwd
  done < "$replies"
  rm -f "$replies"
fi

# A pane's cwd: a DDS answer from any Yazi in its process tree wins (accurate
# even mid-fzf); otherwise fall back to what kitty reports for the foreground
# process (correct for plain shells and other apps).
pane_cwd() {
  local reported=$1 pids=$2 p
  for p in ${(s:,:)pids}; do
    if [[ -n "${yazi_cwd[$p]:-}" ]]; then
      print -r -- "${yazi_cwd[$p]}"
      return
    fi
  done
  print -r -- "$reported"
}

# Pick the target: the first other window whose cwd differs from ours. Copying
# into our own cwd is a no-op, and silently choosing a same-dir pane is exactly
# what led to data loss before — so same-dir panes are skipped. Our own cwd is
# taken from $PWD (Yazi runs shell commands in the hovered directory).
self_cwd=${PWD:A}
dest=
fg=

while IFS=$'\t' read -r wid wcwd wcmd wpids; do
  [[ -n "$wid" ]] || continue
  cand=$(pane_cwd "$(decode_url "$wcwd")" "$wpids")
  [[ -n "$cand" ]] || continue
  [[ "${cand:A}" != "$self_cwd" ]] || continue
  dest=$cand
  fg=$wcmd
  break
done <<< "$windows"

[[ -n "$dest" ]] || die "no eligible next pane found in this tab — need another split
  whose cwd differs from yours ($self_cwd). (Same-directory panes are skipped on purpose.)"

fg_base=${fg:t}

# --- staleness guard -------------------------------------------------------
# A remote/nested session reports its LOCAL launch dir, not where you really
# are — refuse rather than copying somewhere surprising.
case "$fg_base" in
  ssh|mosh|mosh-client|autossh|et|eternal-terminal|docker|podman|kubectl|distrobox-enter|nsenter)
    die "next pane is running '$fg_base' — its reported cwd ($dest) is the local
  launch dir, not the remote/container path. cd to a real local dir there first." ;;
esac

[[ -d "$dest" ]] || die "next pane cwd is not a reachable directory: $dest
  (the pane may be on an unmounted volume or a since-deleted path)"

# --- same-directory guard --------------------------------------------------
# If the destination resolves to a source's own directory, an rsync "copy"
# moves nothing and a naive verify compares the file to itself — after which
# --move would delete the only copy. Refuse outright; this is a data-loss trap.
dest_real=${dest:A}
for src in "${sources[@]}"; do
  src_real=${src:A}
  if [[ "${src_real:h}" == "$dest_real" || "$src_real" == "$dest_real" ]]; then
    die "destination is the source's own directory:
    $dest_real
  Nothing would be copied, and --move would delete '${src:t}'. Refusing.
  (The next pane is in the same folder as the file — pick a different pane.)"
  fi
done

# --- copy ------------------------------------------------------------------

use_bar=0
if [[ -x /opt/homebrew/bin/rsync ]]; then
  rsync_bin=/opt/homebrew/bin/rsync
  copy_opts=(-ah --info=progress2 --protect-args)
  verify_opts=(-an --checksum --itemize-changes --protect-args)
  # For the live bar: raw byte counts (no -h), full file list up front for an
  # accurate percentage, and unbuffered output so \r updates arrive promptly.
  bar_opts=(-a --info=progress2 --no-inc-recursive --outbuf=N --protect-args)
  [[ -t 1 ]] && use_bar=1
else
  rsync_bin=rsync
  copy_opts=(-ah --progress)
  verify_opts=(-an --checksum --itemize-changes)
fi

dest=${dest%/}/
verb="Copying"; (( move )) && verb="Moving"

# Human-readable bytes (1024-based): 1234567 -> 1.2M
humanize() {
  local b=${1:-0}
  if   (( b >= 1073741824 )); then printf '%.2fG' "$(( b / 1073741824.0 ))"
  elif (( b >= 1048576 ));    then printf '%.1fM' "$(( b / 1048576.0 ))"
  elif (( b >= 1024 ));       then printf '%.1fK' "$(( b / 1024.0 ))"
  else                             printf '%dB'   "$b"
  fi
}

# Render a contained progress bar on one line: an indented [████░░░] bar plus
# percent, transferred/total, speed and ETA. Kept well under the terminal width
# (a full-width line would auto-wrap and scroll the labels off screen), redrawn
# in place with \r and cleared to end-of-line with \e[K.
draw_progress() {
  local cols=$1 pct=$2 bytes=$3 rate=$4 eta=$5
  (( pct > 100 )) && pct=100
  (( pct < 0 ))   && pct=0

  local barw=$(( cols - 62 ))
  (( barw > 28 )) && barw=28
  (( barw < 6 ))  && barw=6
  local filled=$(( barw * pct / 100 ))
  (( filled > barw )) && filled=barw
  (( filled < 0 ))    && filled=0
  local empty=$(( barw - filled ))

  local pad= fbar ebar          # pad is set-but-empty so nounset (set -u) is happy
  fbar=${(l:filled:: :)pad}; ebar=${(l:empty:: :)pad}
  fbar=${fbar// /█}; ebar=${ebar// /░}

  local xfer tot
  xfer=$(humanize "$bytes"); tot=$(humanize "$total_bytes")

  local L="  ${c_dim}▕${c_reset}${c_barfill}${fbar}${c_bardim}${ebar}${c_dim}▏${c_reset}"
  L+=" ${c_bold}${(l:3:)pct}%${c_reset}"
  L+="   ${xfer} / ${tot}"
  L+="   ${c_dim}${rate}   ETA ${eta}${c_reset}"

  printf '\r%s\e[K' "$L"
}

# Drive rsync and paint the bar from its progress stream.
copy_with_bar() {
  # errexit OFF for this whole display path. Transient non-zero returns here
  # (tput on a dumb TERM, a false arithmetic clamp, a draw hiccup) must never
  # abort — otherwise the read loop dies and rsync's next progress write hits a
  # closed pipe (rsync exit 13 + SIGUSR1). rsync's real status is captured in
  # $st below and returned, so a genuine copy failure still propagates.
  setopt localoptions noerrexit

  local cols=80
  cols=$(tput cols 2>/dev/null) || cols=80
  [[ "$cols" == <-> ]] || cols=80

  local st
  "$rsync_bin" "${bar_opts[@]}" -- "${sources[@]}" "$dest" | {
    local chunk
    local -a f
    while IFS= read -r -d $'\r' chunk || [[ -n "$chunk" ]]; do
      f=( ${=chunk} )                       # split on whitespace
      [[ ${f[2]:-} == *% ]] || continue     # progress lines look like: BYTES NN% RATE ETA
      local pct=${f[2]%\%}
      [[ $pct == <-> ]] || continue
      draw_progress "$cols" "$pct" "${f[1]//,/}" "${f[3]:-}" "${f[4]:-}"
    done
    :                                        # group exits 0 so pipefail reflects rsync's status
  }
  st=$?                                      # pipeline status (pipefail-aware): rsync's exit
  print -r -- ""                             # end the bar line
  return $st                                 # propagate copy failure even without set -e
}

print -r -- ""
print -r -- "${c_bold}${c_label}Destination:${c_reset}"
print -r -- "  ${c_path}${dest}${c_reset}"
print -r -- "${c_bold}${c_label}${verb} ${#sources[@]} item(s):${c_reset}"

if (( use_bar )); then
  total_bytes=0
  for src in "${sources[@]}"; do
    if [[ -d "$src" ]]; then
      total_bytes=$(( total_bytes + $(du -sk -- "$src" | awk '{print $1}') * 1024 ))
    else
      total_bytes=$(( total_bytes + $(stat -f%z -- "$src") ))
    fi
  done
  copy_with_bar
else
  "$rsync_bin" "${copy_opts[@]}" -- "${sources[@]}" "$dest"
fi

# Per-source checksum verification: empty output == destination is byte-for-byte
# identical to the source. Returns non-zero if anything differs.
verify_one() {
  local src=$1 out
  out=$("$rsync_bin" "${verify_opts[@]}" -- "$src" "$dest") || return 2
  [[ -z "$out" ]]
}

# --- verify (--check) ------------------------------------------------------

if (( check )); then
  print -r -- "${c_dim}Verifying (checksum)…${c_reset}"
  bad=0
  for src in "${sources[@]}"; do
    verify_one "$src" || { bad=1; print -u2 -- "  differs after copy: ${src:t}"; }
  done
  (( bad )) && die "verification FAILED — destination does not match source"
  print -r -- "  ${c_ok}✓${c_reset} verified — destination matches source"
fi

# --- move: delete each source ONLY after proving a distinct, identical copy --
# This is unconditional — it runs even without --check. A source is removed
# only when its counterpart at the destination (a) exists, (b) is a different
# real path, and (c) is confirmed byte-identical by checksum.
if (( move )); then
  for src in "${sources[@]}"; do
    tgt=${dest}${src:t}
    [[ -e "$tgt" ]]                 || die "not deleting '${src:t}': no copy found at destination"
    [[ "${src:A}" != "${tgt:A}" ]]  || die "not deleting '${src:t}': destination is the same file"
    verify_one "$src"               || die "not deleting '${src:t}': destination copy differs (checksum)"
    rm -rf -- "$src"
  done
  print -r -- "${c_ok}${c_bold}✓ moved ${#sources[@]} item(s)${c_reset}"
else
  print -r -- "${c_ok}${c_bold}✓ copied ${#sources[@]} item(s)${c_reset}"
fi
