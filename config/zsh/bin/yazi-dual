#!/usr/bin/env zsh

emulate -L zsh
set -euo pipefail

script_name="${0:t}"
script_path="${0:A}"
user_name="${USER:-${LOGNAME:-$(id -un)}}"

usage() {
  cat <<EOF
$script_name

Launch a two-pane Yazi pair in Kitty and copy from either pane to the other.

Usage:
  $script_name launch [LEFT_DIR [RIGHT_DIR]]
  $script_name pane <left|right> <SESSION_DIR> <START_DIR>
  $script_name copy <PATH>...
  $script_name move <PATH>...
  $script_name jump
  $script_name push
  $script_name copy-run <TARGET_DIR_OR_REMOTE> <PATH>...
  $script_name move-run <TARGET_DIR_OR_REMOTE> <PATH>...
  $script_name peer-cwd

  copy/move  transfer selected paths to the sibling pane's cwd
  jump       cd this Yazi to the sibling pane's cwd
  push       make the sibling shell cd to this pane's cwd

The copy/move commands auto-detect the peer pane: the other Kitty window in
the current tab. No yazi-dual launch required — works for any Yazi in any
split. If launched via 'yazi-dual launch', that peer is preferred.

Keys are wired from Yazi, but the commands are useful directly:
  yazi-dual launch
  yazi-dual copy file1 file2

The launch command gives each Yazi pane a YAZI_DUAL_TARGET_WINDOW_ID pointing
at the other Kitty window. The copy command asks Kitty for that window's current
cwd at transfer time.
EOF
}

have() {
  command -v "$1" >/dev/null 2>&1
}

# POSIX single-quote a string so it survives being typed into a shell.
squote() {
  print -r -- "${(qq)1}"
}

normalize_dir() {
  local input="${1:-$PWD}"

  [[ -f "$input" ]] && input="${input:h}"
  [[ -d "$input" ]] || {
    print -u2 -- "$script_name: not a directory: $input"
    return 1
  }

  print -r -- "${input:A}"
}

candidate_sockets() {
  [[ -n "${YAZI_DUAL_KITTY_SOCKET:-}" ]] && print -r -- "$YAZI_DUAL_KITTY_SOCKET"
  [[ -n "${KITTY_LISTEN_ON:-}" ]] && print -r -- "$KITTY_LISTEN_ON"

  local socket_file
  for socket_file in /tmp/kitty /tmp/kitty-"$user_name" /tmp/kitty-* /tmp/kitty.*(N); do
    [[ -S "$socket_file" ]] || continue
    print -r -- "unix:$socket_file"
  done
}

discover_socket() {
  local candidate
  local -a seen
  seen=()

  while IFS= read -r candidate; do
    [[ -n "$candidate" ]] || continue
    (( ${seen[(Ie)$candidate]} )) && continue
    seen+=( "$candidate" )

    if kitty @ --to "$candidate" ls >/dev/null 2>&1; then
      print -r -- "$candidate"
      return 0
    fi
  done < <(candidate_sockets)

  if kitty @ ls >/dev/null 2>&1; then
    print -r -- ""
    return 0
  fi

  return 1
}

kitty_remote() {
  local socket="$1"
  shift

  if [[ -n "$socket" ]]; then
    command kitty @ --to "$socket" "$@"
  else
    command kitty @ "$@"
  fi
}

decode_cwd() {
  local cwd="$1"

  if [[ "$cwd" == file://* ]] && have python3; then
    python3 - "$cwd" <<'PY'
import sys
from urllib.parse import unquote, urlparse

url = urlparse(sys.argv[1])
print(unquote(url.path))
PY
    return
  fi

  print -r -- "$cwd"
}

window_cwd() {
  local window_id="$1"
  local socket
  socket="$(discover_socket)" || {
    print -u2 -- "$script_name: cannot reach Kitty remote control"
    return 1
  }

  local cwd
  cwd="$(
    kitty_remote "$socket" ls |
      jq -r --arg id "$window_id" '
        def cwd_value:
          if .cwd == null then empty
          elif (.cwd | type) == "string" then .cwd
          elif (.cwd | type) == "object" then (.cwd.path // .cwd.uri // .cwd.file // empty)
          else empty end;

        [.[].tabs[]?.windows[]? | select((.id | tostring) == $id) | cwd_value][0] // empty
      '
  )"

  [[ -n "$cwd" ]] || {
    print -u2 -- "$script_name: Kitty window not found or has no cwd: $window_id"
    return 1
  }

  decode_cwd "$cwd"
}

# Basename of the program running in the foreground of a Kitty window
# (e.g. zsh, ssh, docker). Empty if it can't be determined.
window_fg_cmd() {
  local window_id="$1"
  local socket
  socket="$(discover_socket)" || return 1

  kitty_remote "$socket" ls |
    jq -r --arg id "$window_id" '
      [ .[].tabs[]?.windows[]? | select((.id | tostring) == $id)
        | (.foreground_processes // [])
        | (.[-1].cmdline // [])
        | (.[0] // empty) ][0] // empty
    '
}

# Resolve and validate the peer pane cwd. Prints a usable local directory on
# stdout, or aborts (non-zero) with a message when the reported cwd is stale
# or misleading. This is the guard against copying into thin air.
peer_target_dir() {
  local target_id="$1"

  local target
  target="$(window_cwd "$target_id")" || return 1

  # A remote/nested session reports the LOCAL launch dir, not where you really
  # are — copying there would silently land in the wrong place.
  local fg fg_base
  fg="$(window_fg_cmd "$target_id" 2>/dev/null)"
  fg_base="${fg:t}"
  case "$fg_base" in
    ssh|mosh|mosh-client|autossh|et|eternal-terminal|docker|podman|kubectl|distrobox-enter|nsenter)
      print -u2 -- "$script_name: peer pane is running '$fg_base' — its reported cwd"
      print -u2 -- "  ($target) is the local launch dir, not the remote/container path."
      print -u2 -- "  Aborting to avoid a surprise transfer. cd to a real local dir there first."
      return 1
      ;;
  esac

  # Stale / gone: the reported cwd must be a reachable local directory.
  [[ -d "$target" ]] || {
    print -u2 -- "$script_name: peer cwd is not a reachable directory:"
    print -u2 -- "  $target"
    print -u2 -- "  (the pane may be on an unmounted volume or a since-deleted path)"
    return 1
  }

  print -r -- "$target"
}

wait_for_peer_id() {
  local file="$1"

  for _ in {1..200}; do
    [[ -s "$file" ]] && {
      <"$file"
      return 0
    }
    sleep 0.05
  done

  return 1
}

pane() {
  (( $# == 3 )) || {
    print -u2 -- "Usage: $script_name pane <left|right> <SESSION_DIR> <START_DIR>"
    return 2
  }

  local side="$1"
  local session_dir="$2"
  local start_dir="$3"
  local peer

  case "$side" in
    left) peer="right" ;;
    right) peer="left" ;;
    *)
      print -u2 -- "$script_name: pane side must be left or right"
      return 2
      ;;
  esac

  local peer_id
  peer_id="$(wait_for_peer_id "$session_dir/$peer.id")" || {
    print -u2 -- "$script_name: timed out waiting for $peer pane"
    exec "${SHELL:-/bin/zsh}" -l
  }

  export YAZI_DUAL_SIDE="$side"
  export YAZI_DUAL_SESSION="$session_dir"
  export YAZI_DUAL_SELF_WINDOW_ID="${KITTY_WINDOW_ID:-}"
  export YAZI_DUAL_TARGET_WINDOW_ID="$peer_id"

  exec yazi "$start_dir"
}

launch_pair() {
  local left_dir
  local right_dir
  left_dir="$(normalize_dir "${1:-$PWD}")"
  right_dir="$(normalize_dir "${2:-$left_dir}")"

  have kitty || {
    print -u2 -- "$script_name: kitty not found in PATH"
    return 127
  }

  local socket
  socket="$(discover_socket)" || {
    print -u2 -- "$script_name: cannot reach Kitty remote control"
    print -u2 -- "$script_name: start Kitty with allow_remote_control/listen_on, then retry"
    return 1
  }

  local session_dir
  session_dir="$(mktemp -d "${TMPDIR:-/tmp}/yazi-dual.XXXXXX")"

  local left_id
  left_id="$(
    kitty_remote "$socket" launch \
      --type=tab \
      --tab-title " yazi dual " \
      --title " yazi left " \
      --cwd "$left_dir" \
      --env "YAZI_DUAL_KITTY_SOCKET=$socket" \
      --env "YAZI_DUAL_SESSION=$session_dir" \
      --env "YAZI_DUAL_SIDE=left" \
      -- "$script_path" pane left "$session_dir" "$left_dir"
  )"
  [[ "$left_id" == <-> ]] || {
    print -u2 -- "$script_name: failed to launch left pane"
    return 1
  }
  print -r -- "$left_id" >| "$session_dir/left.id"

  kitty_remote "$socket" goto-layout splits --match "window_id:$left_id" >/dev/null 2>&1 || true

  local right_id
  right_id="$(
    kitty_remote "$socket" launch \
      --type=window \
      --match "window_id:$left_id" \
      --next-to "id:$left_id" \
      --location=hsplit \
      --bias=50 \
      --title " yazi right " \
      --cwd "$right_dir" \
      --env "YAZI_DUAL_KITTY_SOCKET=$socket" \
      --env "YAZI_DUAL_SESSION=$session_dir" \
      --env "YAZI_DUAL_SIDE=right" \
      -- "$script_path" pane right "$session_dir" "$right_dir"
  )"
  [[ "$right_id" == <-> ]] || {
    print -u2 -- "$script_name: failed to launch right pane"
    return 1
  }
  print -r -- "$right_id" >| "$session_dir/right.id"

  kitty_remote "$socket" focus-window --match "id:$left_id" >/dev/null 2>&1 || true
}

rsync_bin() {
  if [[ -x /opt/homebrew/bin/rsync ]]; then
    print -r -- /opt/homebrew/bin/rsync
  else
    print -r -- rsync
  fi
}

copy_with_rsync() {
  local target="$1"
  shift

  [[ -d "$target" ]] || {
    print -u2 -- "$script_name: target is not a local directory: $target"
    return 1
  }

  local rsync
  rsync="$(rsync_bin)"

  local -a progress_opts
  if "$rsync" --version | awk 'NR==1{split($3,v,"."); exit !((v[1]>3)|| (v[1]==3 && v[2]>=1))}'; then
    progress_opts=( --info=progress2 )
  else
    progress_opts=( --progress )
  fi

  print -r -- "rsync target: $target"
  "$rsync" -a -h "${progress_opts[@]}" --protect-args -- "$@" "${target%/}/"
}

copy_with_rclone() {
  local target="$1"
  shift

  have rclone || {
    print -u2 -- "$script_name: rclone not found in PATH"
    return 127
  }

  local source
  print -r -- "rclone target: $target"
  for source in "$@"; do
    if [[ -d "$source" ]]; then
      rclone copy --progress -- "$source" "${target%/}/${source:t}"
    else
      rclone copy --progress -- "$source" "$target"
    fi
  done
}

copy_run() {
  (( $# >= 2 )) || {
    print -u2 -- "Usage: $script_name copy-run <TARGET_DIR_OR_REMOTE> <PATH>..."
    return 2
  }

  local target="$1"
  shift

  local source
  for source in "$@"; do
    [[ -e "$source" ]] || {
      print -u2 -- "$script_name: source does not exist: $source"
      return 1
    }
  done

  if [[ "$target" != /* && "$target" == *:* ]]; then
    copy_with_rclone "$target" "$@"
  else
    copy_with_rsync "$target" "$@"
  fi
}

# Auto-detect the peer: the other window in whichever tab holds this Yazi.
# No launch-time setup needed — works for any Yazi in any Kitty split.
auto_peer_id() {
  local self="${KITTY_WINDOW_ID:-}"
  [[ -n "$self" ]] || {
    print -u2 -- "$script_name: KITTY_WINDOW_ID unset (not running inside Kitty?)"
    return 1
  }

  local socket
  socket="$(discover_socket)" || {
    print -u2 -- "$script_name: cannot reach Kitty remote control"
    return 1
  }

  local -a ids
  ids=( ${(f)"$(
    kitty_remote "$socket" ls |
      jq -r --arg self "$self" '
        [ .[].tabs[]? | select(any(.windows[]?; (.id | tostring) == $self)) ][0] as $tab
        | ($tab.windows // [])
        | [ .[] | select((.id | tostring) != $self) ]
        | ( [ .[] | select(.is_active) ][0] // .[0] )
        | .id // empty
      '
  )"} )

  [[ -n "${ids[1]:-}" ]] || {
    print -u2 -- "$script_name: no other pane found in this tab"
    return 1
  }

  print -r -- "${ids[1]}"
}

resolve_target_id() {
  local target_id="${YAZI_DUAL_TARGET_WINDOW_ID:-}"

  # Trust a launch-time peer only if it still exists; else auto-detect.
  if [[ -n "$target_id" ]] && window_cwd "$target_id" >/dev/null 2>&1; then
    print -r -- "$target_id"
    return 0
  fi

  auto_peer_id
}

transfer_to_peer() {
  local mode="$1"
  shift

  (( $# )) || {
    print -u2 -- "$script_name: no selected paths to $mode"
    return 1
  }

  local target_id
  target_id="$(resolve_target_id)" || return 1

  local target
  target="$(peer_target_dir "$target_id")" || return 1

  # Refuse when the peer cwd is a source's own directory (local targets only):
  # a self-copy transfers nothing and 'move' would then delete the only copy.
  if [[ "$target" == /* || "$target" != *:* ]]; then
    local s
    for s in "$@"; do
      if [[ "${s:A:h}" == "${target:A}" || "${s:A}" == "${target:A}" ]]; then
        print -u2 -- "$script_name: peer cwd is the source's own directory ($target) —"
        print -u2 -- "  nothing would transfer and 'move' would delete '${s:t}'. Refusing."
        return 1
      fi
    done
  fi

  local socket
  socket="$(discover_socket || true)"

  local title=" yazi copy "
  [[ "$mode" == move ]] && title=" yazi move "

  if [[ -n "$socket" || -n "${KITTY_WINDOW_ID:-}" ]]; then
    local -a launch_args
    launch_args=(
      launch
      --type=window
      --location=hsplit
      --bias=30
      --hold
      --title "$title"
      --cwd "$PWD"
    )

    [[ -n "${KITTY_WINDOW_ID:-}" ]] && launch_args+=( --match "window_id:$KITTY_WINDOW_ID" --next-to "id:$KITTY_WINDOW_ID" )

    kitty_remote "$socket" "${launch_args[@]}" -- "$script_path" "$mode-run" "$target" "$@" >/dev/null
  else
    "${mode}_run" "$target" "$@"
  fi
}

copy_to_peer() { transfer_to_peer copy "$@"; }
move_to_peer() { transfer_to_peer move "$@"; }

move_run() {
  (( $# >= 2 )) || {
    print -u2 -- "Usage: $script_name move-run <TARGET_DIR_OR_REMOTE> <PATH>..."
    return 2
  }

  local target="$1"
  shift

  # Copy first; only remove the sources once the copy has fully succeeded.
  copy_run "$target" "$@" || return 1

  local source tgt rsync
  rsync="$(rsync_bin)"
  for source in "$@"; do
    if [[ "$target" != /* && "$target" == *:* ]]; then
      # rclone remote: copy_run already verifies hashes on transfer.
      rm -rf -- "$source"
      continue
    fi

    tgt="${target%/}/${source:t}"
    [[ -e "$tgt" ]] || {
      print -u2 -- "$script_name: not deleting '${source:t}': no copy at target"
      continue
    }
    [[ "${source:A}" != "${tgt:A}" ]] || {
      print -u2 -- "$script_name: not deleting '${source:t}': same file as target"
      continue
    }
    if [[ -n "$("$rsync" -an --checksum --itemize-changes --protect-args -- "$source" "${target%/}/")" ]]; then
      print -u2 -- "$script_name: not deleting '${source:t}': target copy differs (checksum)"
      continue
    fi
    rm -rf -- "$source"
  done
}

# Jump: cd THIS Yazi to the sibling pane's cwd.
cd_to_peer() {
  [[ -n "${YAZI_ID:-}" ]] || {
    print -u2 -- "$script_name: YAZI_ID unset — 'jump' must be run from within Yazi"
    return 1
  }

  local target_id
  target_id="$(resolve_target_id)" || return 1

  local target
  target="$(peer_target_dir "$target_id")" || return 1

  ya emit cd "$target"
}

# Clone/push: make the sibling shell cd to THIS pane's cwd, by typing the
# command into it. Only fires when the sibling is actually at a shell prompt.
push_cwd_to_peer() {
  local target_id
  target_id="$(resolve_target_id)" || return 1

  local fg fg_base
  fg="$(window_fg_cmd "$target_id" 2>/dev/null)"
  fg_base="${fg:t}"
  fg_base="${fg_base#-}"   # strip login-shell leading dash (e.g. -zsh)
  case "$fg_base" in
    zsh|bash|fish|sh|dash|ksh|mksh|tcsh|csh|nu|xonsh|elvish) : ;;
    *)
      print -u2 -- "$script_name: sibling isn't at a shell prompt (running: ${fg_base:-unknown});"
      print -u2 -- "  can't push a 'cd' into it. Focus a shell in that pane and retry."
      return 1
      ;;
  esac

  local socket
  socket="$(discover_socket)" || {
    print -u2 -- "$script_name: cannot reach Kitty remote control"
    return 1
  }

  # --stdin sends bytes as-is (no escape interpretation), so shell-quoting in
  # the path survives intact; the trailing newline runs the cd.
  print -r -- "cd $(squote "$PWD")" |
    kitty_remote "$socket" send-text --match "id:$target_id" --stdin
}

peer_cwd() {
  local target_id
  target_id="$(resolve_target_id)" || return 1
  window_cwd "$target_id"
}

main() {
  local command_name="${1:-}"
  [[ $# -gt 0 ]] && shift

  case "$command_name" in
    launch) launch_pair "$@" ;;
    pane) pane "$@" ;;
    copy) copy_to_peer "$@" ;;
    move) move_to_peer "$@" ;;
    jump) cd_to_peer "$@" ;;
    push) push_cwd_to_peer "$@" ;;
    copy-run) copy_run "$@" ;;
    move-run) move_run "$@" ;;
    peer-cwd) peer_cwd "$@" ;;
    -h|--help|"") usage ;;
    *)
      print -u2 -- "$script_name: unknown command: $command_name"
      usage >&2
      return 2
      ;;
  esac
}

main "$@"
