#!/usr/bin/env zsh
# Helper for the fzf Tab-completion picker.
# Wired in via FZF_COMPLETION_OPTS in config/zsh/autoload/fzf.zsh, and driven by
# the picker in config/zsh/autoload/fzf-completions.zsh (lincheney/fzf-tab-completion).
#
# The picker's fzf gets a bunch of packed fields per line; field {1} is the full
# completion value, (q)-quoted. We resolve it and use it to:
#   window   -> emit a change-preview-window action (reveal when there is a
#               location / definition to show, hide otherwise)
#   preview  -> show the location, then bat a text file / the alias / function
#               definition (binaries show their path + type)
#   edit     -> open the resolved file (a script, or the file defining the
#               alias / function) in $EDITOR
#   copy     -> copy the resolved absolute path to the clipboard
#
# Usage: fzf-comp-preview <window|preview|edit|copy> {1}
emulate -L zsh

action=$1
val=${(Q)2}   # field {1} is (q)-quoted; strip one level of quoting

# Resolve a completion value to an absolute file path, or fail.
_resolve() {
  local v=$1 p
  [[ -z $v ]] && return 1
  if [[ -e $v ]]; then
    print -r -- ${v:A}
    return 0
  fi
  # command completions: only accept a real external binary/script, not
  # builtins/functions/aliases (command -v returns a bare name for those).
  p=$(command -v -- "$v" 2>/dev/null)
  [[ -n $p && $p == /* && -f $p ]] && { print -r -- ${p:A}; return 0 }
  return 1
}

# True if the path is a previewable text file (script, config, etc).
# Pure zsh, no external commands: reveal for a shebang or a first line that
# holds no NUL/control bytes; compiled binaries fail both checks.
_is_text() {
  [[ -f $1 ]] || return 1
  local first
  IFS= read -r first < "$1" 2>/dev/null
  [[ $first == '#!'* ]] && return 0
  [[ -n $first && $first != *[$'\1'-$'\10'$'\13'$'\14'$'\16'-$'\37']* ]]
}

# Describe a bare word that is an alias / function / builtin. Sources the user's
# zshrc so it sees their aliases and functions (they load from zshrc, not
# zshenv, so a plain subshell wouldn't know them).
#
# IMPORTANT: this must be a NON-interactive shell. An interactive one (zsh -i)
# fights fzf for control of the terminal (job control / tcsetpgrp) and soft-hangs
# the preview. `zsh -c` just defines things and exits — no tty contention.
#
# Emits three sections, newline-separated:
#   line 1  <lang>       bat language for the body, or "none"
#   line 2  <location>   absolute file where it is defined (may be empty)
#   line 3+ <body>       the definition text
# Empty output means "nothing to show". Skipped for paths and option flags.
_describe() {
  [[ -z $val || $val == -* || $val == */* ]] && return 1
  zsh -c '
    source ~/.zshrc >/dev/null 2>&1
    zmodload zsh/parameter 2>/dev/null
    w=$1
    o=$(whence -w -- "$w" 2>/dev/null); t=${o##*: }
    # Best-effort: find the file+line that defines an alias (zsh does not track it).
    _alias_src() {
      local files hit f l
      files=( ${ZSH_CONFIG_DIR:-$ZDOTDIR}/**/*.zsh(N) ~/.zshrc(N) )
      (( ${#files} )) || return 1
      hit=$(grep -EnH "^[[:space:]]*alias([[:space:]]+-[[:alpha:]]+)*[[:space:]]+${w}=" -- $files 2>/dev/null | head -1)
      [[ -n $hit ]] || return 1
      f=${hit%%:*}; l=${${hit#*:}%%:*}
      print -r -- "${f:A}:${l}"
    }
    case $t in
      alias)
        print -r -- zsh
        print -r -- "$(_alias_src)"
        print -r -- "$w=${(qq)aliases[$w]}"
        ;;
      function)
        print -r -- zsh
        local src=${functions_source[$w]}
        print -r -- "${src:+${src:A}}"
        functions -- "$w"
        ;;
      builtin|reserved)
        print -r -- none
        print -r --
        whence -v -- "$w"
        ;;
    esac
  ' fzf-comp-describe "$val" 2>/dev/null
}

# Print a dim location header (the path) above the preview body.
_hdr() {
  [[ -n $1 ]] || return
  print -r -- $'\e[2m'"$1"$'\e[0m'
  print -r --
}

# Absolute file to act on (edit / copy): a resolved file, or the file that
# defines the focused alias / function. Empty for builtins / unknown words.
_target_file() {
  [[ -n $target ]] && { print -r -- "$target"; return 0 }
  local desc loc
  desc=$(_describe) && [[ -n $desc ]] || return 1
  loc=${${desc#*$'\n'}%%$'\n'*}   # section 2: location
  loc=${loc%:<->}                 # drop any :line suffix -> pure path
  [[ -n $loc ]] && print -r -- "$loc"
}

# NB: never name this `path` — in zsh that is the special array bound to $PATH,
# and assigning a scalar to it wipes out the command search path.
target=$(_resolve "$val") || target=

case $action in
  window)
    # reveal the preview pane when there is something to show: any resolved file
    # (its location, plus contents for text), or a describable alias/function/builtin.
    local show=
    if [[ -n $target ]] || [[ -n $(_describe) ]]; then
      show=1
    fi
    if [[ -n $show ]]; then
      print -r -- 'change-preview-window(right,55%,border-left)'
    else
      print -r -- 'change-preview-window(hidden)'
    fi
    ;;
  preview)
    if [[ -n $target ]]; then
      _hdr "$target"
      if _is_text "$target"; then
        bat --color=always --style=numbers --paging=never -- "$target" 2>/dev/null \
          || cat -- "$target"
      else
        file -b -- "$target" 2>/dev/null   # binary: just its type
      fi
      exit 0
    fi
    local desc lang loc body rest
    desc=$(_describe) && [[ -n $desc ]] || exit 0
    lang=${desc%%$'\n'*}; rest=${desc#*$'\n'}
    loc=${rest%%$'\n'*};  body=${rest#*$'\n'}
    _hdr "$loc"
    if [[ $lang == none ]]; then
      print -r -- "$body"
    else
      print -r -- "$body" \
        | bat --color=always --style=plain --language="$lang" --paging=never 2>/dev/null \
        || print -r -- "$body"
    fi
    ;;
  edit)
    local f; f=$(_target_file) || exit 0
    "${(@s: :)${EDITOR:-hx}}" "$f"
    ;;
  copy)
    local f; f=$(_target_file) || exit 0
    printf '%s' "$f" | pbcopy
    ;;
esac
