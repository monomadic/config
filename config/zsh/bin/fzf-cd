#!/bin/zsh
set +o monitor

# 00F0F0 aqua
# 00A0F0 light blue
# FF992e oraange

# Color Scheme
FZF_COLOR_OPTS=""
FZF_COLOR_OPTS+="fg:#00A0F0,"      # Regular foreground
FZF_COLOR_OPTS+="bg:#002080,"      # Regular background
FZF_COLOR_OPTS+="hl:#FFe22e,"      # Highlighted text (foreground)
FZF_COLOR_OPTS+="hl+:#FFe22e,"     # Highlighted text in selected line (foreground)
FZF_COLOR_OPTS+="fg+:#DDFFAA,"     # Selected line (foreground)
FZF_COLOR_OPTS+="bg+:#40609F,"     # Selected line (background)
FZF_COLOR_OPTS+="info:#0f81ff,"    # Info line
FZF_COLOR_OPTS+="border:#0040A0,"  # Border color
FZF_COLOR_OPTS+="prompt:#FFFFFF,"  # Prompt
FZF_COLOR_OPTS+="pointer:#FFe22e," # Pointer to the current line
FZF_COLOR_OPTS+="marker:#a6e22e,"  # Multi-select marker
FZF_COLOR_OPTS+="spinner:#FFFFFF,"
FZF_COLOR_OPTS+="preview-bg:#111111,"
FZF_COLOR_OPTS+="preview-border:#111111,"
FZF_COLOR_OPTS+="gutter:#44AADD,"  # non-selected icons
FZF_COLOR_OPTS+="header:#66ddee"
#--color=bg:-1,fg:blue,info:15,header:7,hl:red,hl+:red,gutter:-1,prompt:yellow,marker:-1,bg+:black,pointer:yellow,fg+:yellow

handle_directory_selection() {
  local prompt='  '
  local header=''
  local height='50%'
  local preview_cmd='eza --tree --level=2 --color=always {} 2>/dev/null || ls -la {}'
  local -a extra_fzf_args=()

  while (( $# )); do
    case "$1" in
      --prompt)
        prompt="${2:-$prompt}"
        shift 2
        ;;
      --header)
        header="${2:-$header}"
        shift 2
        ;;
      --height)
        height="${2:-$height}"
        shift 2
        ;;
      --preview-cmd)
        preview_cmd="${2:-$preview_cmd}"
        shift 2
        ;;
      --)
        shift
        extra_fzf_args+=("$@")
        break
        ;;
      *)
        extra_fzf_args+=("$1")
        shift
        ;;
    esac
  done

  local dir
  # Read directly from stdin so fzf can exit immediately on selection without
  # waiting for upstream producers to finish writing.
  dir=$(
    fzf \
      --color="$FZF_COLOR_OPTS" \
      --ansi \
      --gutter='󰉋' --pointer=' ' --marker='󰉋 ' \
      --header="$header" \
      --no-info \
      --no-clear \
      --border=block \
      --input-border=rounded \
      --margin=0 \
      --padding=0 \
      --preview "$preview_cmd" \
      --preview-window='hidden,right,55%,border-left,wrap' \
      --bind 'alt-n:preview-page-down,alt-u:preview-page-up' \
      --bind 'alt-r:execute-silent(open {})' \
      --bind 'ctrl-/:toggle-preview' \
      --bind 'alt-p:toggle-preview' \
      --bind 'ctrl-a:toggle-all' \
      --height="$height" \
      --exact \
      --prompt="$prompt" \
      "${extra_fzf_args[@]}"
  )
  local ret=$?

  if [[ $ret -eq 0 && -n "$dir" ]]; then
    printf '%s\n' "$dir"
  fi
  return $ret
}

handle_directory_selection "$@"
