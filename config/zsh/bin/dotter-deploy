#!/usr/bin/env zsh

set -euo pipefail

# This file lives at <repo>/config/zsh/bin/dotter-deploy and is symlinked onto
# PATH, so resolve through the symlink (:A) to find the checkout it belongs to.
# The repo can therefore live anywhere, not just ~/config.
CONFIG_DIR="${${0:A}:h:h:h:h}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
CACHE_DIR="$XDG_CONFIG_HOME/dotter/cache"
CACHE_FILE="$XDG_CONFIG_HOME/dotter/cache.toml"
GLOBAL_CONFIG="$CONFIG_DIR/dotter/global.toml"
LOCAL_CONFIG="$CONFIG_DIR/dotter/local.toml"
MACOS_ICON_SCRIPT="$CONFIG_DIR/setup/macos/apply-file-icons.sh"
HEALTHCHECK_SCRIPT="$CONFIG_DIR/setup/macos/check.sh"
YAZI_PACKAGE_MANIFEST="$XDG_CONFIG_HOME/yazi/package.toml"
YAZI_PACKAGE_PLUGIN_DIR="$XDG_CONFIG_HOME/yazi/plugins"
FULL_DEPLOY=0
SCRIPT_NAME="${0:t}"

usage() {
  cat <<EOF
Usage: $SCRIPT_NAME [--full]

Runs Dotter deploy. Use --full to also sync Yazi packages and apply macOS app icons.
EOF
}

while (( $# > 0 )); do
  case "$1" in
    --full)
      FULL_DEPLOY=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Error: unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

if [[ ! -d "$CONFIG_DIR" ]]; then
  echo "Error: dotfiles directory not found: $CONFIG_DIR"
  exit 1
fi

if [[ ! -f "$GLOBAL_CONFIG" ]]; then
  echo "Error: Dotter global config not found: $GLOBAL_CONFIG"
  exit 1
fi

if [[ ! -f "$LOCAL_CONFIG" ]]; then
  echo "Error: Dotter local config not found: $LOCAL_CONFIG"
  echo "Create it from one of the examples in $CONFIG_DIR/dotter/."
  exit 1
fi

mkdir -p "$CACHE_DIR"

if [[ -x "$HEALTHCHECK_SCRIPT" ]] && [[ "${DOTTER_SKIP_HEALTHCHECK:-0}" != "1" ]]; then
  "$HEALTHCHECK_SCRIPT"
fi

prepare_yazi_package_manifest() {
  local source_manifest="$CONFIG_DIR/config/yazi/package.toml"

  if [[ ! -f "$source_manifest" ]] || [[ ! -f "$YAZI_PACKAGE_MANIFEST" ]] || [[ -L "$YAZI_PACKAGE_MANIFEST" ]]; then
    return
  fi

  if cmp -s "$source_manifest" "$YAZI_PACKAGE_MANIFEST"; then
    rm -f "$YAZI_PACKAGE_MANIFEST"
  fi
}

prepare_yazi_package_dirs() {
  local dir

  mkdir -p "$YAZI_PACKAGE_PLUGIN_DIR"

  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue

    dir="$YAZI_PACKAGE_PLUGIN_DIR/$dir"
    if [[ -L "$dir" ]]; then
      rm -f "$dir"
    elif [[ -d "$dir" ]]; then
      find "$dir" -type l -delete
    fi
  done < <(
    awk -F '"' '
      /^[[:space:]]*use[[:space:]]*=/ {
        name = $2
        sub(/^.*:/, "", name)
        sub(/^.*\//, "", name)
        if (name !~ /\.yazi$/) name = name ".yazi"
        print name
      }
    ' "$YAZI_PACKAGE_MANIFEST"
  )
}

prepare_yazi_local_plugin_dirs() {
  local source_plugins="$CONFIG_DIR/config/yazi/plugins"
  local source_dir
  local source_file
  local target_dir
  local target_file

  [[ -d "$source_plugins" ]] || return

  mkdir -p "$YAZI_PACKAGE_PLUGIN_DIR"

  for source_dir in "$source_plugins"/*.yazi(N/); do
    target_dir="$YAZI_PACKAGE_PLUGIN_DIR/${source_dir:t}"

    if [[ -L "$target_dir" && "${target_dir:A}" == "${source_dir:A}" ]]; then
      rm -f "$target_dir"
      mkdir -p "$target_dir"
    elif [[ -d "$target_dir" && ! -L "$target_dir" ]]; then
      for source_file in "$source_dir"/*(N); do
        [[ -f "$source_file" || -L "$source_file" ]] || continue

        target_file="$target_dir/${source_file:t}"
        [[ -e "$target_file" || -L "$target_file" ]] || continue

        if [[ ! -L "$target_file" ]] || [[ "${target_file:A}" != "${source_file:A}" ]]; then
          rm -f "$target_file"
        fi
      done
    fi
  done
}

install_yazi_packages() {
  local install_help
  local -a install_args=()

  if [[ "${DOTTER_SKIP_YAZI_PACKAGES:-0}" == "1" ]]; then
    return
  fi

  if [[ ! -f "$YAZI_PACKAGE_MANIFEST" ]]; then
    return
  fi

  if ! command -v ya >/dev/null 2>&1; then
    echo "Skipping Yazi packages: ya is not installed."
    return
  fi

  prepare_yazi_package_dirs

  echo "Installing Yazi packages from $YAZI_PACKAGE_MANIFEST..."
  install_help="$(ya pkg install --help 2>&1 || true)"
  if [[ "$install_help" == *"--discard"* ]]; then
    install_args=(--discard)
  fi
  ya pkg install "${install_args[@]}"
}

if (( FULL_DEPLOY )); then
  prepare_yazi_package_manifest
  prepare_yazi_local_plugin_dirs
fi

(
  cd "$CONFIG_DIR"
  dotter \
    --cache-directory "$CACHE_DIR" \
    --cache-file "$CACHE_FILE" \
    deploy \
    --global-config "$GLOBAL_CONFIG" \
    --local-config "$LOCAL_CONFIG"
)

if (( FULL_DEPLOY )); then
  install_yazi_packages
fi

if (( FULL_DEPLOY )) && [[ "$OSTYPE" == darwin* ]] && [[ -x "$MACOS_ICON_SCRIPT" ]]; then
  "$MACOS_ICON_SCRIPT"
fi

echo
echo "Dotter deploy completed successfully."
