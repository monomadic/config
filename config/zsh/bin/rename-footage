#!/bin/zsh
emulate -L zsh

# rename-footage
# Rename camera footage to the canonical media-library filename syntax:
#
#   YYYY-MM-DD--HH-MM-SS TITLE [RES FPS LENGTH BITRATE CODEC DEVICE ORIENTATION].ext
#
# Viewed at a higher level this is:  DATE TITLE [METADATA].ext
#
#   DATE      determined by, in priority order:
#               1. exif data           (exiftool, if installed)
#               2. existing filename   (a leading canonical timestamp)
#               3. mp4 metadata        (ffprobe creation_time)
#               4. file creation ctime (birth time)
#   TITLE     taken verbatim from the current filename, after stripping any
#             leading DATE and any autogenerated [metadata] block. Each word
#             has its first letter capitalized; all other characters are left
#             exactly as they are (so #tags and hyphen-words are untouched).
#   METADATA  probed fresh with ffprobe (+ exiftool for DEVICE).
#
# Options:
#   --print-target   Print the canonical target path only
#   --dry-run        Show what would be renamed without changing files
#   --verbose        Print debug information about probe/date decisions
#   --color          Enable ANSI colors
#   --icons          Use Nerd Font icons
#   -h, --help       Show this message
#
# Dependencies: ffprobe (required); exiftool (optional, improves DATE + DEVICE)

DRY_RUN=false
VERBOSE=false
USE_COLOR=false
USE_ICONS=false
PRINT_TARGET=false
SCRIPT_NAME="${0:t}"

ICON_VIDEO="▶ "
ICON_OK="✓ "
ICON_WARN="⚠ "
ICON_SKIP="• "

RESET=""
GREEN=""
YELLOW=""
CYAN=""

enable_color() {
  RESET=$'\e[0m'
  GREEN=$'\e[32m'
  YELLOW=$'\e[33m'
  CYAN=$'\e[36m'
  USE_COLOR=true
}

enable_icons() {
  ICON_VIDEO="󰎈 "
  ICON_OK=" "
  ICON_WARN=" "
  ICON_SKIP="󰄱 "
  USE_ICONS=true
}

usage() {
  print -r -- "Usage: ${SCRIPT_NAME} [OPTIONS] video_file..."
  print -r -- ""
  print -r -- "Rename camera footage to:"
  print -r -- "  YYYY-MM-DD--HH-MM-SS TITLE [RES FPS LENGTH BITRATE CODEC DEVICE ORIENTATION].ext"
  print -r -- ""
  print -r -- "Options:"
  print -r -- "  --print-target   Print only the canonical target path"
  print -r -- "  --dry-run        Show what would be renamed without changing files"
  print -r -- "  --verbose        Print debug information about probe/date decisions"
  print -r -- "  --color          Enable ANSI colors in output"
  print -r -- "  --icons          Use Nerd Font icons instead of plain Unicode symbols"
  print -r -- "  -h, --help       Show this message"
}

log_verbose() {
  $VERBOSE || return 0
  print -u2 -r -- "${CYAN}${ICON_SKIP}$*${RESET}"
}

trim_whitespace() {
  local s="$1"

  s="${s//$'\t'/ }"
  s="${s//$'\n'/ }"
  s="${s//$'\r'/ }"

  while [[ "$s" == *"  "* ]]; do
    s="${s//  / }"
  done

  while [[ "$s" == [[:space:]]* ]]; do
    s="${s[2,-1]}"
  done

  while [[ "$s" == *[[:space:]] ]]; do
    s="${s[1,-2]}"
  done

  print -r -- "$s"
}

touch_modified_now() {
  local file="$1"
  touch "$file" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# TITLE
# ---------------------------------------------------------------------------

# Strip a leading canonical DATE and every [metadata] block, leaving the title.
extract_title() {
  local name="$1"

  # remove a leading "YYYY-MM-DD--HH-MM-SS" (with optional trailing space)
  if [[ "$name" =~ '^[0-9]{4}-[0-9]{2}-[0-9]{2}--[0-9]{2}-[0-9]{2}-[0-9]{2}[[:space:]]*' ]]; then
    name="${name[$(( MEND + 1 )),-1]}"
  fi

  # remove every [...] block (autogenerated metadata is rebuilt fresh)
  while [[ "$name" == *\[*\]* ]]; do
    name="${name%%\[*}${name#*\]}"
  done

  trim_whitespace "$name"
}

# Capitalize the first letter of each word. Other characters keep their case,
# and words whose first character is not a letter (#tags, -flags) are untouched.
capitalize_title() {
  local s="$1"
  local -a words
  local w out=""

  words=("${(@s: :)s}")
  for w in "${words[@]}"; do
    [[ -z "$w" ]] && continue
    if [[ "${w[1]}" == [A-Za-z] ]]; then
      w="${(U)w[1]}${w[2,-1]}"
    fi
    out+="${out:+ }$w"
  done

  print -r -- "$out"
}

# ---------------------------------------------------------------------------
# DATE
# ---------------------------------------------------------------------------

# Given raw Y M D H M S digits, print canonical "YYYY-MM-DD--HH-MM-SS" or nothing.
format_stamp() {
  local y="$1" mo="$2" d="$3" h="$4" mi="$5" s="$6"
  [[ -z "$y" || -z "$mo" || -z "$d" ]] && return 0
  [[ "$y" == 0000 ]] && return 0
  printf '%04d-%02d-%02d--%02d-%02d-%02d' \
    "$y" "$mo" "$d" "${h:-0}" "${mi:-0}" "${s:-0}"
}

# EXIF timestamps come as "YYYY:MM:DD HH:MM:SS" (optionally with subsec/offset).
parse_exif_stamp() {
  local raw="$1"
  if [[ "$raw" =~ '([0-9]{4}):([0-9]{2}):([0-9]{2})[ T]([0-9]{2}):([0-9]{2}):([0-9]{2})' ]]; then
    format_stamp "$match[1]" "$match[2]" "$match[3]" "$match[4]" "$match[5]" "$match[6]"
  fi
}

date_from_exif() {
  local file="$1" raw tag
  command -v exiftool >/dev/null 2>&1 || return 0
  for tag in DateTimeOriginal CreateDate MediaCreateDate CreationDate; do
    raw="$(exiftool -s3 -"$tag" -- "$file" 2>/dev/null | head -1)"
    [[ -z "$raw" || "$raw" == 0000* ]] && continue
    local stamp
    stamp="$(parse_exif_stamp "$raw")"
    [[ -n "$stamp" ]] && { print -r -- "$stamp"; return 0; }
  done
}

date_from_filename() {
  local name="$1"
  if [[ "$name" =~ '^([0-9]{4})-([0-9]{2})-([0-9]{2})--([0-9]{2})-([0-9]{2})-([0-9]{2})' ]]; then
    format_stamp "$match[1]" "$match[2]" "$match[3]" "$match[4]" "$match[5]" "$match[6]"
  fi
}

date_from_mp4() {
  local file="$1" raw
  raw="$(
    ffprobe -v error -show_entries format_tags=creation_time \
      -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1
  )"
  # creation_time looks like "2025-02-02T12:23:44.000000Z"
  if [[ "$raw" =~ '([0-9]{4})-([0-9]{2})-([0-9]{2})[ T]([0-9]{2}):([0-9]{2}):([0-9]{2})' ]]; then
    format_stamp "$match[1]" "$match[2]" "$match[3]" "$match[4]" "$match[5]" "$match[6]"
  fi
}

date_from_ctime() {
  local file="$1"
  # macOS stat: %SB is the birth (creation) time, formatted with -t.
  stat -f '%SB' -t '%Y-%m-%d--%H-%M-%S' -- "$file" 2>/dev/null | head -1
}

resolve_date() {
  local file="$1" name="$2" stamp

  stamp="$(date_from_exif "$file")"
  [[ -n "$stamp" ]] && { log_verbose "date source: exif -> $stamp"; print -r -- "$stamp"; return 0; }

  stamp="$(date_from_filename "$name")"
  [[ -n "$stamp" ]] && { log_verbose "date source: filename -> $stamp"; print -r -- "$stamp"; return 0; }

  stamp="$(date_from_mp4 "$file")"
  [[ -n "$stamp" ]] && { log_verbose "date source: mp4 metadata -> $stamp"; print -r -- "$stamp"; return 0; }

  stamp="$(date_from_ctime "$file")"
  [[ -n "$stamp" ]] && { log_verbose "date source: ctime -> $stamp"; print -r -- "$stamp"; return 0; }
}

# ---------------------------------------------------------------------------
# METADATA (fresh probe)
# ---------------------------------------------------------------------------

get_resolution_label() {
  local d=${1:-0}
  if (( d <= 480 )); then
    print -r -- "480p"
  elif (( d <= 720 )); then
    print -r -- "720p"
  elif (( d <= 1080 )); then
    print -r -- "1080p"
  elif (( d <= 1440 )); then
    print -r -- "1440p"
  elif (( d <= 2160 )); then
    print -r -- "2160p"
  else
    print -r -- "${d}p"
  fi
}

format_duration() {
  local secs=${1:-0}
  local hours=$(( secs / 3600 ))
  local mins=$(( secs / 60 ))

  if (( hours > 0 )); then
    print -r -- "${hours}hr"
  elif (( mins > 0 )); then
    print -r -- "${mins}min"
  else
    print -r -- "${secs}sec"
  fi
}

get_rotation() {
  local file="$1"
  local rotation=""

  rotation="$(
    ffprobe -v error -select_streams v:0 \
      -show_entries stream_side_data=rotation \
      -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
  )"
  if [[ -z "$rotation" ]]; then
    rotation="$(
      ffprobe -v error -select_streams v:0 \
        -show_entries stream_tags=rotate \
        -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
    )"
  fi
  if [[ -z "$rotation" ]]; then
    rotation="$(
      ffprobe -v error \
        -show_entries format_tags=rotate \
        -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1 || true
    )"
  fi

  [[ -z "$rotation" ]] && rotation="0"
  print -r -- "$rotation"
}

# One short word naming the capture device, e.g. "iPhone 15 Pro" -> "iPhone15Pro".
get_device() {
  local file="$1" model="" tag

  if command -v exiftool >/dev/null 2>&1; then
    for tag in Model CameraModelName com.apple.quicktime.model Make; do
      model="$(exiftool -s3 -"$tag" -- "$file" 2>/dev/null | head -1)"
      [[ -n "$model" ]] && break
    done
  fi

  if [[ -z "$model" ]]; then
    model="$(
      ffprobe -v error \
        -show_entries format_tags=com.apple.quicktime.model \
        -of default=noprint_wrappers=1:nokey=1 -- "$file" 2>/dev/null | head -1
    )"
  fi

  model="$(trim_whitespace "$model")"
  model="${model// /}"   # device must be a single word
  print -r -- "$model"
}

# ---------------------------------------------------------------------------
# main per-file worker
# ---------------------------------------------------------------------------

process_video() {
  local file="$1"

  log_verbose "processing file: $file"

  local filename="${file:t}"
  local dirname="${file:h}"
  local extension="${filename:e}"
  local name_without_ext="${filename:r}"

  local title
  title="$(extract_title "$name_without_ext")"
  title="$(capitalize_title "$title")"

  local date_stamp
  date_stamp="$(resolve_date "$file" "$name_without_ext")"

  log_verbose "title='${title}' date='${date_stamp}'"

  local video_info
  if ! video_info="$(
    ffprobe -v error -select_streams v:0 \
      -show_entries stream=codec_name,width,height,r_frame_rate,bit_rate \
      -of default=noprint_wrappers=1:nokey=0 -- "$file" 2>/dev/null
  )"; then
    print -r -- "${YELLOW}${ICON_WARN}Could not read video info: $file${RESET}"
    return 0
  fi

  local duration_secs
  if ! duration_secs="$(
    ffprobe -v error -show_entries format=duration -of csv=p=0 -- "$file" 2>/dev/null
  )"; then
    duration_secs="0"
  fi
  duration_secs="$(awk -v d="$duration_secs" 'BEGIN{printf("%d", d+0.5)}')"

  local width="" height="" frame_rate="" bit_rate="" codec_name=""
  local line key value
  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      codec_name) codec_name="$value" ;;
      width)      width="$value" ;;
      height)     height="$value" ;;
      r_frame_rate) frame_rate="$value" ;;
      bit_rate)   bit_rate="$value" ;;
    esac
  done <<< "$video_info"

  if [[ "$frame_rate" == */* ]]; then
    local num=${frame_rate%%/*}
    local denom=${frame_rate##*/}
    if (( denom > 0 )); then
      frame_rate=$(( (num + denom / 2) / denom ))
    else
      frame_rate=0
    fi
  fi

  local rotation abs_rotation display_width display_height
  rotation="$(get_rotation "$file")"
  abs_rotation=${rotation#-}
  display_width=$width
  display_height=$height
  if [[ "$abs_rotation" == "90" || "$abs_rotation" == "270" ]]; then
    display_width=$height
    display_height=$width
  fi

  local smaller_dim=$(( display_width < display_height ? display_width : display_height ))
  local resolution
  resolution="$(get_resolution_label "$smaller_dim")"

  local orientation_flag
  if (( display_width > display_height )); then
    orientation_flag="H"
  elif (( display_height > display_width )); then
    orientation_flag="V"
  else
    orientation_flag="S"
  fi

  local mbps="unknown"
  if [[ -n "$bit_rate" && "$bit_rate" != "N/A" ]]; then
    mbps="$(awk -v b="$bit_rate" 'BEGIN{printf("%dmbps", (b+500000)/1000000)}')"
  fi

  local duration
  duration="$(format_duration "$duration_secs")"

  local codec_flag=""
  case "${codec_name:l}" in
    hevc|h265) codec_flag="h265" ;;
    h264|avc1) codec_flag="h264" ;;
    prores)    codec_flag="PRO" ;;
    vp9)       codec_flag="VP9" ;;
    av1)       codec_flag="AV1" ;;
  esac

  local device
  device="$(get_device "$file")"

  log_verbose "metadata for ${filename}: res=${resolution} fps=${frame_rate} len=${duration} bitrate=${mbps} codec=${codec_flag:-<none>} device=${device:-<none>} orientation=${orientation_flag}"

  # order: RES FPS LENGTH BITRATE CODEC DEVICE ORIENTATION
  local -a tags
  tags+=("$resolution")
  tags+=("${frame_rate}fps")
  tags+=("$duration")
  [[ "$mbps" != "unknown" ]] && tags+=("$mbps")
  [[ -n "$codec_flag" ]] && tags+=("$codec_flag")
  [[ -n "$device" ]] && tags+=("$device")
  tags+=("$orientation_flag")

  local tags_block="[${(j: :)tags}]"

  # assemble: DATE TITLE [METADATA].ext (any empty leading part is dropped)
  local -a segments
  [[ -n "$date_stamp" ]] && segments+=("$date_stamp")
  [[ -n "$title" ]] && segments+=("$title")
  segments+=("$tags_block")

  local new_filename="${(j: :)segments}.${extension}"
  local new_path="${dirname}/${new_filename}"

  log_verbose "rename target for ${filename}: ${new_filename}"

  if $PRINT_TARGET; then
    print -r -- "$new_path"
    return 0
  fi

  if [[ "$filename" == "$new_filename" ]]; then
    print -r -- "${YELLOW}${ICON_SKIP}${filename}${RESET}"
  elif [[ -e "$new_path" ]]; then
    print -r -- "${YELLOW}${ICON_WARN}Exists: $new_filename${RESET}"
  else
    if $DRY_RUN; then
      print -r -- "${CYAN}${ICON_VIDEO}${new_filename}${RESET}"
    else
      if mv -- "$file" "$new_path"; then
        touch_modified_now "$new_path"
        print -r -- "${GREEN}${ICON_OK}${new_filename}${RESET}"
      else
        print -r -- "${YELLOW}${ICON_WARN}Could not rename: ${filename} -> ${new_filename}${RESET}"
        return 1
      fi
    fi
  fi
}

normalize_input_path() {
  local s="$1"
  local unescaped candidate cwd_name

  if [[ -e "$s" ]]; then
    print -r -- "${s:a}"
    return 0
  fi

  unescaped="${(Q)s}"
  if [[ -e "$unescaped" ]]; then
    print -r -- "${unescaped:a}"
    return 0
  fi

  cwd_name="${PWD:t}"

  if [[ "$unescaped" != /* && "$unescaped" == */* && "${unescaped:h:t}" == "$cwd_name" ]]; then
    candidate="${unescaped:t}"
    if [[ -e "$candidate" ]]; then
      print -r -- "${candidate:a}"
      return 0
    fi
  fi

  if [[ "$s" != /* && "$s" == */* && "${s:h:t}" == "$cwd_name" ]]; then
    candidate="${s:t}"
    if [[ -e "$candidate" ]]; then
      print -r -- "${candidate:a}"
      return 0
    fi
  fi

  if [[ "$unescaped" != "$s" ]]; then
    print -r -- "$unescaped"
    return 0
  fi

  print -r -- "$s"
}

main() {
  while (( $# > 0 )); do
    case "$1" in
      --dry-run) DRY_RUN=true; shift ;;
      --verbose) VERBOSE=true; shift ;;
      --color)   enable_color; shift ;;
      --icons)   enable_icons; shift ;;
      --print-target|--target-path) PRINT_TARGET=true; shift ;;
      --) shift; break ;;
      -h|--help) usage; exit 0 ;;
      -*)
        print -u2 -r -- "${YELLOW}${ICON_WARN}Unknown option: $1${RESET}"
        exit 1
        ;;
      *) break ;;
    esac
  done

  if ! command -v ffprobe >/dev/null 2>&1; then
    print -u2 -r -- "${YELLOW}${ICON_WARN}ffprobe is required but not installed.${RESET}"
    exit 1
  fi

  local raw_file file

  for raw_file in "$@"; do
    file="$(normalize_input_path "$raw_file")"

    if [[ -f "$file" ]]; then
      case "${file:l}" in
        *.mp4|*.mov|*.avi|*.mkv|*.wmv|*.flv|*.webm|*.m4v)
          process_video "$file"
          ;;
        *)
          print -r -- "${YELLOW}${ICON_SKIP}${file:t}${RESET}"
          ;;
      esac
    else
      print -r -- "${YELLOW}${ICON_SKIP}${file:t}${RESET}"
    fi
  done
}

main "$@"
