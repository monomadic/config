#!/usr/bin/env zsh
# ============================================================
# ffmpeg-lossless-cut
# Select a keyframe in fzf, then write a trimmed copy beside the
# source file using ffmpeg stream copy only.
#
# Workflow:
# - always open keyframe selector
# - --detect-black-scenes:
#     first try ffmpeg-detect-black-scenes; if a leading black scene is
#     found, open selector starting after it, otherwise keep the normal flow
#
# Output:
# - replaces the source in place, keeping its original name
# - writes to a hidden temp file beside the source, then renames into place
# - copies embedded/container metadata, including source date tags
# - copies the source filesystem creation date to the output
# - moves the original to Trash after a successful cut
#
# Requirements:
# - zsh
# - ffprobe
# - ffmpeg
# - fzf
#
# Optional:
# - ffmpeg-detect-black-scenes
# - kitty, wezterm, imgcat, chafa
# ============================================================

emulate -L zsh
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ffmpeg-lossless-cut [options] <video1> [video2 ...]

Options:
  -n, --keyframes <n>       Number of keyframes to show (default: 20)
  -w, --width <px>          Preview width for thumbnails (default: 480)
  -r, --reverse             Trim from the end backward to remove an outro
  -y, --yes                 Skip confirmation after keyframe selection
  -f, --force               Replace the source without the overwrite prompt
  -k, --keep-previews       Keep temporary preview directories
  --dry-run                 Show planned actions only
  --print-start             Select a keyframe, print FLC_START=<seconds> to
                            stdout, and exit without cutting anything
  --mov-faststart           Enable MP4/MOV FastStart on the output
  --skip-detection          Deprecated no-op; detection is off unless requested
  --detect-black-scenes     Auto-start after a leading black scene when found
  --from <seconds>          Start selector at/after this timestamp
  -h, --help                Show this help

After a successful cut, copies embedded/container metadata and the original
file creation date to the output, moves the original file to Trash, then
renames the output onto the original's name (replacing it in place).

Examples:
  ffmpeg-lossless-cut clip.mp4
  ffmpeg-lossless-cut *.mp4
  ffmpeg-lossless-cut --detect-black-scenes *.mp4
  ffmpeg-lossless-cut --from 12.5 clip.mp4
  ffmpeg-lossless-cut --reverse clip.mp4
EOF
}

die() {
  print -r -u2 -- "error: $*"
  exit 1
}

warn() {
  print -r -u2 -- "warning: $*"
}

info() {
  print -r -- "$*"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

is_number() {
  [[ "${1:-}" == <-> || "${1:-}" == <->.<-> ]]
}

float_gt_zero() {
  awk -v v="$1" 'BEGIN { exit !(v > 0.0005) }'
}

float_le() {
  awk -v a="$1" -v b="$2" 'BEGIN { exit !(a <= b + 1e-9) }'
}

normalize_seconds() {
  python3 - "$1" <<'PY'
import sys
print(f"{float(sys.argv[1]):.6f}")
PY
}

format_ts() {
  python3 - "$1" <<'PY'
import sys
s = float(sys.argv[1])
h = int(s // 3600)
m = int((s % 3600) // 60)
sec = s % 60
print(f"{h:02d}:{m:02d}:{sec:09.6f}")
PY
}

esc_prompt() {
  # Double literal % so paths are safe to hand to `print -P`.
  print -r -- "${1//\%/%%}"
}

human_size() {
  awk -v b="${1:-0}" 'BEGIN {
    b = b + 0
    if (b < 1024) { printf "%d B", b; exit }
    split("KB MB GB TB PB", u, " ")
    s = b; i = 0
    do { s /= 1024; i++ } while (s >= 1024 && i < 5)
    printf "%.1f %s", s, u[i]
  }'
}

format_frame_rate() {
  local rate="${1:-}"

  [[ -n "$rate" && "$rate" != "0/0" ]] || {
    print -r -- "unknown"
    return
  }

  awk -v rate="$rate" '
    BEGIN {
      split(rate, parts, "/")
      if (parts[2] == "" || parts[2] == 0) {
        value = parts[1]
      } else {
        value = parts[1] / parts[2]
      }
      if (value == int(value)) {
        printf "%dfps\n", value
      } else {
        printf "%.2ffps\n", value
      }
    }
  '
}

term_columns() {
  local c
  c="$(tput cols 2>/dev/null || true)"
  [[ "$c" == <1-> ]] || c="${COLUMNS:-80}"
  [[ "$c" == <1-> ]] || c=80
  print -r -- "$c"
}

# Precompute per-file metadata (constant across keyframes) into a key=value file
# so the fzf preview can render it instantly without re-probing on every frame.
write_file_meta() {
  local input_file="$1"
  local meta_file="$2"
  local sz w="" h="" afr="" rfr="" key value line created epoch

  {
    print -r -- "dir=${input_file:A:h}"
    print -r -- "file=${input_file:t}"

    sz="$(stat -f '%z' -- "$input_file" 2>/dev/null || true)"
    if [[ "$sz" == <-> ]]; then
      print -r -- "size=$(human_size "$sz")"
    else
      print -r -- "size=unknown"
    fi

    while IFS= read -r line; do
      key="${line%%=*}"
      value="${line#*=}"
      case "$key" in
        width) w="$value" ;;
        height) h="$value" ;;
        avg_frame_rate) afr="$value" ;;
        r_frame_rate) rfr="$value" ;;
      esac
    done < <(
      ffprobe -v error -select_streams v:0 \
        -show_entries stream=width,height,avg_frame_rate,r_frame_rate \
        -of default=noprint_wrappers=1 -- "$input_file" 2>/dev/null
    )

    if [[ "$w" == <-> && "$h" == <-> ]]; then
      print -r -- "res=${w}x${h}"
    else
      print -r -- "res=unknown"
    fi
    print -r -- "fps=$(format_frame_rate "${afr:-$rfr}")"

    epoch="$(stat -f '%B' -- "$input_file" 2>/dev/null || true)"
    if [[ "$epoch" == <-> ]] && (( epoch > 0 )); then
      created="$(date -r "$epoch" '+%Y-%m-%d %H:%M' 2>/dev/null || true)"
      print -r -- "created=${created:-unknown}"
    else
      print -r -- "created=unknown"
    fi
  } > "$meta_file"
}

# One-line "size · res · fps" summary for the encode banner.
media_summary_line() {
  local input_file="$1"
  local sz w="" h="" afr="" rfr="" key value line res fps size

  sz="$(stat -f '%z' -- "$input_file" 2>/dev/null || true)"
  if [[ "$sz" == <-> ]]; then
    size="$(human_size "$sz")"
  else
    size="unknown"
  fi

  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      width) w="$value" ;;
      height) h="$value" ;;
      avg_frame_rate) afr="$value" ;;
      r_frame_rate) rfr="$value" ;;
    esac
  done < <(
    ffprobe -v error -select_streams v:0 \
      -show_entries stream=width,height,avg_frame_rate,r_frame_rate \
      -of default=noprint_wrappers=1 -- "$input_file" 2>/dev/null
  )

  if [[ "$w" == <-> && "$h" == <-> ]]; then
    res="${w}x${h}"
  else
    res="unknown"
  fi
  fps="$(format_frame_rate "${afr:-$rfr}")"

  print -r -- "${size} · ${res} · ${fps}"
}

make_work_output() {
  # Hidden, uniquely named temp beside the source. The extension is preserved
  # so ffmpeg selects the right muxer; the file is renamed onto the original
  # name only after a successful cut and trash.
  local input_file="$1"
  local dir base stem ext candidate n=0

  dir="${input_file:h}"
  base="${input_file:t}"

  if [[ "$base" == *.* ]]; then
    stem="${base:r}"
    ext=".${base:e}"
  else
    stem="$base"
    ext=""
  fi

  candidate="${dir}/.${stem}.cut-$$${ext}"
  while [[ -e "$candidate" ]]; do
    (( ++n ))
    candidate="${dir}/.${stem}.cut-$$-${n}${ext}"
  done

  print -r -- "$candidate"
}

command_path_arg() {
  local file_path="$1"

  if [[ "$file_path" != /* && "${file_path:t}" == -* ]]; then
    print -r -- "./$file_path"
  else
    print -r -- "$file_path"
  fi
}

detect_black_leader_seconds() {
  local input_file="$1"
  local tolerance="$2"
  local input_arg output line start end
  local black_re='black_start:([0-9]+([.][0-9]+)?)[[:space:]]+black_end:([0-9]+([.][0-9]+)?)'

  have ffmpeg-detect-black-scenes || return 1

  input_arg="$(command_path_arg "$input_file")"
  output="$(ffmpeg-detect-black-scenes "$input_arg" 2>&1 || true)"

  while IFS= read -r line; do
    if [[ "$line" =~ $black_re ]]; then
      start="${match[1]}"
      end="${match[3]}"

      if float_le "$start" "$tolerance" && float_gt_zero "$end"; then
        normalize_seconds "$end"
        return 0
      fi
    fi
  done <<< "$output"

  return 1
}

probe_keyframes_after() {
  local input_file="$1"
  local start="$2"
  local want="$3"
  local window="$4"

  ffprobe -v error \
    -select_streams v:0 \
    -read_intervals "${start}%+${window}" \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v want="$want" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (!seen[$1]++) {
        print $1
        count++
        if (count >= want) {
          exit
        }
      }
    }
  '
}

probe_keyframes_after_full() {
  local input_file="$1"
  local start="$2"
  local want="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v want="$want" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (!seen[$1]++) {
        print $1
        count++
        if (count >= want) {
          exit
        }
      }
    }
  '
}

probe_keyframes_after_frames_full() {
  local input_file="$1"
  local start="$2"
  local want="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -skip_frame nokey \
    -show_frames \
    -show_entries frame=best_effort_timestamp_time \
    -of default=nw=1:nk=1 \
    -- "$input_file" 2>/dev/null |
  awk -v start="$start" -v want="$want" '
    $1 ~ /^[0-9.]+$/ && ($1 + 0) >= (start + 0) {
      if (!seen[$1]++) {
        print $1
        count++
        if (count >= want) {
          exit
        }
      }
    }
  '
}

probe_last_keyframes_in_interval() {
  local input_file="$1"
  local start="$2"
  local window="$3"
  local keep="$4"

  ffprobe -v error \
    -select_streams v:0 \
    -read_intervals "${start}%+${window}" \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v keep="$keep" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (seen[$1]++) {
        next
      }
      vals[count % keep] = $1
      count++
    }
    END {
      begin = count > keep ? count - keep : 0
      for (i = begin; i < count; i++) {
        print vals[i % keep]
      }
    }
  '
}

probe_last_keyframes_full() {
  local input_file="$1"
  local start="$2"
  local keep="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v keep="$keep" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (seen[$1]++) {
        next
      }
      vals[count % keep] = $1
      count++
    }
    END {
      begin = count > keep ? count - keep : 0
      for (i = begin; i < count; i++) {
        print vals[i % keep]
      }
    }
  '
}

probe_last_keyframes_frames_full() {
  local input_file="$1"
  local start="$2"
  local keep="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -skip_frame nokey \
    -show_frames \
    -show_entries frame=best_effort_timestamp_time \
    -of default=nw=1:nk=1 \
    -- "$input_file" 2>/dev/null |
  awk -v start="$start" -v keep="$keep" '
    $1 ~ /^[0-9.]+$/ && ($1 + 0) >= (start + 0) {
      if (seen[$1]++) {
        next
      }
      vals[count % keep] = $1
      count++
    }
    END {
      begin = count > keep ? count - keep : 0
      for (i = begin; i < count; i++) {
        print vals[i % keep]
      }
    }
  '
}

video_duration_seconds() {
  local input_file="$1"

  ffprobe -v error \
    -show_entries format=duration \
    -of default=nw=1:nk=1 \
    -- "$input_file" 2>/dev/null |
  awk 'NR == 1 && $1 ~ /^[0-9.]+$/ { print $1 }'
}

interval_start_for_tail() {
  local duration="$1"
  local window="$2"
  local minimum="$3"

  awk -v duration="$duration" -v window="$window" -v minimum="$minimum" '
    BEGIN {
      start = duration - window
      if (start < minimum) {
        start = minimum
      }
      if (start < 0) {
        start = 0
      }
      printf "%.6f\n", start
    }
  '
}

keyframes_forward() {
  local input_file="$1"
  local start="$2"
  local want="$3"
  local window ts
  local -a vals=()
  local -a windows=(30 120 600 1800)

  for window in "${windows[@]}"; do
    vals=()
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      vals+=("$ts")
    done < <(probe_keyframes_after "$input_file" "$start" "$want" "$window")

    if (( ${#vals[@]} >= want )); then
      print -r -- "${(@F)vals}"
      return 0
    fi
  done

  vals=()
  while IFS= read -r ts; do
    [[ -n "$ts" ]] || continue
    vals+=("$ts")
  done < <(probe_keyframes_after_full "$input_file" "$start" "$want")

  if (( ${#vals[@]} == 0 )); then
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      vals+=("$ts")
    done < <(probe_keyframes_after_frames_full "$input_file" "$start" "$want")
  fi

  (( ${#vals[@]} > 0 )) || return 1
  print -r -- "${(@F)vals}"
}

keyframes_reverse() {
  local input_file="$1"
  local start="$2"
  local want="$3"
  local duration interval_start window ts
  local -a vals=()
  local -a windows=(60 300 900 1800 3600)

  duration="$(video_duration_seconds "$input_file")"

  if [[ -n "$duration" ]]; then
    for window in "${windows[@]}"; do
      interval_start="$(interval_start_for_tail "$duration" "$window" "$start")"
      vals=()
      while IFS= read -r ts; do
        [[ -n "$ts" ]] || continue
        vals+=("$ts")
      done < <(probe_last_keyframes_in_interval "$input_file" "$interval_start" "$window" "$want")

      if (( ${#vals[@]} >= want )); then
        print -r -- "${(@F)vals}"
        return 0
      fi
    done
  fi

  vals=()
  while IFS= read -r ts; do
    [[ -n "$ts" ]] || continue
    vals+=("$ts")
  done < <(probe_last_keyframes_full "$input_file" "$start" "$want")

  if (( ${#vals[@]} == 0 )); then
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      vals+=("$ts")
    done < <(probe_last_keyframes_frames_full "$input_file" "$start" "$want")
  fi

  (( ${#vals[@]} > 0 )) || return 1
  print -r -- "${(@F)vals}"
}

selector_embedded() {
  local input_file="$1"
  local keyframes="$2"
  local width="$3"
  local keep="$4"
  local from_ts="${5:-0}"
  local reverse_mode="${6:-false}"

  local tmp_dir
  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/fzf-select-keyframe.XXXXXXXX")"

  selector_cleanup() {
    if [[ "$keep" == true ]]; then
      print -u2 -- "kept previews in: $tmp_dir"
    else
      rm -rf -- "$tmp_dir"
    fi
  }

  local -a key_ts=()
  local ts
  local from_num
  from_num="$(python3 - "$from_ts" <<'PY'
import sys
print(float(sys.argv[1]))
PY
)"

  if [[ "$reverse_mode" == true ]]; then
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      key_ts+=("$ts")
    done < <(keyframes_reverse "$input_file" "$from_num" "$keyframes")
  else
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      key_ts+=("$ts")
    done < <(keyframes_forward "$input_file" "$from_num" "$keyframes")
  fi

  if (( ${#key_ts[@]} == 0 )); then
    selector_cleanup
    return 1
  fi

  local list_file="$tmp_dir/list.tsv"
  : > "$list_file"
  print -r -- "$input_file" > "$tmp_dir/input.path"
  print -r -- "$width" > "$tmp_dir/preview.width"
  write_file_meta "$input_file" "$tmp_dir/meta"

  local idx=1
  local pretty_ts img_file
  for ts in "${key_ts[@]}"; do
    pretty_ts="$(format_ts "$ts")"
    img_file="$tmp_dir/keyframe-${idx}.jpg"

    printf '%s\t%s\t%s\t%s\n' "$idx" "$ts" "$pretty_ts" "$img_file" >> "$list_file"
    (( ++idx ))
  done

  local preview_script="$tmp_dir/preview.zsh"
  cat > "$preview_script" <<'EOF'
#!/usr/bin/env zsh
emulate -L zsh
set -euo pipefail

idx="$1"
raw_ts="$2"
pretty_ts="$3"
img="$4"

cache_dir="${0:h}"
input_file="$(< "$cache_dir/input.path")"
width="$(< "$cache_dir/preview.width")"

preview_cols="${FZF_PREVIEW_COLUMNS:-80}"
preview_lines="${FZF_PREVIEW_LINES:-24}"

# Modern truecolor accent palette
esc=$'\e'
accent="${esc}[38;2;137;180;250m"   # blue
pink="${esc}[38;2;245;194;231m"
green="${esc}[38;2;166;227;161m"
dim="${esc}[38;2;108;112;134m"
bold="${esc}[1m"
reset="${esc}[0m"

# Load precomputed file metadata (key=value)
typeset -A meta=()
if [[ -r "$cache_dir/meta" ]]; then
  while IFS= read -r ml; do
    meta[${ml%%=*}]="${ml#*=}"
  done < "$cache_dir/meta"
fi

# Build the header, wrapping the (potentially long) directory and filename to
# the preview width, and counting rows so the image can be placed just below it.
integer header_rows=0
header=""
append() { header+="$1"$'\n'; (( ++header_rows )); }
wrap() { print -r -- "$1" | fold -s -w "$preview_cols"; }

append "${dim}working directory${reset}"
while IFS= read -r wline; do append "${accent}${wline}${reset}"; done < <(wrap "${meta[dir]:-.}")
append ""
append "${dim}file${reset}"
while IFS= read -r wline; do append "${bold}${wline}${reset}"; done < <(wrap "${meta[file]:-?}")
append ""
append "${dim}${meta[size]:-?}  ·  ${meta[res]:-?}  ·  ${meta[fps]:-?}  ·  ${meta[created]:-?}${reset}"
append ""
append "${pink}keyframe${reset}  ${bold}${pretty_ts}${reset}  ${dim}(${raw_ts}s)${reset}"

print -rn -- "$header"

image_start=$(( header_rows + 1 ))
image_lines=$(( preview_lines - image_start ))
(( image_lines < 1 )) && image_lines=1

ensure_preview() {
  [[ -s "$img" ]] && return 0

  local tmp="${img}.$$.jpg"

  trap 'rm -f -- "$tmp"' EXIT INT TERM HUP
  ffmpeg -v error -y \
    -ss "$raw_ts" -i "$input_file" \
    -frames:v 1 \
    -vf "scale=${width}:-2:flags=lanczos" \
    -q:v 3 \
    -- "$tmp" &&
  mv -f -- "$tmp" "$img"
  trap - EXIT INT TERM HUP
}

if ! ensure_preview; then
  print -- "Preview unavailable"
  print -- "$img"
  exit 0
fi

if [[ -n "${KITTY_WINDOW_ID:-}" ]] && command -v kitty >/dev/null 2>&1; then
  kitty +kitten icat \
    --clear \
    --transfer-mode=stream \
    --stdin=no \
    --place="${preview_cols}x${image_lines}@0x${image_start}" \
    -- "$img"
elif [[ -n "${WEZTERM_PANE:-}" ]] && command -v wezterm >/dev/null 2>&1; then
  wezterm imgcat --width "${preview_cols}" -- "$img"
elif command -v imgcat >/dev/null 2>&1; then
  imgcat "$img"
elif command -v chafa >/dev/null 2>&1; then
  chafa --animate=off --size="${preview_cols}x${image_lines}" -- "$img"
else
  print -- "$img"
fi
EOF
  chmod +x "$preview_script"

  local selection
  selection="$(
    fzf \
      --delimiter=$'\t' \
      --with-nth=1,3 \
      --no-sort \
      --no-input \
      --layout=reverse \
      --height=100% \
      --border=none \
      --info=inline \
      --pointer='▍' \
      --color='bg:-1,bg+:-1,gutter:-1,fg:#7f849c,fg+:#ffffff,hl:#f5c2e7,hl+:#f5c2e7,pointer:#89b4fa,header:#89b4fa,info:#585b70,prompt:#89b4fa' \
      --header='keyframe:' \
      --bind='j:down,k:up,h:page-up,l:page-down,g:first,G:last' \
      --preview-window='right,70%,border-none' \
      --preview "zsh '$preview_script' {1} {2} {3} {4}" \
      < "$list_file"
  )" || {
    rc=$?
    selector_cleanup
    return "$rc"
  }

  print -r -- "$selection" | awk -F $'\t' '{ print $2 }'
  selector_cleanup
}

select_keyframe() {
  local input_file="$1"
  local keyframes="$2"
  local width="$3"
  local keep="$4"
  local from_ts="${5:-0}"
  local reverse_mode="${6:-false}"

  selector_embedded "$input_file" "$keyframes" "$width" "$keep" "$from_ts" "$reverse_mode"
}

# Draw a single in-place progress bar frame from ffmpeg -progress values.
draw_progress_bar() {
  emulate -L zsh
  local total="$1" out_time="$2" speed="$3" state="${4:-}" cols="${5:-80}"
  local total_size="${6:-}" wall="${7:-0}"

  awk -v total="$total" -v t="$out_time" -v speed="$speed" -v state="$state" \
      -v cols="$cols" -v tsize="$total_size" -v wall="$wall" '
    function clk(s,   h, m, sec) {
      if (s < 0) s = 0
      h = int(s / 3600); s -= h * 3600
      m = int(s / 60);   sec = int(s - m * 60)
      return (h > 0) ? sprintf("%d:%02d:%02d", h, m, sec) : sprintf("%02d:%02d", m, sec)
    }
    BEGIN {
      esc = sprintf("%c", 27)
      accent = esc "[38;2;137;180;250m"; green = esc "[38;2;166;227;161m"
      pink = esc "[38;2;245;194;231m"; dim = esc "[38;2;108;112;134m"
      white = esc "[38;2;205;214;244m"
      reset = esc "[0m"; clr = esc "[K"

      n = split(t, p, ":")
      elapsed = (n == 3) ? p[1] * 3600 + p[2] * 60 + p[3] : t + 0
      sp = speed; gsub(/[^0-9.]/, "", sp); sp = sp + 0
      total = total + 0
      if (state == "end" && total > 0) elapsed = total

      # Disk write throughput, if we have bytes written and a wall clock.
      thr = ""
      mb = tsize + 0; wl = wall + 0
      if (wl > 0.1 && mb > 0) {
        thr = sprintf("   %s%.1f MB/s%s", dim, mb / 1048576 / wl, reset)
      }

      if (total > 0) {
        pct = elapsed / total * 100
        if (pct < 0) pct = 0; if (pct > 100) pct = 100
        eta = (sp > 0 && total > elapsed) ? (total - elapsed) / sp : 0
        barw = cols - 52
        if (barw < 12) barw = 12; if (barw > 40) barw = 40
        filled = int(pct / 100 * barw + 0.5)
        if (filled > barw) filled = barw; if (filled < 0) filled = 0
        fill = ""; for (i = 0; i < filled; i++) fill = fill "█"
        emp = "";  for (i = 0; i < barw - filled; i++) emp = emp "─"
        printf "\r  %s%s%s%s%s  %s%3d%%%s   %s%s%s / %s%s%s   %sETA %s%s   %s%.1fx%s%s%s",
          green, fill, dim, emp, reset,
          accent, pct, reset,
          white, clk(elapsed), reset, white, clk(total), reset,
          dim, clk(eta), reset,
          pink, sp, reset,
          thr, clr
      } else {
        sps = (sp > 0) ? sprintf("   %s%.1fx%s", pink, sp, reset) : ""
        printf "\r  %s⏳ copying…%s   %s%s elapsed%s%s%s%s",
          accent, reset, dim, clk(elapsed), reset, sps, thr, clr
      }
    }
  '
}

# Consume ffmpeg -progress key=value stream on stdin, redrawing the bar.
render_progress() {
  emulate -L zsh
  zmodload zsh/datetime 2>/dev/null || true
  local total="${1:-}" cols="${2:-80}"
  local line key value out_time="" speed="" state="" total_size="" drew=false
  local start="${EPOCHREALTIME:-0}" wall=0

  while IFS= read -r line; do
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      out_time) out_time="$value" ;;
      speed) speed="$value" ;;
      total_size) total_size="$value" ;;
      progress)
        state="$value"
        wall="$(( ${EPOCHREALTIME:-0} - start ))"
        draw_progress_bar "$total" "$out_time" "$speed" "$state" "$cols" "$total_size" "$wall"
        drew=true
        ;;
    esac
  done

  [[ "$drew" == true ]] && print -- ""
  return 0
}

trim_copy() {
  local input_file="$1"
  local start_time="$2"
  local output_file="$3"
  local mov_faststart="$4"
  local total="${5:-}"
  local cols="${6:-80}"
  local movflags="use_metadata_tags"

  [[ "$mov_faststart" == true ]] && movflags="+faststart+use_metadata_tags"

  local errlog
  errlog="$(mktemp "${TMPDIR:-/tmp}/flc-ffmpeg.XXXXXX")"
  integer rc=0

  ffmpeg -hide_banner -y -progress pipe:1 \
    -ss "$start_time" -i "$input_file" \
    -map 0 \
    -map_metadata 0 \
    -movflags "$movflags" \
    -c copy \
    "$output_file" 2>"$errlog" | render_progress "$total" "$cols" || rc=$?

  (( rc != 0 )) && cat -- "$errlog" >&2
  rm -f -- "$errlog"
  return $rc
}

trim_copy_reverse() {
  local input_file="$1"
  local end_time="$2"
  local output_file="$3"
  local mov_faststart="$4"
  local total="${5:-}"
  local cols="${6:-80}"
  local movflags="use_metadata_tags"

  [[ "$mov_faststart" == true ]] && movflags="+faststart+use_metadata_tags"

  local errlog
  errlog="$(mktemp "${TMPDIR:-/tmp}/flc-ffmpeg.XXXXXX")"
  integer rc=0

  ffmpeg -hide_banner -y -progress pipe:1 \
    -to "$end_time" -i "$input_file" \
    -map 0 \
    -map_metadata 0 \
    -movflags "$movflags" \
    -c copy \
    "$output_file" 2>"$errlog" | render_progress "$total" "$cols" || rc=$?

  (( rc != 0 )) && cat -- "$errlog" >&2
  rm -f -- "$errlog"
  return $rc
}

confirm_overwrite() {
  local output_file="$1"
  local reply=""

  read -r "?Output exists. Overwrite '$output_file'? [y/N] " reply
  [[ "$reply" == [Yy] || "$reply" == [Yy][Ee][Ss] ]]
}

setfile_path_arg() {
  local file_path="$1"

  command_path_arg "$file_path"
}

creation_date_for_setfile() {
  local input_file="$1"
  local epoch

  epoch="$(stat -f '%B' -- "$input_file" 2>/dev/null)" || return 1
  [[ "$epoch" == <-> ]] || return 1
  (( epoch > 0 )) || return 1

  date -r "$epoch" '+%m/%d/%Y %H:%M:%S'
}

copy_creation_date() {
  local input_file="$1"
  local output_file="$2"
  local created output_arg

  if ! have SetFile; then
    warn "SetFile not found; could not copy creation date"
    return 1
  fi

  if ! created="$(creation_date_for_setfile "$input_file")"; then
    warn "could not read creation date: $input_file"
    return 1
  fi

  output_arg="$(setfile_path_arg "$output_file")"
  if SetFile -d "$created" "$output_arg"; then
    info "Copied creation date: $created"
    return 0
  fi

  warn "failed to copy creation date to: $output_file"
  return 1
}

touch_modified_now() {
  local file="$1"

  touch "$file" 2>/dev/null || true
}

trash_original() {
  local input_file="$1"
  local target="$input_file"

  if have trash; then
    [[ "$target" != /* && "${target:t}" == -* ]] && target="./$target"
    trash "$target"
    return
  fi

  local trash_dir="$HOME/.Trash"
  local base dst stamp n

  mkdir -p -- "$trash_dir"
  base="${input_file:t}"
  dst="$trash_dir/$base"

  if [[ -e "$dst" ]]; then
    stamp="$(date +%Y%m%d-%H%M%S)"
    n=1
    while [[ -e "$trash_dir/${base} (${stamp}-${n})" ]]; do
      (( ++n ))
    done
    dst="$trash_dir/${base} (${stamp}-${n})"
  fi

  mv -n -- "$input_file" "$dst"
}

maybe_trash_original() {
  local input_file="$1"

  if trash_original "$input_file"; then
    info "Trashed original:  $input_file"
    return 0
  fi

  warn "failed to trash original: $input_file"
  return 1
}

perform_cut() {
  local input_file="$1"
  local cut_time="$2"
  local output_file="$3"
  local force="$4"
  local reverse_mode="$5"
  local mov_faststart="$6"

  if ! float_gt_zero "$cut_time"; then
    warn "cut time <= 0, skipping: $input_file"
    return 1
  fi

  if [[ -e "$output_file" && "$force" != true ]]; then
    if ! confirm_overwrite "$output_file"; then
      warn "output already exists: $output_file"
      warn "skipped"
      return 1
    fi
  fi

  local cols total dur
  cols="$(term_columns)"
  if [[ "$reverse_mode" == true ]]; then
    total="$cut_time"
  else
    dur="$(video_duration_seconds "$input_file")"
    if [[ -n "$dur" ]]; then
      total="$(awk -v d="$dur" -v s="$cut_time" 'BEGIN { v = d - s; if (v < 0) v = 0; print v }')"
    else
      total=""
    fi
  fi

  print
  if [[ "$reverse_mode" == true ]]; then
    trim_copy_reverse "$input_file" "$cut_time" "$output_file" "$mov_faststart" "$total" "$cols"
  else
    trim_copy "$input_file" "$cut_time" "$output_file" "$mov_faststart" "$total" "$cols"
  fi
}

keyframes=20
width=480
reverse_mode=false
yes=false
force=false
keep_previews=false
dry_run=false
print_start=false
mov_faststart=false
detect_black_leader=false
black_leader_start_tolerance="${BLACK_LEADER_START_TOLERANCE:-0.25}"
from_ts="0"

typeset -a files=()

while (( $# > 0 )); do
  case "$1" in
    -n|--keyframes)
      (( $# >= 2 )) || die "missing value for $1"
      keyframes="$2"
      shift 2
      ;;
    --count)
      (( $# >= 2 )) || die "missing value for $1"
      warn "--count is deprecated; use --keyframes"
      keyframes="$2"
      shift 2
      ;;
    -w|--width)
      (( $# >= 2 )) || die "missing value for $1"
      width="$2"
      shift 2
      ;;
    -r|--reverse)
      reverse_mode=true
      shift
      ;;
    -y|--yes)
      yes=true
      shift
      ;;
    -f|--force)
      force=true
      shift
      ;;
    -k|--keep-previews)
      keep_previews=true
      shift
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    --print-start)
      print_start=true
      shift
      ;;
    --mov-faststart|--faststart)
      mov_faststart=true
      shift
      ;;
    --skip-detection)
      warn "--skip-detection is deprecated; detection is off unless --detect-black-scenes is set"
      shift
      ;;
    --detect-black-scenes|--detect-black-leader)
      detect_black_leader=true
      shift
      ;;
    --skip-intro-detection)
      warn "--skip-intro-detection is deprecated; detection is off unless --detect-black-scenes is set"
      shift
      ;;
    --from)
      (( $# >= 2 )) || die "missing value for $1"
      from_ts="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      files+=("$@")
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      files+=("$1")
      shift
      ;;
  esac
done

(( ${#files[@]} > 0 )) || {
  usage
  exit 1
}

have ffprobe || die "ffprobe not found"
have ffmpeg  || die "ffmpeg not found"
have fzf     || die "fzf not found"

[[ "$keyframes" == <-> ]] || die "--keyframes must be an integer"
[[ "$width" == <-> ]] || die "--width must be an integer"
(( keyframes > 0 )) || die "--keyframes must be > 0"
(( width > 0 )) || die "--width must be > 0"
is_number "$from_ts" || die "--from must be numeric seconds"
is_number "$black_leader_start_tolerance" || die "BLACK_LEADER_START_TOLERANCE must be numeric seconds"

integer ok_count=0
integer skip_count=0
integer fail_count=0
integer creation_date_fail_count=0
integer trash_fail_count=0

print -P -- "%F{blue}%Bffmpeg lossless cut%b%f"

for input_file in "${files[@]}"; do
  if [[ ! -f "$input_file" ]]; then
    warn "not a file, skipping: $input_file"
    (( ++skip_count ))
    continue
  fi

  effective_from="$from_ts"
  effective_from_label=""

  if [[ "$detect_black_leader" == true && "$reverse_mode" != true ]]; then
    if black_ts="$(detect_black_leader_seconds "$input_file" "$black_leader_start_tolerance")"; then
      effective_from="$black_ts"
      effective_from_label="Leading black ends at"
    fi
  fi

  if [[ -n "$effective_from_label" ]]; then
    info "${effective_from_label}: $(format_ts "$effective_from")"
  fi

  if [[ "$effective_from" != "0" && "$reverse_mode" != true ]]; then
    info "Selector start:    $(format_ts "$effective_from")"
  fi

  ts=""
  if ! ts="$(select_keyframe "$input_file" "$keyframes" "$width" "$keep_previews" "$effective_from" "$reverse_mode")"; then
    rc=$?
    if (( rc == 130 )); then
      warn "selection cancelled, skipping"
      (( ++skip_count ))
      continue
    fi
    warn "failed to select keyframe, skipping"
    (( ++fail_count ))
    continue
  fi

  pretty_ts="$(format_ts "$ts")"

  if [[ "$print_start" == true ]]; then
    print -r -- "FLC_START=$ts"
    (( ++ok_count ))
    continue
  fi

  final_output="$input_file"
  work_output="$(make_work_output "$input_file")"

  print
  print -P -- "  %F{white}%B$(esc_prompt "${input_file:t}")%b%f"
  print -P -- "  %F{8}$(esc_prompt "$(media_summary_line "$input_file")")%f"
  if [[ "$reverse_mode" == true ]]; then
    print -P -- "  %F{magenta}outro%f %F{white}$pretty_ts%f %F{8}($ts)%f"
  else
    print -P -- "  %F{magenta}cut%f   %F{white}$pretty_ts%f %F{8}($ts)%f"
  fi

  if [[ "$dry_run" == true ]]; then
    dry_run_movflags="use_metadata_tags"
    [[ "$mov_faststart" == true ]] && dry_run_movflags="+faststart+use_metadata_tags"

    if [[ "$reverse_mode" == true ]]; then
      print -- "ffmpeg -hide_banner -y -to '$ts' -i '$input_file' -map 0 -map_metadata 0 -movflags '$dry_run_movflags' -c copy '$work_output'"
    else
      print -- "ffmpeg -hide_banner -y -ss '$ts' -i '$input_file' -map 0 -map_metadata 0 -movflags '$dry_run_movflags' -c copy '$work_output'"
    fi
    print -- "copy embedded/container metadata from '$input_file' to '$work_output'"
    print -- "copy creation date from '$input_file' to '$work_output'"
    print -- "trash '$input_file'"
    print -- "rename '$work_output' to '$final_output'"
    (( ++ok_count ))
    continue
  fi

  if perform_cut "$input_file" "$ts" "$work_output" "$force" "$reverse_mode" "$mov_faststart"; then
    copy_creation_date "$input_file" "$work_output" || (( ++creation_date_fail_count ))
    touch_modified_now "$work_output"

    # Trash must free the original's name before the rename can take it; the
    # original therefore stays recoverable in Trash if the rename ever fails.
    if maybe_trash_original "$input_file"; then
      if mv -f -- "$work_output" "$final_output"; then
        print -P -- "  %F{green}%B✓ $(esc_prompt "${final_output:t}")%b%f"
        (( ++ok_count ))
      else
        warn "failed to rename output into place; left at: $work_output"
        (( ++fail_count ))
      fi
    else
      (( ++trash_fail_count ))
      warn "original not trashed; left output at: $work_output"
      (( ++fail_count ))
    fi
  else
    rm -f -- "$work_output"
    (( ++fail_count ))
  fi
  print
done

print -P -- "%F{white}%BSummary%b%f  %F{green}✓ $ok_count ok%f · %F{yellow}$skip_count skipped%f · %F{red}$fail_count failed%f · %F{8}dates failed: $creation_date_fail_count, trash failed: $trash_fail_count%f"
(( fail_count == 0 && creation_date_fail_count == 0 && trash_fail_count == 0 ))
