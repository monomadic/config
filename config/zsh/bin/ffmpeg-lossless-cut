#!/usr/bin/env zsh
# ============================================================
# ffmpeg-lossless-cut
# Select a keyframe in fzf, then write a trimmed copy beside the
# source file using ffmpeg stream copy only.
#
# Workflow:
# - always open keyframe selector
# - --detect-black-scenes:
#     first try ffmpeg-detect-black-scenes; if a leading black scene is
#     found, open selector starting after it, otherwise keep the normal flow
#
# Output:
# - writes beside source as *.trimmed.ext
# - copies embedded/container metadata, including source date tags
# - copies the source filesystem creation date to the trimmed output
# - moves the original to Trash after a successful cut
#
# Requirements:
# - zsh
# - ffprobe
# - ffmpeg
# - fzf
#
# Optional:
# - ffmpeg-detect-black-scenes
# - kitty, wezterm, imgcat, chafa
# ============================================================

emulate -L zsh
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  ffmpeg-lossless-cut [options] <video1> [video2 ...]

Options:
  -n, --keyframes <n>       Number of keyframes to show (default: 20)
  -w, --width <px>          Preview width for thumbnails (default: 480)
  -r, --reverse             Trim from the end backward to remove an outro
  -y, --yes                 Skip confirmation after keyframe selection
  -f, --force               Overwrite existing *.trimmed output
  -k, --keep-previews       Keep temporary preview directories
  --dry-run                 Show planned actions only
  --mov-faststart           Enable MP4/MOV FastStart on the trimmed output
  --skip-detection          Deprecated no-op; detection is off unless requested
  --detect-black-scenes     Auto-start after a leading black scene when found
  --from <seconds>          Start selector at/after this timestamp
  -h, --help                Show this help

After a successful cut, copies embedded/container metadata and the original
file creation date to the trimmed output, then moves the original file to
Trash.

Examples:
  ffmpeg-lossless-cut clip.mp4
  ffmpeg-lossless-cut *.mp4
  ffmpeg-lossless-cut --detect-black-scenes *.mp4
  ffmpeg-lossless-cut --from 12.5 clip.mp4
  ffmpeg-lossless-cut --reverse clip.mp4
EOF
}

die() {
  print -r -u2 -- "error: $*"
  exit 1
}

warn() {
  print -r -u2 -- "warning: $*"
}

info() {
  print -r -- "$*"
}

have() {
  command -v "$1" >/dev/null 2>&1
}

is_number() {
  [[ "${1:-}" == <-> || "${1:-}" == <->.<-> ]]
}

float_gt_zero() {
  awk -v v="$1" 'BEGIN { exit !(v > 0.0005) }'
}

float_le() {
  awk -v a="$1" -v b="$2" 'BEGIN { exit !(a <= b + 1e-9) }'
}

normalize_seconds() {
  python3 - "$1" <<'PY'
import sys
print(f"{float(sys.argv[1]):.6f}")
PY
}

format_ts() {
  python3 - "$1" <<'PY'
import sys
s = float(sys.argv[1])
h = int(s // 3600)
m = int((s % 3600) // 60)
sec = s % 60
print(f"{h:02d}:{m:02d}:{sec:09.6f}")
PY
}

make_output_name() {
  local input_file="$1"
  local suffix="${2:-trimmed}"
  local dir base stem ext out

  dir="${input_file:h}"
  base="${input_file:t}"

  if [[ "$base" == *.* ]]; then
    stem="${base:r}"
    ext="${base:e}"
    out="${dir}/${stem}.${suffix}.${ext}"
  else
    out="${dir}/${base}.${suffix}"
  fi

  print -- "$out"
}

command_path_arg() {
  local file_path="$1"

  if [[ "$file_path" != /* && "${file_path:t}" == -* ]]; then
    print -r -- "./$file_path"
  else
    print -r -- "$file_path"
  fi
}

detect_black_leader_seconds() {
  local input_file="$1"
  local tolerance="$2"
  local input_arg output line start end
  local black_re='black_start:([0-9]+([.][0-9]+)?)[[:space:]]+black_end:([0-9]+([.][0-9]+)?)'

  have ffmpeg-detect-black-scenes || return 1

  input_arg="$(command_path_arg "$input_file")"
  output="$(ffmpeg-detect-black-scenes "$input_arg" 2>&1 || true)"

  while IFS= read -r line; do
    if [[ "$line" =~ $black_re ]]; then
      start="${match[1]}"
      end="${match[3]}"

      if float_le "$start" "$tolerance" && float_gt_zero "$end"; then
        normalize_seconds "$end"
        return 0
      fi
    fi
  done <<< "$output"

  return 1
}

probe_keyframes_after() {
  local input_file="$1"
  local start="$2"
  local want="$3"
  local window="$4"

  ffprobe -v error \
    -select_streams v:0 \
    -read_intervals "${start}%+${window}" \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v want="$want" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (!seen[$1]++) {
        print $1
        count++
        if (count >= want) {
          exit
        }
      }
    }
  '
}

probe_keyframes_after_full() {
  local input_file="$1"
  local start="$2"
  local want="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v want="$want" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (!seen[$1]++) {
        print $1
        count++
        if (count >= want) {
          exit
        }
      }
    }
  '
}

probe_keyframes_after_frames_full() {
  local input_file="$1"
  local start="$2"
  local want="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -skip_frame nokey \
    -show_frames \
    -show_entries frame=best_effort_timestamp_time \
    -of default=nw=1:nk=1 \
    -- "$input_file" 2>/dev/null |
  awk -v start="$start" -v want="$want" '
    $1 ~ /^[0-9.]+$/ && ($1 + 0) >= (start + 0) {
      if (!seen[$1]++) {
        print $1
        count++
        if (count >= want) {
          exit
        }
      }
    }
  '
}

probe_last_keyframes_in_interval() {
  local input_file="$1"
  local start="$2"
  local window="$3"
  local keep="$4"

  ffprobe -v error \
    -select_streams v:0 \
    -read_intervals "${start}%+${window}" \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v keep="$keep" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (seen[$1]++) {
        next
      }
      vals[count % keep] = $1
      count++
    }
    END {
      begin = count > keep ? count - keep : 0
      for (i = begin; i < count; i++) {
        print vals[i % keep]
      }
    }
  '
}

probe_last_keyframes_full() {
  local input_file="$1"
  local start="$2"
  local keep="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -show_packets \
    -show_entries packet=pts_time,flags \
    -of csv=p=0 \
    -- "$input_file" 2>/dev/null |
  awk -F, -v start="$start" -v keep="$keep" '
    $1 ~ /^[0-9.]+$/ && $2 ~ /K/ && ($1 + 0) >= (start + 0) {
      if (seen[$1]++) {
        next
      }
      vals[count % keep] = $1
      count++
    }
    END {
      begin = count > keep ? count - keep : 0
      for (i = begin; i < count; i++) {
        print vals[i % keep]
      }
    }
  '
}

probe_last_keyframes_frames_full() {
  local input_file="$1"
  local start="$2"
  local keep="$3"

  ffprobe -v error \
    -select_streams v:0 \
    -skip_frame nokey \
    -show_frames \
    -show_entries frame=best_effort_timestamp_time \
    -of default=nw=1:nk=1 \
    -- "$input_file" 2>/dev/null |
  awk -v start="$start" -v keep="$keep" '
    $1 ~ /^[0-9.]+$/ && ($1 + 0) >= (start + 0) {
      if (seen[$1]++) {
        next
      }
      vals[count % keep] = $1
      count++
    }
    END {
      begin = count > keep ? count - keep : 0
      for (i = begin; i < count; i++) {
        print vals[i % keep]
      }
    }
  '
}

video_duration_seconds() {
  local input_file="$1"

  ffprobe -v error \
    -show_entries format=duration \
    -of default=nw=1:nk=1 \
    -- "$input_file" 2>/dev/null |
  awk 'NR == 1 && $1 ~ /^[0-9.]+$/ { print $1 }'
}

interval_start_for_tail() {
  local duration="$1"
  local window="$2"
  local minimum="$3"

  awk -v duration="$duration" -v window="$window" -v minimum="$minimum" '
    BEGIN {
      start = duration - window
      if (start < minimum) {
        start = minimum
      }
      if (start < 0) {
        start = 0
      }
      printf "%.6f\n", start
    }
  '
}

keyframes_forward() {
  local input_file="$1"
  local start="$2"
  local want="$3"
  local window ts
  local -a vals=()
  local -a windows=(30 120 600 1800)

  for window in "${windows[@]}"; do
    vals=()
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      vals+=("$ts")
    done < <(probe_keyframes_after "$input_file" "$start" "$want" "$window")

    if (( ${#vals[@]} >= want )); then
      print -r -- "${(@F)vals}"
      return 0
    fi
  done

  vals=()
  while IFS= read -r ts; do
    [[ -n "$ts" ]] || continue
    vals+=("$ts")
  done < <(probe_keyframes_after_full "$input_file" "$start" "$want")

  if (( ${#vals[@]} == 0 )); then
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      vals+=("$ts")
    done < <(probe_keyframes_after_frames_full "$input_file" "$start" "$want")
  fi

  (( ${#vals[@]} > 0 )) || return 1
  print -r -- "${(@F)vals}"
}

keyframes_reverse() {
  local input_file="$1"
  local start="$2"
  local want="$3"
  local duration interval_start window ts
  local -a vals=()
  local -a windows=(60 300 900 1800 3600)

  duration="$(video_duration_seconds "$input_file")"

  if [[ -n "$duration" ]]; then
    for window in "${windows[@]}"; do
      interval_start="$(interval_start_for_tail "$duration" "$window" "$start")"
      vals=()
      while IFS= read -r ts; do
        [[ -n "$ts" ]] || continue
        vals+=("$ts")
      done < <(probe_last_keyframes_in_interval "$input_file" "$interval_start" "$window" "$want")

      if (( ${#vals[@]} >= want )); then
        print -r -- "${(@F)vals}"
        return 0
      fi
    done
  fi

  vals=()
  while IFS= read -r ts; do
    [[ -n "$ts" ]] || continue
    vals+=("$ts")
  done < <(probe_last_keyframes_full "$input_file" "$start" "$want")

  if (( ${#vals[@]} == 0 )); then
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      vals+=("$ts")
    done < <(probe_last_keyframes_frames_full "$input_file" "$start" "$want")
  fi

  (( ${#vals[@]} > 0 )) || return 1
  print -r -- "${(@F)vals}"
}

selector_embedded() {
  local input_file="$1"
  local keyframes="$2"
  local width="$3"
  local keep="$4"
  local from_ts="${5:-0}"
  local reverse_mode="${6:-false}"

  local tmp_dir
  tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/fzf-select-keyframe.XXXXXXXX")"

  selector_cleanup() {
    if [[ "$keep" == true ]]; then
      print -u2 -- "kept previews in: $tmp_dir"
    else
      rm -rf -- "$tmp_dir"
    fi
  }

  local -a key_ts=()
  local ts
  local from_num
  from_num="$(python3 - "$from_ts" <<'PY'
import sys
print(float(sys.argv[1]))
PY
)"

  if [[ "$reverse_mode" == true ]]; then
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      key_ts+=("$ts")
    done < <(keyframes_reverse "$input_file" "$from_num" "$keyframes")
  else
    while IFS= read -r ts; do
      [[ -n "$ts" ]] || continue
      key_ts+=("$ts")
    done < <(keyframes_forward "$input_file" "$from_num" "$keyframes")
  fi

  if (( ${#key_ts[@]} == 0 )); then
    selector_cleanup
    return 1
  fi

  local list_file="$tmp_dir/list.tsv"
  : > "$list_file"
  print -r -- "$input_file" > "$tmp_dir/input.path"
  print -r -- "$width" > "$tmp_dir/preview.width"

  local idx=1
  local pretty_ts img_file
  for ts in "${key_ts[@]}"; do
    pretty_ts="$(format_ts "$ts")"
    img_file="$tmp_dir/keyframe-${idx}.jpg"

    printf '%s\t%s\t%s\t%s\n' "$idx" "$ts" "$pretty_ts" "$img_file" >> "$list_file"
    (( ++idx ))
  done

  local preview_script="$tmp_dir/preview.zsh"
  cat > "$preview_script" <<'EOF'
#!/usr/bin/env zsh
emulate -L zsh
set -euo pipefail

idx="$1"
raw_ts="$2"
pretty_ts="$3"
img="$4"

cache_dir="${0:h}"
input_file="$(< "$cache_dir/input.path")"
width="$(< "$cache_dir/preview.width")"

preview_cols="${FZF_PREVIEW_COLUMNS:-80}"
preview_lines="${FZF_PREVIEW_LINES:-24}"
image_lines=$(( preview_lines > 4 ? preview_lines - 4 : preview_lines ))

print -- "$input_file\n"
print -- "Keyframe #$idx"
print -- "Raw:     $raw_ts"
print -- "Display: $pretty_ts"
print -- ""

ensure_preview() {
  [[ -s "$img" ]] && return 0

  local tmp="${img}.$$.jpg"

  trap 'rm -f -- "$tmp"' EXIT INT TERM HUP
  ffmpeg -v error -y \
    -ss "$raw_ts" -i "$input_file" \
    -frames:v 1 \
    -vf "scale=${width}:-2:flags=lanczos" \
    -q:v 3 \
    -- "$tmp" &&
  mv -f -- "$tmp" "$img"
  trap - EXIT INT TERM HUP
}

if ! ensure_preview; then
  print -- "Preview unavailable"
  print -- "$img"
  exit 0
fi

if [[ -n "${KITTY_WINDOW_ID:-}" ]] && command -v kitty >/dev/null 2>&1; then
  kitty +kitten icat \
    --clear \
    --transfer-mode=stream \
    --stdin=no \
    --place="${preview_cols}x${image_lines}@0x4" \
    -- "$img"
elif [[ -n "${WEZTERM_PANE:-}" ]] && command -v wezterm >/dev/null 2>&1; then
  wezterm imgcat --width "${preview_cols}" -- "$img"
elif command -v imgcat >/dev/null 2>&1; then
  imgcat "$img"
elif command -v chafa >/dev/null 2>&1; then
  chafa --animate=off --size="${preview_cols}x${image_lines}" -- "$img"
else
  print -- "$img"
fi
EOF
  chmod +x "$preview_script"

  local header
  if [[ "$reverse_mode" == true ]]; then
    header="Select an outro cut point - ${input_file:t}"
  elif awk -v start="$from_num" 'BEGIN { exit !(start > 0) }'; then
    header="Select a keyframe at/after $(format_ts "$from_num") - ${input_file:t}"
  else
    header="Select a keyframe for lossless cut start - ${input_file:t}"
  fi

  local selection
  selection="$(
    fzf \
      --delimiter=$'\t' \
      --with-nth=1,3 \
      --no-sort \
      --no-input \
      --layout=reverse \
      --height=100% \
      --border \
      --bind='j:down,k:up,h:page-up,l:page-down,g:first,G:last' \
      --header="$header" \
      --preview-window='right,70%,border-left' \
      --preview "zsh '$preview_script' {1} {2} {3} {4}" \
      < "$list_file"
  )" || {
    rc=$?
    selector_cleanup
    return "$rc"
  }

  print -r -- "$selection" | awk -F $'\t' '{ print $2 }'
  selector_cleanup
}

select_keyframe() {
  local input_file="$1"
  local keyframes="$2"
  local width="$3"
  local keep="$4"
  local from_ts="${5:-0}"
  local reverse_mode="${6:-false}"

  selector_embedded "$input_file" "$keyframes" "$width" "$keep" "$from_ts" "$reverse_mode"
}

trim_copy() {
  local input_file="$1"
  local start_time="$2"
  local output_file="$3"
  local mov_faststart="$4"
  local movflags="use_metadata_tags"

  [[ "$mov_faststart" == true ]] && movflags="+faststart+use_metadata_tags"

  ffmpeg -hide_banner -y \
    -ss "$start_time" -i "$input_file" \
    -map 0 \
    -map_metadata 0 \
    -movflags "$movflags" \
    -c copy \
    "$output_file"
}

trim_copy_reverse() {
  local input_file="$1"
  local end_time="$2"
  local output_file="$3"
  local mov_faststart="$4"
  local movflags="use_metadata_tags"

  [[ "$mov_faststart" == true ]] && movflags="+faststart+use_metadata_tags"

  ffmpeg -hide_banner -y \
    -to "$end_time" -i "$input_file" \
    -map 0 \
    -map_metadata 0 \
    -movflags "$movflags" \
    -c copy \
    "$output_file"
}

confirm_overwrite() {
  local output_file="$1"
  local reply=""

  read -r "?Output exists. Overwrite '$output_file'? [y/N] " reply
  [[ "$reply" == [Yy] || "$reply" == [Yy][Ee][Ss] ]]
}

setfile_path_arg() {
  local file_path="$1"

  command_path_arg "$file_path"
}

creation_date_for_setfile() {
  local input_file="$1"
  local epoch

  epoch="$(stat -f '%B' -- "$input_file" 2>/dev/null)" || return 1
  [[ "$epoch" == <-> ]] || return 1
  (( epoch > 0 )) || return 1

  date -r "$epoch" '+%m/%d/%Y %H:%M:%S'
}

copy_creation_date() {
  local input_file="$1"
  local output_file="$2"
  local created output_arg

  if ! have SetFile; then
    warn "SetFile not found; could not copy creation date"
    return 1
  fi

  if ! created="$(creation_date_for_setfile "$input_file")"; then
    warn "could not read creation date: $input_file"
    return 1
  fi

  output_arg="$(setfile_path_arg "$output_file")"
  if SetFile -d "$created" "$output_arg"; then
    info "Copied creation date: $created"
    return 0
  fi

  warn "failed to copy creation date to: $output_file"
  return 1
}

touch_modified_now() {
  local file="$1"

  touch "$file" 2>/dev/null || true
}

trash_original() {
  local input_file="$1"
  local target="$input_file"

  if have trash; then
    [[ "$target" != /* && "${target:t}" == -* ]] && target="./$target"
    trash "$target"
    return
  fi

  local trash_dir="$HOME/.Trash"
  local base dst stamp n

  mkdir -p -- "$trash_dir"
  base="${input_file:t}"
  dst="$trash_dir/$base"

  if [[ -e "$dst" ]]; then
    stamp="$(date +%Y%m%d-%H%M%S)"
    n=1
    while [[ -e "$trash_dir/${base} (${stamp}-${n})" ]]; do
      (( ++n ))
    done
    dst="$trash_dir/${base} (${stamp}-${n})"
  fi

  mv -n -- "$input_file" "$dst"
}

maybe_trash_original() {
  local input_file="$1"

  if trash_original "$input_file"; then
    info "Trashed original:  $input_file"
    return 0
  fi

  warn "failed to trash original: $input_file"
  return 1
}

perform_cut() {
  local input_file="$1"
  local cut_time="$2"
  local output_file="$3"
  local force="$4"
  local reverse_mode="$5"
  local mov_faststart="$6"

  if ! float_gt_zero "$cut_time"; then
    warn "cut time <= 0, skipping: $input_file"
    return 1
  fi

  if [[ -e "$output_file" && "$force" != true ]]; then
    if ! confirm_overwrite "$output_file"; then
      warn "output already exists: $output_file"
      warn "skipped"
      return 1
    fi
  fi

  info "Output:            $output_file"
  if [[ "$reverse_mode" == true ]]; then
    trim_copy_reverse "$input_file" "$cut_time" "$output_file" "$mov_faststart"
  else
    trim_copy "$input_file" "$cut_time" "$output_file" "$mov_faststart"
  fi
}

keyframes=20
width=480
reverse_mode=false
yes=false
force=false
keep_previews=false
dry_run=false
mov_faststart=false
detect_black_leader=false
black_leader_start_tolerance="${BLACK_LEADER_START_TOLERANCE:-0.25}"
from_ts="0"

typeset -a files=()

while (( $# > 0 )); do
  case "$1" in
    -n|--keyframes)
      (( $# >= 2 )) || die "missing value for $1"
      keyframes="$2"
      shift 2
      ;;
    --count)
      (( $# >= 2 )) || die "missing value for $1"
      warn "--count is deprecated; use --keyframes"
      keyframes="$2"
      shift 2
      ;;
    -w|--width)
      (( $# >= 2 )) || die "missing value for $1"
      width="$2"
      shift 2
      ;;
    -r|--reverse)
      reverse_mode=true
      shift
      ;;
    -y|--yes)
      yes=true
      shift
      ;;
    -f|--force)
      force=true
      shift
      ;;
    -k|--keep-previews)
      keep_previews=true
      shift
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    --mov-faststart|--faststart)
      mov_faststart=true
      shift
      ;;
    --skip-detection)
      warn "--skip-detection is deprecated; detection is off unless --detect-black-scenes is set"
      shift
      ;;
    --detect-black-scenes|--detect-black-leader)
      detect_black_leader=true
      shift
      ;;
    --skip-intro-detection)
      warn "--skip-intro-detection is deprecated; detection is off unless --detect-black-scenes is set"
      shift
      ;;
    --from)
      (( $# >= 2 )) || die "missing value for $1"
      from_ts="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      files+=("$@")
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      files+=("$1")
      shift
      ;;
  esac
done

(( ${#files[@]} > 0 )) || {
  usage
  exit 1
}

have ffprobe || die "ffprobe not found"
have ffmpeg  || die "ffmpeg not found"
have fzf     || die "fzf not found"

[[ "$keyframes" == <-> ]] || die "--keyframes must be an integer"
[[ "$width" == <-> ]] || die "--width must be an integer"
(( keyframes > 0 )) || die "--keyframes must be > 0"
(( width > 0 )) || die "--width must be > 0"
is_number "$from_ts" || die "--from must be numeric seconds"
is_number "$black_leader_start_tolerance" || die "BLACK_LEADER_START_TOLERANCE must be numeric seconds"

integer ok_count=0
integer skip_count=0
integer fail_count=0
integer creation_date_fail_count=0
integer trash_fail_count=0

for input_file in "${files[@]}"; do
  print
  info "────────────────────────────────────────────────────────────"
  info "File: $input_file"

  if [[ ! -f "$input_file" ]]; then
    warn "not a file, skipping"
    (( ++skip_count ))
    continue
  fi

  effective_from="$from_ts"
  effective_from_label=""

  if [[ "$detect_black_leader" == true && "$reverse_mode" != true ]]; then
    if black_ts="$(detect_black_leader_seconds "$input_file" "$black_leader_start_tolerance")"; then
      effective_from="$black_ts"
      effective_from_label="Leading black ends at"
    fi
  fi

  if [[ -n "$effective_from_label" ]]; then
    info "${effective_from_label}: $(format_ts "$effective_from")"
  fi

  if [[ "$effective_from" != "0" && "$reverse_mode" != true ]]; then
    info "Selector start:    $(format_ts "$effective_from")"
  fi

  ts=""
  if ! ts="$(select_keyframe "$input_file" "$keyframes" "$width" "$keep_previews" "$effective_from" "$reverse_mode")"; then
    rc=$?
    if (( rc == 130 )); then
      warn "selection cancelled, skipping"
      (( ++skip_count ))
      continue
    fi
    warn "failed to select keyframe, skipping"
    (( ++fail_count ))
    continue
  fi

  pretty_ts="$(format_ts "$ts")"
  output_file="$(make_output_name "$input_file" "trimmed")"

  if [[ "$reverse_mode" == true ]]; then
    info "Selected outro:    $pretty_ts  ($ts)"
  else
    info "Selected cut:      $pretty_ts  ($ts)"
  fi
  info "Trimmed output:    $output_file"

  if [[ "$dry_run" == true ]]; then
    dry_run_movflags="use_metadata_tags"
    [[ "$mov_faststart" == true ]] && dry_run_movflags="+faststart+use_metadata_tags"

    if [[ "$reverse_mode" == true ]]; then
      print -- "ffmpeg -hide_banner -y -to '$ts' -i '$input_file' -map 0 -map_metadata 0 -movflags '$dry_run_movflags' -c copy '$output_file'"
    else
      print -- "ffmpeg -hide_banner -y -ss '$ts' -i '$input_file' -map 0 -map_metadata 0 -movflags '$dry_run_movflags' -c copy '$output_file'"
    fi
    print -- "copy embedded/container metadata from '$input_file' to '$output_file'"
    print -- "copy creation date from '$input_file' to '$output_file'"
    print -- "trash '$input_file'"
    (( ++ok_count ))
    continue
  fi

  if perform_cut "$input_file" "$ts" "$output_file" "$force" "$reverse_mode" "$mov_faststart"; then
    info "Done: wrote trimmed copy"
    copy_creation_date "$input_file" "$output_file" || (( ++creation_date_fail_count ))
    touch_modified_now "$output_file"
    (( ++ok_count ))
    maybe_trash_original "$input_file" || (( ++trash_fail_count ))
  else
    (( ++fail_count ))
  fi
done

print
info "Summary: ok=$ok_count skipped=$skip_count failed=$fail_count creation_date_failed=$creation_date_fail_count trash_failed=$trash_fail_count"
(( fail_count == 0 && creation_date_fail_count == 0 && trash_fail_count == 0 ))
