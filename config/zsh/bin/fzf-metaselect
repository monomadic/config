#!/usr/bin/env zsh
set -euo pipefail
#
#   fzf-metaselect — an enhanced fzf-select that renders richer, multi-line
#   entries using fzf's multi-line item feature (fzf >= 0.53).
#
#   Each entry spans two lines:
#     line 1: the filename   (name color)
#     line 2: the full path  (path color)
#
#   Like fzf-select it reads paths on stdin and prints the selected paths back
#   out, mapping the on-screen display to the real path via an index table.
#   Because the display is multi-line, records are ALWAYS fed to fzf as
#   NUL-delimited items regardless of how this script reads its own stdin.
#
#   Performance: the per-record loop does no forks (display is formatted with
#   zsh builtins, the index table is written via a dedicated fd), and UTF-8
#   sanitisation runs once over the whole stream rather than once per file.

# Colors for the parsed fields (edit to taste). Layout:
#   line 1:  <Title> <Rating> <res> <fps> <length>
#   line 2:  <Actors>  <directory>
# The title is deliberately high-contrast; metadata and path are dimmer. The
# match-highlight and selected-row colors are set on the fzf command below.
title_color=$'\033[1;38;5;231m'   # bright white, bold — title/name (stands out)
rating_color=$'\033[38;5;220m'    # yellow — rating stars
meta_color=$'\033[38;5;79m'          # teal — resolution / fps / length
actor_color=$'\033[38;2;80;250;123m' # green — actors
path_color=$'\033[38;5;244m'      # grey — directory path
reset=$'\033[0m'

show_absolute=false
read0=false
print0=false
stream=false
colorize=true
persistent=false
passthrough_args=()
records_loaded=0

for arg in "$@"; do
  case "$arg" in
    --absolute-paths) show_absolute=true ;;
    --no-color)       colorize=false ;;
    --color)          colorize=true ;;   # default; accepted for fzf-select parity
    -0|--read0)       read0=true ;;
    --print0)         print0=true ;;
    --stream)         stream=true ;;
    --persistent)     persistent=true ;;  # Enter plays via mpv but keeps fzf open
    *)                passthrough_args+=("$arg") ;;
  esac
done

# With --no-color the same code emits the fields plain, just without color.
if ! $colorize; then
  title_color="" rating_color="" meta_color="" actor_color="" path_color="" reset=""
fi

if [[ -t 0 ]]; then
  print -u2 "Error: expected piped input"
  exit 1
fi

for bin in fzf mktemp awk; do
  command -v "$bin" >/dev/null 2>&1 || {
    print -u2 "Error: missing dependency: $bin"
    exit 1
  }
done

tmp_map=$(mktemp -t fzf-metaselect.map.XXXXXX)
tmp_lines=$(mktemp -t fzf-metaselect.lines.XXXXXX)
tmp_lines_raw=$(mktemp -t fzf-metaselect.lines-raw.XXXXXX)
tmp_selected=$(mktemp -t fzf-metaselect.selected.XXXXXX)
tmp_selected_lines=$(mktemp -t fzf-metaselect.selected-lines.XXXXXX)
tmp_fzf_status=$(mktemp -t fzf-metaselect.status.XXXXXX)

cleanup() {
  rm -f -- "$tmp_map" "$tmp_lines" "$tmp_lines_raw" "$tmp_selected" \
           "$tmp_selected_lines" "$tmp_fzf_status"
  (stty sane < /dev/tty >/dev/null 2>&1) 2>/dev/null || true
}
trap cleanup EXIT INT TERM

status_message() {
  [[ -t 2 ]] || return 0
  print -u2 -- "fzf-metaselect: $*"
}

sanitize_utf8() {
  if command -v iconv >/dev/null 2>&1; then
    iconv -f UTF-8 -t UTF-8 -c 2>/dev/null
  else
    cat
  fi
}

# Parse a basename into fields (sets the F_* globals). Fork-free and best-effort:
# actors = text before the first " - "; everything spec-like (rating, resolution,
# fps, length) is pulled out of the trailing " [ … ] " block and the stars; the
# id "(…_…)", #tags, a leading "[Channel]" and a trailing "(Channel)" are dropped;
# whatever descriptive text remains is the title.
typeset -g F_TITLE="" F_RATING="" F_RES="" F_FPS="" F_LEN="" F_ACTORS=""
parse_fields() {
  setopt local_options extended_glob
  local fname="$1" stem rest specs b bl tok vid
  local -a keep
  F_TITLE="" F_RATING="" F_RES="" F_FPS="" F_LEN="" F_ACTORS=""

  # strip the final extension, then a secondary marker ext (.trimmed/.original/…)
  stem="${fname%.*}"
  case "${stem##*.}" in
    trimmed|original|cut|edit|final|fixed) stem="${stem%.*}" ;;
  esac

  # rating stars
  if [[ "$stem" == *[★☆] && "$stem" =~ ' ([★☆]+)$' ]]; then
    F_RATING="$match[1]"; stem="${stem% $F_RATING}"
  fi

  # trailing "[ … ]" — pull resolution / fps / length out of a spec-like block
  if [[ "$stem" == *'['*']' ]]; then
    b="${stem##*\[}"; b="${b%\]}"; bl="${(L)b}"
    if [[ "$bl" =~ '[0-9]+(p|k)|fps|mbps|h26[45]|av1|[0-9]+(min|sec)' ]]; then
      specs="$b"; stem="${stem% \[$b\]}"
      for tok in ${(s: :)specs}; do
        [[ -z "$tok" ]] && continue
        if [[ -z "$F_RES" && "${(L)tok}" == ([0-9]##p|[0-9]##k) ]]; then F_RES="$tok"; continue; fi
        if [[ -z "$F_FPS" && "${(L)tok}" == [0-9]##fps ]]; then F_FPS="$tok"; continue; fi
        if [[ -z "$F_LEN" ]]; then
          if [[ "$tok" == [0-9]##:[0-9][0-9](:[0-9][0-9])# ]]; then F_LEN="$tok"; continue; fi
          if [[ "${(L)tok}" == [0-9]##(min|mins|sec|secs|s|m|h|hr|hrs) ]]; then F_LEN="$tok"; continue; fi
        fi
      done
    fi
  fi

  # drop the provider id "(…_…)"
  if [[ "$stem" == *'('*'_'*')'* && "$stem" =~ '\(([^()]*_[^()]*)\)' ]]; then
    vid="$match[1]"; stem="${stem/ \(${vid}\)/}"; stem="${stem/\(${vid}\)/}"
  fi

  # actors = before the first " - ";  rest = after it
  if [[ "$stem" == *' - '* ]]; then
    F_ACTORS="${stem%% - *}"; rest="${stem#* - }"
  else
    rest="$stem"
  fi

  # drop a trailing "(Channel)" from actors and a leading "[Channel]" from rest
  if [[ "$F_ACTORS" == *')' && "$F_ACTORS" =~ ' \(([^()]+)\)$' ]]; then
    F_ACTORS="${F_ACTORS% \($match[1]\)}"
  fi
  if [[ "$rest" == \[* && "$rest" =~ '^\[([^][]+)\] (.+)$' ]]; then
    rest="$match[2]"
  fi

  # drop #tags; whatever non-empty tokens remain make the title
  keep=()
  for tok in ${(s: :)rest}; do
    [[ -z "$tok" || "$tok" == '#'* ]] && continue
    keep+=("$tok")
  done
  F_TITLE="${(j: :)keep}"
  [[ -n "$F_TITLE" ]] || F_TITLE="${fname%.*}"
}

# Emit one NUL-delimited two-line record to stdout and record its raw path on
# $map_fd:
#   line 1:  <Title> <Rating> <res> <fps> <length>
#   line 2:  <Actors>  <directory>
emit_one() {
  local raw="$1" idx="$2" base dir line1 line2

  print -r -u $map_fd -- "$raw"

  if $show_absolute; then
    printf '%s\t%s\0' "$idx" "$raw"
    return 0
  fi

  base=${raw:t}; dir=${raw:h}
  parse_fields "$base"

  line1="${title_color}${F_TITLE}${reset}"
  if [[ -n "$F_RATING" ]]; then
    local stars="${F_RATING//★/􀋃 }"; stars="${stars//☆/􀋂 }"
    line1+=" ${rating_color}${stars}${reset}"
  fi
  [[ -n "$F_RES" ]]    && line1+=" ${meta_color}${F_RES}${reset}"
  [[ -n "$F_FPS" ]]    && line1+=" ${meta_color}${F_FPS}${reset}"
  [[ -n "$F_LEN" ]]    && line1+=" ${meta_color}${F_LEN}${reset}"

  line2=""
  [[ -n "$F_ACTORS" ]] && line2="${actor_color}${F_ACTORS}${reset}"
  line2+="${line2:+  }${path_color}${dir}${reset}"

  printf '%s\t%s\n%s\0' "$idx" "$line1" "$line2"
}

# Read stdin (NUL or newline) and emit records to stdout. The index advances
# only for records actually emitted, keeping it aligned with $map_fd line N.
build_records() {
  local raw idx=1

  if $read0; then
    while IFS= read -r -d $'\0' raw || [[ -n "$raw" ]]; do
      [[ -z "$raw" ]] && { raw=""; continue; }
      emit_one "$raw" "$idx"
      (( ++idx )); raw=""
    done
  else
    while IFS= read -r raw || [[ -n "$raw" ]]; do
      [[ -z "$raw" ]] && { raw=""; continue; }
      emit_one "$raw" "$idx"
      (( ++idx )); raw=""
    done
  fi

  records_loaded=$(( idx - 1 ))
  return 0
}

map_selection() {
  if $print0; then
    tr '\0' '\n' < "$tmp_selected" > "$tmp_selected_lines"
    LC_ALL=C awk '
      NR == FNR { paths[NR] = $0; next }
      $1 in paths { printf "%s%c", paths[$1], 0 }
    ' "$tmp_map" "$tmp_selected_lines"
  else
    LC_ALL=C awk '
      NR == FNR { paths[NR] = $0; next }
      $1 in paths { print paths[$1] }
    ' "$tmp_map" "$tmp_selected"
  fi
}

# Each bind resolves the highlighted row's real path from the index map ($1 is
# the index field {1}, $2 the map file), then acts on it. The reveal bind is
# silent; the rest hand the terminal to a TUI/editor via execute(). After a
# rename/trim the new path is appended with `media-index add` (the stale entry is
# left for mpv to skip / `media-index prune` to clean up).
reveal_bind="execute-silent(zsh -c 'p=\$(sed -n \"\${1}p\" \"\$2\"); [[ -n \"\$p\" ]] && open --reveal \"\$p\"' _ {1} ${(q)tmp_map})"
yazi_bind="execute(zsh -c 'p=\$(sed -n \"\${1}p\" \"\$2\"); [[ -n \"\$p\" ]] && yazi \"\$p\"' _ {1} ${(q)tmp_map})"
trim_bind="execute(zsh -c 'p=\$(sed -n \"\${1}p\" \"\$2\"); [[ -n \"\$p\" ]] || exit 0; ffmpeg-lossless-cut \"\$p\"; n=\"\${p:r}.trimmed.\${p:e}\"; [[ ! -e \"\$p\" && -f \"\$n\" ]] && media-index add \"\$n\"' _ {1} ${(q)tmp_map})"
rename_bind="execute(zsh -c 'p=\$(sed -n \"\${1}p\" \"\$2\"); [[ -n \"\$p\" ]] || exit 0; d=\${p:h}; o=\${p:t}; t=\$(mktemp -t fms-rename.XXXXXX) || exit 1; print -r -- \"\$o\" >| \"\$t\"; \${EDITOR:-vi} \"\$t\"; n=\$(sed -n 1p \"\$t\"); rm -f \"\$t\"; [[ -n \"\$n\" && \"\$n\" != \"\$o\" ]] || exit 0; mv -i -- \"\$p\" \"\$d/\$n\" && media-index add \"\$d/\$n\"' _ {1} ${(q)tmp_map})"

# Enter: by default select everything and accept (closes fzf, caller plays it).
# With --persistent, play the marked/current row(s) via mpv-send and stay open;
# {+1} gives the index field of each selected row, resolved against the map.
if $persistent; then
  enter_bind="execute-silent(zsh -c 'm=\$1; shift; for i in \"\$@\"; do sed -n \"\${i}p\" \"\$m\"; done | mpv-send play' _ ${(q)tmp_map} {+1})"
else
  enter_bind="select-all+accept"
fi

fzf_args=(
  --multi
  --read0
  --ansi
  --highlight-line
  --gap
  --gap-line=' '
  --exact
  --cycle
  --delimiter=$'\t'
  --with-nth='2..'
  --accept-nth=1
  --preview-window=next
  --color=hl:bold:#FE2A6E,hl+:bold:#FFFF5F,fg+:bold:#FFFFFF,bg+:#5E0A6E,pointer:#FF5FAF,marker:#87FF5F
  --bind "enter:$enter_bind"
  --bind 'ctrl-p:up'
  --bind 'alt-p:toggle-preview'
  --bind "alt-r:$reveal_bind"
  --bind "ctrl-y:$yazi_bind"
  --bind "ctrl-r:$rename_bind"
  --bind "ctrl-t:$trim_bind"
)

$print0 && fzf_args+=(--print0)
fzf_args+=("${passthrough_args[@]}")

exec {map_fd}>"$tmp_map"

set +e
if $stream; then
  build_records | sanitize_utf8 | {
    fzf "${fzf_args[@]}" > "$tmp_selected"
    print -r -- "$?" > "$tmp_fzf_status"
  }
  fzf_status="$(< "$tmp_fzf_status")"
  [[ -n "$fzf_status" ]] || fzf_status=1
else
  status_message "reading stdin before launching fzf (safe mode; use --stream for experimental live input)"
  build_records > "$tmp_lines_raw"
  sanitize_utf8 < "$tmp_lines_raw" > "$tmp_lines"
  status_message "loaded $records_loaded item(s); launching fzf"
  fzf "${fzf_args[@]}" < "$tmp_lines" > "$tmp_selected"
  fzf_status=$?
fi
set -e

exec {map_fd}>&-

case "$fzf_status" in
  0) ;;
  1) exit 0 ;;
  130) exit 130 ;;
  *) exit "$fzf_status" ;;
esac

if [[ -s "$tmp_selected" ]]; then
  map_selection
fi
