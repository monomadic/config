#!/usr/bin/env zsh
# ============================================================================
# vdjstems-pack — package stem WAVs into VirtualDJ stem files
# ============================================================================
#
# Takes a directory of separated stem WAVs (from vdjstems-split, demucs,
# MDX23, …) and produces one of the two stem formats VirtualDJ accepts.
# See docs/vdjstems-format.md for the full reverse-engineered spec.
#
# FORMATS (be explicit — they are not interchangeable):
#
#   SIDECAR (--sidecar ORIGINAL) — VirtualDJ's native prepared-stems cache.
#     Matroska container named "<original filename>.vdjstems" written next
#     to the original track. Exactly 5 AAC-LC 44.1 kHz stereo streams in
#     this order, each titled: vocal, hihat, bass, instruments, kick.
#     No mixed track — VDJ plays the original file and uses the sidecar
#     for stem separation. This mirrors the 1500+ sidecars VDJ itself has
#     generated in this library (verified July 2026, VDJ 2026 builds).
#
#   STANDALONE (default) — self-contained 6-track M4A loadable as a track:
#     stream order mixed, vocal, hihat, bass, instruments, kick with MP4Box
#     udta track names, brands isom:512/mp42/mp41, flat storage — the
#     community format (reverse-engineered from VirtualDJ 2023-era output)
#     that VDJ detects as a stems file. mixed.wav is used as the master
#     when present, otherwise the master is summed from the unique stems
#     (amix normalize=1 into float32 — no fixed gain, no clipping).
#     Output: <name>-stems.m4a (AAC 320k, or ALAC with --lossless).
#
# Shared input handling:
#   - Filename aliases: drums.wav → kick, other.wav → instruments,
#     vocals.wav → vocal, drums-hihats.wav → hihat, …
#   - Missing hihat: the drums/kick stem is duplicated into both kick and
#     hihat at −6 dB each, so the pair sums back to the original level.
#
# Metadata (standalone only; a sidecar's tags live in the original file):
#   - tempo: --bpm, or measured from the master with aubio when available
#   - key: --key, written as the iTunes freeform initialkey atom
#     (AtomicParsley) that Mixed In Key / Serato use
#
# Dependencies: ffmpeg, ffprobe; MP4Box for standalone (brew install gpac)
#   optional:   aubio (BPM detection), AtomicParsley (key tag)
# See also: vdjstems-split (make the input WAVs), vdjstems-create
#           (lossless standalone one-shot from CWD), vdjstems-from-nistem,
#           vdjstems-extract, vdjstems-info
# ============================================================================

set -euo pipefail
SELF="${0:t}"

# Colors
BOLD='\033[1m'
RESET='\033[0m'

# Stream orders (do not change — VirtualDJ matches on these)
SIDECAR_ORDER=("vocal" "hihat" "bass" "instruments" "kick")
STANDALONE_NAMES=("mixed track" "vocal" "hihat" "bass" "instruments" "kick")

# Required input stems (internal collection order)
STEMS=("kick" "instruments" "vocal" "bass" "hihat")

# Defaults
FORMAT="standalone"       # standalone | sidecar
ORIGINAL=""               # original audio file (sidecar)
CODEC="aac"
CODEC_EXT="aac"
CODEC_OPTS=("-c:a" "aac" "-b:a" "320k")
LOSSLESS=false
BPM=""
KEY=""
OUT=""

usage() {
  cat <<EOF
${BOLD}VirtualDJ Stem Packer${RESET}
Package stem WAVs into a VirtualDJ stem file.

${BOLD}USAGE:${RESET}
  $SELF [OPTIONS] <stem_directory>

${BOLD}OPTIONS:${RESET}
  --sidecar ORIGINAL  Write VDJ-native sidecar "<ORIGINAL>.vdjstems"
                      (Matroska, 5 AAC stems, no mixed track) next to the
                      original audio file
  --standalone        Self-contained 6-track M4A (default)
  -l, --lossless      Standalone only: ALAC instead of AAC 320k
  -o, --out FILE      Output path (default: sidecar → next to ORIGINAL;
                      standalone → <dir name>-stems.m4a in the dir)
  -b, --bpm BPM       Standalone: tag tempo (default: measured with aubio)
  -k, --key KEY       Standalone: tag initial key (needs AtomicParsley)
  -h, --help          Show this help

${BOLD}FORMATS:${RESET}
  ${BOLD}Sidecar${RESET}    = what VirtualDJ itself creates: stems for an existing
               track in your library. Play the original; VDJ finds the
               .vdjstems next to it.
  ${BOLD}Standalone${RESET} = a 6-track M4A that is itself a library track (mixed
               master + 5 stems). Uses mixed.wav as master if present,
               else sums one from the stems.

${BOLD}REQUIRED STEMS${RESET} (aliases accepted):
    • kick        (or drums.wav, drums-main.wav)
    • instruments (or other.wav)
    • vocal       (or vocals.wav)
    • bass
    • hihat       (or drums-hihats.wav, hihats.wav) — optional; falls back
                  to duplicating drums/kick at −6 dB

${BOLD}EXAMPLES:${RESET}
  $SELF --sidecar ~/Music/song.flac ~/Music/song.stems   # VDJ-native
  $SELF ~/Music/MySong/stems                             # standalone AAC
  $SELF -l -k Am ~/Music/MySong/stems                    # standalone ALAC
EOF
  exit 0
}

info()    { print -P "%F{blue}→%f $*"; }
success() { print -P "%F{green}✓%f $*"; }
warn()    { print -P "%F{yellow}⚠%f $*" >&2; }
error()   { print -P "%F{red}✗%f $*" >&2; }
die()     { error "$*"; exit 1; }

# Parse options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --sidecar)
      FORMAT="sidecar"
      ORIGINAL="${2:-}"
      [[ -n "$ORIGINAL" ]] || die "--sidecar requires the original audio file"
      shift 2
      ;;
    -s|--standalone)
      FORMAT="standalone"
      shift
      ;;
    -l|--lossless)
      LOSSLESS=true
      CODEC="alac"
      CODEC_EXT="m4a"
      CODEC_OPTS=("-c:a" "alac" "-sample_fmt" "s16p")
      shift
      ;;
    -o|--out)
      OUT="${2:-}"
      [[ -n "$OUT" ]] || die "--out requires a value"
      shift 2
      ;;
    -b|--bpm)
      BPM="${2:-}"
      [[ -n "$BPM" ]] || die "--bpm requires a value"
      shift 2
      ;;
    -k|--key)
      KEY="${2:-}"
      [[ -n "$KEY" ]] || die "--key requires a value"
      shift 2
      ;;
    -h|--help)
      usage
      ;;
    -*)
      die "Unknown option: $1 (use -h for help)"
      ;;
    *)
      break
      ;;
  esac
done

# Check dependencies
command -v ffmpeg  >/dev/null 2>&1 || die "ffmpeg not found (brew install ffmpeg)"
command -v ffprobe >/dev/null 2>&1 || die "ffprobe not found (brew install ffmpeg)"
if [[ "$FORMAT" == "standalone" ]]; then
  command -v MP4Box >/dev/null 2>&1 || die "MP4Box not found (brew install gpac)"
fi
if [[ "$FORMAT" == "sidecar" ]]; then
  [[ -f "$ORIGINAL" ]] || die "Original file not found: $ORIGINAL"
  ORIGINAL="${ORIGINAL:A}"
  if [[ "$LOSSLESS" == "true" ]]; then
    warn "sidecar is AAC to match VirtualDJ's native format — ignoring --lossless"
    CODEC="aac"; CODEC_OPTS=("-c:a" "aac" "-b:a" "320k")
  fi
fi

[[ $# -eq 1 ]] || { error "Missing stem directory"; print "Use -h for help"; exit 2; }

FOLDER="$(cd "$1" 2>/dev/null && pwd)" || die "Cannot access directory: $1"
[[ -d "$FOLDER" ]] || die "Not a directory: $FOLDER"

print -P "\n%F{cyan}%B━━━ VirtualDJ Stem Packer ━━━%b%f\n"
if [[ "$FORMAT" == "sidecar" ]]; then
  print -P "%F{cyan}Format:%f %BSIDECAR%b %F{244}(VDJ-native Matroska, 5 stems, no mixed track)%f"
  print -P "%F{cyan}For:%f    %F{244}${ORIGINAL}%f"
else
  print -P "%F{cyan}Format:%f %BSTANDALONE%b %F{244}(self-contained 6-track M4A)%f"
fi

# Create temp workspace
tmpdir="$(mktemp -d)"
trap "rm -rf '$tmpdir'" EXIT

# Find input files
find_stem() {
  local stem="$1"
  local f

  # Direct match
  [[ -f "$FOLDER/${stem}.wav" ]] && { print "$FOLDER/${stem}.wav"; return; }

  # Common aliases
  case "$stem" in
    kick)        for f in "$FOLDER"/drums.wav "$FOLDER"/drums-main.wav "$FOLDER"/kick.wav; do
                   [[ -f "$f" ]] && { print "$f"; return; }
                 done ;;
    hihat)       for f in "$FOLDER"/drums-hihats.wav "$FOLDER"/hihat.wav "$FOLDER"/hihats.wav; do
                   [[ -f "$f" ]] && { print "$f"; return; }
                 done ;;
    instruments) for f in "$FOLDER"/other.wav "$FOLDER"/instruments.wav; do
                   [[ -f "$f" ]] && { print "$f"; return; }
                 done ;;
    vocal)       for f in "$FOLDER"/vocals.wav "$FOLDER"/vocal.wav; do
                   [[ -f "$f" ]] && { print "$f"; return; }
                 done ;;
    bass)        [[ -f "$FOLDER"/bass.wav ]] && { print "$FOLDER/bass.wav"; return; } ;;
  esac

  # Case-insensitive fallback
  for f in "$FOLDER"/*.wav; do
    [[ -f "$f" ]] || continue
    local name="$(basename "${f%.wav}" | tr '[:upper:]' '[:lower:]')"
    [[ "$name" == "$stem" ]] && { print "$f"; return; }
  done

  return 1
}

# Collect input files into an associative map stem → file
info "\nLocating stem files..."
typeset -A STEM_FILE
HIHAT_FALLBACK=false
for stem in "${STEMS[@]}"; do
  if f="$(find_stem "$stem")"; then
    STEM_FILE[$stem]="$f"
    print -P "  %F{green}✓%f %-12s %F{244}%s%f" "$stem" "$(basename "$f")"
  elif [[ "$stem" == "hihat" ]]; then
    HIHAT_FALLBACK=true
    print -P "  %F{yellow}⚠%f %-12s %F{244}using drums/kick at −6 dB as fallback%f" "$stem"
  else
    die "Missing stem: $stem.wav"
  fi
done
[[ "$HIHAT_FALLBACK" == "true" ]] && STEM_FILE[hihat]="${STEM_FILE[kick]}"

# ============================================================================
# SIDECAR: one ffmpeg run — Matroska, 5 AAC streams, titled, VDJ order
# ============================================================================
if [[ "$FORMAT" == "sidecar" ]]; then
  output="${OUT:-${ORIGINAL}.vdjstems}"

  info "\nWriting Matroska sidecar (vocal, hihat, bass, instruments, kick)..."
  ff_in=()
  for stem in "${SIDECAR_ORDER[@]}"; do
    ff_in+=(-i "${STEM_FILE[$stem]}")
  done
  # Streams 1 (hihat) and 4 (kick) drop −6 dB when both come from drums,
  # so the duplicated pair sums back to the original drum level.
  vol_args=()
  if [[ "$HIHAT_FALLBACK" == "true" ]]; then
    vol_args=(-filter:a:1 "volume=-6.0206dB" -filter:a:4 "volume=-6.0206dB")
  fi
  ffmpeg -y -loglevel error "${ff_in[@]}" \
    -map 0:a -map 1:a -map 2:a -map 3:a -map 4:a \
    "${vol_args[@]}" \
    -c:a aac -b:a 320k -ar 44100 -ac 2 \
    -disposition:a:0 0 -disposition:a:1 0 -disposition:a:2 0 \
    -disposition:a:3 0 -disposition:a:4 0 \
    -metadata:s:a:0 title="vocal" \
    -metadata:s:a:1 title="hihat" \
    -metadata:s:a:2 title="bass" \
    -metadata:s:a:3 title="instruments" \
    -metadata:s:a:4 title="kick" \
    -f matroska "$output" || die "Sidecar mux failed"

  # Verify against the native spec
  info "\nVerifying sidecar..."
  fmt="$(ffprobe -v error -show_entries format=format_name -of default=nk=1:nw=1 "$output")"
  titles="$(ffprobe -v error -select_streams a -show_entries stream_tags=title -of default=nk=1:nw=1 "$output" | tr '\n' ',')"
  if [[ "$fmt" == matroska* && "$titles" == "vocal,hihat,bass,instruments,kick," ]]; then
    success "Matroska container, 5 streams titled in VDJ order"
    print -P "\n%F{green}%B✓ Created SIDECAR stems%b%f"
    print -P "Output: %F{cyan}%U${output}%u%f"
    print -P "Size:   %F{244}$(du -h "$output" | cut -f1)%f"
    print -P "%F{244}Load the original track in VirtualDJ — it will use this sidecar.%f\n"
  else
    warn "Verification failed (format=$fmt titles=$titles)"
    exit 1
  fi
  exit 0
fi

# ============================================================================
# STANDALONE: 6-track M4A (mixed + stems), MP4Box udta names, flat storage
# ============================================================================
print -P "\n%F{cyan}Codec:%f %B${(U)CODEC}%b"

# Master track: mixed.wav if provided, else summed from the unique stems
mixed_src=""
for f in "$FOLDER/mixed.wav" "$FOLDER/mixed track.wav" "$FOLDER/Mixed.wav" "$FOLDER/Mixed Track.wav"; do
  [[ -f "$f" ]] && { mixed_src="$f"; break; }
done

if [[ -n "$mixed_src" ]]; then
  info "\nMaster: existing $(basename "$mixed_src")"
  mixed_wav="$mixed_src"
else
  info "\nMaster: summing unique stems (no mixed.wav found)..."
  mixed_wav="$tmpdir/mixed.wav"
  MIX_FILES=()
  for stem in "${STEMS[@]}"; do
    # skip the duplicated hihat so drums aren't counted twice
    [[ "$stem" == "hihat" && "$HIHAT_FALLBACK" == "true" ]] && continue
    MIX_FILES+=("${STEM_FILE[$stem]}")
  done
  mix_args=()
  for f in "${MIX_FILES[@]}"; do mix_args+=(-i "$f"); done
  ffmpeg -y -loglevel error "${mix_args[@]}" \
    -filter_complex "amix=inputs=${#MIX_FILES[@]}:normalize=1:duration=longest" \
    -c:a pcm_f32le "$mixed_wav" || die "Mix failed"
  success "Master summed from ${#MIX_FILES[@]} unique sources"
fi

# Measure tempo from the master unless the user supplied one
if [[ -z "$BPM" ]] && command -v aubio >/dev/null 2>&1; then
  BPM="$(aubio tempo -i "$mixed_wav" 2>/dev/null | tail -1 | awk '/bpm/{printf "%.0f", $1}')"
  [[ -n "$BPM" ]] && info "Measured tempo: ${BPM} BPM (aubio)"
fi

# Encode all tracks in parallel (independent ffmpeg jobs)
info "\nEncoding $CODEC tracks (parallel)..."
ENCODED_FILES=()
encode_pids=()
for stem in "${STEMS[@]}"; do
  dst="$tmpdir/$stem.$CODEC_EXT"
  # Duplicated drums (kick + hihat fallback) each drop −6 dB so they sum
  # back to the original drum level when both stems play.
  filter_args=()
  if [[ "$HIHAT_FALLBACK" == "true" ]] && [[ "$stem" == "kick" || "$stem" == "hihat" ]]; then
    filter_args=(-filter:a "volume=-6.0206dB")
  fi
  ffmpeg -y -loglevel error -i "${STEM_FILE[$stem]}" -vn "${filter_args[@]}" "${CODEC_OPTS[@]}" "$dst" &
  encode_pids+=($!)
  ENCODED_FILES+=("$dst")
done

# Master too (ALAC master gets s32p for headroom)
dst="$tmpdir/mixed.$CODEC_EXT"
MIXED_OPTS=("${CODEC_OPTS[@]}")
[[ "$CODEC" == "alac" ]] && MIXED_OPTS=("-c:a" "alac" "-sample_fmt" "s32p")
ffmpeg -y -loglevel error -i "$mixed_wav" -vn "${MIXED_OPTS[@]}" "$dst" &
encode_pids+=($!)
ENCODED_FILES+=("$dst")

for pid in "${encode_pids[@]}"; do
  wait "$pid" || die "An encode job failed"
done
for dst in "${ENCODED_FILES[@]}"; do
  [[ -s "$dst" ]] || die "Encode produced no output: $(basename "$dst")"
  print -P "  %F{green}✓%f $(basename "$dst")"
done

# Mux with the proven stream order
# ENCODED_FILES: 1 kick, 2 instruments, 3 vocal, 4 bass, 5 hihat, 6 mixed
# Output order:  mixed → vocal → hihat → bass → instruments → kick
info "\nMuxing M4A container..."
temp_m4a="$tmpdir/temp.m4a"

ffmpeg -y -loglevel error \
  -i "${ENCODED_FILES[1]}" \
  -i "${ENCODED_FILES[2]}" \
  -i "${ENCODED_FILES[3]}" \
  -i "${ENCODED_FILES[4]}" \
  -i "${ENCODED_FILES[5]}" \
  -i "${ENCODED_FILES[6]}" \
  -map 5:a -map 2:a -map 4:a -map 3:a -map 1:a -map 0:a \
  -c copy \
  -disposition:a:0 default \
  -disposition:a:1 0 -disposition:a:2 0 -disposition:a:3 0 \
  -disposition:a:4 0 -disposition:a:5 0 \
  -metadata title="virtualdj" \
  -metadata artist="output" \
  "$temp_m4a" || die "Mux failed"
success "Tracks muxed (order: mixed → vocal → hihat → bass → instruments → kick)"

# Finalize with MP4Box: udta track names, brands, flat storage (all three
# match the format VirtualDJ is known to accept — do not "improve" them)
info "\nApplying VirtualDJ metadata..."

output="${OUT:-$FOLDER/$(basename "$FOLDER")-stems.m4a}"

meta="$tmpdir/meta.txt"
cat > "$meta" <<EOF
tool=VirtualDJ 2023.7544
created=0
rate=0
EOF
[[ -n "$BPM" ]] && print "tempo=$BPM" >> "$meta"

MP4Box \
  -udta "1:type=name" -udta "1:type=name:str=${STANDALONE_NAMES[1]}" \
  -udta "2:type=name" -udta "2:type=name:str=${STANDALONE_NAMES[2]}" \
  -udta "3:type=name" -udta "3:type=name:str=${STANDALONE_NAMES[3]}" \
  -udta "4:type=name" -udta "4:type=name:str=${STANDALONE_NAMES[4]}" \
  -udta "5:type=name" -udta "5:type=name:str=${STANDALONE_NAMES[5]}" \
  -udta "6:type=name" -udta "6:type=name:str=${STANDALONE_NAMES[6]}" \
  -itags "$meta" \
  -brand isom:512 -rb mp42 -ab mp41 \
  -flat -out "$output" "$temp_m4a" 2>&1 | grep -v "Setting up" | grep -v "Flat storage" | grep -v "Unrecognize tag" || true

success "Track names applied"

# Initial key: MP4Box drops INITIALKEY, so write the iTunes freeform atom
# (----:com.apple.iTunes:initialkey) that DJ software actually reads.
if [[ -n "$KEY" ]]; then
  if command -v AtomicParsley >/dev/null 2>&1; then
    AtomicParsley "$output" --rDNSatom "$KEY" name=initialkey domain=com.apple.iTunes -W >/dev/null 2>&1 \
      && success "initialkey=$KEY tagged" \
      || warn "AtomicParsley failed — key not tagged"
  else
    warn "AtomicParsley not found — key not tagged (brew install atomicparsley)"
  fi
fi

# Verify structure
info "\nVerifying output..."
track_count="$(ffprobe -v error -show_streams -select_streams a "$output" 2>/dev/null | grep -c "index=")"
if [[ "$track_count" -eq 6 ]]; then
  success "6 audio tracks detected"
  MP4Box -info "$output" 2>&1 | grep -q "udta" && success "Track metadata (udta) present"

  print -P "\n%F{green}%B✓ Created STANDALONE stems%b%f"
  print -P "Output: %F{cyan}%U$(basename "$output")%u%f  %F{244}(6-track ${(U)CODEC} M4A: mixed + 5 stems)%f"
  print -P "Size:   %F{244}$(du -h "$output" | cut -f1)%f"
  print -P "%F{244}Load this file itself in VirtualDJ; it is its own library track.%f\n"
else
  warn "Expected 6 tracks, found $track_count"
  print -P "%F{244}File may not be recognized as a stem file.%f\n"
  exit 1
fi
