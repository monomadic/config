#!/usr/bin/env zsh
# ============================================================================
# vdjstems-audit — fzf audit of prepared-stems status for VirtualDJ tracks
# ============================================================================
#
# Give it audio file paths (arguments and/or stdin); get an fzf list showing
# each track's prepared-stems status:
#
#   • whether stems exist, as a SIDECAR (<track>.vdjstems Matroska next to
#     the file) or a STANDALONE multi-track M4A (the track itself)
#   • the stem codec (aac / flac / alac / pcm)
#   • provenance — who made the stems:
#       vdj    AAC sidecar (what VirtualDJ itself writes)
#       tool   lossless sidecar or any standalone (vdjstems toolchain;
#              VDJ never writes FLAC/ALAC stems or standalone M4As)
#       BAD!   sidecar missing the "VirtualDJ …stems2" writing-application
#              stamp, or without the five titled stems — VDJ ignores it
#
#   Provenance is a codec heuristic: both VDJ and vdjstems-pack stamp the
#   same writing-application, so an AAC sidecar made with the tool (no -l)
#   is indistinguishable from a genuine one and shows as "vdj".
#
# Speed: the list streams into fzf as tracks are probed (no up-front barrier;
# order is roughly, not exactly, input order). Sidecars are classified from a
# single 128 KB header read — codec IDs (A_AAC/A_FLAC/…), the five stem
# titles, and the writing-application stamp all live at the front of the
# Matroska — so no ffprobe/mkvmerge process per file. ffprobe only runs for
# .m4a/.mp4 tracks without a sidecar (the standalone check) and in the
# preview pane. Evicted iCloud files (dataless placeholders) are detected
# from their inode flag and shown as ☁ "not downloaded" — the tool never
# reads their bytes, so it can't hang waiting on a materialization that may
# never complete on a secondary machine.
#
# Keys inside fzf:
#   tab            select multiple tracks
#   enter, ctrl-s  make FLAC sidecar stems (vdjstems make -l) for the selected
#                  tracks, or the hovered one if none selected; rows reload
#   ctrl-r         re-probe / reload the list
#
# Examples:
#   fd -e flac -e m4a . ~/Music/Tracks | vdjstems-audit
#   vdjstems-audit ~/Music/Tracks/*.flac
#
# Dependencies: fzf, ffprobe (standalone check + preview);
#               mkvmerge + jq only for the exact stamp string in the preview
# See also: vdjstems (make/split/pack), vdjstems-info,
#           docs in ~/src/virtualdj-api-reference/docs/Stem File Format.md
# ============================================================================
set -euo pipefail
SELF="${0:t}"
SELF_PATH="${0:A}"

die() { print -r -- "ERROR: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

# True if the file's data isn't local — an evicted iCloud placeholder. Reads
# only the inode flags (instant), so it never blocks the way head/ffprobe do
# when they trigger a materialization that may never complete on this machine.
is_dataless() { [[ "$(stat -f '%Sf' "$1" 2>/dev/null)" == *dataless* ]]; }

# Colors
RED=$'\033[31m'   GREEN=$'\033[32m'  YELLOW=$'\033[33m'
CYAN=$'\033[36m'  MAGENTA=$'\033[35m'
DIM=$'\033[2m'    BOLD=$'\033[1m'    RESET=$'\033[0m'

usage() {
  cat <<EOF
Usage: $SELF [FILE...]           (and/or pipe one path per line on stdin)

Audit VirtualDJ prepared-stems status for a list of audio files.
Inside fzf:

  tab            select multiple
  enter, ctrl-s  create FLAC sidecar stems for selected/hovered (vdjstems make -l)
  ctrl-r         reload
EOF
  exit 2
}

# ── writing-application of a Matroska sidecar ("" if tools missing) ─────────
# Preview-only: the list view sniffs the stamp from the file header instead.
stamp_of() {
  local f="$1"
  if have mkvmerge && have jq; then
    mkvmerge -J "$f" 2>/dev/null \
      | jq -r '.container.properties.writing_application // ""' 2>/dev/null \
      || true
  fi
}

# ── probe one track and emit its display line ───────────────────────────────
# arg: path; emits "path<TAB>colored display"
probe_line() {
  local trk="$1"
  local sidecar="${trk}.vdjstems"
  local kind="—" codec="—" origin="—" icon="${RED}○${RESET}"
  local name_color="$DIM" origin_color="$DIM"

  if [[ -f "$sidecar" ]]; then
    kind="sidecar"
    if is_dataless "$sidecar"; then
      # A sidecar exists (that's metadata) but its bytes aren't downloaded —
      # reading them would hang, so report "present but not downloaded".
      origin="cloud" origin_color="$CYAN"
      icon="${CYAN}☁${RESET}"
      name_color="$CYAN"
      _emit_line; return
    fi
    # One header read classifies everything: Matroska codec IDs, the five
    # stem titles, and the writing-application stamp all sit near the start.
    local hdr
    hdr="$(head -c 131072 "$sidecar" 2>/dev/null | LC_ALL=C tr -cd '[:print:]' || true)"
    case "$hdr" in
      *A_FLAC*) codec="flac" ;;
      *A_ALAC*) codec="alac" ;;
      *A_AAC*)  codec="aac"  ;;
      *A_PCM*)  codec="pcm"  ;;
      *)        codec="?"    ;;
    esac
    local complete=true
    [[ "$hdr" == *vocal* && "$hdr" == *hihat* && "$hdr" == *bass* \
       && "$hdr" == *instruments* && "$hdr" == *kick* ]] || complete=false
    if [[ "$hdr" != *.stems2* || "$complete" == "false" ]]; then
      origin="BAD!" origin_color="$MAGENTA"   # VDJ silently ignores it
      icon="${MAGENTA}⚠${RESET}"
      name_color="$MAGENTA"
    elif [[ "$codec" == "aac" ]]; then
      origin="vdj" origin_color="$RED"
      icon="${YELLOW}●${RESET}"
      name_color=""
    else
      origin="tool" origin_color="$GREEN"
      icon="${GREEN}●${RESET}"
      name_color=""
    fi
  elif [[ "${trk:l}" == *.m4a || "${trk:l}" == *.mp4 ]]; then
    # No sidecar — an M4A track may itself be a standalone stem file.
    # Only MP4-family files can be; everything else skips the probe.
    if is_dataless "$trk"; then
      origin="cloud" origin_color="$CYAN"   # can't ffprobe without the bytes
      icon="${CYAN}☁${RESET}"
      name_color="$CYAN"
      _emit_line; return
    fi
    local codecs
    codecs=("${(@f)$(ffprobe -v error -select_streams a \
      -show_entries stream=codec_name -of csv=p=0 "$trk" 2>/dev/null || true)}")
    if (( ${#codecs} >= 2 )); then
      kind="standalone"
      codec="${codecs[2]:-${codecs[1]}}"   # stream 0 is the mixed track
      origin="tool" origin_color="$GREEN"
      if [[ "$codec" == "alac" || "$codec" == "flac" ]]; then
        icon="${GREEN}●${RESET}"
      else
        icon="${YELLOW}●${RESET}"
      fi
      name_color=""
    fi
  fi

  _emit_line
}

# Render one probe_line row. Relies on zsh dynamic scoping — it reads the
# locals (trk, kind, codec, origin, icon, *_color) set by its caller.
_emit_line() {
  local codec_color=""
  case "$codec" in
    flac|alac|pcm) codec_color="$GREEN" ;;
    aac)           codec_color="$YELLOW" ;;
    —)             codec_color="$DIM" ;;
  esac

  local dir="${trk:h:t}"
  printf '%s\t%s %s%-10s%s %s%-5s%s %s%-5s%s %s%s%s %s%s%s\n' \
    "$trk" \
    "$icon" \
    "$DIM" "$kind" "$RESET" \
    "$codec_color" "$codec" "$RESET" \
    "$origin_color" "$origin" "$RESET" \
    "$name_color" "${trk:t}" "$RESET" \
    "$DIM" "$dir/" "$RESET"
}

# ── probe the whole saved list, streaming (initial view + reloads) ──────────
# No sort barrier: lines reach fzf as each probe finishes, so the list
# populates immediately even when slow (iCloud) files are still loading.
relist() {
  tr '\n' '\0' < "$1" | xargs -0 -P 12 -n 16 "$SELF_PATH" --line
}

# ── fzf preview pane ────────────────────────────────────────────────────────
preview() {
  local trk="$1" sidecar="${1}.vdjstems"
  print -P "%B${trk:t}%b"
  # Reading any dataless (evicted iCloud) file would hang the preview pane, so
  # short-circuit on the inode flag before touching bytes with ffprobe.
  if is_dataless "$trk"; then
    print "${CYAN}☁ not downloaded from iCloud${RESET}"
    print "${DIM}the track's data isn't on this machine — can't probe it${RESET}"
    if [[ -f "$sidecar" ]]; then
      if is_dataless "$sidecar"; then
        print "${CYAN}a .vdjstems sidecar exists but is also not downloaded${RESET}"
      else
        print "${GREEN}a .vdjstems sidecar exists and is downloaded${RESET}"
      fi
    fi
    print "${DIM}download it in Finder (or: brctl download) then ctrl-r${RESET}"
    return 0
  fi
  ffprobe -v error -select_streams a:0 \
    -show_entries stream=codec_name,sample_rate,channels \
    -of csv=p=0 "$trk" 2>/dev/null \
    | IFS=, read -r c r ch && print "${DIM}track: $c ${r} Hz ${ch}ch${RESET}" || true
  print ""

  local target=""
  if [[ -f "$sidecar" ]]; then
    print "${BOLD}SIDECAR${RESET} ${DIM}${sidecar:t}${RESET}"
    if is_dataless "$sidecar"; then
      print "${CYAN}☁ sidecar not downloaded — can't read its streams${RESET}"
      print "${DIM}download it (Finder / brctl download) then ctrl-r${RESET}"
      return 0
    fi
    target="$sidecar"
  else
    local n
    n="$(ffprobe -v error -select_streams a -show_entries stream=index \
          -of csv=p=0 "$trk" 2>/dev/null | wc -l | tr -d ' ')"
    if (( n >= 2 )); then
      print "${BOLD}STANDALONE${RESET} ${DIM}($n audio streams)${RESET}"
      target="$trk"
    else
      print "${RED}no prepared stems${RESET}"
      print "${DIM}ctrl-s creates a FLAC sidecar with vdjstems make -l${RESET}"
      return 0
    fi
  fi

  print "${DIM}codec|rate|ch|title:${RESET}"
  ffprobe -v error -select_streams a \
    -show_entries stream=codec_name,sample_rate,channels:stream_tags=title \
    -of compact=p=0:nk=1 "$target" 2>/dev/null | sed 's/^/  /'

  if [[ "$target" == "$sidecar" ]]; then
    local stamp; stamp="$(stamp_of "$sidecar")"
    if [[ -z "$stamp" ]]; then
      print "${DIM}writing app: (mkvmerge/jq not available)${RESET}"
    elif [[ "$stamp" == VirtualDJ* ]]; then
      print "${GREEN}writing app: $stamp${RESET}"
    else
      print "${MAGENTA}writing app: $stamp — NOT stamped, VDJ ignores this sidecar${RESET}"
    fi
    # Sample-rate contract: sidecar must match the original or playback breaks
    local orig_sr side_sr
    orig_sr="$(ffprobe -v error -select_streams a:0 -show_entries stream=sample_rate \
      -of csv=p=0 "$trk" 2>/dev/null)"
    side_sr="$(ffprobe -v error -select_streams a:0 -show_entries stream=sample_rate \
      -of csv=p=0 "$sidecar" 2>/dev/null)"
    if [[ -n "$orig_sr" && -n "$side_sr" && "$orig_sr" != "$side_sr" ]]; then
      (( orig_sr > 96000 )) ||
        print "${RED}⚠ rate mismatch: sidecar ${side_sr} Hz vs original ${orig_sr} Hz — plays broken${RESET}"
    fi
  fi
}

# ── ctrl-s action: make FLAC sidecars (runs in fzf's execute terminal) ──────
make_stems() {
  local f rc=0
  for f in "$@"; do
    print -P "\n%F{cyan}%B── vdjstems make -l ──%b %f${f:t}"
    if [[ -f "${f}.vdjstems" ]]; then
      print -P "%F{yellow}replacing existing sidecar ${f:t}.vdjstems%f"
    fi
    vdjstems make -l "$f" || { rc=1; print -P "%F{red}FAILED: ${f:t}%f" }
  done
  print -P "\n%F{244}done — press any key to return%f"
  read -k1 -s || true
  return $rc
}

# ── entry points ────────────────────────────────────────────────────────────
case "${1:-}" in
  -h|--help)  usage ;;
  --line)     shift; for f in "$@"; do probe_line "$f"; done; exit 0 ;;
  --relist)   relist "${2:?}"; exit 0 ;;
  --preview)  preview "${2:?}"; exit 0 ;;
  --make)     shift; make_stems "$@"; exit 0 ;;
  -*)         die "Unknown option: $1" ;;
esac

have fzf     || die "fzf not found"
have ffprobe || die "ffprobe not found (brew install ffmpeg)"
(( $# )) || [[ ! -t 0 ]] || usage

# Collect input paths from arguments, then stdin (one per line, if piped).
# Keep files that exist; skip stray .vdjstems entries and directories.
listfile="$(mktemp -t vdjstems-audit)"
trap 'rm -f "$listfile"' EXIT
{
  for p in "$@"; do print -r -- "$p"; done
  [[ -t 0 ]] || cat
} | while IFS= read -r p; do
  [[ -n "$p" && -f "$p" && "$p" != *.vdjstems ]] || continue
  print -r -- "${p:A}"
done > "$listfile"
[[ -s "$listfile" ]] || die "no audio files given (arguments or stdin)"

header="stems audit — ${GREEN}●${RESET} lossless  ${YELLOW}●${RESET} aac  ${RED}○${RESET} none  ${MAGENTA}⚠${RESET} broken  ${CYAN}☁${RESET} not downloaded
tab select · enter/ctrl-s make FLAC sidecar · ctrl-r reload"

# enter and ctrl-s both make FLAC sidecars for the selected tracks (or the
# hovered one), then reload the rows so their status flips to the new sidecar.
make_bind="execute($SELF_PATH --make {+1})+reload($SELF_PATH --relist $listfile)"

"$SELF_PATH" --relist "$listfile" | fzf \
  --ansi --multi \
  --delimiter $'\t' --with-nth 2 --accept-nth 1 \
  --header "$header" --header-first \
  --preview "$SELF_PATH --preview {1}" \
  --preview-window 'down,15,border-top' \
  --bind "enter:$make_bind" \
  --bind "ctrl-s:$make_bind" \
  --bind "ctrl-r:reload($SELF_PATH --relist $listfile)"
