#!/usr/bin/env zsh

emulate -L zsh
set -u
setopt pipefail extended_glob

TTY=/dev/tty
if { exec 3< "$TTY" } 2>/dev/null && { exec 4> "$TTY" } 2>/dev/null; then
  :
else
  exec 3<&0
  exec 4>&2
fi

CHECK_UTF8=true
CHECK_FASTSTART=true
CHECK_BLACKFRAMES=true
CHECK_URL=true
CHECK_METADATA=true
CHECK_RENAME=true
CHECK_LENGTH=true

MAX_FILENAME_BYTES=240
RENAME_MEDIA_TIMEOUT="${RENAME_MEDIA_TIMEOUT:-20}"

typeset -a INPUT_FILES=()
typeset -i processed_count=0
typeset -i total_count=0
typeset -i clean_count=0
typeset -i issue_file_count=0
typeset -i fix_count=0
typeset -i skip_count=0
typeset -i fail_count=0

C_RESET=$'\033[0m'
C_DIM=$'\033[2m'
C_CYAN=$'\033[36m'
C_GREEN=$'\033[32m'
C_RED=$'\033[31m'
C_YELLOW=$'\033[33m'
ICON_PASS="✓"
ICON_FAIL="✕"
CURRENT_FILE=""
CURRENT_CHECK=""
CURRENT_TOTAL=0
CURRENT_PASS=0
CURRENT_FAIL=0
typeset -a ENABLED_CHECKS=()
typeset -A CHECK_STATUS=()

usage() {
  cat >&2 <<'EOF'
Usage:
  media-check-files [options] [file ...]

Audits a media library. With no file arguments it streams files from fd-media.
When files are provided, only those files are checked.

Checks:
  MP4/MOV/M4V FastStart
  black frames at the start of video
  embedded source URL
  embedded title metadata
  filename health: invalid UTF-8, rename-media canonical syntax, length

Options:
  --bypass-check-utf8
  --bypass-check-faststart
  --bypass-check-blackframes, --bypass-check-black-frames
  --bypass-check-url
  --bypass-check-metadata
  --bypass-check-rename
  --bypass-check-length
  --bypass-check-filename       Bypass UTF-8, rename, and length checks
  --max-filename-bytes N        Default: 240
  -h, --help
EOF
}

say() {
  print -P -u4 -- "$*"
}

say_raw() {
  print -r -u4 -- "$*"
}

warn() {
  say "%F{yellow}!%f $*"
}

fail() {
  say "%F{red}x%f $*"
}

pass() {
  say "%F{green}ok%f $*"
}

display_path() {
  local s="$1"
  local reserved="${2:-14}"
  local width="${COLUMNS:-100}"
  local max=$(( width - reserved ))

  (( max < 30 )) && max=30

  if (( ${#s} > max )); then
    local keep=$(( max - 3 ))
    print -r -- "...${s[-$keep,-1]}"
  else
    print -r -- "$s"
  fi
}

status_line() {
  [[ -t 4 ]] || return 0

  local shown prefix_plain

  prefix_plain="Checking "
  shown="$(display_path "${1:t}" "${#prefix_plain}")"
  print -n -u4 -- $'\r\033[K'
  print -n -u4 -- "Checking ${C_CYAN}${shown}${C_RESET}"
}

clear_status() {
  [[ -t 4 ]] || return 0
  print -n -u4 -- $'\r\033[K'
}

session_stats_line() {
  local files_word="files"
  local corrections_word="corrections"

  (( processed_count == 1 )) && files_word="file"
  (( fix_count == 1 )) && corrections_word="correction"

  say "${processed_count} ${files_word} checked: ${C_GREEN}${clean_count} pass${C_RESET}, ${C_RED}${issue_file_count} fail${C_RESET}"
  say "- ${fix_count} ${corrections_word} made this session"
}

check_stats_line() {
  say "${CURRENT_TOTAL} total, ${CURRENT_PASS} pass, ${CURRENT_FAIL} fail"
}

build_enabled_checks() {
  ENABLED_CHECKS=()

  $CHECK_BLACKFRAMES && ENABLED_CHECKS+=("black-frames")
  $CHECK_URL && ENABLED_CHECKS+=("source-url")
  $CHECK_METADATA && ENABLED_CHECKS+=("metadata")

  if $CHECK_UTF8 || $CHECK_RENAME || $CHECK_LENGTH; then
    ENABLED_CHECKS+=("filename")
  fi

  $CHECK_FASTSTART && ENABLED_CHECKS+=("faststart")
}

check_enabled() {
  local check="$1"
  local item

  for item in "${ENABLED_CHECKS[@]}"; do
    [[ "$item" == "$check" ]] && return 0
  done

  return 1
}

reset_file_checks() {
  local item

  CHECK_STATUS=()
  CURRENT_TOTAL=0
  CURRENT_PASS=0
  CURRENT_FAIL=0

  for item in "${ENABLED_CHECKS[@]}"; do
    CHECK_STATUS[$item]=""
  done
}

refresh_current_counts() {
  local item check_state

  CURRENT_TOTAL=0
  CURRENT_PASS=0
  CURRENT_FAIL=0

  for item in "${ENABLED_CHECKS[@]}"; do
    check_state="${CHECK_STATUS[$item]-}"
    [[ -n "$check_state" ]] || continue
    (( CURRENT_TOTAL++ ))
    case "$check_state" in
      pass) (( CURRENT_PASS++ )) ;;
      fail) (( CURRENT_FAIL++ )) ;;
    esac
  done
}

set_check_status() {
  local check="$1"
  local check_state="$2"

  check_enabled "$check" || return 0
  CHECK_STATUS[$check]="$check_state"
  refresh_current_counts
}

check_icon() {
  local check_state="$1"

  case "$check_state" in
    pass) print -r -- "${C_GREEN}${ICON_PASS}${C_RESET}" ;;
    fail) print -r -- "${C_RED}${ICON_FAIL}${C_RESET}" ;;
    *) print -r -- "" ;;
  esac
}

draw_checks() {
  local item check_state icon

  say "%BCHECKS:%b"
  say ""

  for item in "${ENABLED_CHECKS[@]}"; do
    check_state="${CHECK_STATUS[$item]-}"
    icon="$(check_icon "$check_state")"
    printf "%-22s %b\n" "$item" "$icon" >&4
  done

  say ""
}

draw_header() {
  say "%B%F{cyan}MEDIA LIBRARY FILE CHECK v1%f%b"
  say ""
  session_stats_line
  say ""
  draw_checks
  check_stats_line
  say ""
}

redraw_screen() {
  [[ -t 4 ]] || return 0
  print -n -u4 -- $'\033[2J\033[H'
  draw_header
}

colored_path() {
  local file="$1"
  local dir="${file:h}"
  local base="${file:t}"

  if [[ "$dir" == "." ]]; then
    print -r -- "${C_CYAN}${base}${C_RESET}"
  else
    print -r -- "${C_DIM}${dir}/${C_RESET}${C_CYAN}${base}${C_RESET}"
  fi
}

show_checking_path() {
  local file="$1"

  print -r -u4 -- "Checking ${C_CYAN}${file:t}${C_RESET}"
}

issue_screen() {
  local check="$1"
  local file="$2"

  CURRENT_CHECK="$check"
  set_check_status "$check" "fail"

  if [[ -t 4 ]]; then
    print -n -u4 -- $'\033[2J\033[H'
    draw_header
  fi
  clear_status
  say ""
  show_checking_path "$file"
  say ""
  say "%B%F{red}FAIL%f%b ${C_RED}${ICON_FAIL}${C_RESET}"
  say ""
}

mark_fixed() {
  local message="${1:-Fixed.}"

  (( fix_count++ ))
  [[ -n "$CURRENT_CHECK" ]] && set_check_status "$CURRENT_CHECK" "pass"

  if [[ -t 4 ]]; then
    redraw_screen
  else
    pass "$message"
  fi
}

mark_unresolved() {
  (( FILE_UNRESOLVED++ ))
  [[ -n "$CURRENT_CHECK" ]] && set_check_status "$CURRENT_CHECK" "fail"
}

run_check() {
  local check="$1"
  shift

  check_enabled "$check" || return 0
  CURRENT_CHECK="$check"

  "$@"
  local rc=$?

  if (( rc == 0 )); then
    set_check_status "$check" "pass"
    [[ -t 4 ]] && redraw_screen
  else
    set_check_status "$check" "fail"
  fi

  return "$rc"
}

prompt_yes_no() {
  local prompt="$1"
  local default="${2:-Y}"
  local ans suffix

  if [[ "$default" == Y ]]; then
    suffix="(Y/n)"
  else
    suffix="(y/N)"
  fi

  while true; do
    print -n -P -u4 -- "${prompt} ${suffix} "
    read_prompt_line || return 1
    ans="$READ_PROMPT_REPLY"
    ans="${ans:-$default}"

    case "$ans" in
      [Yy]|[Yy][Ee][Ss]) return 0 ;;
      [Nn]|[Nn][Oo]) return 1 ;;
      *) warn "Please answer y or n." ;;
    esac
  done
}

READ_PROMPT_REPLY=""
read_prompt_line() {
  local saved_stty rc ch buffer

  READ_PROMPT_REPLY=""
  saved_stty=""
  buffer=""

  if [[ ! -t 3 ]]; then
    IFS= read -r -u 3 READ_PROMPT_REPLY
    return $?
  fi

  if command -v stty >/dev/null 2>&1; then
    saved_stty="$(stty -g <&3 2>/dev/null || true)"
    stty -echo -icanon min 1 time 0 <&3 2>/dev/null || true
  fi

  trap '[[ -n "$saved_stty" ]] && stty "$saved_stty" <&3 2>/dev/null; trap - INT; print -u4; return 130' INT

  while true; do
    IFS= read -r -k 1 -u 3 ch
    rc=$?
    (( rc == 0 )) || break

    case "$ch" in
      $'\003')
        [[ -n "$saved_stty" ]] && stty "$saved_stty" <&3 2>/dev/null || true
        trap - INT
        print -u4
        return 130
        ;;
      $'\004')
        [[ -n "$buffer" ]] || {
          rc=1
          break
        }
        ;;
      $'\n'|$'\r')
        print -u4
        READ_PROMPT_REPLY="$buffer"
        rc=0
        break
        ;;
      $'\177'|$'\010')
        if [[ -n "$buffer" ]]; then
          buffer="${buffer[1,-2]}"
          print -n -u4 -- $'\b \b'
        fi
        ;;
      $'\025')
        while [[ -n "$buffer" ]]; do
          buffer="${buffer[1,-2]}"
          print -n -u4 -- $'\b \b'
        done
        ;;
      *)
        buffer+="$ch"
        print -n -u4 -- "$ch"
        ;;
    esac
  done

  trap - INT

  [[ -n "$saved_stty" ]] && stty "$saved_stty" <&3 2>/dev/null || true
  return "$rc"
}

PROMPT_REPLY=""
prompt_input_or_skip() {
  local prompt="$1"

  PROMPT_REPLY=""
  print -n -P -u4 -- "${prompt} "
  read_prompt_line || return 130
  PROMPT_REPLY="$READ_PROMPT_REPLY"
  return 0
}

is_video_path() {
  case "${1:l}" in
    *.mp4|*.mov|*.m4v|*.avi|*.mkv|*.wmv|*.flv|*.webm) return 0 ;;
    *) return 1 ;;
  esac
}

is_faststart_path() {
  case "${1:l}" in
    *.mp4|*.mov|*.m4v) return 0 ;;
    *) return 1 ;;
  esac
}

is_url() {
  [[ "$1" == http://* || "$1" == https://* ]]
}

normalize_audit_path() {
  local path="$1"

  if [[ -e "$path" || "$path" == /* ]]; then
    print -r -- "$path"
    return 0
  fi

  if [[ -e "/$path" ]]; then
    print -r -- "/$path"
    return 0
  fi

  print -r -- "$path"
}

creation_date_for_setfile() {
  local file="$1"
  local epoch

  epoch="$(stat -f '%B' -- "$file" 2>/dev/null)" || return 1
  [[ "$epoch" == <-> ]] || return 1
  (( epoch > 0 )) || return 1

  date -r "$epoch" '+%m/%d/%Y %H:%M:%S'
}

copy_creation_date() {
  local source="$1"
  local target="$2"
  local created

  command -v SetFile >/dev/null 2>&1 || return 1
  created="$(creation_date_for_setfile "$source")" || return 1
  SetFile -d "$created" "$target" >/dev/null 2>&1
}

touch_modified_now() {
  local file="$1"

  touch "$file" 2>/dev/null || true
}

filename_byte_length() {
  LC_ALL=C printf '%s' "$1" | wc -c | tr -d '[:space:]'
}

shorten_filename() {
  local filename="$1"
  local max_bytes="$2"

  python3 - "$filename" "$max_bytes" <<'PY'
import os
import sys

name = sys.argv[1]
max_bytes = int(sys.argv[2])
stem, ext = os.path.splitext(name)
marker = "..."
suffix_bytes = len(ext.encode("utf-8"))
marker_bytes = len(marker.encode("utf-8"))
available = max_bytes - suffix_bytes - marker_bytes

if available < 12:
    available = max(1, max_bytes - suffix_bytes)
    marker = ""

out = ""
for ch in stem:
    if len((out + ch).encode("utf-8")) > available:
        break
    out += ch

out = out.rstrip()
if marker and out:
    out += marker

print(out + ext)
PY
}

color_filename_diff() {
  local source_name="$1"
  local target_name="$2"

  python3 - "$source_name" "$target_name" <<'PY'
import difflib
import re
import sys

red = "\033[31m"
green = "\033[32m"
reset = "\033[0m"

source = sys.argv[1]
target = sys.argv[2]

def tokens(value):
    return re.findall(r"\s+|\S+", value)

source_tokens = tokens(source)
target_tokens = tokens(target)
matcher = difflib.SequenceMatcher(None, source_tokens, target_tokens)
source_out = []
target_out = []

for tag, i1, i2, j1, j2 in matcher.get_opcodes():
    source_part = "".join(source_tokens[i1:i2])
    target_part = "".join(target_tokens[j1:j2])

    if tag == "equal":
        source_out.append(source_part)
        target_out.append(target_part)
    elif tag == "delete":
        source_out.append(red + source_part + reset)
    elif tag == "insert":
        target_out.append(green + target_part + reset)
    else:
        source_out.append(red + source_part + reset)
        target_out.append(green + target_part + reset)

print("".join(source_out))
print("".join(target_out))
PY
}

prompt_rename_path() {
  local current="$1"
  local target="$2"
  local reason="${3:-filename}"
  local -a diff_lines=()

  [[ -n "$target" && "$current" != "$target" ]] || return 0

  (( FILE_ISSUES++ ))
  issue_screen "$reason" "$current"
  diff_lines=("${(@f)$(color_filename_diff "${current:t}" "${target:t}")}")
  print -r -u4 -- "filename:  ${diff_lines[1]-${current:t}}"
  print -r -u4 -- "proposed:  ${diff_lines[2]-${target:t}}"
  say ""

  if [[ -e "$target" ]]; then
    fail "filename: cannot rename because the target already exists"
    say_raw "$target"
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  if mv -n -- "$current" "$target"; then
    AUDIT_PATH="$target"
    CURRENT_FILE="$target"
    touch_modified_now "$target"
    mark_fixed "Renamed: ${target:t}"
    return 0
  fi

  fail "filename: rename failed"
  (( fail_count++ ))
  mark_unresolved
  return 1
}

check_utf8_filename() {
  local file="$1"
  local filename="${file:t}"
  local fixed target

  $CHECK_UTF8 || return 0
  command -v iconv >/dev/null 2>&1 || return 0

  if printf '%s' "$filename" | iconv -f UTF-8 -t UTF-8 >/dev/null 2>&1; then
    return 0
  fi

  fixed="$(printf '%s' "$filename" | iconv -f UTF-8 -t UTF-8 -c 2>/dev/null)"
  fixed="${fixed##[[:space:]]##}"
  fixed="${fixed%%[[:space:]]##}"

  if [[ -z "$fixed" || "$fixed" == "$filename" ]]; then
    (( FILE_ISSUES++ ))
    issue_screen "filename" "$file"
    say "filename: invalid UTF-8"
    warn "The shell cannot safely recover the original byte sequence for this filename."
    warn "Use a byte-safe rename tool such as convmv, then re-run this audit."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  target="${file:h}/${fixed}"
  prompt_rename_path "$file" "$target" "filename"
}

faststart_state() {
  local file="$1"

  python3 - "$file" <<'PY'
import os
import struct
import sys

path = sys.argv[1]
try:
    size = os.path.getsize(path)
    with open(path, "rb") as fh:
        pos = 0
        for _ in range(100000):
            if pos + 8 > size:
                sys.exit(2)
            fh.seek(pos)
            header = fh.read(8)
            if len(header) < 8:
                sys.exit(2)
            atom_size, atom_type = struct.unpack(">I4s", header)
            atom_type = atom_type.decode("latin-1")
            header_len = 8
            if atom_size == 1:
                ext = fh.read(8)
                if len(ext) < 8:
                    sys.exit(2)
                atom_size = struct.unpack(">Q", ext)[0]
                header_len = 16
            elif atom_size == 0:
                atom_size = size - pos
            if atom_size < header_len:
                sys.exit(2)
            if atom_type == "moov":
                sys.exit(0)
            if atom_type == "mdat":
                sys.exit(1)
            pos += atom_size
    sys.exit(2)
except Exception:
    sys.exit(2)
PY
}

enable_faststart() {
  local file="$1"
  local dir="${file:h}"
  local base="${file:t:r}"
  local ext="${file:e}"
  local tmp

  command -v ffmpeg >/dev/null 2>&1 || return 1
  tmp="$(mktemp "${dir}/.${base}.faststart.XXXXXX.${ext}")" || return 1

  if ffmpeg -hide_banner -loglevel error -nostdin -y \
      -i "$file" \
      -map 0 \
      -map_metadata 0 \
      -c copy \
      -movflags +faststart+use_metadata_tags \
      "$tmp"; then
    copy_creation_date "$file" "$tmp" || {
      rm -f -- "$tmp" 2>/dev/null || true
      return 1
    }
    mv -f -- "$tmp" "$file"
    touch_modified_now "$file"
    return 0
  fi

  rm -f -- "$tmp" 2>/dev/null || true
  return 1
}

check_faststart() {
  local file="$1"
  local state

  $CHECK_FASTSTART || return 0
  is_faststart_path "$file" || return 0
  command -v python3 >/dev/null 2>&1 || return 0

  faststart_state "$file"
  state=$?

  case "$state" in
    0)
      return 0
      ;;
    1)
      (( FILE_ISSUES++ ))
      issue_screen "faststart" "$file"
      say "faststart: not enabled"
      say "auto-fix: enabling FastStart with ffmpeg stream copy."
      if enable_faststart "$file" && faststart_state "$file"; then
        mark_fixed "FastStart enabled."
        return 0
      fi
      fail "FastStart repair failed."
      (( fail_count++ ))
      mark_unresolved
      return 1
      ;;
    *)
      (( FILE_ISSUES++ ))
      issue_screen "faststart" "$file"
      say "faststart: inconclusive"
      warn "Could not read the top-level MP4/MOV atoms; leaving the file unchanged."
      (( fail_count++ ))
      mark_unresolved
      return 1
      ;;
  esac
}

detect_black_leader_seconds() {
  local file="$1"
  local output line start end
  local black_re='black_start:([0-9]+([.][0-9]+)?)[[:space:]]+black_end:([0-9]+([.][0-9]+)?)'

  command -v ffmpeg-detect-black-scenes >/dev/null 2>&1 || return 1

  output="$(BLACK_SCAN_DURATION=10 ffmpeg-detect-black-scenes "$file" 2>/dev/null || true)"

  while IFS= read -r line; do
    if [[ "$line" =~ $black_re ]]; then
      start="${match[1]}"
      end="${match[3]}"

      if awk -v s="$start" -v e="$end" 'BEGIN { exit !(s <= 0.25 && e > 0.05) }'; then
        print -r -- "$end"
        return 0
      fi
    fi
  done <<< "$output"

  return 1
}

trimmed_path_for() {
  local file="$1"
  local dir="${file:h}"
  local base="${file:t}"

  if [[ "$base" == *.* ]]; then
    print -r -- "${dir}/${base:r}.trimmed.${base:e}"
  else
    print -r -- "${dir}/${base}.trimmed"
  fi
}

check_black_frames() {
  local file="$1"
  local seconds trimmed

  $CHECK_BLACKFRAMES || return 0
  is_video_path "$file" || return 0

  seconds="$(detect_black_leader_seconds "$file")" || return 0

  (( FILE_ISSUES++ ))
  issue_screen "black-frames" "$file"
  say "black-frames: leading black detected (${seconds}s)"
  say ""

  if prompt_yes_no "Trim File?" "Y"; then
    if ffmpeg-lossless-cut-by-fzf-keyframe-select --from "$seconds" "$file" < "$TTY" > "$TTY" 2>&1; then
      trimmed="$(trimmed_path_for "$file")"
      if [[ -f "$trimmed" ]]; then
        AUDIT_PATH="$trimmed"
      fi
      mark_fixed "Trim complete."
      return 0
    fi

    fail "Trim workflow did not complete."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  warn "Skipped trim."
  (( skip_count++ ))
  mark_unresolved
  return 1
}

PROBE_TITLE=""
PROBE_URL=""
probe_media_tags() {
  local file="$1"
  local tags_json

  PROBE_TITLE=""
  PROBE_URL=""

  command -v ffprobe >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1

  tags_json="$(ffprobe -v error -show_entries format_tags -of json -- "$file" 2>/dev/null)" || return 1

  PROBE_TITLE="$(
    jq -r '(.format.tags // {}) | with_entries(.key |= ascii_downcase) | .title // empty' <<< "$tags_json"
  )"

  PROBE_URL="$(
    jq -r '(.format.tags // {}) | with_entries(.key |= ascii_downcase) as $t |
      [$t.source_url, $t.webpage_url, $t.purl, $t.url, $t.comment, $t.description] |
      [.[]? | strings | (try capture("(?<url>https?://[^[:space:]\"<>]+)").url catch empty)] |
      .[0] // empty' <<< "$tags_json"
  )"

  return 0
}

rewrite_with_metadata() {
  local file="$1"
  shift

  local dir="${file:h}"
  local base="${file:t:r}"
  local ext="${file:e}"
  local tmp
  local -a ffmpeg_args metadata_args

  metadata_args=("$@")

  command -v ffmpeg >/dev/null 2>&1 || return 1
  tmp="$(mktemp "${dir}/.${base}.metadata.XXXXXX.${ext}")" || return 1

  ffmpeg_args=(
    -hide_banner -loglevel error -nostdin -y
    -i "$file"
    -map 0
    -c copy
    -map_metadata 0
  )

  if is_faststart_path "$file"; then
    ffmpeg_args+=(-movflags use_metadata_tags)
  fi

  ffmpeg_args+=("${metadata_args[@]}" "$tmp")

  if ffmpeg "${ffmpeg_args[@]}"; then
    copy_creation_date "$file" "$tmp" || {
      rm -f -- "$tmp" 2>/dev/null || true
      return 1
    }
    mv -f -- "$tmp" "$file"
    touch_modified_now "$file"
    return 0
  fi

  rm -f -- "$tmp" 2>/dev/null || true
  return 1
}

embed_source_url() {
  local file="$1"
  local url="$2"

  rewrite_with_metadata "$file" \
    -metadata "source_url=$url" \
    -metadata "webpage_url=$url" \
    -metadata "purl=$url" \
    -metadata "comment=$url"
}

fetch_and_embed_metadata() {
  local file="$1"
  local url="$2"
  local tmp_json title uploader channel webpage_url original_url description upload_date timestamp duration id extractor
  local -a metadata_args

  command -v yt-dlp >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1

  tmp_json="$(mktemp -t media-check-ytmeta.XXXXXX.json)" || return 1

  if ! yt-dlp --skip-download --dump-single-json --no-warnings "$url" > "$tmp_json"; then
    rm -f -- "$tmp_json"
    return 1
  fi

  title="$(jq -r '.title // empty' "$tmp_json")"
  uploader="$(jq -r '.uploader // empty' "$tmp_json")"
  channel="$(jq -r '.channel // empty' "$tmp_json")"
  webpage_url="$(jq -r '.webpage_url // empty' "$tmp_json")"
  original_url="$(jq -r '.original_url // empty' "$tmp_json")"
  description="$(jq -r '.description // empty' "$tmp_json")"
  upload_date="$(jq -r '.upload_date // empty' "$tmp_json")"
  timestamp="$(jq -r '.timestamp // empty' "$tmp_json")"
  duration="$(jq -r '.duration // empty' "$tmp_json")"
  id="$(jq -r '.id // empty' "$tmp_json")"
  extractor="$(jq -r '.extractor // empty' "$tmp_json")"

  [[ -n "$webpage_url" ]] || webpage_url="$url"
  [[ -n "$original_url" ]] || original_url="$url"

  metadata_args=(
    -metadata "source_url=$webpage_url"
    -metadata "webpage_url=$webpage_url"
    -metadata "original_url=$original_url"
    -metadata "purl=$webpage_url"
    -metadata "comment=$webpage_url"
    -metadata "artist=${uploader:-$channel}"
    -metadata "album_artist=$channel"
    -metadata "description=$description"
    -metadata "yt_dlp_extractor=$extractor"
    -metadata "yt_dlp_id=$id"
    -metadata "yt_dlp_upload_date=$upload_date"
    -metadata "yt_dlp_timestamp=$timestamp"
    -metadata "yt_dlp_duration=$duration"
  )

  [[ -n "$title" ]] && metadata_args+=(-metadata "title=$title")

  if rewrite_with_metadata "$file" "${metadata_args[@]}"; then
    rm -f -- "$tmp_json"
    return 0
  fi

  rm -f -- "$tmp_json"
  return 1
}

check_source_url() {
  local file="$1"
  local url

  $CHECK_URL || return 0

  [[ -n "$PROBE_URL" ]] && return 0

  (( FILE_ISSUES++ ))
  issue_screen "source-url" "$file"
  say "source-url: missing"
  say ""

  while true; do
    if ! prompt_input_or_skip "Source URL (Ctrl-C to skip):"; then
      warn "Skipped source URL."
      (( skip_count++ ))
      mark_unresolved
      return 1
    fi

    url="$PROMPT_REPLY"
    if [[ -z "$url" ]]; then
      warn "Blank URL ignored. Press Ctrl-C to skip."
      continue
    fi

    if ! is_url "$url"; then
      warn "Expected http:// or https:// URL."
      continue
    fi

    break
  done

  if embed_source_url "$file" "$url"; then
    PROBE_URL="$url"
    mark_fixed "Source URL embedded."
    return 0
  fi

  fail "Could not embed source URL."
  (( fail_count++ ))
  mark_unresolved
  return 1
}

check_title_metadata() {
  local file="$1"

  $CHECK_METADATA || return 0

  [[ -n "$PROBE_TITLE" ]] && return 0

  (( FILE_ISSUES++ ))
  issue_screen "metadata" "$file"
  say "metadata: missing title"
  say ""

  if [[ -z "$PROBE_URL" ]]; then
    warn "No embedded source URL is available, so yt-dlp metadata cannot be fetched."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  say "%BSOURCE URL:%b"
  say_raw "$PROBE_URL"
  say ""

  if prompt_yes_no "Fetch Metadata?" "Y"; then
    if fetch_and_embed_metadata "$file" "$PROBE_URL"; then
      probe_media_tags "$file" >/dev/null 2>&1 || true
      mark_fixed "Metadata embedded."
      return 0
    fi

    fail "Could not fetch/embed metadata."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  warn "Skipped metadata fetch."
  (( skip_count++ ))
  mark_unresolved
  return 1
}

check_canonical_name() {
  local file="$1"
  local rename_media_cmd target rc

  $CHECK_RENAME || return 0
  is_video_path "$file" || return 0
  command -v python3 >/dev/null 2>&1 || return 0
  rename_media_cmd="$(command -v rename-media 2>/dev/null)" || return 0

  target="$(
    python3 - "$RENAME_MEDIA_TIMEOUT" "$rename_media_cmd" "$file" <<'PY'
import os
import signal
import subprocess
import sys
import time

timeout = float(sys.argv[1])
cmd = [sys.argv[2], "--print-target", sys.argv[3]]

proc = subprocess.Popen(
    cmd,
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
    text=True,
    start_new_session=True,
)

try:
    stdout, _ = proc.communicate(timeout=timeout)
except subprocess.TimeoutExpired:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass

    deadline = time.monotonic() + 2
    while proc.poll() is None and time.monotonic() < deadline:
        time.sleep(0.05)

    if proc.poll() is None:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass

    proc.wait()
    sys.exit(124)

if proc.returncode != 0:
    sys.exit(proc.returncode)

lines = [line for line in stdout.splitlines() if line]
if lines:
    print(lines[-1])
PY
  )"
  rc=$?

  if (( rc == 124 )); then
    (( FILE_ISSUES++ ))
    issue_screen "filename" "$file"
    say "filename: rename-media timed out"
    warn "Skipped canonical rename check after ${RENAME_MEDIA_TIMEOUT}s."
    (( fail_count++ ))
    mark_unresolved
    return 1
  elif (( rc != 0 )); then
    return 0
  fi

  [[ -n "$target" ]] || return 0

  prompt_rename_path "$file" "$target" "filename"
}

check_filename_length() {
  local file="$1"
  local name="${file:t}"
  local bytes target_name target

  $CHECK_LENGTH || return 0
  command -v python3 >/dev/null 2>&1 || return 0

  bytes="$(filename_byte_length "$name")"
  [[ "$bytes" == <-> ]] || return 0
  (( bytes <= MAX_FILENAME_BYTES )) && return 0

  target_name="$(shorten_filename "$name" "$MAX_FILENAME_BYTES")"
  [[ -n "$target_name" && "$target_name" != "$name" ]] || {
    (( FILE_ISSUES++ ))
    issue_screen "filename" "$file"
    say "filename: too long (${bytes} bytes)"
    warn "Filename is ${bytes} bytes; could not build a safe shorter proposal."
    (( fail_count++ ))
    mark_unresolved
    return 1
  }

  target="${file:h}/${target_name}"
  prompt_rename_path "$file" "$target" "filename"
}

check_filename_checks() {
  local rc=0

  check_utf8_filename "$AUDIT_PATH" || rc=1
  check_canonical_name "$AUDIT_PATH" || rc=1
  check_filename_length "$AUDIT_PATH" || rc=1

  return "$rc"
}

audit_file() {
  local file="$1"
  integer FILE_ISSUES=0
  integer FILE_UNRESOLVED=0

  [[ -n "$file" ]] || return 0
  file="$(normalize_audit_path "$file")"

  (( processed_count++ ))
  AUDIT_PATH="$file"
  CURRENT_FILE="$AUDIT_PATH"
  CURRENT_CHECK=""
  reset_file_checks

  if [[ -t 4 ]]; then
    redraw_screen
  fi

  status_line "$AUDIT_PATH"

  if [[ ! -f "$AUDIT_PATH" ]]; then
    (( FILE_ISSUES++ ))
    issue_screen "file" "$AUDIT_PATH"
    say "file: not found"
    (( fail_count++ ))
    mark_unresolved
    (( issue_file_count++ ))
    return 1
  fi

  if is_video_path "$AUDIT_PATH"; then
    run_check "black-frames" check_black_frames "$AUDIT_PATH"
    status_line "$AUDIT_PATH"

    if $CHECK_URL || $CHECK_METADATA; then
      if probe_media_tags "$AUDIT_PATH"; then
        run_check "source-url" check_source_url "$AUDIT_PATH"
        status_line "$AUDIT_PATH"
        run_check "metadata" check_title_metadata "$AUDIT_PATH"
        status_line "$AUDIT_PATH"
      else
        (( FILE_ISSUES++ ))
        issue_screen "metadata" "$AUDIT_PATH"
        say "metadata: probe failed"
        warn "Could not read format tags with ffprobe/jq."
        (( fail_count++ ))
        mark_unresolved
      fi
    fi
  fi

  run_check "filename" check_filename_checks
  status_line "$AUDIT_PATH"

  if is_video_path "$AUDIT_PATH"; then
    run_check "faststart" check_faststart "$AUDIT_PATH"
    status_line "$AUDIT_PATH"
  fi

  if (( FILE_UNRESOLVED == 0 )); then
    (( clean_count++ ))
  else
    (( issue_file_count++ ))
  fi
}

parse_args() {
  while (( $# > 0 )); do
    case "$1" in
      --bypass-check-utf8)
        CHECK_UTF8=false
        shift
        ;;
      --bypass-check-faststart)
        CHECK_FASTSTART=false
        shift
        ;;
      --bypass-check-blackframes|--bypass-check-black-frames)
        CHECK_BLACKFRAMES=false
        shift
        ;;
      --bypass-check-url)
        CHECK_URL=false
        shift
        ;;
      --bypass-check-metadata)
        CHECK_METADATA=false
        shift
        ;;
      --bypass-check-rename)
        CHECK_RENAME=false
        shift
        ;;
      --bypass-check-length)
        CHECK_LENGTH=false
        shift
        ;;
      --bypass-check-filename)
        CHECK_UTF8=false
        CHECK_RENAME=false
        CHECK_LENGTH=false
        shift
        ;;
      --max-filename-bytes)
        (( $# >= 2 )) || {
          fail "Missing value for --max-filename-bytes"
          exit 1
        }
        MAX_FILENAME_BYTES="$2"
        [[ "$MAX_FILENAME_BYTES" == <-> ]] || {
          fail "--max-filename-bytes must be an integer"
          exit 1
        }
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        INPUT_FILES+=("$@")
        break
        ;;
      -*)
        usage
        fail "Unknown option: $1"
        exit 1
        ;;
      *)
        INPUT_FILES+=("$1")
        shift
        ;;
    esac
  done
}

process_fd_media() {
  command -v fd-media >/dev/null 2>&1 || {
    fail "fd-media not found."
    exit 1
  }

  while IFS= read -r -d $'\0' file; do
    audit_file "$file"
  done < <(fd-media --print0)
}

process_stdin_or_fd_media() {
  local line
  local saw_stdin=false

  if [[ ! -t 0 ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      saw_stdin=true
      audit_file "$line"
    done
  fi

  $saw_stdin && return 0
  process_fd_media
}

main() {
  local file

  parse_args "$@"
  build_enabled_checks
  reset_file_checks

  if (( ${#INPUT_FILES[@]} > 0 )); then
    total_count="${#INPUT_FILES[@]}"
  fi

  draw_header

  if (( ${#INPUT_FILES[@]} > 0 )); then
    for file in "${INPUT_FILES[@]}"; do
      audit_file "$file"
    done
  else
    process_stdin_or_fd_media
  fi

  clear_status
  say ""
  say "%B%F{green}DONE%f%b"
  say "CHECKED: ${processed_count}  CLEAN: ${clean_count}  ATTENTION: ${issue_file_count}  FIXES: ${fix_count}  SKIPPED: ${skip_count}  FAILED: ${fail_count}"
}

main "$@"
