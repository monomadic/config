#!/usr/bin/env zsh

emulate -L zsh
set -u
setopt pipefail extended_glob

TTY=/dev/tty
if { exec 3< "$TTY" } 2>/dev/null && { exec 4> "$TTY" } 2>/dev/null; then
  :
else
  exec 3<&0
  exec 4>&2
fi

CHECK_UTF8=true
CHECK_FASTSTART=true
CHECK_BLACKFRAMES=true
CHECK_URL=true
CHECK_METADATA=true
CHECK_RENAME=true
CHECK_LENGTH=true

SHOW_THUMBNAIL=true
THUMB_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/media-check-files/thumbs"
THUMB_PX=480

MAX_FILENAME_BYTES=240
RENAME_MEDIA_TIMEOUT="${RENAME_MEDIA_TIMEOUT:-20}"

typeset -a INPUT_FILES=()
typeset -i processed_count=0
typeset -i total_count=0
typeset -i clean_count=0
typeset -i issue_file_count=0
typeset -i fix_count=0
typeset -i repaired_file_count=0
typeset -i skip_count=0
typeset -i fail_count=0

C_RESET=$'\033[0m'
C_DIM=$'\033[2m'
C_BOLD=$'\033[1m'
C_REVERSE=$'\033[7m'
C_CYAN=$'\033[36m'
C_GREEN=$'\033[32m'
C_RED=$'\033[31m'
C_YELLOW=$'\033[33m'
ICON_PASS="✓"
ICON_FAIL="✕"
CURRENT_FILE=""
CURRENT_CHECK=""
CURRENT_TOTAL=0
CURRENT_PASS=0
CURRENT_FAIL=0
typeset -a ENABLED_CHECKS=()
typeset -A CHECK_STATUS=()
MENU_CHECK=""
typeset -a MENU_OPTIONS=()
MENU_INDEX=0
MENU_NOTE=""
FETCH_ERROR=""
CHECKS_HEADER_ROW=0
typeset -a PENDING_METADATA_ARGS=()
typeset -a PENDING_FIXES=()
PENDING_FASTSTART=false
PENDING_TRIM_START=""
THUMB_ENABLE=false
THUMB_BACKEND=""
THUMB_ROWS=0
THUMB_COLS=0
THUMB_CURRENT_IMG=""

usage() {
  cat >&2 <<'EOF'
Usage:
  media-check-files [options] [file ...]

Audits a media library. With no file arguments it streams files from fd-media.
When files are provided, only those files are checked. A directory argument is
recursed for media files via fd-media.

Checks:
  MP4/MOV/M4V FastStart
  black screens/scenes at the start of video
  embedded source URL
  embedded title metadata
  filename health: invalid UTF-8, rename-media canonical syntax, length

Options:
  --bypass-check-utf8
  --bypass-check-faststart
  --bypass-check-blackframes, --bypass-check-black-frames
  --bypass-check-url
  --bypass-check-metadata
  --bypass-check-rename
  --bypass-check-length
  --bypass-check-filename       Bypass UTF-8, rename, and length checks
  --max-filename-bytes N        Default: 240
  --no-thumbnail                Do not render a video thumbnail at the top
  -h, --help
EOF
}

say() {
  print -P -u4 -- "$*"
}

say_raw() {
  print -r -u4 -- "$*"
}

warn() {
  say "%F{yellow}!%f $*"
}

fail() {
  say "%F{red}x%f $*"
}

pass() {
  say "%F{green}ok%f $*"
}

display_path() {
  local s="$1"
  local reserved="${2:-14}"
  local width="${COLUMNS:-100}"
  local max=$(( width - reserved ))

  (( max < 30 )) && max=30

  if (( ${#s} > max )); then
    local keep=$(( max - 3 ))
    print -r -- "...${s[-$keep,-1]}"
  else
    print -r -- "$s"
  fi
}

status_line() {
  [[ -t 4 ]] || return 0

  local shown prefix_plain

  prefix_plain="Checking "
  shown="$(display_path "${1:t}" "${#prefix_plain}")"
  print -n -u4 -- $'\r\033[K'
  print -n -u4 -- "Checking ${C_CYAN}${shown}${C_RESET}"
}

clear_status() {
  [[ -t 4 ]] || return 0
  print -n -u4 -- $'\r\033[K'
}

session_summary_line() {
  local issues_word="issues"
  local files_word="files"

  (( fix_count == 1 )) && issues_word="issue"
  (( repaired_file_count == 1 )) && files_word="file"

  say "Successfully repaired ${C_GREEN}${fix_count}${C_RESET} ${issues_word} on ${C_GREEN}${repaired_file_count}${C_RESET} ${files_word}."
}

build_enabled_checks() {
  ENABLED_CHECKS=()

  $CHECK_BLACKFRAMES && ENABLED_CHECKS+=("black-frames")
  $CHECK_URL && ENABLED_CHECKS+=("source-url")
  $CHECK_METADATA && ENABLED_CHECKS+=("metadata")
  $CHECK_FASTSTART && ENABLED_CHECKS+=("faststart")

  if $CHECK_UTF8 || $CHECK_RENAME || $CHECK_LENGTH; then
    ENABLED_CHECKS+=("filename")
  fi
}

check_enabled() {
  local check="$1"
  local item

  for item in "${ENABLED_CHECKS[@]}"; do
    [[ "$item" == "$check" ]] && return 0
  done

  return 1
}

reset_file_checks() {
  local item

  CHECK_STATUS=()
  CURRENT_TOTAL=0
  CURRENT_PASS=0
  CURRENT_FAIL=0

  for item in "${ENABLED_CHECKS[@]}"; do
    CHECK_STATUS[$item]=""
  done
}

refresh_current_counts() {
  local item check_state

  CURRENT_TOTAL=0
  CURRENT_PASS=0
  CURRENT_FAIL=0

  for item in "${ENABLED_CHECKS[@]}"; do
    check_state="${CHECK_STATUS[$item]-}"
    [[ -n "$check_state" ]] || continue
    (( CURRENT_TOTAL++ ))
    case "$check_state" in
      pass) (( CURRENT_PASS++ )) ;;
      fail) (( CURRENT_FAIL++ )) ;;
    esac
  done
}

set_check_status() {
  local check="$1"
  local check_state="$2"

  check_enabled "$check" || return 0
  CHECK_STATUS[$check]="$check_state"
  refresh_current_counts
}

check_icon() {
  local check_state="$1"

  case "$check_state" in
    pass) print -r -- "${C_GREEN}${ICON_PASS}" ;;
    fail) print -r -- "${C_RED}${ICON_FAIL}" ;;
    *) print -r -- "${C_DIM}${ICON_PASS}${C_RESET}" ;;
  esac
}

# A check's list label carries its own state: dim name while pending, then
# "name: <word>" in green (good) or red (problem) once it has been evaluated.
check_label() {
  local item="$1" state="$2"
  local good bad

  case "$item" in
    black-frames) good="none";    bad="found" ;;
    source-url)   good="found";   bad="missing" ;;
    metadata)     good="found";   bad="missing" ;;
    faststart)    good="enabled"; bad="disabled" ;;
    filename)     good="ok";      bad="issues" ;;
    *)            good="ok";      bad="issue" ;;
  esac

  case "$state" in
    pass) print -r -- "${C_GREEN}${item}: ${good}${C_RESET}" ;;
    fail) print -r -- "${C_RED}${item}: ${bad}${C_RESET}" ;;
    *)    print -r -- "${C_DIM}${item}${C_RESET}" ;;
  esac
}

# Truncate a menu option to fit within the checklist indent.
menu_option_text() {
  local text="$1" fw="$2"
  (( ${#text} > fw )) && text="${text[1,fw-1]}…"
  print -r -- "$text"
}

draw_checks_block() {
  local item check_state icon label i text width fw

  width="${COLUMNS:-100}"
  fw=$(( width - 9 ))
  (( fw < 20 )) && fw=20

  say "%Bchecks:%b"

  for item in "${ENABLED_CHECKS[@]}"; do
    check_state="${CHECK_STATUS[$item]-}"
    icon="$(check_icon "$check_state")"
    label="$(check_label "$item" "$check_state")"
    print -rn -u4 -- $'\r\033[K'" ${icon}${C_RESET} ${label}"
    print -u4 -- ""

    # Draw the active menu directly beneath its check, indented.
    if [[ -n "$MENU_CHECK" && "$item" == "$MENU_CHECK" ]]; then
      if [[ -n "$MENU_NOTE" ]]; then
        print -rn -u4 -- $'\r\033[K'"    ${C_RED}$(menu_option_text "$MENU_NOTE" "$fw")${C_RESET}"
        print -u4 -- ""
      fi
      for (( i = 1; i <= ${#MENU_OPTIONS[@]}; i++ )); do
        text="$(menu_option_text "${MENU_OPTIONS[i]}" "$fw")"
        if (( i == MENU_INDEX )); then
          print -rn -u4 -- $'\r\033[K'"    ${C_REVERSE}${C_BOLD} ❯ ${text} ${C_RESET}"
        else
          print -rn -u4 -- $'\r\033[K'"       ${C_DIM}${text}${C_RESET}"
        fi
        print -u4 -- ""
      done
      print -u4 -- ""
    fi
  done
}

draw_filename() {
  local name max

  [[ -n "$CURRENT_FILE" ]] || return 0
  name="${CURRENT_FILE:t}"
  max=$(( ${COLUMNS:-100} - 2 ))
  (( max < 20 )) && max=20
  (( ${#name} > max )) && name="${name[1,max-1]}…"

  say_raw "${C_BOLD}${C_YELLOW}${name}${C_RESET}"
}

# Row (1-based) of the "checks:" header, so the checklist region can be
# repainted without disturbing the thumbnail band above it.
checks_header_row() {
  local band=0
  $THUMB_ENABLE && [[ -n "$THUMB_CURRENT_IMG" ]] && band=$THUMB_ROWS
  print -r -- $(( band + 6 ))
}

draw_header() {
  say_raw "${C_REVERSE}${C_BOLD} MEDIA LIBRARY FILE CHECK v1 ${C_RESET}"
  session_summary_line
  say ""
  CHECKS_HEADER_ROW="$(checks_header_row)"
  render_thumb_band
  draw_filename
  say ""
  draw_checks_block
  say ""
}

# Repaint only the checklist (and any inline menu) in place, leaving the
# title, summary and thumbnail untouched — used for menu navigation and for
# per-check updates, so the screen never fully clears and flickers.
render_checks_region() {
  [[ -t 4 ]] || return 0
  print -n -u4 -- $'\033['"${CHECKS_HEADER_ROW}"$';1H\033[J'
  draw_checks_block
}

# Repaint just the summary line (row 2); the fix tally changes as fixes land.
render_summary_line() {
  [[ -t 4 ]] || return 0
  print -n -u4 -- $'\033[2;1H\033[K'
  session_summary_line
}

# Pick an image backend the same way ffmpeg-lossless-cut's fzf preview does:
# kitty icat when in kitty, else wezterm/imgcat/chafa. Sized to the tty so the
# thumbnail band never crowds out the checks panel below it.
detect_thumb_backend() {
  local size rows cols

  THUMB_BACKEND=""
  THUMB_ROWS=0
  THUMB_COLS=0
  THUMB_ENABLE=false

  $SHOW_THUMBNAIL || return 0
  [[ -t 4 ]] || return 0
  command -v ffmpeg >/dev/null 2>&1 || return 0

  if [[ -n "${KITTY_WINDOW_ID:-}" ]] && command -v kitty >/dev/null 2>&1; then
    THUMB_BACKEND=kitty
  elif [[ -n "${WEZTERM_PANE:-}" ]] && command -v wezterm >/dev/null 2>&1; then
    THUMB_BACKEND=wezterm
  elif command -v imgcat >/dev/null 2>&1; then
    THUMB_BACKEND=imgcat
  elif command -v chafa >/dev/null 2>&1; then
    THUMB_BACKEND=chafa
  else
    return 0
  fi

  size="$(stty size <&3 2>/dev/null)"
  rows="${size%% *}"
  cols="${size##* }"
  { [[ "$rows" == <-> ]] && (( rows > 0 )) } || rows="${LINES:-40}"
  { [[ "$cols" == <-> ]] && (( cols > 0 )) } || cols="${COLUMNS:-100}"

  THUMB_ROWS=12
  (( THUMB_ROWS > rows - 18 )) && THUMB_ROWS=$(( rows - 18 ))
  if (( THUMB_ROWS < 6 )); then
    THUMB_ROWS=0
    return 0
  fi

  THUMB_COLS=$(( cols / 3 ))
  (( THUMB_COLS < 16 )) && THUMB_COLS=16
  (( THUMB_COLS > 44 )) && THUMB_COLS=44

  THUMB_ENABLE=true
}

thumb_cache_path() {
  local file="$1"
  local mtime size key

  mtime="$(stat -f '%m' -- "$file" 2>/dev/null)"
  size="$(stat -f '%z' -- "$file" 2>/dev/null)"
  key="$(printf '%s:%s:%s' "$file" "$mtime" "$size" | md5 -q 2>/dev/null)"
  [[ -n "$key" ]] || key="$(printf '%s' "${file:t}" | md5 -q 2>/dev/null)"
  [[ -n "$key" ]] || return 1

  print -r -- "$THUMB_CACHE_DIR/${key}.jpg"
}

generate_thumb() {
  local file="$1"
  local img="$2"
  local tmp

  [[ -s "$img" ]] && return 0
  mkdir -p -- "${img:h}" 2>/dev/null || return 1
  tmp="${img}.$$.jpg"

  # A few seconds in usually clears any black leader; fall back to frame 0.
  if ffmpeg -v error -y -ss 2 -i "$file" -frames:v 1 \
      -vf "scale=${THUMB_PX}:-2:flags=lanczos" -q:v 3 -- "$tmp" 2>/dev/null \
      && [[ -s "$tmp" ]]; then
    mv -f -- "$tmp" "$img"
    return 0
  fi

  rm -f -- "$tmp" 2>/dev/null || true
  if ffmpeg -v error -y -i "$file" -frames:v 1 \
      -vf "scale=${THUMB_PX}:-2:flags=lanczos" -q:v 3 -- "$tmp" 2>/dev/null \
      && [[ -s "$tmp" ]]; then
    mv -f -- "$tmp" "$img"
    return 0
  fi

  rm -f -- "$tmp" 2>/dev/null || true
  return 1
}

set_current_thumb() {
  local file="$1"
  local img

  THUMB_CURRENT_IMG=""
  $THUMB_ENABLE || return 0
  is_video_path "$file" || return 0

  img="$(thumb_cache_path "$file")" || return 0
  generate_thumb "$file" "$img" || return 0
  THUMB_CURRENT_IMG="$img"
}

# Three header rows sit above the thumbnail: title, summary, blank.
THUMB_ABOVE=3
render_thumb_band() {
  $THUMB_ENABLE || return 0

  if [[ -z "$THUMB_CURRENT_IMG" ]]; then
    [[ "$THUMB_BACKEND" == kitty ]] && kitty +kitten icat --clear --stdin=no >&4 2>/dev/null
    return 0
  fi

  case "$THUMB_BACKEND" in
    kitty)
      kitty +kitten icat --clear --transfer-mode=stream --stdin=no --align=left \
        --place="${THUMB_COLS}x${THUMB_ROWS}@0x${THUMB_ABOVE}" -- "$THUMB_CURRENT_IMG" >&4 2>/dev/null
      ;;
    wezterm)
      wezterm imgcat --width "${THUMB_COLS}" -- "$THUMB_CURRENT_IMG" >&4 2>/dev/null
      ;;
    imgcat)
      imgcat "$THUMB_CURRENT_IMG" >&4 2>/dev/null
      ;;
    chafa)
      chafa --animate=off --align=left --size="${THUMB_COLS}x${THUMB_ROWS}" \
        -- "$THUMB_CURRENT_IMG" >&4 2>/dev/null
      ;;
  esac

  # Land the cursor just below a fixed-height band so the layout below the
  # thumbnail is deterministic regardless of the image's aspect ratio.
  print -n -u4 -- $'\033['"$(( THUMB_ABOVE + THUMB_ROWS + 1 ))"$';1H'
}

clear_thumb() {
  $THUMB_ENABLE || return 0
  [[ "$THUMB_BACKEND" == kitty ]] || return 0
  kitty +kitten icat --clear --stdin=no >&4 2>/dev/null || true
}

redraw_screen() {
  [[ -t 4 ]] || return 0
  print -n -u4 -- $'\033[2J\033[H'
  draw_header
}

colored_path() {
  local file="$1"
  local dir="${file:h}"
  local base="${file:t}"

  if [[ "$dir" == "." ]]; then
    print -r -- "${C_CYAN}${base}${C_RESET}"
  else
    print -r -- "${C_DIM}${dir}/${C_RESET}${C_CYAN}${base}${C_RESET}"
  fi
}

issue_screen() {
  local check="$1"
  local file="$2"

  CURRENT_CHECK="$check"
  set_check_status "$check" "fail"

  [[ -t 4 ]] && render_checks_region
  clear_status
}

# Count this file toward the repaired total once, on its first applied fix.
# FILE_REPAIRED is an audit_file local, visible here via zsh dynamic scope.
note_repaired_file() {
  ${FILE_REPAIRED:-true} && return 0
  FILE_REPAIRED=true
  (( repaired_file_count++ ))
}

mark_fixed() {
  local message="${1:-Fixed.}"

  (( fix_count++ ))
  note_repaired_file
  [[ -n "$CURRENT_CHECK" ]] && set_check_status "$CURRENT_CHECK" "pass"

  if [[ -t 4 ]]; then
    render_summary_line
    render_checks_region
  else
    pass "$message"
  fi
}

mark_unresolved() {
  (( FILE_UNRESOLVED++ ))
  [[ -n "$CURRENT_CHECK" ]] && set_check_status "$CURRENT_CHECK" "fail"
}

run_check() {
  local check="$1"
  shift

  check_enabled "$check" || return 0
  CURRENT_CHECK="$check"

  "$@"
  local rc=$?

  if (( rc == 0 )); then
    set_check_status "$check" "pass"
    [[ -t 4 ]] && render_checks_region
  else
    set_check_status "$check" "fail"
  fi

  return "$rc"
}

prompt_yes_no() {
  local prompt="$1"
  local default="${2:-Y}"
  local ans suffix

  if [[ "$default" == Y ]]; then
    suffix="(Y/n)"
  else
    suffix="(y/N)"
  fi

  while true; do
    print -n -P -u4 -- "${prompt} ${suffix} "
    read_prompt_line || return 1
    ans="$READ_PROMPT_REPLY"
    ans="${ans:-$default}"

    case "$ans" in
      [Yy]|[Yy][Ee][Ss]) return 0 ;;
      [Nn]|[Nn][Oo]) return 1 ;;
      *) warn "Please answer y or n." ;;
    esac
  done
}

READ_PROMPT_REPLY=""
read_prompt_line() {
  local saved_stty rc ch buffer

  READ_PROMPT_REPLY=""
  saved_stty=""
  buffer=""

  if [[ ! -t 3 ]]; then
    IFS= read -r -u 3 READ_PROMPT_REPLY
    return $?
  fi

  if command -v stty >/dev/null 2>&1; then
    saved_stty="$(stty -g <&3 2>/dev/null || true)"
    stty -echo -icanon min 1 time 0 <&3 2>/dev/null || true
  fi

  trap '[[ -n "$saved_stty" ]] && stty "$saved_stty" <&3 2>/dev/null; trap - INT; print -u4; return 130' INT

  while true; do
    IFS= read -r -k 1 -u 3 ch
    rc=$?
    (( rc == 0 )) || break

    case "$ch" in
      $'\003')
        [[ -n "$saved_stty" ]] && stty "$saved_stty" <&3 2>/dev/null || true
        trap - INT
        print -u4
        return 130
        ;;
      $'\004')
        [[ -n "$buffer" ]] || {
          rc=1
          break
        }
        ;;
      $'\n'|$'\r')
        print -u4
        READ_PROMPT_REPLY="$buffer"
        rc=0
        break
        ;;
      $'\177'|$'\010')
        if [[ -n "$buffer" ]]; then
          buffer="${buffer[1,-2]}"
          print -n -u4 -- $'\b \b'
        fi
        ;;
      $'\025')
        while [[ -n "$buffer" ]]; do
          buffer="${buffer[1,-2]}"
          print -n -u4 -- $'\b \b'
        done
        ;;
      *)
        buffer+="$ch"
        print -n -u4 -- "$ch"
        ;;
    esac
  done

  trap - INT

  [[ -n "$saved_stty" ]] && stty "$saved_stty" <&3 2>/dev/null || true
  return "$rc"
}

# Arrow/vim-key select control on fds 3 (input) and 4 (output).
# Sets SELECT_INDEX (1-based). Returns 130 on Ctrl-C.
# Non-TTY fallback reads a 1-based index as a line from fd 3.
SELECT_INDEX=0
prompt_select() {
  local -a options=("$@")
  local count=${#options[@]}
  local i key seq saved_stty line

  SELECT_INDEX=0
  (( count > 0 )) || return 1

  if [[ ! -t 3 ]]; then
    for (( i = 1; i <= count; i++ )); do
      say_raw "  ${i}) ${options[i]}"
    done
    IFS= read -r -u 3 line || return 130
    [[ "$line" == <-> ]] && (( line >= 1 && line <= count )) || return 130
    SELECT_INDEX=$line
    return 0
  fi

  saved_stty=""
  if command -v stty >/dev/null 2>&1; then
    saved_stty="$(stty -g <&3 2>/dev/null || true)"
    stty -echo -icanon min 1 time 0 <&3 2>/dev/null || true
  fi
  print -n -u4 -- $'\033[?25l'

  # Host the menu inside the checklist, under the check being resolved.
  MENU_CHECK="$CURRENT_CHECK"
  MENU_OPTIONS=("${options[@]}")
  MENU_INDEX=1

  select_restore() {
    [[ -n "$saved_stty" ]] && stty "$saved_stty" <&3 2>/dev/null || true
    print -n -u4 -- $'\033[?25h'
    MENU_CHECK=""
    MENU_OPTIONS=()
    MENU_INDEX=0
    render_checks_region
    trap - INT
  }

  trap 'select_restore; return 130' INT

  while true; do
    render_checks_region

    IFS= read -r -k 1 -u 3 key || {
      select_restore
      return 130
    }

    case "$key" in
      $'\033')
        seq=""
        IFS= read -r -k 1 -t 0.05 -u 3 seq 2>/dev/null || seq=""
        if [[ "$seq" == "[" ]]; then
          seq=""
          IFS= read -r -k 1 -t 0.05 -u 3 seq 2>/dev/null || seq=""
          case "$seq" in
            A) (( MENU_INDEX > 1 )) && (( MENU_INDEX-- )) ;;
            B) (( MENU_INDEX < count )) && (( MENU_INDEX++ )) ;;
          esac
        fi
        ;;
      j) (( MENU_INDEX < count )) && (( MENU_INDEX++ )) ;;
      k) (( MENU_INDEX > 1 )) && (( MENU_INDEX-- )) ;;
      $'\n'|$'\r')
        SELECT_INDEX=$MENU_INDEX
        select_restore
        return 0
        ;;
      $'\003')
        select_restore
        return 130
        ;;
      [1-9])
        if (( key <= count )); then
          SELECT_INDEX=$key
          select_restore
          return 0
        fi
        ;;
    esac
  done
}

PROMPT_REPLY=""
prompt_input_or_skip() {
  local prompt="$1"

  PROMPT_REPLY=""
  print -n -P -u4 -- "${prompt} "
  read_prompt_line || return 130
  PROMPT_REPLY="$READ_PROMPT_REPLY"
  return 0
}

# Prompts until a valid http(s) URL is entered. Sets PROMPT_URL and returns 0,
# or returns 1 if the user pressed Ctrl-C to skip.
PROMPT_URL=""
prompt_valid_url() {
  PROMPT_URL=""

  while true; do
    if ! prompt_input_or_skip "Source URL (Ctrl-C to skip):"; then
      return 1
    fi
    if [[ -z "$PROMPT_REPLY" ]]; then
      warn "Blank URL ignored. Press Ctrl-C to skip."
      continue
    fi
    if ! is_url "$PROMPT_REPLY"; then
      warn "Expected http:// or https:// URL."
      continue
    fi
    PROMPT_URL="$PROMPT_REPLY"
    return 0
  done
}

# Animate a spinner on fd 4 until $1 (a background PID) exits; returns its
# exit status. Falls back to a plain wait when fd 4 is not a terminal.
spin_until_pid() {
  local pid="$1"
  local label="${2:-working…}"
  local start=$SECONDS
  integer i=0
  local -a spin=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')

  if [[ ! -t 4 ]]; then
    wait "$pid"
    return $?
  fi

  while kill -0 "$pid" 2>/dev/null; do
    print -n -u4 -- $'\r\033[K'"  ${C_CYAN}${spin[i % 10 + 1]}${C_RESET}  ${label} ${C_DIM}$(( SECONDS - start ))s${C_RESET}"
    (( i++ ))
    sleep 0.15
  done

  print -n -u4 -- $'\r\033[K'
  wait "$pid"
  return $?
}

is_video_path() {
  case "${1:l}" in
    *.mp4|*.mov|*.m4v|*.avi|*.mkv|*.wmv|*.flv|*.webm) return 0 ;;
    *) return 1 ;;
  esac
}

is_faststart_path() {
  case "${1:l}" in
    *.mp4|*.mov|*.m4v) return 0 ;;
    *) return 1 ;;
  esac
}

is_url() {
  [[ "$1" == http://* || "$1" == https://* ]]
}

normalize_audit_path() {
  local path="$1"

  if [[ "$path" == /* ]]; then
    print -r -- "$path"
    return 0
  fi

  if [[ -e "$path" ]]; then
    print -r -- "${path:A}"
    return 0
  fi

  if [[ -e "/$path" ]]; then
    print -r -- "/$path"
    return 0
  fi

  print -r -- "${path:A}"
}

creation_date_for_setfile() {
  local file="$1"
  local epoch

  epoch="$(stat -f '%B' -- "$file" 2>/dev/null)" || return 1
  [[ "$epoch" == <-> ]] || return 1
  (( epoch > 0 )) || return 1

  date -r "$epoch" '+%m/%d/%Y %H:%M:%S'
}

copy_creation_date() {
  local source="$1"
  local target="$2"
  local created

  command -v SetFile >/dev/null 2>&1 || return 1
  created="$(creation_date_for_setfile "$source")" || return 1
  SetFile -d "$created" "$target" >/dev/null 2>&1
}

touch_modified_now() {
  local file="$1"

  touch "$file" 2>/dev/null || true
}

filename_byte_length() {
  LC_ALL=C printf '%s' "$1" | wc -c | tr -d '[:space:]'
}

shorten_filename() {
  local filename="$1"
  local max_bytes="$2"

  python3 - "$filename" "$max_bytes" <<'PY'
import os
import sys

name = sys.argv[1]
max_bytes = int(sys.argv[2])
stem, ext = os.path.splitext(name)
marker = "..."
suffix_bytes = len(ext.encode("utf-8"))
marker_bytes = len(marker.encode("utf-8"))
available = max_bytes - suffix_bytes - marker_bytes

if available < 12:
    available = max(1, max_bytes - suffix_bytes)
    marker = ""

out = ""
for ch in stem:
    if len((out + ch).encode("utf-8")) > available:
        break
    out += ch

out = out.rstrip()
if marker and out:
    out += marker

print(out + ext)
PY
}

color_filename_diff() {
  local source_name="$1"
  local target_name="$2"

  python3 - "$source_name" "$target_name" <<'PY'
import difflib
import re
import sys

red = "\033[31m"
green = "\033[32m"
reset = "\033[0m"

source = sys.argv[1]
target = sys.argv[2]

def tokens(value):
    return re.findall(r"\s+|\S+", value)

source_tokens = tokens(source)
target_tokens = tokens(target)
matcher = difflib.SequenceMatcher(None, source_tokens, target_tokens)
source_out = []
target_out = []

for tag, i1, i2, j1, j2 in matcher.get_opcodes():
    source_part = "".join(source_tokens[i1:i2])
    target_part = "".join(target_tokens[j1:j2])

    if tag == "equal":
        source_out.append(source_part)
        target_out.append(target_part)
    elif tag == "delete":
        source_out.append(red + source_part + reset)
    elif tag == "insert":
        target_out.append(green + target_part + reset)
    else:
        source_out.append(red + source_part + reset)
        target_out.append(green + target_part + reset)

print("".join(source_out))
print("".join(target_out))
PY
}

prompt_rename_path() {
  local current="$1"
  local target="$2"
  local reason="${3:-filename}"
  local -a diff_lines=()

  [[ -n "$target" && "$current" != "$target" ]] || return 0

  (( FILE_ISSUES++ ))
  issue_screen "$reason" "$current"
  diff_lines=("${(@f)$(color_filename_diff "${current:t}" "${target:t}")}")
  print -r -u4 -- "filename:  ${diff_lines[1]-${current:t}}"
  print -r -u4 -- "proposed:  ${diff_lines[2]-${target:t}}"
  say ""

  if [[ -e "$target" ]]; then
    fail "filename: cannot rename because the target already exists"
    say_raw "$target"
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  if mv -n -- "$current" "$target"; then
    AUDIT_PATH="$target"
    CURRENT_FILE="$target"
    touch_modified_now "$target"
    mark_fixed "Renamed: ${target:t}"
    return 0
  fi

  fail "filename: rename failed"
  (( fail_count++ ))
  mark_unresolved
  return 1
}

check_utf8_filename() {
  local file="$1"
  local filename="${file:t}"
  local fixed target

  $CHECK_UTF8 || return 0
  command -v iconv >/dev/null 2>&1 || return 0

  if printf '%s' "$filename" | iconv -f UTF-8 -t UTF-8 >/dev/null 2>&1; then
    return 0
  fi

  fixed="$(printf '%s' "$filename" | iconv -f UTF-8 -t UTF-8 -c 2>/dev/null)"
  fixed="${fixed##[[:space:]]##}"
  fixed="${fixed%%[[:space:]]##}"

  if [[ -z "$fixed" || "$fixed" == "$filename" ]]; then
    (( FILE_ISSUES++ ))
    issue_screen "filename" "$file"
    say "filename: invalid UTF-8"
    warn "The shell cannot safely recover the original byte sequence for this filename."
    warn "Use a byte-safe rename tool such as convmv, then re-run this audit."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  target="${file:h}/${fixed}"
  prompt_rename_path "$file" "$target" "filename"
}

faststart_state() {
  local file="$1"

  python3 - "$file" <<'PY'
import os
import struct
import sys

path = sys.argv[1]
try:
    size = os.path.getsize(path)
    with open(path, "rb") as fh:
        pos = 0
        for _ in range(100000):
            if pos + 8 > size:
                sys.exit(2)
            fh.seek(pos)
            header = fh.read(8)
            if len(header) < 8:
                sys.exit(2)
            atom_size, atom_type = struct.unpack(">I4s", header)
            atom_type = atom_type.decode("latin-1")
            header_len = 8
            if atom_size == 1:
                ext = fh.read(8)
                if len(ext) < 8:
                    sys.exit(2)
                atom_size = struct.unpack(">Q", ext)[0]
                header_len = 16
            elif atom_size == 0:
                atom_size = size - pos
            if atom_size < header_len:
                sys.exit(2)
            if atom_type == "moov":
                sys.exit(0)
            if atom_type == "mdat":
                sys.exit(1)
            pos += atom_size
    sys.exit(2)
except Exception:
    sys.exit(2)
PY
}

check_faststart() {
  local file="$1"
  local state

  $CHECK_FASTSTART || return 0
  is_faststart_path "$file" || return 0
  command -v python3 >/dev/null 2>&1 || return 0

  faststart_state "$file"
  state=$?

  case "$state" in
    0)
      return 0
      ;;
    1)
      (( FILE_ISSUES++ ))
      issue_screen "faststart" "$file"
      PENDING_FASTSTART=true
      PENDING_FIXES+=("faststart")
      return 0
      ;;
    *)
      (( FILE_ISSUES++ ))
      issue_screen "faststart" "$file"
      say "faststart: inconclusive"
      warn "Could not read the top-level MP4/MOV atoms; leaving the file unchanged."
      (( fail_count++ ))
      mark_unresolved
      return 1
      ;;
  esac
}

detect_black_leader_seconds() {
  local file="$1"
  local output line start end
  local black_re='black_start:([0-9]+([.][0-9]+)?)[[:space:]]+black_end:([0-9]+([.][0-9]+)?)'

  command -v ffmpeg-detect-black-scenes >/dev/null 2>&1 || return 2

  output="$(BLACK_SCAN_DURATION=10 ffmpeg-detect-black-scenes "$file" 2>/dev/null || true)"

  while IFS= read -r line; do
    if [[ "$line" =~ $black_re ]]; then
      start="${match[1]}"
      end="${match[3]}"

      if awk -v s="$start" -v e="$end" 'BEGIN { exit !(s <= 0.25 && e > 0.05) }'; then
        print -r -- "$end"
        return 0
      fi
    fi
  done <<< "$output"

  return 1
}

check_black_frames() {
  local file="$1"
  local seconds rc output trim_start

  $CHECK_BLACKFRAMES || return 0
  is_video_path "$file" || return 0

  seconds="$(detect_black_leader_seconds "$file")"
  rc=$?

  if (( rc == 1 )); then
    return 0
  fi

  if (( rc != 0 )); then
    (( FILE_ISSUES++ ))
    issue_screen "black-frames" "$file"
    say "black-frames: check could not run"
    warn "ffmpeg-detect-black-scenes is required for the black-screen audit."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  (( FILE_ISSUES++ ))
  issue_screen "black-frames" "$file"

  if prompt_yes_no "Trim leading black (${seconds}s)?" "Y"; then
    output="$(ffmpeg-lossless-cut --print-start --from "$seconds" -- "$file" < "$TTY" 2> "$TTY")"
    rc=$?

    local -a marker_lines
    marker_lines=("${(@M)${(@f)output}:#FLC_START=*}")
    trim_start=""
    (( ${#marker_lines[@]} > 0 )) && trim_start="${marker_lines[-1]#FLC_START=}"

    if (( rc == 0 )) && [[ -n "$trim_start" ]]; then
      PENDING_TRIM_START="$trim_start"
      PENDING_FIXES+=("black-frames")
      return 0
    fi

    if (( rc == 0 )); then
      warn "Keyframe selection cancelled; skipped trim."
      (( skip_count++ ))
      mark_unresolved
      return 1
    fi

    fail "Keyframe selection did not complete."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  warn "Skipped trim."
  (( skip_count++ ))
  mark_unresolved
  return 1
}

PROBE_TITLE=""
PROBE_URL=""
probe_media_tags() {
  local file="$1"
  local tags_json

  PROBE_TITLE=""
  PROBE_URL=""

  command -v ffprobe >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1

  tags_json="$(ffprobe -v error -show_entries format_tags -of json -- "$file" 2>/dev/null)" || return 1

  PROBE_TITLE="$(
    jq -r '(.format.tags // {}) | with_entries(.key |= ascii_downcase) | .title // empty' <<< "$tags_json"
  )"

  PROBE_URL="$(
    jq -r '(.format.tags // {}) | with_entries(.key |= ascii_downcase) as $t |
      [$t.source_url, $t.webpage_url, $t.purl, $t.url, $t.comment, $t.description] |
      [.[]? | strings | (try capture("(?<url>https?://[^[:space:]\"<>]+)").url catch empty)] |
      .[0] // empty' <<< "$tags_json"
  )"

  return 0
}

media_duration_seconds() {
  ffprobe -v error -show_entries format=duration \
    -of default=noprint_wrappers=1:nokey=1 -- "$1" 2>/dev/null
}

# Draw a single in-place progress bar frame from ffmpeg -progress values.
draw_rewrite_progress_bar() {
  local total="$1" out_time="$2" speed="$3" state="${4:-}" cols="${5:-80}"

  awk -v total="$total" -v t="$out_time" -v speed="$speed" -v state="$state" -v cols="$cols" '
    function clk(s,   h, m, sec) {
      if (s < 0) s = 0
      h = int(s / 3600); s -= h * 3600
      m = int(s / 60);   sec = int(s - m * 60)
      return (h > 0) ? sprintf("%d:%02d:%02d", h, m, sec) : sprintf("%02d:%02d", m, sec)
    }
    BEGIN {
      esc = sprintf("%c", 27)
      cyan = esc "[1;36m"; dim = esc "[2m"; green = esc "[1;32m"
      yellow = esc "[1;33m"; reset = esc "[0m"; clr = esc "[K"

      n = split(t, p, ":")
      elapsed = (n == 3) ? p[1] * 3600 + p[2] * 60 + p[3] : t + 0
      sp = speed; gsub(/[^0-9.]/, "", sp); sp = sp + 0
      total = total + 0
      if (state == "end" && total > 0) elapsed = total

      if (total > 0) {
        pct = elapsed / total * 100
        if (pct < 0) pct = 0; if (pct > 100) pct = 100
        barw = cols - 40
        if (barw < 10) barw = 10; if (barw > 48) barw = 48
        filled = int(pct / 100 * barw + 0.5)
        if (filled > barw) filled = barw; if (filled < 0) filled = 0
        fill = ""; for (i = 0; i < filled; i++) fill = fill "█"
        emp = "";  for (i = 0; i < barw - filled; i++) emp = emp "░"
        printf "\r  %s%3d%%%s  %s%s%s%s%s  %s / %s  %s%.2fx%s%s",
          cyan, pct, reset,
          green, fill, dim, emp, reset,
          clk(elapsed), clk(total),
          yellow, sp, reset, clr
      } else {
        printf "\r  %scopying…%s  %s%s elapsed%s%s",
          cyan, reset, dim, clk(elapsed), reset, clr
      }
    }
  ' >&4
}

# Poll ffmpeg's -progress file while it runs. Once the muxed data hits ~100%,
# ffmpeg's faststart pass rewrites the whole file to move the moov atom to the
# front and emits no further progress, so animate a spinner for that phase
# instead of freezing the bar at 99%.
monitor_ffmpeg_progress() {
  local pid="$1" pfile="$2" total="$3" cols="$4"
  local tail_label="${5:-finalizing…}"
  local block out_time speed pct
  local start=$SECONDS
  integer spin_i=0
  local -a spin=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')

  while kill -0 "$pid" 2>/dev/null; do
    out_time=""
    speed=""
    pct=0

    if [[ -n "$pfile" && -s "$pfile" ]]; then
      local -a plines
      plines=("${(@f)$(tail -n 16 -- "$pfile" 2>/dev/null)}")
      out_time="${${(@M)plines:#out_time=*}[-1]#out_time=}"
      speed="${${(@M)plines:#speed=*}[-1]#speed=}"
    fi

    if [[ -n "$out_time" ]]; then
      pct="$(awk -v t="$out_time" -v tot="$total" 'BEGIN {
        n = split(t, p, ":")
        e = (n == 3) ? p[1] * 3600 + p[2] * 60 + p[3] : t + 0
        if (tot + 0 > 0) { x = e / tot * 100; if (x > 100) x = 100; printf "%d", x }
        else { print 0 }
      }')"
    fi

    if (( pct >= 99 )); then
      print -n -u4 -- $'\r\033[K'"  ${C_CYAN}${spin[spin_i % 10 + 1]}${C_RESET}  ${tail_label} ${C_DIM}$(( SECONDS - start ))s${C_RESET}"
      (( spin_i++ ))
    else
      draw_rewrite_progress_bar "$total" "$out_time" "$speed" "continue" "$cols"
    fi

    sleep 0.15
  done

  print -n -u4 -- $'\r\033[K'
}

rewrite_with_metadata() {
  local file="$1"
  shift

  local dir="${file:h}"
  local base="${file:t:r}"
  local ext="${file:e}"
  local tmp total errlog
  local -a ffmpeg_args metadata_args
  integer rc=0

  metadata_args=("$@")

  command -v ffmpeg >/dev/null 2>&1 || return 1
  tmp="$(mktemp "${dir}/.${base}.metadata.XXXXXX.${ext}")" || return 1

  ffmpeg_args=(-hide_banner -loglevel error -nostdin -y)

  [[ -n "$PENDING_TRIM_START" ]] && ffmpeg_args+=(-ss "$PENDING_TRIM_START")

  ffmpeg_args+=(
    -i "$file"
    -map '0:v?'
    -map '0:a?'
    -map '0:s?'
    -c copy
    -map_metadata 0
  )

  if is_faststart_path "$file"; then
    ffmpeg_args+=(-movflags +faststart+use_metadata_tags)
  fi

  ffmpeg_args+=("${metadata_args[@]}" "$tmp")

  if [[ -t 4 ]]; then
    local pfile pid tail_label
    total="$(media_duration_seconds "$file")"
    if [[ -n "$total" && -n "$PENDING_TRIM_START" ]]; then
      total="$(awk -v t="$total" -v s="$PENDING_TRIM_START" 'BEGIN { d = t - s; if (d < 0) d = 0; print d }')"
    fi

    tail_label="finalizing…"
    is_faststart_path "$file" && tail_label="finalizing (faststart)…"

    errlog="$(mktemp -t media-check-ffmpeg.XXXXXX)" || errlog=""
    pfile="$(mktemp -t media-check-progress.XXXXXX)" || pfile=""
    clear_status
    ffmpeg -progress "${pfile:-/dev/null}" "${ffmpeg_args[@]}" \
      >/dev/null 2>"${errlog:-/dev/null}" &
    pid=$!
    monitor_ffmpeg_progress "$pid" "$pfile" "$total" "${COLUMNS:-80}" "$tail_label"
    wait "$pid"
    rc=$?

    if (( rc != 0 )) && [[ -n "$errlog" ]]; then
      cat -- "$errlog" >&4
    fi
    [[ -n "$errlog" ]] && rm -f -- "$errlog"
    [[ -n "$pfile" ]] && rm -f -- "$pfile"
  else
    ffmpeg "${ffmpeg_args[@]}" || rc=$?
  fi

  if (( rc == 0 )); then
    copy_creation_date "$file" "$tmp" || {
      rm -f -- "$tmp" 2>/dev/null || true
      return 1
    }
    mv -f -- "$tmp" "$file"
    touch_modified_now "$file"
    return 0
  fi

  rm -f -- "$tmp" 2>/dev/null || true
  return 1
}

queue_source_url() {
  local url="$1"

  PENDING_METADATA_ARGS+=(
    -metadata "source_url=$url"
    -metadata "webpage_url=$url"
    -metadata "purl=$url"
    -metadata "comment=$url"
  )
}

queue_fetched_metadata() {
  local url="$1"
  local tmp_json errlog title uploader channel webpage_url original_url description upload_date timestamp duration id extractor
  integer rc=0

  command -v yt-dlp >/dev/null 2>&1 || return 1
  command -v jq >/dev/null 2>&1 || return 1

  tmp_json="$(mktemp -t media-check-ytmeta.XXXXXX.json)" || return 1
  errlog="$(mktemp -t media-check-ytmeta-err.XXXXXX)" || errlog=""

  yt-dlp --skip-download --dump-single-json --no-warnings "$url" \
    > "$tmp_json" 2>"${errlog:-/dev/null}" &
  spin_until_pid $! "Fetching metadata…" || rc=$?

  if (( rc != 0 )); then
    FETCH_ERROR=""
    if [[ -n "$errlog" && -s "$errlog" ]]; then
      # Keep the last real line of yt-dlp's stderr (usually the ERROR: line) so
      # the caller can surface why the fetch failed (e.g. cookies-from-browser).
      FETCH_ERROR="$(grep -a . -- "$errlog" | tail -n 1)"
    fi
    [[ -n "$errlog" ]] && rm -f -- "$errlog"
    rm -f -- "$tmp_json"
    return 1
  fi
  [[ -n "$errlog" ]] && rm -f -- "$errlog"

  title="$(jq -r '.title // empty' "$tmp_json")"
  uploader="$(jq -r '.uploader // empty' "$tmp_json")"
  channel="$(jq -r '.channel // empty' "$tmp_json")"
  webpage_url="$(jq -r '.webpage_url // empty' "$tmp_json")"
  original_url="$(jq -r '.original_url // empty' "$tmp_json")"
  description="$(jq -r '.description // empty' "$tmp_json")"
  upload_date="$(jq -r '.upload_date // empty' "$tmp_json")"
  timestamp="$(jq -r '.timestamp // empty' "$tmp_json")"
  duration="$(jq -r '.duration // empty' "$tmp_json")"
  id="$(jq -r '.id // empty' "$tmp_json")"
  extractor="$(jq -r '.extractor // empty' "$tmp_json")"

  [[ -n "$webpage_url" ]] || webpage_url="$url"
  [[ -n "$original_url" ]] || original_url="$url"

  PENDING_METADATA_ARGS+=(
    -metadata "source_url=$webpage_url"
    -metadata "webpage_url=$webpage_url"
    -metadata "original_url=$original_url"
    -metadata "purl=$webpage_url"
    -metadata "comment=$webpage_url"
    -metadata "artist=${uploader:-$channel}"
    -metadata "album_artist=$channel"
    -metadata "description=$description"
    -metadata "yt_dlp_extractor=$extractor"
    -metadata "yt_dlp_id=$id"
    -metadata "yt_dlp_upload_date=$upload_date"
    -metadata "yt_dlp_timestamp=$timestamp"
    -metadata "yt_dlp_duration=$duration"
  )

  [[ -n "$title" ]] && PENDING_METADATA_ARGS+=(-metadata "title=$title")

  PROBE_TITLE="$title"
  PROBE_URL="$webpage_url"

  rm -f -- "$tmp_json"
  return 0
}

apply_pending_rewrite() {
  local file="$1"
  local item

  (( ${#PENDING_FIXES[@]} > 0 )) || return 0

  status_line "$file"

  if rewrite_with_metadata "$file" "${PENDING_METADATA_ARGS[@]}"; then
    if $PENDING_FASTSTART && ! faststart_state "$file"; then
      CURRENT_CHECK="faststart"
      (( fail_count++ ))
      mark_unresolved
      (( fix_count += ${#PENDING_FIXES[@]} - 1 ))
      (( ${#PENDING_FIXES[@]} > 1 )) && note_repaired_file
      clear_status
      fail "FastStart verification failed after rewrite."
      return 1
    fi

    (( fix_count += ${#PENDING_FIXES[@]} ))
    note_repaired_file
    if [[ -t 4 ]]; then
      render_summary_line
      render_checks_region
    fi
    return 0
  fi

  clear_status
  fail "Combined ffmpeg rewrite failed; queued fixes were not applied."
  for item in "${PENDING_FIXES[@]}"; do
    CURRENT_CHECK="$item"
    (( fail_count++ ))
    mark_unresolved
  done
  CURRENT_CHECK=""
  return 1
}

# Prints four lines: full-strip query, its search URL,
# braces-only-strip query, its search URL.
filename_search_query() {
  local name="$1"

  python3 - "$name" <<'PY'
import os
import re
import sys
import urllib.parse

stem = os.path.splitext(sys.argv[1])[0]

def clean(value):
    # Strip any stray bracket/brace/paren characters and hyphens so they can
    # never leak into the search query.
    value = re.sub(r"[][(){}-]", "", value)
    return re.sub(r"\s+", " ", value).strip()

braces_only = clean(re.sub(r"\{[^}]*\}", " ", stem))
full = clean(re.sub(r"\[[^\]]*\]", " ", braces_only))

for query in (full, braces_only):
    print(query)
    print("https://www.google.com/search?q=" + urllib.parse.quote_plus(query))
PY
}

open_in_browser() {
  local url="$1"

  if command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1
  else
    warn "No browser opener (open/xdg-open) found."
    return 1
  fi
}

check_source_url() {
  local file="$1"
  local url action
  local -a search_info options actions

  $CHECK_URL || return 0

  [[ -n "$PROBE_URL" ]] && return 0

  (( FILE_ISSUES++ ))
  issue_screen "source-url" "$file"

  options=()
  actions=()

  if command -v python3 >/dev/null 2>&1; then
    search_info=("${(@f)$(filename_search_query "${file:t}")}")
    if [[ -n "${search_info[1]-}" ]]; then
      options+=("search browser: ${search_info[1]}")
      actions+=("open:${search_info[2]}")
    fi
    if [[ -n "${search_info[3]-}" && "${search_info[3]-}" != "${search_info[1]-}" ]]; then
      options+=("search browser: ${search_info[3]}")
      actions+=("open:${search_info[4]}")
    fi
  fi

  options+=("enter URL manually" "skip this file")
  actions+=("manual" "skip")

  if ! prompt_select "${options[@]}"; then
    action="skip"
  else
    action="${actions[$SELECT_INDEX]}"
  fi

  case "$action" in
    open:*)
      open_in_browser "${action#open:}" || true
      ;;
    manual)
      ;;
    skip)
      warn "Skipped source URL."
      (( skip_count++ ))
      mark_unresolved
      return 1
      ;;
  esac

  say ""

  if ! prompt_valid_url; then
    warn "Skipped source URL."
    (( skip_count++ ))
    mark_unresolved
    return 1
  fi
  url="$PROMPT_URL"

  queue_source_url "$url"
  PENDING_FIXES+=("source-url")
  PROBE_URL="$url"
  return 0
}

check_title_metadata() {
  local file="$1"
  local url

  $CHECK_METADATA || return 0

  [[ -n "$PROBE_TITLE" ]] && return 0

  (( FILE_ISSUES++ ))
  issue_screen "metadata" "$file"

  if [[ -z "$PROBE_URL" ]]; then
    warn "No embedded source URL is available, so yt-dlp metadata cannot be fetched."
    (( fail_count++ ))
    mark_unresolved
    return 1
  fi

  # A source URL is present, so try to pull metadata automatically. Only fall
  # back to a prompt when the fetch fails.
  url="$PROBE_URL"

  while true; do
    if queue_fetched_metadata "$url"; then
      MENU_NOTE=""
      PENDING_FIXES+=("metadata")
      return 0
    fi

    # Surface yt-dlp's own error under the check so a config problem (e.g. a
    # locked cookies-from-browser database) is visible instead of a silent fail.
    MENU_NOTE="${FETCH_ERROR:-yt-dlp could not fetch metadata for that URL.}"

    if ! prompt_select "try a different URL" "skip metadata" || (( SELECT_INDEX == 2 )); then
      MENU_NOTE=""
      warn "Skipped metadata fetch."
      (( skip_count++ ))
      mark_unresolved
      return 1
    fi

    if ! prompt_valid_url; then
      MENU_NOTE=""
      warn "Skipped metadata fetch."
      (( skip_count++ ))
      mark_unresolved
      return 1
    fi
    url="$PROMPT_URL"
  done
}

check_canonical_name() {
  local file="$1"
  local rename_media_cmd target rc

  $CHECK_RENAME || return 0
  is_video_path "$file" || return 0
  command -v python3 >/dev/null 2>&1 || return 0
  rename_media_cmd="$(command -v rename-media 2>/dev/null)" || return 0

  target="$(
    python3 - "$RENAME_MEDIA_TIMEOUT" "$rename_media_cmd" "$file" <<'PY'
import os
import signal
import subprocess
import sys
import time

timeout = float(sys.argv[1])
cmd = [sys.argv[2], "--print-target", sys.argv[3]]

proc = subprocess.Popen(
    cmd,
    stdout=subprocess.PIPE,
    stderr=subprocess.DEVNULL,
    text=True,
    start_new_session=True,
)

try:
    stdout, _ = proc.communicate(timeout=timeout)
except subprocess.TimeoutExpired:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        pass

    deadline = time.monotonic() + 2
    while proc.poll() is None and time.monotonic() < deadline:
        time.sleep(0.05)

    if proc.poll() is None:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass

    proc.wait()
    sys.exit(124)

if proc.returncode != 0:
    sys.exit(proc.returncode)

lines = [line for line in stdout.splitlines() if line]
if lines:
    print(lines[-1])
PY
  )"
  rc=$?

  if (( rc == 124 )); then
    (( FILE_ISSUES++ ))
    issue_screen "filename" "$file"
    say "filename: rename-media timed out"
    warn "Skipped canonical rename check after ${RENAME_MEDIA_TIMEOUT}s."
    (( fail_count++ ))
    mark_unresolved
    return 1
  elif (( rc != 0 )); then
    return 0
  fi

  [[ -n "$target" ]] || return 0

  prompt_rename_path "$file" "$target" "filename"
}

check_filename_length() {
  local file="$1"
  local name="${file:t}"
  local bytes target_name target

  $CHECK_LENGTH || return 0
  command -v python3 >/dev/null 2>&1 || return 0

  bytes="$(filename_byte_length "$name")"
  [[ "$bytes" == <-> ]] || return 0
  (( bytes <= MAX_FILENAME_BYTES )) && return 0

  target_name="$(shorten_filename "$name" "$MAX_FILENAME_BYTES")"
  [[ -n "$target_name" && "$target_name" != "$name" ]] || {
    (( FILE_ISSUES++ ))
    issue_screen "filename" "$file"
    say "filename: too long (${bytes} bytes)"
    warn "Filename is ${bytes} bytes; could not build a safe shorter proposal."
    (( fail_count++ ))
    mark_unresolved
    return 1
  }

  target="${file:h}/${target_name}"
  prompt_rename_path "$file" "$target" "filename"
}

check_filename_checks() {
  local rc=0

  check_utf8_filename "$AUDIT_PATH" || rc=1
  check_canonical_name "$AUDIT_PATH" || rc=1
  check_filename_length "$AUDIT_PATH" || rc=1

  return "$rc"
}

audit_file() {
  local file="$1"
  integer FILE_ISSUES=0
  integer FILE_UNRESOLVED=0
  local FILE_REPAIRED=false

  [[ -n "$file" ]] || return 0
  file="$(normalize_audit_path "$file")"

  (( processed_count++ ))
  AUDIT_PATH="$file"
  CURRENT_FILE="$AUDIT_PATH"
  CURRENT_CHECK=""
  PENDING_METADATA_ARGS=()
  PENDING_FIXES=()
  PENDING_FASTSTART=false
  PENDING_TRIM_START=""
  MENU_NOTE=""
  reset_file_checks
  set_current_thumb "$AUDIT_PATH"

  if [[ -t 4 ]]; then
    redraw_screen
  fi

  status_line "$AUDIT_PATH"

  if [[ ! -f "$AUDIT_PATH" ]]; then
    (( FILE_ISSUES++ ))
    issue_screen "file" "$AUDIT_PATH"
    say "file: not found"
    (( fail_count++ ))
    mark_unresolved
    (( issue_file_count++ ))
    return 1
  fi

  if is_video_path "$AUDIT_PATH"; then
    run_check "black-frames" check_black_frames "$AUDIT_PATH"
    status_line "$AUDIT_PATH"

    if $CHECK_URL || $CHECK_METADATA; then
      if probe_media_tags "$AUDIT_PATH"; then
        run_check "source-url" check_source_url "$AUDIT_PATH"
        status_line "$AUDIT_PATH"
        run_check "metadata" check_title_metadata "$AUDIT_PATH"
        status_line "$AUDIT_PATH"
      else
        (( FILE_ISSUES++ ))
        issue_screen "metadata" "$AUDIT_PATH"
        say "metadata: probe failed"
        warn "Could not read format tags with ffprobe/jq."
        (( fail_count++ ))
        mark_unresolved
      fi
    fi
  fi

  if is_video_path "$AUDIT_PATH"; then
    run_check "faststart" check_faststart "$AUDIT_PATH"
    status_line "$AUDIT_PATH"
  fi

  apply_pending_rewrite "$AUDIT_PATH"
  status_line "$AUDIT_PATH"

  run_check "filename" check_filename_checks
  status_line "$AUDIT_PATH"

  if (( FILE_UNRESOLVED == 0 )); then
    (( clean_count++ ))
  else
    (( issue_file_count++ ))
  fi
}

parse_args() {
  while (( $# > 0 )); do
    case "$1" in
      --bypass-check-utf8)
        CHECK_UTF8=false
        shift
        ;;
      --bypass-check-faststart)
        CHECK_FASTSTART=false
        shift
        ;;
      --bypass-check-blackframes|--bypass-check-black-frames)
        CHECK_BLACKFRAMES=false
        shift
        ;;
      --bypass-check-url)
        CHECK_URL=false
        shift
        ;;
      --bypass-check-metadata)
        CHECK_METADATA=false
        shift
        ;;
      --bypass-check-rename)
        CHECK_RENAME=false
        shift
        ;;
      --bypass-check-length)
        CHECK_LENGTH=false
        shift
        ;;
      --no-thumbnail|--no-thumb)
        SHOW_THUMBNAIL=false
        shift
        ;;
      --bypass-check-filename)
        CHECK_UTF8=false
        CHECK_RENAME=false
        CHECK_LENGTH=false
        shift
        ;;
      --max-filename-bytes)
        (( $# >= 2 )) || {
          fail "Missing value for --max-filename-bytes"
          exit 1
        }
        MAX_FILENAME_BYTES="$2"
        [[ "$MAX_FILENAME_BYTES" == <-> ]] || {
          fail "--max-filename-bytes must be an integer"
          exit 1
        }
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        INPUT_FILES+=("$@")
        break
        ;;
      -*)
        usage
        fail "Unknown option: $1"
        exit 1
        ;;
      *)
        INPUT_FILES+=("$1")
        shift
        ;;
    esac
  done
}

process_fd_media() {
  command -v fd-media >/dev/null 2>&1 || {
    fail "fd-media not found."
    exit 1
  }

  while IFS= read -r -d $'\0' file; do
    audit_file "$file"
  done < <(fd-media --print0)
}

audit_dir() {
  local dir="$1"

  command -v fd-media >/dev/null 2>&1 || {
    fail "fd-media not found; cannot recurse ${dir}"
    exit 1
  }

  while IFS= read -r -d $'\0' file; do
    audit_file "$file"
  done < <(fd-media --print0 . "$dir")
}

audit_arg() {
  local arg="$1"

  if [[ -d "$arg" ]]; then
    audit_dir "$arg"
  else
    audit_file "$arg"
  fi
}

process_stdin_or_fd_media() {
  local line
  local saw_stdin=false

  if [[ ! -t 0 ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] || continue
      saw_stdin=true
      audit_arg "$line"
    done
  fi

  $saw_stdin && return 0
  process_fd_media
}

main() {
  local file

  parse_args "$@"
  build_enabled_checks
  detect_thumb_backend
  reset_file_checks

  if (( ${#INPUT_FILES[@]} > 0 )); then
    total_count="${#INPUT_FILES[@]}"
  fi

  draw_header

  if (( ${#INPUT_FILES[@]} > 0 )); then
    for file in "${INPUT_FILES[@]}"; do
      audit_arg "$file"
    done
  else
    process_stdin_or_fd_media
  fi

  clear_status
  clear_thumb
  say ""
  say "%B%F{green}DONE%f%b"
  say "CHECKED: ${processed_count}  CLEAN: ${clean_count}  ATTENTION: ${issue_file_count}  FIXES: ${fix_count}  SKIPPED: ${skip_count}  FAILED: ${fail_count}"
}

main "$@"
