#!/usr/bin/env zsh
# mpv-send
# Send files and simple control commands to a running mpv instance via JSON IPC.
# Starts mpv automatically if needed, supports verbose debugging, and streams
# playlist additions to the socket without waiting for upstream EOF.
#
# play supports:
#   -0 | --read0   read NUL-delimited stdin
#   --shuffle      shuffle once after all queued files have been sent
# start supports:
#   --socket PATH   start/listen on a specific IPC socket
#   --profile NAME  launch mpv with a specific mpv profile

set -euo pipefail

SOCKET="${SOCKET:-${MPV_SOCKET:-/tmp/mpv-socket}}"
MPV_LOG="${MPV_LOG:-/tmp/mpv-ipc.log}"
MPV_PROFILE="${MPV_PROFILE:-}"
MPV_SEND_BATCH_SIZE="${MPV_SEND_BATCH_SIZE:-64}"
VERBOSE=0

_have() { command -v "$1" >/dev/null 2>&1; }

have_ipc_client() {
  _have socat || _have nc
}

require_ipc_client() {
  have_ipc_client && return 0
  echo "Error: need 'socat' or 'nc' installed." >&2
  return 1
}

log() {
  (( VERBOSE )) && print -u2 -- "[mpv-send] $*"
  return 0
}

log_json() {
  (( VERBOSE )) || return 0
  print -u2 -- "[mpv-send][json] $*"
  return 0
}

json_escape() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//\"/\\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\r'/\\r}
  s=${s//$'\t'/\\t}
  print -r -- "$s"
}

abs_path() {
  local f="$1"
  [[ "$f" != /* ]] && f="$(pwd)/$f"
  print -r -- "$f"
}

usage() {
  cat <<'USAGE'
Usage: mpv-send [options] <command> [args]

Send files and simple control commands to a running mpv instance via IPC.

This utility can start mpv automatically if it is not already running with
the configured IPC socket, then send control commands or replace/append files
to the playlist.

Commands:
  start [options] [--] [mpv-args-or-file...]
                          Start a background mpv instance and wait for IPC.
                          Remaining args after -- are passed to mpv, so this
                          can also load an initial splash image.
  play [options] [track-number|files...]
                          Load files into mpv.
                          Reads from stdin first (newline by default).
                          Falls back to args if stdin is empty.
                          With one positive integer arg, plays that existing
                          playlist item using one-based track numbering.
                          Options:
                            -0|--read0   NUL-delimited stdin
                            --shuffle    shuffle playlist after all files sent
  next                    Skip to next file
  prev                    Jump to previous file
  shuffle                 Shuffle the current playlist
  sort                    Sort the current playlist using mpv's sort script
  random                  Jump to a random file (shuffle + next)
  osd on|off|toggle|0..3  Control OSD (osd-level)
  panscan <0..1>|on|off|toggle
                          Set/toggle pan&scan

Options:
  -s, --socket <path>     Use a specific mpv IPC socket
  -p, --profile <name>    Profile to use when this script starts mpv
  --log <path>            Log file for background mpv starts
  --verbose               Print IPC/debug messages

Env:
  SOCKET=/tmp/mpv-socket or MPV_SOCKET=/tmp/mpv-socket
  MPV_PROFILE=vj
  MPV_LOG=/tmp/mpv-ipc.log
  MPV_SEND_BATCH_SIZE=64

Examples:
  mpv-send --socket /tmp/mpv-vj.sock --profile vj start
  mpv-send --socket /tmp/mpv-vj.sock play clip.mp4
  mpv-send -s /tmp/mpv-vj.sock -p vj start -- --image-display-duration=inf splash.png
USAGE
}

send_ipc() {
  local payload="$1"
  log "send one command"
  log_json "$payload"

  if _have socat; then
    printf '%s\n' "$payload" | socat - "$SOCKET"
  elif _have nc; then
    printf '%s\n' "$payload" | nc -U "$SOCKET"
  else
    echo "Error: need 'socat' or 'nc' installed." >&2
    return 1
  fi
}

send_ipc_quiet() {
  local payload="$1"
  if (( VERBOSE )); then
    send_ipc "$payload" >/dev/null
  else
    if _have socat; then
      printf '%s\n' "$payload" | socat - "$SOCKET" >/dev/null 2>&1
    elif _have nc; then
      printf '%s\n' "$payload" | nc -U "$SOCKET" >/dev/null 2>&1
    else
      echo "Error: need 'socat' or 'nc' installed." >&2
      return 1
    fi
  fi
}

send_ipc_many() {
  local payload="$1"
  local bytes
  bytes=$(printf '%s' "$payload" | wc -c | tr -d ' ')

  log "send batch: ${bytes} bytes"

  if (( VERBOSE )); then
    print -u2 -- "----- mpv batch begin -----"
    printf '%s' "$payload" >&2
    [[ "$payload" != *$'\n' ]] && print -u2 -- ""
    print -u2 -- "----- mpv batch end -------"
  fi

  if _have socat; then
    printf '%s' "$payload" | socat - "$SOCKET"
  elif _have nc; then
    printf '%s' "$payload" | nc -U "$SOCKET"
  else
    echo "Error: need 'socat' or 'nc' installed." >&2
    return 1
  fi
}

test_socket() {
  [[ -S "$SOCKET" ]] || return 1

  if _have socat; then
    printf '{"command":["get_property","idle-active"]}\n' | socat - "$SOCKET" >/dev/null 2>&1
  elif _have nc; then
    printf '{"command":["get_property","idle-active"]}\n' | nc -U "$SOCKET" >/dev/null 2>&1
  else
    return 1
  fi
}

start_mpv() {
  local ready=false
  local i
  local -a mpv_args

  mpv_args=(--idle=yes --force-window=immediate --input-ipc-server="$SOCKET")
  [[ -n "$MPV_PROFILE" ]] && mpv_args=(--profile="$MPV_PROFILE" "${mpv_args[@]}")
  (( $# > 0 )) && mpv_args+=("$@")

  log "starting mpv"
  log "mpv args: ${(q)mpv_args}"
  rm -f -- "$SOCKET"
  mpv "${mpv_args[@]}" >"$MPV_LOG" 2>&1 & disown

  for i in {1..50}; do
    if test_socket; then
      ready=true
      break
    fi
    sleep 0.1
  done

  if ! $ready; then
    echo "Error: mpv socket $SOCKET did not become usable. Check $MPV_LOG" >&2
    exit 1
  fi

  log "mpv ready"
}

mpv_cmd() {
  local -a parts=()
  local a joined

  for a in "$@"; do
    parts+=$'"'$(json_escape "$a")$'"'
  done

  joined="$(IFS=,; echo "${parts[*]}")"
  send_ipc_quiet '{ "command": ['"$joined"'] }'
}

mpv_cmd_json() {
  local -a parts=()
  local a joined

  for a in "$@"; do
    parts+=$'"'$(json_escape "$a")$'"'
  done

  joined="$(IFS=,; echo "${parts[*]}")"
  printf '{ "command": [%s] }' "$joined"
}

ensure_mpv() {
  local i

  log "socket: $SOCKET"
  log "mpv log: $MPV_LOG"
  log "mpv profile: ${MPV_PROFILE:-<default>}"
  log "verbose: $VERBOSE"

  require_ipc_client || exit 1

  if test_socket; then
    log "using existing mpv socket"
    return 0
  fi

  if pgrep -qf "mpv.*input-ipc-server=$SOCKET"; then
    log "matched an mpv process, waiting for socket readiness"
    for i in {1..10}; do
      if test_socket; then
        log "using existing mpv instance"
        return 0
      fi
      sleep 0.1
    done
    log "matched mpv process did not expose a usable socket"
  fi

  start_mpv
}

focus_mpv() {
  osascript -e 'tell application "System Events" to set frontmost of process "mpv" to true' >/dev/null 2>&1 || true
}

start_cmd() {
  local -a mpv_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -s|--socket)
        [[ $# -ge 2 ]] || { echo "Error: $1 requires a socket path" >&2; exit 1; }
        SOCKET="$2"
        shift 2
        ;;
      --socket=*)
        SOCKET="${1#*=}"
        shift
        ;;
      -p|--profile)
        [[ $# -ge 2 ]] || { echo "Error: $1 requires a profile name" >&2; exit 1; }
        MPV_PROFILE="$2"
        shift 2
        ;;
      --profile=*)
        MPV_PROFILE="${1#*=}"
        shift
        ;;
      --log)
        [[ $# -ge 2 ]] || { echo "Error: $1 requires a log path" >&2; exit 1; }
        MPV_LOG="$2"
        shift 2
        ;;
      --log=*)
        MPV_LOG="${1#*=}"
        shift
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --)
        shift
        mpv_args+=("$@")
        break
        ;;
      -*)
        echo "Error: unknown start option: $1" >&2
        echo "Usage: mpv-send start [-s socket] [-p profile] [--log path] [--] [mpv-args-or-file...]" >&2
        exit 1
        ;;
      *)
        mpv_args+=("$1")
        shift
        ;;
    esac
  done

  require_ipc_client || exit 1

  if test_socket; then
    echo "mpv is already listening on $SOCKET"
    return 0
  fi

  start_mpv "${mpv_args[@]}"
  echo "Started mpv on $SOCKET${MPV_PROFILE:+ with profile $MPV_PROFILE}"
  focus_mpv
}

play_cmd() {
  local read0=false
  local shuffle_after=false
  local track_number=""
  local track_index
  local line f payload batch_count
  local sent=0
  local batch_size="$MPV_SEND_BATCH_SIZE"

  log "play_cmd: parsing options/inputs"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -0|--read0)
        read0=true
        log "stdin mode: NUL-delimited"
        shift
        ;;
      --shuffle)
        shuffle_after=true
        log "post-action: shuffle playlist"
        shift
        ;;
      --)
        shift
        break
        ;;
      -*)
        echo "Error: unknown play option: $1" >&2
        echo "Usage: mpv-send play [-0|--read0] [--shuffle] [--] [track-number|files...]" >&2
        exit 1
        ;;
      *)
        break
        ;;
    esac
  done

  if (( $# == 1 )) && [[ "$1" == <-> ]]; then
    if (( 10#$1 < 1 )); then
      echo "Error: track numbers are one-based; use 1 or greater" >&2
      exit 1
    fi

    track_number="$1"
    shift
  fi

  case "$batch_size" in
    ""|*[!0-9]*) batch_size=64 ;;
  esac
  (( batch_size > 0 )) || batch_size=64

  payload=""
  batch_count=0

  flush_payload() {
    (( batch_count > 0 )) || return 0

    send_ipc_many "$payload" >/dev/null || return 1
    payload=""
    batch_count=0
    return 0
  }

  queue_item() {
    local raw="$1"
    local mode item_payload

    [[ -n "$raw" ]] || return 0

    f="$(abs_path "$raw")"

    if (( sent == 0 )); then
      ensure_mpv
      mode="replace"
      item_payload="$(mpv_cmd_json loadfile "$f" "$mode")"$'\n'
      item_payload+="$(mpv_cmd_json set_property pause no)"$'\n'
      log "send first file mode=$mode file=$f"
      if ! send_ipc_many "$item_payload" >/dev/null 2>/dev/null; then
        log "first send failed; restarting mpv and retrying once"
        start_mpv
        send_ipc_many "$item_payload" >/dev/null || return 1
      fi
    else
      mode="append-play"
      log "queue file #$(( sent + 1 )) mode=$mode file=$f"
      payload+="$(mpv_cmd_json loadfile "$f" "$mode")"$'\n'
      (( ++batch_count ))

      if (( batch_count >= batch_size )); then
        flush_payload || return 1
      fi
    fi

    (( ++sent ))
    return 0
  }

  play_track_number() {
    (( track_index = 10#$track_number - 1 ))
    ensure_mpv

    mpv_cmd playlist-play-index "$track_index" || {
      echo "Error: failed to play playlist track $track_number" >&2
      exit 1
    }

    mpv_cmd set_property pause no || {
      echo "Error: failed to resume playback" >&2
      exit 1
    }
  }

  if [[ ! -t 0 ]]; then
    log "stdin detected"
    if $read0; then
      while IFS= read -r -d $'\0' line || [[ -n "$line" ]]; do
        queue_item "$line" || {
          echo "Error: failed to send playlist item to mpv" >&2
          exit 1
        }
        line=""
      done
    else
      while IFS= read -r line || [[ -n "$line" ]]; do
        queue_item "$line" || {
          echo "Error: failed to send playlist item to mpv" >&2
          exit 1
        }
        line=""
      done
    fi
  fi

  if (( sent == 0 && $# > 0 )); then
    log "using argv input: $# item(s)"
    for f in "$@"; do
      queue_item "$f" || {
        echo "Error: failed to send playlist item to mpv" >&2
        exit 1
      }
    done
  fi

  if (( sent == 0 && -z "$track_number" )); then
    echo "Error: no input. Pipe paths on stdin or pass files as arguments." >&2
    exit 1
  fi

  flush_payload || {
    echo "Error: failed to send playlist batch to mpv" >&2
    exit 1
  }

  if $shuffle_after; then
    log "sending post-action: playlist-shuffle"
    mpv_cmd playlist-shuffle || {
      echo "Error: failed to shuffle playlist" >&2
      exit 1
    }
  fi

  if [[ -n "$track_number" ]]; then
    play_track_number
  fi

  if (( sent > 0 )) && $shuffle_after && [[ -n "$track_number" ]]; then
    echo "Sent $sent file(s) to mpv, shuffled playlist, and played track $track_number"
  elif (( sent > 0 )) && $shuffle_after; then
    echo "Sent $sent file(s) to mpv and shuffled playlist"
  elif (( sent > 0 )) && [[ -n "$track_number" ]]; then
    echo "Sent $sent file(s) to mpv and played track $track_number"
  elif [[ -n "$track_number" ]]; then
    echo "Playing playlist track $track_number"
  else
    echo "Sent $sent file(s) to mpv"
  fi

  focus_mpv
}

sort_cmd() {
  ensure_mpv
  mpv_cmd script-binding sort_playlist_by_mtime || {
    echo "Error: failed to trigger mpv playlist sort" >&2
    exit 1
  }
  echo "Triggered mpv playlist sort"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--socket)
      [[ $# -ge 2 ]] || { echo "Error: $1 requires a socket path" >&2; exit 1; }
      SOCKET="$2"
      shift 2
      ;;
    --socket=*)
      SOCKET="${1#*=}"
      shift
      ;;
    -p|--profile)
      [[ $# -ge 2 ]] || { echo "Error: $1 requires a profile name" >&2; exit 1; }
      MPV_PROFILE="$2"
      shift 2
      ;;
    --profile=*)
      MPV_PROFILE="${1#*=}"
      shift
      ;;
    --log)
      [[ $# -ge 2 ]] || { echo "Error: $1 requires a log path" >&2; exit 1; }
      MPV_LOG="$2"
      shift 2
      ;;
    --log=*)
      MPV_LOG="${1#*=}"
      shift
      ;;
    --verbose)
      VERBOSE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      break
      ;;
  esac
done

cmd="${1:-}"
[[ -n "$cmd" ]] && shift || { usage; exit 1; }

case "$cmd" in
  start)
    start_cmd "$@"
    ;;

  play)
    play_cmd "$@"
    ;;

  next)
    ensure_mpv
    mpv_cmd playlist-next
    echo "Skipped to next track"
    ;;

  prev)
    ensure_mpv
    mpv_cmd playlist-prev
    echo "Jumped to previous track"
    ;;

  shuffle)
    ensure_mpv
    mpv_cmd playlist-shuffle
    echo "Shuffled playlist"
    ;;

  sort)
    sort_cmd "$@"
    ;;

  random)
    ensure_mpv
    mpv_cmd playlist-shuffle
    mpv_cmd playlist-next force
    echo "Jumped to a random track"
    ;;

  osd)
    ensure_mpv
    case "${1:-}" in
      on)       mpv_cmd set_property osd-level 3; echo "OSD: on" ;;
      off)      mpv_cmd set_property osd-level 0; echo "OSD: off" ;;
      toggle)   mpv_cmd cycle-values osd-level 0 3; echo "OSD: toggled 0↔3" ;;
      0|1|2|3)  mpv_cmd set_property osd-level "$1"; echo "OSD level: $1" ;;
      *)        echo "Usage: mpv-send osd on|off|toggle|0..3"; exit 1 ;;
    esac
    ;;

  panscan|pan-scan)
    ensure_mpv
    case "${1:-}" in
      on)      mpv_cmd set_property panscan 1; echo "panscan: 1" ;;
      off)     mpv_cmd set_property panscan 0; echo "panscan: 0" ;;
      toggle)  mpv_cmd cycle-values panscan 0 1; echo "panscan: toggled 0↔1" ;;
      "")      echo "Usage: mpv-send panscan <0..1>|on|off|toggle"; exit 1 ;;
      *)       mpv_cmd set_property panscan "$1"; echo "panscan: $1" ;;
    esac
    ;;

  *)
    usage
    exit 1
    ;;
esac
