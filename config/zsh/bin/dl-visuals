#!/usr/bin/env zsh
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: dl-visuals [options] URL [URL...] [-- yt-dlp-args...]

Download the highest-resolution format available, then make the final file video-only.

Files are saved to:
  $ICLOUD_HOME/Movies/Visuals/Downloads/

Download history is stored at:
  $ICLOUD_HOME/Movies/Visuals/Downloads/history.txt

Final container rules:
  - VP9 / VP8 / AV1  -> .webm
  - H264 / HEVC      -> .mp4   (HEVC tagged hvc1 for Apple compatibility)

Format selection prefers true video-only streams first, then falls back to
video-containing formats when a site does not expose separate video.

Options:
  -t, --tmpl TEMPLATE  yt-dlp output template
                       (default: %(channel|Unknown Channel)s [%(id)s].%(ext)s)
  --no-playlist        Do not download playlists
  --keep-original      Keep original downloaded file if remux occurs
  --force              Bypass history and overwrite existing target files
  -h, --help           Show help

Passthrough:
  Anything after -- is passed directly to yt-dlp
EOF
  exit 1
}

: "${ICLOUD_HOME:?ICLOUD_HOME must be set}"

out_dir="$ICLOUD_HOME/Movies/Visuals/Downloads"
archive_file="$out_dir/history.txt"
tmpl='%(channel|Unknown Channel)s [%(id)s].%(ext)s'
no_playlist=0
keep_original=0
force=0

while (( $# )); do
  case "$1" in
    -t|--tmpl)
      [[ $# -ge 2 ]] || usage
      tmpl="$2"
      shift 2
      ;;
    --no-playlist)
      no_playlist=1
      shift
      ;;
    --keep-original)
      keep_original=1
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    -h|--help)
      usage
      ;;
    --)
      shift
      break
      ;;
    --*)
      print -u2 "Unknown option: $1"
      usage
      ;;
    *)
      break
      ;;
  esac
done

urls=()
user_extra_args=()
hit_sep=0

for arg in "$@"; do
  if (( hit_sep )); then
    user_extra_args+=("$arg")
    continue
  fi
  if [[ "$arg" == "--" ]]; then
    hit_sep=1
    continue
  fi
  urls+=("$arg")
done

(( ${#urls[@]} > 0 )) || usage

need() {
  command -v "$1" >/dev/null 2>&1 || {
    print -u2 "Missing dependency: $1"
    exit 1
  }
}

need yt-dlp
need ffmpeg
need ffprobe
need rg

mkdir -p -- "$out_dir"
touch -- "$archive_file"

c_reset='%f%k'
c_dim='%F{245}'
c_blue='%F{39}'
c_green='%F{70}'
c_yellow='%F{178}'
c_red='%F{160}'

best_video_format='bv[vcodec!=none][acodec=none]/bv[acodec=none]/bv*[vcodec!=none]/bv*/b'
best_video_sort='res,fps,tbr'

header() { print -P "${c_blue}$*${c_reset}"; }
ok()     { print -P "${c_green}✔${c_reset} $*"; }
warn()   { print -P "${c_yellow}⚠${c_reset} $*"; }
err()    { print -P "${c_red}✘${c_reset} $*"; }
note()   { print -P "${c_dim}$*${c_reset}"; }

run() {
  local arg
  print -P "${c_dim}Executing:${c_reset}" >&2
  for arg in "$@"; do
    printf '%q ' "$arg" >&2
  done
  printf '\n' >&2
  "$@"
}

probe_codec() {
  ffprobe -v error \
    -select_streams v:0 \
    -show_entries stream=codec_name \
    -of default=nw=1:nk=1 \
    -- "$1" 2>/dev/null || true
}

probe_resolution() {
  ffprobe -v error \
    -select_streams v:0 \
    -show_entries stream=width,height \
    -of csv=s=x:p=0 \
    -- "$1" 2>/dev/null || true
}

probe_has_audio() {
  ffprobe -v error \
    -select_streams a \
    -show_entries stream=index \
    -of csv=p=0 \
    -- "$1" 2>/dev/null | rg -q '.'
}

target_ext_for_codec() {
  case "$1" in
    vp9|vp8|av1) print -r -- webm ;;
    h264|hevc)   print -r -- mp4 ;;
    *)           print -r -- "" ;;
  esac
}

codec_label() {
  case "$1" in
    h264) print -r -- "H.264" ;;
    hevc) print -r -- "HEVC" ;;
    vp9)  print -r -- "VP9" ;;
    vp8)  print -r -- "VP8" ;;
    av1)  print -r -- "AV1" ;;
    *)    print -r -- "$1" ;;
  esac
}

typeset -ga tmp_files=()
typeset -ga final_files=()

cleanup() {
  local f
  for f in "${tmp_files[@]:-}"; do
    [[ -n "$f" && -e "$f" ]] && rm -f -- "$f"
  done
}
trap cleanup EXIT

for url in "${urls[@]}"; do
  extra_args=()
  (( no_playlist )) && extra_args+=(--no-playlist)
  extra_args+=("${user_extra_args[@]}")

  archive_args=(--download-archive "$archive_file")
  (( force )) && archive_args+=(--no-download-archive --force-overwrites)

  paths_file="$(mktemp -t dlvisuals.paths.XXXXXX)"
  tmp_files+=("$paths_file")

  header "Downloading highest-resolution format..."
  yt_dlp_rc=0
  run yt-dlp \
    -f "$best_video_format" \
    -S "$best_video_sort" \
    --format-sort-force \
    --ignore-no-formats-error \
    -o "$tmpl" \
    --print-to-file 'after_move:filepath' "$paths_file" \
    "${extra_args[@]}" \
    --paths "$out_dir" \
    "${archive_args[@]}" \
    -- "$url" || yt_dlp_rc=$?

  downloaded_files=()
  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    [[ "$line" == /* ]] || continue
    [[ -f "$line" ]] || continue
    downloaded_files+=("$line")
  done < "$paths_file" || true

  if (( ${#downloaded_files[@]} == 0 )); then
    if (( yt_dlp_rc != 0 )); then
      err "yt-dlp failed and did not report any downloaded files."
      exit "$yt_dlp_rc"
    fi
    warn "No files downloaded."
    continue
  fi

  if (( yt_dlp_rc != 0 )); then
    warn "yt-dlp reported errors after saving file(s); continuing with saved file(s)."
  fi

  for file in "${downloaded_files[@]}"; do
    header "Inspecting downloaded file..."
    note "  path            : ${file:A}"

    codec="$(probe_codec "$file")"
    if [[ -z "$codec" ]]; then
      err "Could not detect video codec: $file"
      continue
    fi

    res="$(probe_resolution "$file")"
    [[ -n "$res" ]] || res="unknown"

    has_audio=0
    if probe_has_audio "$file"; then
      has_audio=1
    fi

    target_ext="$(target_ext_for_codec "$codec")"
    if [[ -z "$target_ext" ]]; then
      warn "Unknown codec '$codec'; keeping original container"
      target_ext="${file:e}"
    fi

    base_no_ext="${file%.*}"
    target="${base_no_ext}.${target_ext}"

    note "  detected codec  : $(codec_label "$codec")"
    note "  detected ext    : ${file:e}"
    note "  detected res    : ${res}"
    note "  detected audio  : $([[ $has_audio -eq 1 ]] && print yes || print no)"
    note "  remux rule      : $(codec_label "$codec") -> ${target_ext}"
    note "  output ext      : ${target_ext}"
    note "  output filename : ${target:t}"

    if [[ "$target" == "$file" && $has_audio -eq 0 ]]; then
      ok "Final file already correct: ${file:t}"
      final_files+=("$file")
      continue
    fi

    if [[ "$target" == "$file" && $has_audio -eq 1 ]]; then
      header "Stripping audio..."
    elif [[ "$target" != "$file" && $has_audio -eq 0 ]]; then
      header "Changing container..."
    else
      header "Changing container and stripping audio..."
    fi

    tmp="${base_no_ext}.dlvisuals.tmp.$$.${target_ext}"
    tmp_files+=("$tmp")

    ffmpeg_args=(
      -hide_banner
      -loglevel error
      -y
      -i "$file"
      -map 0:v:0
      -c:v copy
      -an
    )

    [[ "$codec" == "hevc" && "$target_ext" == "mp4" ]] && ffmpeg_args+=(-tag:v hvc1)
    ffmpeg_args+=("$tmp")

    run ffmpeg "${ffmpeg_args[@]}"

    mv -f -- "$tmp" "$target"
    ok "Created: ${target:t}"
    final_files+=("$target")

    if [[ $keep_original -eq 0 && "$target" != "$file" ]]; then
      rm -f -- "$file"
      note "  removed original: ${file:t}"
    elif [[ $keep_original -eq 1 && "$target" != "$file" ]]; then
      note "  kept original   : ${file:t}"
    fi
  done
done

if (( ${#final_files[@]} > 0 )); then
  print
  if (( ${#final_files[@]} == 1 )); then
    print -P "${c_green}Saved:${c_reset} ${c_blue}${final_files[1]:A}${c_reset}"
  else
    print -P "${c_green}Saved files:${c_reset}"
    for file in "${final_files[@]}"; do
      print -P "  ${c_blue}${file:A}${c_reset}"
    done
  fi
fi
