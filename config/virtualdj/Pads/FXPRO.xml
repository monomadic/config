<?xml version="1.0" encoding="UTF-8"?>
<page name="OPEN FORMAT FX">
  <!-- Row 1 : target selection -->
  <pad1 name="VOCAL FX" color="color '#53E08B'" query="effect_stems 'vocal'">
    effect_stems 'vocal'
  </pad1>
  <pad2 name="MELODY FX" color="color '#AA33DD'" query="effect_stems 'melody'">
    effect_stems 'melody' ? effect_stems off : effect_stems 'melody'
  </pad2>
  <pad3 name="DRUM FX" color="color '#59B7FF'" query="effect_stems 'rhythm'">
    effect_stems 'rhythm' ? effect_stems off : effect_stems 'rhythm'
  </pad3>
  <pad4 name="ALL FX" color="color 'yellow'" query="effect_stems ? off : on">
    effect_stems 'rhythm' off &amp;
    effect_stems 'vocal' off &amp;
    effect_stems 'melody' off &amp;
    effect_stems off
  </pad4>
  <!-- Row 2 : transition / release tools -->
  <pad5 name="ECHO OUT" color="color '#F2D14C'">
    effect_stems off &amp; padfx_single 'echo out' 75% 1bt
  </pad5>
  <pad6 name="VOC OUT" color="color '#53E08B'">
    padfx_single 'echo out' 75% 1bt 'stemfx:vocal'
  </pad6>
  <pad7 name="INST OUT" color="color '#F2D14C'">
    padfx_single 'echo out' 75% 1bt 'stemfx:melorhythm'
  </pad7>
  <pad8 name="BRAKE" color="color '#FF8A65'">
    effect_stems off &amp; padfx 'vinylbrake' 50% 4bt 0% 0%
  </pad8>
  <!-- Row 3 : musical texture -->
  <pad9 name="ECHO" color="color '#F2D14C'">
    effect_stems off &amp; padfx 'echo' 45% 1bt 55%
  </pad9>
  <pad10 name="VOC ECHO" color="color '#53E08B'">
    padfx 'echo' 45% 1bt 55% 'stemfx:vocal'
  </pad10>
  <pad11 name="REVERB" color="color '#F2D14C'">
    effect_stems off &amp; padfx 'reverb' 30% 45% 45% 55%
  </pad11>
  <pad12 name="VOC VERB" color="color '#53E08B'">
    padfx 'reverb' 30% 45% 45% 55% 'stemfx:vocal'
  </pad12>
  <!-- Row 4 : rhythmic mashup tools + panic reset -->
  <pad13 name="INST GRID" color="color '#59B7FF'">
    padfx 'Beat Grid' 'stemfx:melorhythm'
  </pad13>
  <pad14 name="1/2 ROLL" color="color '#59B7FF'">
    loop_roll 0.5
  </pad14>
  <pad15 name="1BT ROLL" color="color '#59B7FF'">
    loop_roll 1
  </pad15>
  <pad16 name="FX RESET" color="color '#FF5A5A'">
    effect_stems off &amp;
    effect_active 1 off &amp;
    effect_active 2 off &amp;
    effect_active 3 off &amp;
    effect_active 4 off &amp;
    effect_active 5 off &amp;
    effect_active 6 off &amp;
    effect_active 'colorfx' off &amp;
    filter 50%
  </pad16>
</page>
