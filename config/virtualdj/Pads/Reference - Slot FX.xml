<?xml version="1.0" encoding="UTF-8"?>
<!--
  Reference - Slot FX.xml
  Canonical slot-based audio FX pad page.

  Pattern: select an effect into a numbered slot, activate the slot, control per-slot sliders.
  This is the preferred approach over name-based toggling because:
    - it mirrors the actual deck FX rack model
    - slot state is unambiguous regardless of what other effects are loaded
    - effect_slider and effect_active always target the correct slot

  Source: Official
  See: Reference/VirtualDJ Reference.md — Deck FX Slots section
-->
<page name="REF: SLOT FX">

  <!-- SLOT 1 — Echo
       Tap to load Echo into slot 1 and activate. Tap again to deactivate.
       query drives the blink when active. color is static per slot for visual identification. -->
  <pad1 name="ECHO" color="color 'yellow'" query="effect_active 1 ? blink 500ms : off">
    effect_active 1 ?
      effect_active 1 off :
      effect_select 1 'Echo' &amp; effect_slider 1 1 75% &amp; effect_slider 1 2 50% &amp; effect_active 1 on
  </pad1>

  <!-- SLOT 2 — Reverb -->
  <pad2 name="REVERB" color="color 'cyan'" query="effect_active 2 ? blink 500ms : off">
    effect_active 2 ?
      effect_active 2 off :
      effect_select 2 'Reverb' &amp; effect_slider 2 1 75% &amp; effect_active 2 on
  </pad2>

  <!-- SLOT 3 — Delay -->
  <pad3 name="DELAY" color="color 'green'" query="effect_active 3 ? blink 500ms : off">
    effect_active 3 ?
      effect_active 3 off :
      effect_select 3 'Delay' &amp; effect_slider 3 1 75% &amp; effect_slider 3 2 50% &amp; effect_active 3 on
  </pad3>

  <!-- SLOT 4 — Flanger -->
  <pad4 name="FLANGER" color="color 'blue'" query="effect_active 4 ? blink 500ms : off">
    effect_active 4 ?
      effect_active 4 off :
      effect_select 4 'Flanger' &amp; effect_slider 4 1 50% &amp; effect_active 4 on
  </pad4>

  <!-- SLOT 1 — Echo Out (variant for slot 1, overwrites whatever is in slot 1) -->
  <pad5 name="ECHO OUT" color="color 'yellow'" query="effect_active 1 ? blink 500ms : off">
    effect_active 1 ?
      effect_active 1 off :
      effect_select 1 'Echo Out' &amp; effect_slider 1 1 75% &amp; effect_active 1 on
  </pad5>

  <!-- SLOT 1 — Loop Roll -->
  <pad6 name="LOOP ROLL" color="color 'yellow'" query="effect_active 1 ? blink 500ms : off">
    effect_active 1 ?
      effect_active 1 off :
      effect_select 1 'Loop Roll' &amp; effect_slider 1 1 50% &amp; effect_active 1 on
  </pad6>

  <!-- SLOT 1 — Phaser -->
  <pad7 name="PHASER" color="color 'yellow'" query="effect_active 1 ? blink 500ms : off">
    effect_active 1 ?
      effect_active 1 off :
      effect_select 1 'Phaser' &amp; effect_slider 1 1 50% &amp; effect_active 1 on
  </pad7>

  <!-- SLOT 1 — Beat Grid -->
  <pad8 name="BEAT GRID" color="color 'yellow'" query="effect_active 1 ? blink 500ms : off">
    effect_active 1 ?
      effect_active 1 off :
      effect_select 1 'Beat Grid' &amp; effect_slider 1 1 75% &amp; effect_active 1 on
  </pad8>

  <!-- Slider controls for slot 1, param 1 — nudge up/down by 10% -->
  <pad9 name="S1 P1 +" color="color 'yellow'">effect_slider 1 1 +10%</pad9>
  <pad10 name="S1 P1 -" color="color 'yellow'">effect_slider 1 1 -10%</pad10>

  <!-- Slider controls for slot 1, param 2 -->
  <pad11 name="S1 P2 +" color="color 'yellow'">effect_slider 1 2 +10%</pad11>
  <pad12 name="S1 P2 -" color="color 'yellow'">effect_slider 1 2 -10%</pad12>

  <!-- Kill all four slots at once -->
  <pad13 name="KILL ALL" color="color 'red'">
    effect_active 1 off &amp; effect_active 2 off &amp; effect_active 3 off &amp; effect_active 4 off
  </pad13>

  <!-- Current slot 1 name display (read-only informational pad) -->
  <pad14 name="SLOT 1: `effect_select 1`" color="color 'yellow'" query="effect_active 1 ? on : off">
    effect_active 1
  </pad14>

  <!-- Current slot 2 name display -->
  <pad15 name="SLOT 2: `effect_select 2`" color="color 'cyan'" query="effect_active 2 ? on : off">
    effect_active 2
  </pad15>

  <!-- Open the FX GUI for slot 1 -->
  <pad16 name="EDIT S1" color="color 'white'">effect_show_gui 1</pad16>

  <!-- Shift variants: load a different effect into slot 1 without activating -->
  <shift_pad1 name="LOAD ECHO" color="color 'yellow'">effect_select 1 'Echo'</shift_pad1>
  <shift_pad2 name="LOAD REVERB" color="color 'cyan'">effect_select 2 'Reverb'</shift_pad2>
  <shift_pad5 name="LOAD ECHO OUT" color="color 'yellow'">effect_select 1 'Echo Out'</shift_pad5>
  <shift_pad6 name="LOAD LOOP ROLL" color="color 'yellow'">effect_select 1 'Loop Roll'</shift_pad6>

  <!-- Param buttons: open the effect selection GUI for slots 1 and 2 -->
  <param1 name="SLOT 1: `effect_select 1`">effect_select_popup 1</param1>
  <param2 name="SLOT 2: `effect_select 2`">effect_select_popup 2</param2>

</page>
