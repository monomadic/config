<?xml version="1.0" encoding="UTF-8"?>
<page name="FX">
  <!-- row 1: full-track persistent fx -->
  <pad4 name="ECHO OUT 1bt" color="color 'yellow'">
    padfx 'echo out' 80% 1bt 50% 0%
  </pad4>
  <pad2 name="REVERB" color="color 'yellow'">
    padfx 'reverb' 0.4 0.1 0.3 0.4
  </pad2>
  <pad3 name="LOOP ROLL 2bt" color="color 'yellow'">
    padfx 'loop roll' 100% 2bt 50% 50%
  </pad3>
  <pad1 name="FLANGER" color="color 'yellow'">
    padfx 'flanger' 0.5 8bt 0.5 0.5
  </pad1>
  <!-- row 2: vocal-only persistent fx -->
  <pad5 name="Vocals``\nECHO 1bt" color="stem_color 'vocal'">
    padfx 'echo' 100% 1bt 50% 50% 'stemfx:vocal'
  </pad5>
  <pad6 name="Vocals``\nREVERB" color="stem_color 'vocal'">
    padfx 'reverb' 20% 32% 11% 50% 'stemfx:vocal'
  </pad6>
  <pad7 name="Vocals``\nLOOP ROLL 2bt" color="stem_color 'vocal'">
    padfx 'loop roll' 100% 2bt 50% 50% 'stemfx:vocal'
  </pad7>
  <pad8 name="Vocals``\nECHO OUT 1bt" color="stem_color 'vocal'">
    padfx 'echo out' 80% 1bt 50% 0% 'stemfx:vocal'
  </pad8>
  <!-- row 3: melody/rhythm -->
  <pad12 name="Vocals``\nECHO OUT 2bt" color="stem_color 'vocal'">
    padfx 'echo out' 80% 2bt 50% 0% 'stemfx:vocal'
  </pad12>
  <pad10 name="Drums``\nREVERB" color="stem_color 'rhythm'">
    padfx 'reverb' 0.4 0.1 0.3 0.4 'stemfx:rhythm'
  </pad10>
  <!-- <pad10 name="FLANGER - Melody" color="stem_color 'melody'" query="effect_stems 'melody' ? effect_active 'flanger' : off"> -->
  <!-- padfx 'flanger' 0.4 0.1 0.3 0.4 'stemfx:melody' -->
  <!-- </pad10> -->
  <pad11 name="Vocals``\nLOOP ROLL 1bt" color="stem_color 'vocal'">
    padfx 'loop roll' 100% 1bt 50% 50% 'stemfx:vocal'
  </pad11>
  <pad9 name="Drums``\nECHO 1/2bt" color="stem_color 'rhythm'">
    padfx 'echo' 50% 0.5 50% 0.4 'stemfx:rhythm'
  </pad9>
  <!-- row 4: stem mode / off -->
  <pad13 name="VocalFX" color="stem_color 'vocal'" query="effect_stems 'vocal' ? blink 1bt">
    effect_stems 'vocal'
  </pad13>
  <pad14 name="MelodyFX" color="stem_color 'melody'" query="effect_stems 'melody' ? blink 1bt">
    effect_stems 'melody'
  </pad14>
  <pad15 name="DrumFX" color="stem_color 'rhythm'" query="effect_stems 'rhythm' ? blink 1bt">
    effect_stems 'rhythm'
  </pad15>
  <pad16 name="`effects_used 'deck' ? get_text 'FX ON' : get_text 'FX OFF'`" color="effects_used 'deck' ? color 'yellow' : color '#444444'" query="effects_used 'deck' ? blink 1bt">effect_disable_all 'padfx' &amp; filter 50%</pad16>
  <!-- shift: edit GUIs -->
  <!-- <shift_pad1 name="EDIT`\n`ECHO" color="color 'yellow'">effect_show_gui 'echo'</shift_pad1> -->
  <!-- <shift_pad2 name="EDIT`\n`REVERB" color="color 'yellow'">effect_show_gui 'reverb'</shift_pad2> -->
  <!-- <shift_pad3 name="EDIT`\n`FLANGER" color="color 'yellow'">effect_show_gui 'flanger'</shift_pad3> -->
  <!-- <shift_pad4 name="EDIT`\n`BEATGRID" color="color 'yellow'">effect_show_gui 'beatgrid'</shift_pad4> -->
  <!-- <shift_pad5 name="VOCAL`\n`EDIT ECHO" color="stem_color 'vocal'">effect_show_gui 'vocal' 'echo'</shift_pad5> -->
  <!-- <shift_pad6 name="VOCAL`\n`EDIT REV" color="stem_color 'vocal'">effect_show_gui 'vocal' 'reverb'</shift_pad6> -->
  <!-- <shift_pad7 name="VOCAL`\n`EDIT FLANG" color="stem_color 'vocal'">effect_show_gui 'vocal' 'flanger'</shift_pad7> -->
  <!-- <shift_pad8 name="VOCAL`\n`OFF" color="stem_color 'vocal'">effect_stems 'vocal' &amp; effect_active 'echo out' off</shift_pad8> -->
  <!-- <shift_pad9 name="INST`\n`EDIT REV" color="stem_color 'melody'">effect_show_gui 'melody' 'reverb'</shift_pad9> -->
  <!-- <shift_pad10 name="INST`\n`EDIT FLANG" color="stem_color 'melody'">effect_show_gui 'melody' 'flanger'</shift_pad10> -->
  <!-- <shift_pad11 name="DRUM`\n`EDIT GRID" color="stem_color 'rhythm'">effect_show_gui 'rhythm' 'beatgrid'</shift_pad11> -->
  <!-- <shift_pad12 name="DRUM`\n`EDIT ECHO" color="stem_color 'rhythm'">effect_show_gui 'rhythm' 'echo'</shift_pad12> -->
  <!-- <shift_pad13 name="FULL TRACK" color="color 'yellow'">effect_stems off</shift_pad13> -->
  <!-- <shift_pad14 name="MELO+RHY" color="stem_color 'melody'">effect_stems 'melorhythm'</shift_pad14> -->
  <!-- <shift_pad15 name="ACAPELLA" color="stem_color 'vocal'">effect_stems 'acapella'</shift_pad15> -->
  <shift_pad16 name="FX KILL" color="color 'red'">
    effect_stems off &amp;
    effect_active 'echo' off &amp;
    effect_active 'reverb' off &amp;
    effect_active 'flanger' off &amp;
    effect_active 'beatgrid' off &amp;
    effect_active 'echo out' off
  </shift_pad16>
  <menu>Edit Effect: Echo Out =[effect_show_gui 'echo out']
    Edit Effect: Echo =[effect_show_gui 'echo']
    Edit Effect: Reverb =[effect_show_gui 'reverb']
    Edit Effect: Flanger =[effect_show_gui 'flanger']
    Edit Effect: BeatGrid =[effect_show_gui 'beatgrid']

    Edit Effect: Echo (Vocals) =[effect_show_gui 'vocals' 'echo']
    Edit Effect: Echo Out (Vocals) =[effect_show_gui 'vocals' 'echo out']
    Edit Effect: Reverb (Vocals) =[effect_show_gui 'vocals' 'reverb']
    Edit Effect: Loop Roll (Vocals) =[effect_show_gui 'vocals' 'loop roll']

    Edit Effect: Echo (Drums) =[effect_show_gui 'rhythm' 'echo']
    Edit Effect: Reverb (Drums) =[effect_show_gui 'rhythm' 'reverb']
</menu>
</page>
