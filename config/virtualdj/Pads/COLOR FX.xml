<?xml version="1.0" encoding="UTF-8"?>
<page name="COLOR FX">
  <!-- Pads 1-8: select ColorFX and activate. Query blinks when that effect is selected AND colorfx is on. -->
  <pad1 name="FILTER" color="color 'magenta'" query="filter_selectcolorfx 'Filter' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Filter' &amp; effect_active 'colorfx' on</pad1>
  <pad2 name="DELAY" color="color 'magenta'" query="param_equal `filter_label` 'Delay' ? (effect_active 'colorfx' ? blink 500ms : on) : off">filter_selectcolorfx 'Delay'</pad2>
  <pad3 name="ECHO" color="color 'magenta'" query="filter_selectcolorfx 'Echo' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Echo' &amp; effect_active 'colorfx' on</pad3>
  <pad4 name="LOOP ROLL" color="color 'magenta'" query="filter_selectcolorfx 'Loop Roll' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Loop Roll' &amp; effect_active 'colorfx' on</pad4>
  <pad5 name="SWEEP" color="color 'magenta'" query="filter_selectcolorfx 'Sweep' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Sweep' &amp; effect_active 'colorfx' on</pad5>
  <pad6 name="SPIRAL" color="color 'magenta'" query="filter_selectcolorfx 'Spiral' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'spiral' &amp; effect_active 'colorfx' on</pad6>
  <pad7 name="NOISE" color="color 'magenta'" query="filter_selectcolorfx 'Noise' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'noise' &amp; effect_active 'colorfx' on</pad7>
  <pad8 name="SLIP ROLL" color="color 'magenta'" query="filter_selectcolorfx 'Slip Roll' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Slip Roll' &amp; effect_active 'colorfx' on</pad8>
  <pad9 name="FLANGER" color="color 'magenta'" query="filter_selectcolorfx 'Flanger' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Flanger' &amp; effect_active 'colorfx' on</pad9>
  <pad10 name="REVERB" color="color 'magenta'" query="filter_selectcolorfx 'Reverb' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Reverb' &amp; effect_active 'colorfx' on</pad10>
  <pad11 name="CUT" color="color 'magenta'" query="filter_selectcolorfx 'Cut' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Cut' &amp; effect_active 'colorfx' on</pad11>
  <pad12 name="ECHO OUT" color="color 'magenta'" query="filter_selectcolorfx 'Echo Out' &amp; effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx 'Echo Out' &amp; effect_active 'colorfx' on</pad12>
  <!-- <pad12 name="`filter_label`" color="color 'magenta'" query="effect_active 'colorfx'"> -->
  <!-- filter_selectcolorfx &amp; effect_active 'colorfx' on</pad12> -->
  <!-- Stems context for ColorFX: route effect to a specific stem -->
  <pad13 name="VOCAL FX\n`effect_stems 'vocal' ? get_text 'on' : get_text 'off'`" color="stem_color 'Vocal'" query="effect_stems 'vocal' ? blink 500ms : off">
    effect_stems 'vocal'</pad13>
  <pad14 name="MELODY FX\n`effect_stems 'melody' ? get_text 'on' : get_text 'off'`" color="stem_color 'Melody'" query="effect_stems 'melody' ? blink 500ms : off">
    effect_stems 'melody'</pad14>
  <pad15 name="DRUM FX\n`effect_stems 'rhythm' ? get_text 'on' : get_text 'off'`" color="stem_color 'Rhythm'" query="effect_stems 'rhythm' ? blink 500ms : off">
    effect_stems 'rhythm'</pad15>
  <!-- Master ColorFX on/off toggle -->
  <pad16 name="COLOR FX\n`effect_active 'colorfx' ? filter_label &amp; param_lowercase : get_text 'off'`" color="color 'magenta'" query="effect_active 'colorfx' ? blink 500ms : off">
    effect_active 'colorfx'</pad16>
  <shift_pad16 name="COLOR FX\n`effect_active 'colorfx'`" color="color 'magenta'" query="effect_active 'colorfx' ? blink 500ms : off">
    filter_selectcolorfx &amp; effect_active 'colorfx' on</shift_pad16>
  <!-- Shift pads: select effect and open its GUI for parameter editing -->
  <shift_pad1 name="`get_text 'FILTER\nedit'`" color="color 'magenta'" query="filter_selectcolorfx 'filter' ? effect_show_gui 'colorfx'">
    filter_selectcolorfx 'filter' &amp; effect_show_gui 'colorfx'</shift_pad1>
  <shift_pad2 name="`get_text 'ECHO OUT\nedit'`" color="color 'magenta'" query="filter_selectcolorfx 'echo out' ? effect_show_gui 'colorfx'">
    filter_selectcolorfx 'echo out' &amp; effect_show_gui 'colorfx'</shift_pad2>
  <shift_pad3 name="`get_text 'REVERB\nedit'`" color="color 'magenta'" query="filter_selectcolorfx 'reverb' ? effect_show_gui 'colorfx'">
    filter_selectcolorfx 'reverb' &amp; effect_show_gui 'colorfx'</shift_pad3>
  <menu>FX =[pad_page "EFFECTS"]
    SELECT =[filter_selectcolorfx]</menu>
  <param1 name="COLOR FX">pad_page "PAD FX"</param1>
</page>
