  <pad9 name="▼ PITCH" color="color '#F5D5FF'" autodim="false">pitch -1 bpm</pad9>
  <pad10 name="▼ BPM" color="color '#75D5FF'" autodim="false">pitch -1 bpm</pad10>
  <pad11 name="BPM ▲" color="color '#75D5FF'" autodim="false">pitch +1 bpm</pad11>
  <pad10 query="true" name="`param_contains &quot;DROP&quot; &quot;`cue_name 1`&quot; ? cue_name 1 : param_contains &quot;DROP&quot; &quot;`cue_name 2`&quot; ? cue_name 2 : param_contains &quot;DROP&quot; &quot;`cue_name 3`&quot; ? cue_name 3 : param_contains &quot;DROP&quot; &quot;`cue_name 4`&quot; ? cue_name 4 : param_contains &quot;DROP&quot; &quot;`cue_name 5`&quot; ? cue_name 5 : param_contains &quot;DROP&quot; &quot;`cue_name 6`&quot; ? cue_name 6 : param_contains &quot;DROP&quot; &quot;`cue_name 7`&quot; ? cue_name 7 : param_contains &quot;DROP&quot; &quot;`cue_name 8`&quot; ? cue_name 8 : get_text &quot;&quot;`" color="param_contains &quot;DROP&quot; &quot;`cue_name 1`&quot; ? cue_color 1 : param_contains &quot;DROP&quot; &quot;`cue_name 2`&quot; ? cue_color 2 : param_contains &quot;DROP&quot; &quot;`cue_name 3`&quot; ? cue_color 3 : param_contains &quot;DROP&quot; &quot;`cue_name 4`&quot; ? cue_color 4 : param_contains &quot;DROP&quot; &quot;`cue_name 5`&quot; ? cue_color 5 : param_contains &quot;DROP&quot; &quot;`cue_name 6`&quot; ? cue_color 6 : param_contains &quot;DROP&quot; &quot;`cue_name 7`&quot; ? cue_color 7 : param_contains &quot;DROP&quot; &quot;`cue_name 8`&quot; ? cue_color 8 : get_text &quot;none&quot;">param_contains "DROP" "`cue_name 1`" ? goto_cue 1 : param_contains "DROP" "`cue_name 2`" ? goto_cue 2 : param_contains "DROP" "`cue_name 3`" ? goto_cue 3 : param_contains "DROP" "`cue_name 4`" ? goto_cue 4 : param_contains "DROP" "`cue_name 5`" ? goto_cue 5 : param_contains "DROP" "`cue_name 6`" ? goto_cue 6 : param_contains "DROP" "`cue_name 7`" ? goto_cue 7 : param_contains "DROP" "`cue_name 8`" ? goto_cue 8 : nothing</pad10>
  <pad12 name="PITCH ▲" color="color '#F5D5FF'" autodim="false">pitch +1 bpm</pad12>
  <!-- <pad11 name="PAD FX" color="color 'yellow'">effect_stems +1</pad11> -->
  <!-- <pad12 name="COLOR FX" color="color magenta" query="effect_active 'colorfx'">effect_active 'colorfx'</pad12> -->
  <!-- ROW 4 -->
  <!-- <pad13 name="RESET PITCH 4bt" color="color pink" autodim="false" query="loaded ? masterdeck ? dim : match_key ? blink 500ms : true">pitch_reset 4bt</pad13> -->
  <!-- <pad13 name="RESET PITCH 4bt" color="color pink" autodim="false" query="loaded ? get_pitch_zero 'absolute' 0.1% ? off : param_bigger `get_pitch_value` 125% ? blink 500ms : param_smaller `get_pitch_value` 75% ? blink 500ms : on : off">pitch_reset 4bt</pad13> -->
  <!-- <pad13 name="RESET PITCH `get_text '%Ppitch%'`" color="loaded ? param_bigger `get_pitch_value` 125% ? color 'red' : param_smaller `get_pitch_value` 75% ? color 'red' : param_bigger `get_pitch_value` 105% ? color 'yellow' : param_smaller `get_pitch_value` 95% ? color 'yellow' : color 'green' : color 'black'" autodim="false" query="loaded ? param_bigger `get_pitch_value` 125% ? blink 500ms : param_smaller `get_pitch_value` 75% ? blink 500ms : on : off">pitch_reset 4bt</pad13> -->
  <!-- <pad13 name="RESET PITCH `get_text '%Ppitch%'`" autodim="false" query="loaded" color="loaded ? param_bigger `get_pitch_value` 125% ? blink 500ms ? color 'red' : color 'black' : param_smaller `get_pitch_value` 75% ? blink 500ms ? color 'red' : color 'black' : param_bigger `get_pitch_value` 105% ? color 'yellow' : param_smaller `get_pitch_value` 95% ? color 'yellow' : color 'green' : color 'black'">pitch_reset 4bt</pad13> -->
  <!-- <pad13 name="RESET PITCH `get_text '%Ppitch%'`" autodim="false" color="loaded ? get_pitch_value &amp; param_bigger 125% ? blink 500ms ? color 'red' : color 'black' : get_pitch_value &amp; param_smaller 75% ? blink 500ms ? color 'red' : color 'black' : get_pitch_value &amp; param_bigger 105% ? color 'yellow' : get_pitch_value &amp; param_smaller 95% ? color 'yellow' : color 'green' : color 'black'" query="loaded">pitch_reset 4bt</pad13> -->
  <pad13 name="RESET PITCH `get_text '%Ppitch%'`" autodim="false" color="loaded ? get_pitch_value &amp; param_bigger 125 ? color 'red' : get_pitch_value &amp; param_smaller 75 ? color 'red' : get_pitch_value &amp; param_bigger 105 ? color 'yellow' : get_pitch_value &amp; param_smaller 95 ? color 'yellow' : color 'green' : color 'black'" query="loaded ? get_pitch_value &amp; param_bigger 125 ? blink 500ms : get_pitch_value &amp; param_smaller 75 ? blink 500ms : on : off">pitch_reset 4bt</pad13>
  <pad16 name="`play ? get_text 'PAUSE' : get_text '▶ PLAY'`" color="color &quot;green&quot;">play_button</pad16>
  <!-- SHIFT PADS -->
  <shift_pad5 name="◀ FIRST BEAT" color="color '#FF2600'" autodim="false">goto_first_beat</shift_pad5>
  <shift_pad6 name="◀ BEAT" color="color '#FFFF44'" autodim="false">goto -1</shift_pad6>
  <shift_pad7 name="BEAT ▶" color="color '#FFFF44'" autodim="false">goto +1</shift_pad7>
  <shift_pad14 name="▼ BPM -5" color="color '#99FFAA'" autodim="false">pitch -5 bpm</shift_pad14>
  <shift_pad15 name="BPM +5 ▲" color="color '#99ffAA'" autodim="false">pitch +5 bpm</shift_pad15>
