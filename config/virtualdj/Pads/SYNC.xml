  <shift_pad16 name="STOP" color="color &quot;red&quot;" query="true">pause_stop</shift_pad16>
  <param1 name="BPM `get_bpm`">param_bigger 0 ? pitch +1 bpm : pitch -1 bpm</param1>
  <param2 name="KEY `get_key`">param_bigger 0 ? key_move +1 : key_move -1</param2>
