#!/usr/bin/env zsh

set -euo pipefail

CONFIG_DIR="${DOTFILES_DIR:-$HOME/config}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
CACHE_DIR="$XDG_CONFIG_HOME/dotter/cache"
CACHE_FILE="$XDG_CONFIG_HOME/dotter/cache.toml"
GLOBAL_CONFIG="$CONFIG_DIR/dotter/global.toml"
LOCAL_CONFIG="$CONFIG_DIR/dotter/local.toml"
MACOS_ICON_SCRIPT="$CONFIG_DIR/scripts/macos-apply-file-icons.sh"

if [[ ! -d "$CONFIG_DIR" ]]; then
  echo "Error: dotfiles directory not found: $CONFIG_DIR"
  exit 1
fi

if [[ ! -f "$GLOBAL_CONFIG" ]]; then
  echo "Error: Dotter global config not found: $GLOBAL_CONFIG"
  exit 1
fi

if [[ ! -f "$LOCAL_CONFIG" ]]; then
  echo "Error: Dotter local config not found: $LOCAL_CONFIG"
  echo "Create it from one of the examples in $CONFIG_DIR/dotter/."
  exit 1
fi

mkdir -p "$CACHE_DIR"

(
  cd "$CONFIG_DIR"
  dotter \
    --cache-directory "$CACHE_DIR" \
    --cache-file "$CACHE_FILE" \
    deploy \
    --global-config "$GLOBAL_CONFIG" \
    --local-config "$LOCAL_CONFIG"
)

if [[ "$OSTYPE" == darwin* ]] && [[ -x "$MACOS_ICON_SCRIPT" ]]; then
  "$MACOS_ICON_SCRIPT"
fi

echo
echo "Dotter deploy completed successfully."
