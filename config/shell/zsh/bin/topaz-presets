#!/usr/bin/env zsh
emulate -L zsh
set -euo pipefail

(( $# == 0 )) && {
  print -u2 "usage: $0 file1 [file2 ...]"
  exit 1
}

for input in "$@"; do
  [[ -f "$input" ]] || {
    print -u2 "not a file: $input"
    exit 1
  }
done

command -v fzf >/dev/null 2>&1 || {
  print -u2 "fzf not found"
  exit 1
}

command -v topaz-run >/dev/null 2>&1 || {
  print -u2 "topaz-run not found in PATH"
  exit 1
}

selection="$(
  printf '%s\n' \
    "4K Conservative Cleanup" \
    "4K Balanced Enhancement" \
    "4K Aggressive Artifact Cleanup" \
    "4K Make It Pop" \
    "1080p -> 4K Clean Upscale" \
    "1080p -> 4K Medium Enhancement" \
    "1080p -> 4K Strong Detail Recovery" \
    "Iris MQ Moderate Cleanup" \
    "Artemis HQ Gentle" \
    "Nyx Strong Denoise" \
    "Proteus Manual Balanced" |
    fzf \
      --prompt='󰎆 Topaz preset > ' \
      --height=40% \
      --reverse \
      --border
)"

[[ -n "$selection" ]] || {
  print -u2 "no preset selected"
  exit 1
}

preset_name=""
filter_complex=""

case "$selection" in
  "4K Conservative Cleanup")
    preset_name="4k-conservative-cleanup"
    filter_complex="scale=1920:-1,tvai_up=model=prob-4:scale=2:preblur=0:noise=0.20:details=0.22:halo=0.03:blur=0.08:compression=0.18:estimate=8:grain=0.02:gsize=2:device=0:vram=0.95:instances=1"
    ;;
  "4K Balanced Enhancement")
    preset_name="4k-balanced-enhancement"
    filter_complex="scale=1920:-1,tvai_up=model=prob-4:scale=2:preblur=0:noise=0.32:details=0.36:halo=0.05:blur=0.14:compression=0.30:estimate=8:grain=0.03:gsize=2:device=0:vram=0.95:instances=1"
    ;;
  "4K Aggressive Artifact Cleanup")
    preset_name="4k-aggressive-artifact-cleanup"
    filter_complex="scale=1920:-1,tvai_up=model=prob-4:scale=2:preblur=0:noise=0.50:details=0.28:halo=0.10:blur=0.18:compression=0.42:estimate=8:grain=0.02:gsize=2:device=0:vram=0.95:instances=1"
    ;;
  "4K Make It Pop")
    preset_name="4k-make-it-pop"
    filter_complex="scale=1920:-1,tvai_up=model=prob-4:scale=2:preblur=0:noise=0.10:details=0.30:halo=0.02:blur=0.06:compression=0.10:estimate=8:grain=0.01:gsize=2:device=0:vram=0.95:instances=1"
    ;;
  "1080p -> 4K Clean Upscale")
    preset_name="1080p-to-4k-clean"
    filter_complex="tvai_up=model=prob-4:scale=2:preblur=0:noise=0.16:details=0.26:halo=0.02:blur=0.08:compression=0.12:estimate=8:grain=0.02:gsize=2:device=0:vram=0.95:instances=1"
    ;;
  "1080p -> 4K Medium Enhancement")
    preset_name="1080p-to-4k-medium"
    filter_complex="tvai_up=model=prob-4:scale=2:preblur=0:noise=0.35:details=0.60:halo=0:blur=0.20:compression=0.30:estimate=8:grain=0.02:gsize=2:device=0:vram=0.90:instances=1"
    ;;
  "1080p -> 4K Strong Detail Recovery")
    preset_name="1080p-to-4k-strong"
    filter_complex="tvai_up=model=prob-4:scale=2:preblur=0:noise=0.55:details=0.90:halo=0:blur=0.50:compression=0.45:estimate=8:grain=0.03:gsize=2:device=0:vram=0.90:instances=1"
    ;;
  "Iris MQ Moderate Cleanup")
    preset_name="iris-mq-moderate"
    filter_complex="tvai_up=model=iris-3:scale=1:preblur=0:noise=0.25:details=0.50:halo=0:blur=0.15:compression=0.20:estimate=8:grain=0.01:gsize=2:device=0:vram=0.90:instances=1"
    ;;
  "Artemis HQ Gentle")
    preset_name="artemis-hq-gentle"
    filter_complex="tvai_up=model=ahq-12:scale=1:preblur=0:noise=0.15:details=0.35:halo=0:blur=0.10:compression=0.15:estimate=8:grain=0:gsize=2:device=0:vram=0.90:instances=1"
    ;;
  "Nyx Strong Denoise")
    preset_name="nyx-strong-denoise"
    filter_complex="tvai_up=model=nyx-3:scale=1:preblur=0:noise=0.80:details=0.25:halo=0:blur=0.20:compression=0.25:estimate=8:grain=0:gsize=2:device=0:vram=0.90:instances=1"
    ;;
  "Proteus Manual Balanced")
    preset_name="proteus-manual-balanced"
    filter_complex="tvai_up=model=prob-3:scale=1:preblur=0:noise=0.40:details=0.55:halo=0.05:blur=0.15:compression=0.25:estimate=8:grain=0.02:gsize=2:device=0:vram=0.90:instances=1"
    ;;
  *)
    print -u2 "unknown preset selected"
    exit 1
    ;;
esac

cmd_preview=(
  topaz-run
  --preset_name "$preset_name"
  --filter_complex "$filter_complex"
  --
  "$@"
)

print -P -- "%F{cyan}󰏬%f preset: $selection"
print -P -- "%F{242}slug:%f   $preset_name"
print -P -- "%F{242}cmd:%f    ${(q+)cmd_preview}"
print

cmd_preview=(topaz-run --preset_name "$preset_name" --filter_complex "$filter_complex" -- "$@")
print -P -- "%F{242}cmd:%f    ${(q+)cmd_preview}"
